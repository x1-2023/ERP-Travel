# ============================================================
# VietERP Platform — Cấu hình Sản Xuất / Production Configuration
# Sao chép sang .env.production và cập nhật giá trị
# Copy to .env.production and update values with real secrets
# ============================================================

# ─── Ứng dụng / Application ──────────────────────────────────
NODE_ENV=production
PORT=3000
# URL công cộng của ứng dụng / Public application URL
APP_URL=https://your-domain.com

# ─── Cơ sở dữ liệu / Database ───────────────────────────────
# PostgreSQL 16 connection string
# Format: postgresql://user:password@host:port/database
POSTGRES_USER=vierp
POSTGRES_PASSWORD=your-strong-postgres-password-min-32-chars
POSTGRES_DB=vierp_prod
DATABASE_URL=postgresql://vierp:your-strong-postgres-password-min-32-chars@postgres:5432/vierp_prod

# ─── Bộ nhớ đệm / Caching Layer ──────────────────────────────
# Redis configuration for distributed caching and sessions
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ─── Hệ thống sự kiện / Event Bus (NATS JetStream) ──────────
# NATS JetStream for async messaging and event streaming
NATS_URL=nats://nats:4222
NATS_USER=vierp_nats
NATS_PASSWORD=your-nats-password

# ─── Xác thực và Phân quyền / Authentication & Authorization ─
# Keycloak SSO Configuration
SSO_URL=https://keycloak.your-domain.com
SSO_REALM=vierp
SSO_CLIENT_ID=vierp-main
SSO_CLIENT_SECRET=your-keycloak-client-secret-min-32-chars
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your-strong-admin-password

# JWT Configuration (Fallback authentication)
# Tối thiểu 32 ký tự / Minimum 32 characters
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-generated-with-openssl
NEXTAUTH_URL=https://your-domain.com

# Session Configuration
SESSION_SECRET=your-session-secret-min-32-chars
TOKEN_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# ─── Cổng API / API Gateway Configuration (Kong) ──────────────
# Kong gateway for microservice routing and rate limiting
API_GATEWAY_URL=http://kong:8000
KONG_ADMIN_API_URL=http://kong:8001

# ─── Tích hợp AI / AI Integration Services ───────────────────
# Anthropic Claude API (for HRM-AI, ExcelAI services)
ANTHROPIC_API_KEY=sk-your-anthropic-api-key-here

# ─── Email / SMTP Configuration ──────────────────────────────
# Email service for notifications and communications
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="VietERP <noreply@your-domain.com>"
SMTP_TLS=true

# ─── Lưu trữ / Cloud Storage Configuration ──────────────────
# AWS S3 or compatible object storage for file uploads
S3_BUCKET=vierp-files-prod
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com

# ─── Thanh toán Việt Nam / Vietnamese Payment Integration ────
# Integration with Vietnamese payment gateways
# VNPAY - Thanh toán qua ngân hàng Việt Nam
VNPAY_TMN_CODE=your-vnpay-merchant-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_API_URL=https://sandbox.vnpayment.vn

# MOMO - Thanh toán qua ví MOMO
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
MOMO_API_URL=https://test-payment.momo.vn

# GHN - Logistics partner for shipping
GHN_TOKEN=your-ghn-api-token
GHN_SHOP_ID=your-ghn-shop-id
GHN_API_URL=https://online-gateway.ghn.vn

# ─── Thương hiệu / Branding Configuration ────────────────────
# Customize branding for your deployment
BRAND_NAME=VietERP
BRAND_SHORT=VIERP
BRAND_DOMAIN=your-domain.com
BRAND_LOGO_URL=https://your-domain.com/logo.png
BRAND_ACCENT_COLOR=#1976d2

# ─── Quản lý hình ảnh / Image Configuration ──────────────────
# Image upload and processing
IMAGE_MAX_SIZE=10485760
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
IMAGE_COMPRESSION_QUALITY=80

# ─── Docker Compose / Container Configuration ────────────────
# Image tag for all microservices (git SHA or semantic version)
IMAGE_TAG=latest

# ─── Ghi nhật ký / Logging Configuration ──────────────────────
# Application logging level: debug, info, warn, error
LOG_LEVEL=info
LOG_FORMAT=json
# Send logs to external service (optional)
LOG_DESTINATION=stdout

# ─── Bảo mật / Security Configuration ────────────────────────
# CORS origins for frontend access
CORS_ORIGIN=https://your-domain.com,https://app.your-domain.com
# Rate limiting (requests per minute)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=1000
# Security headers
SECURE_HEADERS=true
# HTTPS/SSL enforcement
FORCE_HTTPS=true

# ─── Giám sát / Monitoring Configuration ─────────────────────
# Application Performance Monitoring
APM_ENABLED=true
APM_SERVICE_NAME=vierp-platform
APM_SERVER_URL=https://your-apm-server.com

# Health check and readiness endpoints
HEALTH_CHECK_ENABLED=true

# ─── Tính năng thử nghiệm / Feature Flags ─────────────────────
# Enable/disable features in production
FEATURE_FLAG_ADVANCED_ANALYTICS=true
FEATURE_FLAG_API_V2=true
FEATURE_FLAG_BATCH_OPERATIONS=true
FEATURE_FLAG_CUSTOM_WORKFLOWS=true

# ─── Thông tin liên hệ / Support Configuration ────────────────
SUPPORT_EMAIL=support@your-domain.com
SUPPORT_PHONE=+84-your-phone
SUPPORT_WEBSITE=https://support.your-domain.com

# ─── Chính sách / Policy URLs ────────────────────────────────
PRIVACY_POLICY_URL=https://your-domain.com/privacy
TERMS_OF_SERVICE_URL=https://your-domain.com/terms
