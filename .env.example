# ============================================================
# VietERP Platform — Cấu hình Môi trường / Environment Configuration
# Sao chép sang .env và cập nhật giá trị / Copy to .env and update values
# ============================================================

# ─── Ứng dụng / Application ───────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Cơ sở dữ liệu / Database ─────────────────────────────
DATABASE_URL=postgresql://vierp:your-password@localhost:5432/vierp_dev

# ─── Redis / Bộ nhớ đệm ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── NATS JetStream / Hệ thống sự kiện ────────────────────
NATS_URL=nats://localhost:4222

# ─── Xác thực / Authentication ─────────────────────────────
# Keycloak SSO
SSO_URL=http://localhost:8080
SSO_REALM=vierp
SSO_CLIENT_ID=vierp-app
SSO_CLIENT_SECRET=your-client-secret

# JWT (dự phòng / fallback)
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Cổng API / API Gateway (Kong) ────────────────────────
API_GATEWAY_URL=http://localhost:8000

# ─── Tích hợp AI / AI Integration ─────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_FROM="VietERP <noreply@your-domain.com>"

# ─── Lưu trữ / Storage ────────────────────────────────────
S3_BUCKET=vierp-files
S3_REGION=ap-southeast-1

# ─── Thị trường Việt Nam / Vietnamese Market ───────────────
# VNPAY_TMN_CODE=your-vnpay-code
# MOMO_PARTNER_CODE=your-momo-code
# GHN_TOKEN=your-ghn-token

# ─── Tuỳ chỉnh thương hiệu / Branding Override ────────────
# BRAND_NAME="Your Platform Name"
# BRAND_SHORT="YPN"
# BRAND_DOMAIN="your-domain.com"
