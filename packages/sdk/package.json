{
  "name": "@vierp/sdk",
  "version": "1.0.0",
  "private": true,
  "description": "ERP Developer SDK — REST client, webhooks, plugins, OpenAPI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./webhooks": "./src/webhooks/index.ts",
    "./plugins": "./src/plugins/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vierp/shared": "*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
