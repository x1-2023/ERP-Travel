// AuditLog Schema for @vierp/audit
// Stores all audit trail entries

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())

  // User information
  userId   String
  userName String

  // Entity information
  module   String
  entity   String
  entityId String

  // Action and changes
  action AuditAction
  changes Json? // Array of { field, oldValue, newValue }

  // Full values (before/after)
  oldValue Json?
  newValue Json?

  // Context information
  ipAddress  String?
  userAgent  String?
  metadata   Json?

  // Indexes for efficient querying
  @@index([userId])
  @@index([module])
  @@index([entity])
  @@index([entityId])
  @@index([timestamp])
  @@index([action])
  @@index([module, entity, entityId])
  @@index([userId, timestamp])
  @@fulltext([entity, entityId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
}
