{
  "name": "@vierp/rate-limit",
  "version": "1.0.0",
  "private": true,
  "description": "Rate limiting package for VietERP using Redis and flexible strategies",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs",
      "types": "./dist/middleware.d.ts"
    },
    "./limiter": {
      "import": "./dist/limiter.js",
      "require": "./dist/limiter.cjs",
      "types": "./dist/limiter.d.ts"
    },
    "./strategies": {
      "import": "./dist/strategies.js",
      "require": "./dist/strategies.cjs",
      "types": "./dist/strategies.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs",
      "types": "./dist/types.d.ts"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs",
      "types": "./dist/constants.d.ts"
    }
  },
  "dependencies": {
    "ioredis": "^5.3.0",
    "rate-limiter-flexible": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
