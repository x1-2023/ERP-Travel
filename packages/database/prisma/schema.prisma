/// 3.6 Work Orders (Lệnh sản xuất)
model WorkOrder {
  id           String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  woNo         String          @unique @map("wo_no") @db.VarChar(30)
  bomId        String          @map("bom_id") @db.Uuid
  bom          Bom             @relation(fields: [bomId], references: [id])
  itemId       String          @map("item_id") @db.Uuid
  item         Item            @relation(fields: [itemId], references: [id])
  qtyToProduce Decimal         @map("qty_to_produce") @db.Decimal(10, 4)
  qtyProduced  Decimal         @default(0) @map("qty_produced") @db.Decimal(10, 4)
  status       WorkOrderStatus @default(draft)

  plannedStart DateTime? @map("planned_start") @db.Date
  plannedEnd   DateTime? @map("planned_end") @db.Date
  actualStart  DateTime? @map("actual_start") @db.Timestamptz
  actualEnd    DateTime? @map("actual_end") @db.Timestamptz

  sourceWarehouseId String?    @map("source_warehouse_id") @db.Uuid
  sourceWarehouse   Warehouse? @relation("WoSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  wipWarehouseId    String?    @map("wip_warehouse_id") @db.Uuid
  wipWarehouse      Warehouse? @relation("WoWipWarehouse", fields: [wipWarehouseId], references: [id])
  targetWarehouseId String?    @map("target_warehouse_id") @db.Uuid
  targetWarehouse   Warehouse? @relation("WoTargetWarehouse", fields: [targetWarehouseId], references: [id])

  salesOrderRef String? @map("sales_order_ref") @db.VarChar(50)
  customerName  String? @map("customer_name") @db.VarChar(200)

  companyId    String?  @map("company_id") @db.Uuid
  company      Company? @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz
  larkRecordId String?  @map("lark_record_id") @db.VarChar(50)

  jobCards JobCard[]

  @@index([status], map: "idx_wo_status")
  @@index([plannedStart, plannedEnd], map: "idx_wo_dates")
  @@map("work_orders")
}

enum WorkOrderStatus {
  draft
  submitted
  in_progress
  completed
  cancelled
}

