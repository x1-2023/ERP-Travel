  pricingProfile  String?   @map("pricing_profile") @db.VarChar(30)
  exchangeRate    Decimal   @default(24500) @map("exchange_rate") @db.Decimal(10, 2)
  calculatedBy    String    @default("ai_copilot") @map("calculated_by") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  larkRecordId    String?   @map("lark_record_id") @db.VarChar(50)

  @@map("costing_history")
}

// ============================================================
// 7. LARK SYNC — Bảng theo dõi đồng bộ
// ============================================================

model LarkSyncLog {
  id           String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tableName    String        @map("table_name") @db.VarChar(100)
  recordId     String        @map("record_id") @db.Uuid
  larkRecordId String?       @map("lark_record_id") @db.VarChar(50)
  direction    SyncDirection
  status       SyncStatus    @default(success)
  payload      Json?         @db.JsonB
  errorMessage String?       @map("error_message") @db.Text
  syncedAt     DateTime      @default(now()) @map("synced_at") @db.Timestamptz

  @@index([tableName, recordId], map: "idx_sync_table")
  @@map("lark_sync_log")
}

enum SyncDirection {
  to_lark
  from_lark
}

enum SyncStatus {
  success
  failed
  pending
}
