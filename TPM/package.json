{
  "name": "vierp-tpm",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@vierp/tpm-web",
    "dev:api": "turbo run dev --filter=@vierp/tpm-api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@vierp/tpm-web",
    "build:api": "turbo run build --filter=@vierp/tpm-api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:push": "turbo run db:push --filter=@vierp/tpm-api",
    "db:seed": "turbo run db:seed --filter=@vierp/tpm-api",
    "db:studio": "npm run db:studio --workspace=@vierp/tpm-api",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "terser": "^5.46.0",
    "turbo": "^2.0.0",
    "vite-plugin-compression2": "^2.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
