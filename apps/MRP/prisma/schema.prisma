generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS (Manufacturing Strategy) ============
enum ManufacturingStrategy {
  MTS // Make-to-Stock
  MTO // Make-to-Order
  ATO // Assemble-to-Order
}

enum PickingStrategy {
  FIFO // First In First Out (by createdAt)
  FEFO // First Expiry First Out (by expiryDate)
  ANY // No preference (current behavior)
}

enum WorkOrderType {
  DISCRETE // One product at a time
  BATCH // Batch processing
}

// ============ ENUMS (Parts Enhancement v2.0) ============
enum MakeOrBuy {
  MAKE
  BUY
  BOTH
}

enum ProcurementType {
  STOCK
  ORDER
  CONSIGNMENT
}

enum LifecycleStatus {
  DEVELOPMENT
  PROTOTYPE
  ACTIVE
  PHASE_OUT
  OBSOLETE
  EOL
}

enum BomType {
  ENGINEERING
  MANUFACTURING
  CONFIGURABLE
  PLANNING
  SERVICE
}

enum AlternateType {
  FORM_FIT_FUNCTION
  FUNCTIONAL
  EMERGENCY
  APPROVED_VENDOR
}

enum DocumentType {
  DRAWING
  DATASHEET
  SPECIFICATION
  CERTIFICATE
  TEST_REPORT
  MSDS
  MANUAL
  OTHER
}

enum CertificationType {
  ROHS
  REACH
  CE
  UL
  ISO
  AS9100
  ITAR
  NDAA
  COC
  COA
  OTHER
}

// ============ SUPPLIERS ============
model Supplier {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  taxId         String? // Mã số thuế
  country       String
  ndaaCompliant Boolean  @default(true)
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  paymentTerms  String?
  leadTimeDays  Int
  rating        Float?
  category      String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  partSuppliers       PartSupplier[]
  purchaseOrders      PurchaseOrder[]
  mrpSuggestions      MrpSuggestion[]
  riskScore           SupplierRiskScore?
  leadTimePredictions LeadTimePrediction[]
  inspectionPlans     InspectionPlan[]

  // Financial relations
  purchaseInvoices PurchaseInvoice[]

  // Evaluation relations
  scores SupplierScore[]
  audits SupplierAudit[]

  @@index([status])
  @@index([rating])
  @@map("suppliers")
}

// ============ SUPPLIER EVALUATION ============

model SupplierScore {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Period
  periodStart     DateTime
  periodEnd       DateTime

  // KPI Scores (0-100)
  deliveryScore   Float    @default(0)
  qualityScore    Float    @default(0)
  priceScore      Float    @default(0)
  responseScore   Float    @default(0)

  // Weighted Overall Score
  overallScore    Float    @default(0)

  // Raw Stats
  totalOrders     Int      @default(0)
  onTimeOrders    Int      @default(0)
  lateOrders      Int      @default(0)
  totalItems      Int      @default(0)
  acceptedItems   Int      @default(0)
  rejectedItems   Int      @default(0)
  avgLeadTimeDays Float?
  avgPriceVariance Float?

  // Audit
  calculatedAt    DateTime @default(now())
  calculatedById  String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([supplierId, periodStart, periodEnd])
  @@index([supplierId])
  @@index([overallScore])
  @@index([periodEnd])
  @@map("supplier_scores")
}

model SupplierAudit {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  auditDate       DateTime
  auditType       String   // quality, compliance, financial, site_visit
  auditorId       String

  // Results
  score           Float?
  findings        String?
  recommendations String?

  // Follow-up
  nextAuditDate   DateTime?
  status          String   @default("completed")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([supplierId])
  @@index([auditDate])
  @@map("supplier_audits")
}

// ============ PARTS (Enhanced v2.0) ============
model Part {
  id            String   @id @default(cuid())
  partNumber    String   @unique
  name          String
  category      String
  description   String?
  unit          String   @default("pcs")
  unitCost      Float    @default(0)
  weightKg      Float?
  isCritical    Boolean  @default(false)
  minStockLevel Int      @default(0)
  reorderPoint  Int      @default(0)
  safetyStock   Int      @default(0)
  shelfLifeDays Int?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // === Physical Specifications ===
  lengthMm  Float?
  widthMm   Float?
  heightMm  Float?
  volumeCm3 Float?
  color     String?
  material  String?

  // === Classification ===
  subCategory String?
  partType    String?

  // === Procurement & Sourcing ===
  makeOrBuy             MakeOrBuy             @default(BUY)
  procurementType       ProcurementType       @default(STOCK)
  manufacturingStrategy ManufacturingStrategy @default(MTS)
  pickingStrategy       PickingStrategy       @default(ANY)
  abcClass              String? // A, B, or C (ABC classification)
  buyerCode             String?
  moq                   Int                   @default(1)
  orderMultiple         Int                   @default(1)
  standardPack          Int                   @default(1)
  leadTimeDays          Int                   @default(14)

  // === Compliance & Origin (CRITICAL for NDAA) ===
  countryOfOrigin String?
  hsCode          String?
  eccn            String?
  ndaaCompliant   Boolean @default(true)
  itarControlled  Boolean @default(false)

  // === Quality & Traceability ===
  lotControl          Boolean @default(false)
  serialControl       Boolean @default(false)
  inspectionRequired  Boolean @default(true)
  inspectionPlan      String?
  aqlLevel            String?
  certificateRequired Boolean @default(false)
  rohsCompliant       Boolean @default(true)
  reachCompliant      Boolean @default(true)

  // === Engineering & Documents ===
  revision        String          @default("A")
  revisionDate    DateTime?
  drawingNumber   String?
  drawingUrl      String?
  datasheetUrl    String?
  specDocument    String?
  manufacturerPn  String?
  manufacturer    String?
  lifecycleStatus LifecycleStatus @default(ACTIVE)
  effectivityDate DateTime?
  obsoleteDate    DateTime?

  // === Enhanced Costing ===
  standardCost    Float?
  averageCost     Float?
  landedCost      Float?
  freightPercent  Float?
  dutyPercent     Float?
  overheadPercent Float?

  // === Price Breaks ===
  priceBreakQty1  Int?
  priceBreakCost1 Float?
  priceBreakQty2  Int?
  priceBreakCost2 Float?
  priceBreakQty3  Int?
  priceBreakCost3 Float?

  // === Images ===
  imageUrl String?

  // === Normalized Relations (Optional - for future migration) ===
  planning   PartPlanning?
  costs      PartCost[]
  specs      PartSpecs?
  compliance PartCompliance?

  // === Audit ===
  createdBy String?
  updatedBy String?
  tags      String[] @default([])
  notes     String?

  // Existing relations
  partSuppliers       PartSupplier[]
  bomLines            BomLine[]
  inventory           Inventory[]
  poLines             PurchaseOrderLine[]
  mrpSuggestions      MrpSuggestion[]
  allocations         MaterialAllocation[]
  leadTimePredictions LeadTimePrediction[]
  inspectionPlans     InspectionPlan[]
  inspections         Inspection[]
  ncrs                NCR[]
  lotTransactions     LotTransaction[]

  // Financial relations - kept for direct access if needed, or move to PartCost relations?
  // Keeping these on Part for now to minimize refactor impact on other modules
  // partCosts removed to avoid ambiguity with 'cost' field
  costComponents       PartCostComponent[] // The legacy/component relation
  costRollup           PartCostRollup?
  purchaseInvoiceLines PurchaseInvoiceLine[]
  salesInvoiceLines    SalesInvoiceLine[]
  costVariances        CostVariance[]
  pickListLines        PickListLine[]

  // Advanced MRP relations
  inventorySites     InventorySite[]
  transferOrderLines TransferOrderLine[]
  plannedOrders      PlannedOrder[]
  mrpExceptions      MRPException[]
  atpRecords         ATPRecord[]
  primarySubstitutes PartSubstitute[]    @relation("PrimaryPart")
  substituteFor      PartSubstitute[]    @relation("SubstitutePart")

  // Enhanced Relations (v2.0)
  partAlternates     PartAlternate[]     @relation("PartAlternates")
  alternateFor       PartAlternate[]     @relation("AlternateFor")
  partDocuments      PartDocument[]
  partRevisions      PartRevision[]
  partCostsHistory   PartCostHistory[]
  partCertifications PartCertification[]
  scrapDisposals     ScrapDisposal[]

  // Cost Optimization relations
  autonomyStatus          PartAutonomyStatus?
  makeVsBuyAnalyses       MakeVsBuyAnalysis[]       @relation("MakeVsBuyAnalysisPart")
  subEvalOriginal         SubstituteEvaluation[]    @relation("SubEvalOriginalPart")
  subEvalSubstitute       SubstituteEvaluation[]    @relation("SubEvalSubstitutePart")
  costReductionActions    CostReductionAction[]     @relation("CostReductionActionPart")
  grnItems                GRNItem[]
  quotationItems          QuotationItem[]
  pricingRules            PricingRule[]

  @@index([category])
  @@index([lifecycleStatus])
  @@index([status])
  @@index([isCritical])
  @@map("parts")
}

// === NEW: Part Planning Data (MRP relevant) ===
model PartPlanning {
  id     String @id @default(cuid())
  partId String @unique
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  minStockLevel Int  @default(0)
  maxStock      Int?
  reorderPoint  Int  @default(0)
  safetyStock   Int  @default(0)

  leadTimeDays Int @default(14)

  makeOrBuy       MakeOrBuy       @default(BUY)
  procurementType ProcurementType @default(STOCK)

  buyerCode   String?
  plannerCode String?

  moq           Int @default(1)
  orderMultiple Int @default(1)
  standardPack  Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([makeOrBuy])
  @@map("part_planning")
}

// === NEW: Part Cost Data (Legacy - kept for backward compatibility) ===
model PartCost {
  id     String @id @default(cuid())
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  // Standard Costing
  unitCost     Float // Current active cost
  standardCost Float?
  averageCost  Float?
  landedCost   Float?

  // Cost Components
  freightPercent  Float?
  dutyPercent     Float?
  overheadPercent Float?

  // Price Breaks
  priceBreakQty1  Int?
  priceBreakCost1 Float?
  priceBreakQty2  Int?
  priceBreakCost2 Float?
  priceBreakQty3  Int?
  priceBreakCost3 Float?

  updatedAt DateTime @updatedAt

  @@index([partId])
  @@map("part_costs")
}

// === NEW: Part Specifications (Engineering) ===
model PartSpecs {
  id     String @id @default(cuid())
  partId String @unique
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  // Physical
  weightKg  Float?
  lengthMm  Float?
  widthMm   Float?
  heightMm  Float?
  volumeCm3 Float?

  // Aesthetic / Material
  color    String?
  material String?
  finish   String?

  // Engineering
  drawingNumber String?
  drawingUrl    String?
  datasheetUrl  String?
  specDocument  String?

  // Manufacturer
  manufacturerPn String?
  manufacturer   String?

  // Categorization
  subCategory String?
  partType    String?

  updatedAt DateTime @updatedAt

  @@map("part_specs")
}

// === NEW: Optimization for Compliance ===
model PartCompliance {
  id     String @id @default(cuid())
  partId String @unique
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  countryOfOrigin String?
  hsCode          String?
  eccn            String?

  ndaaCompliant  Boolean @default(true)
  itarControlled Boolean @default(false)
  rohsCompliant  Boolean @default(true)
  reachCompliant Boolean @default(true)

  lotControl          Boolean @default(false)
  serialControl       Boolean @default(false)
  inspectionRequired  Boolean @default(true)
  certificateRequired Boolean @default(false)
  shelfLifeDays       Int?
  aqlLevel            String? @default("II")

  updatedAt DateTime @updatedAt

  @@index([ndaaCompliant])
  @@index([itarControlled])
  @@map("part_compliance")
}

model PartSupplier {
  id             String   @id @default(cuid())
  partId         String
  supplierId     String
  supplierPartNo String?
  unitPrice      Float
  minOrderQty    Int      @default(1)
  leadTimeDays   Int
  isPreferred    Boolean  @default(false)
  createdAt      DateTime @default(now())

  // === NEW: Enhanced fields (v2.0) ===
  currency            String    @default("USD")
  orderMultiple       Int       @default(1)
  qualified           Boolean   @default(true)
  qualificationDate   DateTime?
  qualificationExpiry DateTime?
  status              String    @default("active")
  receivingTolerance  Float? // Allowed over/under delivery % (e.g. 5.0 = +/-5%)
  notes               String?
  updatedAt           DateTime  @updatedAt

  part     Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([partId, supplierId])
  @@index([partId])
  @@index([supplierId])
  @@map("part_suppliers")
}

// ============ PART ALTERNATES (NEW v2.0) ============
model PartAlternate {
  id              String @id @default(cuid())
  partId          String
  alternatePartId String

  alternateType    AlternateType @default(FORM_FIT_FUNCTION)
  priority         Int           @default(1)
  conversionFactor Float         @default(1) // Qty conversion

  approved      Boolean   @default(true)
  approvedBy    String?
  approvalDate  DateTime?
  effectiveDate DateTime?
  expiryDate    DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  part          Part @relation("PartAlternates", fields: [partId], references: [id], onDelete: Cascade)
  alternatePart Part @relation("AlternateFor", fields: [alternatePartId], references: [id], onDelete: Cascade)

  @@unique([partId, alternatePartId])
  @@index([partId])
  @@map("part_alternates")
}

// ============ PART DOCUMENTS (NEW v2.0) ============
model PartDocument {
  id     String @id @default(cuid())
  partId String

  documentType   DocumentType
  documentNumber String?
  title          String
  revision       String       @default("A")
  url            String

  effectiveDate DateTime?
  expiryDate    DateTime?

  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@map("part_documents")
}

// ============ PART REVISIONS (NEW v2.0) ============
model PartRevision {
  id     String @id @default(cuid())
  partId String

  revision         String // A, B, C or 01, 02, 03
  previousRevision String?
  revisionDate     DateTime

  changeType        String? // Engineering, Document, etc.
  changeReason      String?
  changeDescription String?

  ecrNumber String? // Engineering Change Request
  ecoNumber String? // Engineering Change Order

  changedBy    String
  approvedBy   String?
  approvalDate DateTime?

  createdAt DateTime @default(now())

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@map("part_revisions")
}

// ============ PART COST HISTORY (NEW v2.0) ============
model PartCostHistory {
  id     String @id @default(cuid())
  partId String

  effectiveDate DateTime
  costType      String // STANDARD, ACTUAL, LANDED

  unitCost   Float
  currency   String  @default("USD")
  supplierId String?
  poNumber   String?

  notes     String?
  createdBy String?
  createdAt DateTime @default(now())

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@index([effectiveDate])
  @@map("part_costs_history")
}

// ============ PART CERTIFICATIONS (NEW v2.0) ============
model PartCertification {
  id     String @id @default(cuid())
  partId String

  certificationType CertificationType
  certificateNumber String?
  issuingBody       String?

  issueDate  DateTime?
  expiryDate DateTime?

  documentUrl  String?
  verified     Boolean   @default(false)
  verifiedBy   String?
  verifiedDate DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@index([certificationType])
  @@map("part_certifications")
}

// ============ PRODUCTS & BOM ============
model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  description   String?
  basePrice     Float?
  assemblyHours Float?
  testingHours  Float?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Default work center for capacity planning
  defaultWorkCenterId String?
  defaultWorkCenter   WorkCenter? @relation("ProductDefaultWorkCenter", fields: [defaultWorkCenterId], references: [id], onDelete: SetNull)

  bomHeaders         BomHeader[]
  salesOrderLines    SalesOrderLine[]
  workOrders         WorkOrder[]
  forecasts          DemandForecast[]
  inspectionPlans    InspectionPlan[]
  inspections        Inspection[]
  ncrs               NCR[]
  lotTransactions    LotTransaction[]
  certificates       CertificateOfConformance[]
  routings           Routing[]
  productionReceipts ProductionReceipt[]
  shipmentLines      ShipmentLine[]

  // Financial relations
  salesInvoiceLines SalesInvoiceLine[]

  // Cost Optimization
  costTargets CostTarget[]

  @@index([status])
  @@index([defaultWorkCenterId])
  @@map("products")
}

model BomHeader {
  id            String    @id @default(cuid())
  productId     String
  version       String
  effectiveDate DateTime
  expiryDate    DateTime?
  status        String    @default("active")
  notes         String?
  createdAt     DateTime  @default(now())

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  bomLines BomLine[]

  @@unique([productId, version])
  @@index([productId])
  @@index([status])
  @@index([effectiveDate])
  @@map("bom_headers")
}

// ============ BOM LINE (Enhanced v2.0) ============
model BomLine {
  id         String  @id @default(cuid())
  bomId      String
  lineNumber Int
  partId     String
  quantity   Float
  unit       String  @default("pcs")
  level      Int     @default(1)
  moduleCode String?
  moduleName String?
  position   String?
  isCritical Boolean @default(false)
  scrapRate  Float   @default(0)
  notes      String?

  // === NEW: Find Number & Reference ===
  findNumber          Int? // Item # on drawing (10, 20, 30)
  referenceDesignator String? // M1, M2 for Motor 1, 2

  // === NEW: Position (for assembly instructions) ===
  positionX Float?
  positionY Float?
  positionZ Float?

  // === NEW: Manufacturing ===
  scrapPercent Float @default(0)
  operationSeq Int? // Which operation uses this

  // === NEW: Effectivity & Revision ===
  revision        String    @default("A")
  effectivityDate DateTime?
  obsoleteDate    DateTime?

  // === NEW: Alternates ===
  alternateGroup String?
  isPrimary      Boolean @default(true)

  // === NEW: BOM Type & Structure ===
  bomType     BomType @default(MANUFACTURING)
  subAssembly Boolean @default(false)
  phantom     Boolean @default(false) // Phantom BOM - no inventory

  // === NEW: Costing ===
  extendedCost Float? // Qty * Part Cost

  // === NEW: Sequence for display ===
  sequence Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bom  BomHeader @relation(fields: [bomId], references: [id], onDelete: Cascade)
  part Part      @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([bomId, lineNumber])
  @@index([moduleCode])
  @@index([bomType])
  @@index([alternateGroup])
  @@map("bom_lines")
}

// ============ INVENTORY ============
model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  location  String?
  type      String? // RECEIVING, QUARANTINE, MAIN, WIP, FINISHED_GOODS, SHIPPING, HOLD, SCRAP
  status    String   @default("active")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  // Site relation
  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  inventory          Inventory[]
  pickListLines      PickListLine[]
  productionReceipts ProductionReceipt[]

  @@index([siteId])
  @@index([type])
  @@map("warehouses")
}

model Inventory {
  id            String    @id @default(cuid())
  partId        String
  warehouseId   String
  quantity      Int       @default(0)
  reservedQty   Int       @default(0)
  lotNumber     String?
  locationCode  String?
  expiryDate    DateTime?
  lastCountDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  part      Part      @relation(fields: [partId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([partId, warehouseId, lotNumber])
  // Performance indexes
  @@index([partId])
  @@index([warehouseId])
  @@index([partId, warehouseId])
  @@index([quantity])
  @@index([expiryDate])
  @@map("inventory")
}

// ============ CUSTOMERS & SALES ============
model Customer {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  type           String?
  country        String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  billingAddress String?
  paymentTerms   String?  @default("NET_30")
  creditLimit    Float    @default(0)
  creditUsed     Float    @default(0)
  tier           String   @default("C")
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  salesOrders  SalesOrder[]
  shipments    Shipment[]
  quotations   Quotation[]
  pricingRules PricingRule[]
  contacts     CustomerContact[]

  // Financial relations
  salesInvoices SalesInvoice[]

  @@index([status])
  @@index([type])
  @@index([tier])
  @@map("customers")
}

model CustomerContact {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  title       String?
  email       String?
  phone       String?
  mobile      String?
  contactType String   @default("general")
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([isPrimary])
  @@map("customer_contacts")
}

model SalesOrder {
  id           String    @id @default(cuid())
  orderNumber  String    @unique
  customerId   String
  orderDate    DateTime
  requiredDate DateTime
  promisedDate DateTime?
  priority     String    @default("normal")
  status       String    @default("draft")
  sourceType   String    @default("direct")
  totalAmount  Float?
  currency     String    @default("USD")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer     Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lines        SalesOrderLine[]
  workOrders   WorkOrder[]
  certificates CertificateOfConformance[]
  quotation    Quotation?

  // Financial relations
  salesInvoices SalesInvoice[]

  // Shipping (one-to-many: partial shipments)
  shipments Shipment[]

  // Performance indexes
  @@index([customerId, orderDate])
  @@index([status])
  @@index([status, orderDate])
  @@index([requiredDate])
  @@map("sales_orders")
}

model SalesOrderLine {
  id         String   @id @default(cuid())
  orderId    String
  lineNumber Int
  productId  String
  quantity   Int
  unitPrice  Float
  discount   Float    @default(0)
  lineTotal  Float?
  options    String?
  status     String   @default("pending")
  shippedQty Int      @default(0)
  createdAt  DateTime @default(now())

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([orderId, lineNumber])
  @@index([orderId])
  @@index([productId])
  @@index([status])
  @@map("sales_order_lines")
}

// ============ SHIPMENTS (Xuất kho & Giao hàng) ============
model Shipment {
  id             String    @id @default(cuid())
  shipmentNumber String    @unique
  salesOrderId   String
  customerId     String
  status         String    @default("PREPARING") // PREPARING | SHIPPED | DELIVERED
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  shippedBy      String?
  deliveredBy    String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  salesOrder SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lines      ShipmentLine[]

  @@index([salesOrderId])
  @@index([status])
  @@index([customerId])
  @@map("shipments")
}

model ShipmentLine {
  id         String   @id @default(cuid())
  shipmentId String
  lineNumber Int
  productId  String
  quantity   Int
  createdAt  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, lineNumber])
  @@index([shipmentId])
  @@index([productId])
  @@map("shipment_lines")
}

// ============ PURCHASING ============
model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique
  supplierId   String
  orderDate    DateTime
  expectedDate DateTime
  status       String   @default("draft")
  totalAmount  Float?
  currency     String   @default("USD")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Approval workflow fields
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  submittedAt     DateTime?

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines    PurchaseOrderLine[]
  grns     GoodsReceiptNote[]
  matchRecords ThreeWayMatch[]

  // Financial relations
  purchaseInvoices PurchaseInvoice[]

  // Performance indexes
  @@index([supplierId, status])
  @@index([status])
  @@index([expectedDate])
  @@index([orderDate])
  @@index([supplierId, orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          String   @id @default(cuid())
  poId        String
  lineNumber  Int
  partId      String
  quantity    Int
  receivedQty Int      @default(0)
  unitPrice   Float
  lineTotal   Float?
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  po   PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  part Part          @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([poId, lineNumber])
  @@index([poId])
  @@index([partId])
  @@index([status])
  @@map("purchase_order_lines")
}

// ============ GOODS RECEIPT NOTE ============

model GoodsReceiptNote {
  id              String   @id @default(cuid())
  grnNumber       String   @unique
  purchaseOrderId String
  receivedById    String
  receivedDate    DateTime @default(now())
  notes           String?
  status          String   @default("completed") // draft, completed, cancelled
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  items         GRNItem[]
  matchRecords  ThreeWayMatch[]

  @@index([purchaseOrderId])
  @@index([grnNumber])
  @@index([receivedDate])
  @@map("goods_receipt_notes")
}

model GRNItem {
  id               String   @id @default(cuid())
  grnId            String
  poLineId         String
  partId           String
  quantityOrdered  Int
  quantityReceived Int
  quantityAccepted Int
  quantityRejected Int      @default(0)
  rejectionReason  String?
  lotNumber        String?
  expiryDate       DateTime?
  createdAt        DateTime @default(now())

  grn  GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  part Part             @relation(fields: [partId], references: [id])

  @@index([grnId])
  @@index([partId])
  @@map("grn_items")
}

// ============ 3-WAY MATCHING ============

model ThreeWayMatch {
  id              String   @id @default(cuid())

  // Links
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  grnId           String?
  grn             GoodsReceiptNote? @relation(fields: [grnId], references: [id])
  purchaseInvoiceId String?
  invoiceNumber   String?

  // Status: pending, matched, mismatch_pending_review, approved, rejected
  status          String   @default("pending")

  // PO Data (snapshot)
  poQuantity      Int
  poUnitPrice     Float
  poTotalAmount   Float

  // GRN Data
  grnQuantity     Int?
  grnAcceptedQty  Int?

  // Invoice Data
  invoiceAmount   Float?
  invoiceDate     DateTime?

  // Variance Calculations
  qtyVariance     Int?
  qtyVariancePct  Float?
  amtVariance     Float?
  amtVariancePct  Float?

  // Review (for mismatches)
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  resolution      String?  // approved_as_is, adjusted, rejected, credited

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
  @@index([grnId])
  @@map("three_way_matches")
}

// ============ QUOTATION ============

model Quotation {
  id              String   @id @default(cuid())
  quoteNumber     String   @unique
  customerId      String
  status          String   @default("draft") // draft, sent, accepted, rejected, expired, converted
  validUntil      DateTime
  sentAt          DateTime?
  acceptedAt      DateTime?
  createdById     String

  // Financials
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  currency        String   @default("VND")

  // Converted SO link
  salesOrderId    String?  @unique

  // Metadata
  notes           String?
  terms           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer   Customer     @relation(fields: [customerId], references: [id])
  items      QuotationItem[]
  salesOrder SalesOrder?  @relation(fields: [salesOrderId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([quoteNumber])
  @@index([validUntil])
  @@map("quotations")
}

model QuotationItem {
  id              String   @id @default(cuid())
  quotationId     String
  partId          String
  description     String?
  quantity        Int
  unitPrice       Float
  discountPercent Float    @default(0)
  taxRate         Float    @default(0)
  lineTotal       Float
  createdAt       DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  part      Part      @relation(fields: [partId], references: [id])

  @@index([quotationId])
  @@index([partId])
  @@map("quotation_items")
}

// ============ PRICING RULES ============

model PricingRule {
  id              String   @id @default(cuid())
  name            String
  description     String?
  type            String   // customer_specific, quantity_break, date_based, category_discount
  customerId      String?
  partId          String?
  category        String?  // For category_discount type

  // Conditions
  minQuantity     Int?
  maxQuantity     Int?
  validFrom       DateTime?
  validTo         DateTime?

  // Discount/Price
  discountType    String   @default("percent") // percent, fixed_amount, fixed_price
  discountValue   Float

  // Priority & Status
  priority        Int      @default(0)
  isActive        Boolean  @default(true)

  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  part     Part?     @relation(fields: [partId], references: [id])

  @@index([customerId])
  @@index([partId])
  @@index([type])
  @@index([isActive])
  @@index([priority])
  @@map("pricing_rules")
}

// ============ USERS ============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // MFA fields
  mfaEnabled     Boolean @default(false)
  mfaMethod      String? // totp, sms, email
  mfaSecret      String? // Encrypted TOTP secret
  mfaBackupCodes Json? // Encrypted backup codes

  // Security fields
  lastLoginAt        DateTime?
  lastLoginIp        String?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  passwordChangedAt  DateTime?
  mustChangePassword Boolean   @default(false)

  // ITAR fields
  itarCertified   Boolean   @default(false)
  itarCertifiedAt DateTime?
  itarCertifiedBy String?
  usPersonStatus  String? // US_CITIZEN, PERMANENT_RESIDENT, NOT_US_PERSON

  laborEntries         LaborEntry[]
  mfaDevices           MFADevice[]
  mfaChallenges        MFAChallenge[]
  sessions             UserSession[]
  passwordHistory      PasswordHistory[]
  electronicSignatures ElectronicSignature[]
  itarAccessLogs       ITARAccessLog[]
  mobileDevices        MobileDevice[]
  workSessions         WorkSession[]

  // Contextual Chat relations
  createdThreads       ConversationThread[] @relation("ThreadCreator")
  sentMessages         Message[]            @relation("MessageSender")
  threadParticipations ThreadParticipant[]
  mentions             Mention[]            @relation("MentionedUser")

  // Notifications
  notifications   Notification[]
  notifyOnMention Boolean        @default(true)
  notifyOnReply   Boolean        @default(true)
  notifyByEmail   Boolean        @default(false)

  // Multi-tenancy
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Workflow Automation relations
  initiatedWorkflows    WorkflowInstance[]     @relation("WorkflowInitiator")
  workflowApprovals     WorkflowApproval[]     @relation("WorkflowApprover")
  delegatedApprovals    WorkflowApproval[]     @relation("WorkflowDelegate")
  workflowActions       WorkflowHistory[]      @relation("WorkflowHistoryActor")
  workflowNotifications WorkflowNotification[] @relation("WorkflowNotificationRecipient")

  // Analytics relations
  analyticsDashboards AnalyticsDashboard[]
  savedReports        SavedReport[]

  // Sprint 3: Import & Views relations
  importSessions ImportSession[] @relation("ImportSessionUser")
  importMappings ImportMapping[] @relation("ImportMappingUser")
  savedViews     SavedView[]     @relation("SavedViewUser")

  // Password Reset
  passwordResetTokens PasswordResetToken[]

  // Extended notification settings (JSON for flexibility)
  notificationSettings Json?

  // Cost Optimization relations
  costTargets             CostTarget[]             @relation("CostTargetCreator")
  costReductionActions    CostReductionAction[]    @relation("CostReductionActionOwner")
  makeVsBuyAnalyses       MakeVsBuyAnalysis[]      @relation("MakeVsBuyAnalysisCreator")
  substituteEvaluations   SubstituteEvaluation[]   @relation("SubstituteEvaluationCreator")

  @@index([tenantId])
  @@map("users")
}

// ============ PASSWORD RESET TOKENS ============
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ============ MRP ============
model MrpRun {
  id                  String    @id @default(cuid())
  runNumber           String    @unique
  runDate             DateTime  @default(now())
  planningHorizon     Int       @default(90)
  status              String    @default("running")
  totalParts          Int?
  purchaseSuggestions Int?
  expediteAlerts      Int?
  shortageWarnings    Int?
  parameters          Json?
  completedAt         DateTime?
  createdBy           String?
  createdAt           DateTime  @default(now())

  suggestions MrpSuggestion[]

  @@index([status])
  @@index([runDate])
  @@index([status, runDate])
  @@map("mrp_runs")
}

model MrpSuggestion {
  id              String    @id @default(cuid())
  mrpRunId        String
  partId          String
  actionType      String
  priority        String
  suggestedQty    Int?
  suggestedDate   DateTime?
  currentStock    Int?
  requiredQty     Int?
  shortageQty     Int?
  reason          String?
  sourceOrderId   String?
  sourceOrderType String?
  supplierId      String?
  estimatedCost   Float?
  status          String    @default("pending")
  approvedBy      String?
  approvedAt      DateTime?
  convertedPoId   String?
  notes           String?
  createdAt       DateTime  @default(now())

  mrpRun   MrpRun    @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)
  part     Part      @relation(fields: [partId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([mrpRunId])
  @@index([partId])
  @@index([status])
  @@map("mrp_suggestions")
}

// ============ PRODUCTION ============
model WorkOrder {
  id              String        @id @default(cuid())
  woNumber        String        @unique
  productId       String
  salesOrderId    String?
  salesOrderLine  Int?
  quantity        Int
  priority        String        @default("normal")
  status          String        @default("draft")
  woType          WorkOrderType @default(DISCRETE)
  batchSize       Int?
  outputLotNumber String?
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  assignedTo      String?
  workCenter      String?
  workCenterId    String?
  notes           String?
  completedQty    Int           @default(0)
  scrapQty        Int           @default(0)
  dueDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesOrder    SalesOrder?          @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  workCenterRef WorkCenter?          @relation("WorkOrderWorkCenter", fields: [workCenterId], references: [id], onDelete: SetNull)
  allocations   MaterialAllocation[]
  inspections   Inspection[]
  ncrs          NCR[]
  operations    WorkOrderOperation[]

  // Production receipt (warehouse approval flow)
  productionReceipt ProductionReceipt?

  // Financial relations
  workOrderCosts WorkOrderCost[]
  costVariances  CostVariance[]

  // Performance indexes
  @@index([status])
  @@index([productId])
  @@index([status, createdAt])
  @@index([plannedStart, plannedEnd])
  @@map("work_orders")
}

model ProductionReceipt {
  id             String    @id @default(cuid())
  receiptNumber  String    @unique
  workOrderId    String    @unique
  productId      String
  partId         String?
  quantity       Int
  lotNumber      String
  warehouseId    String
  status         String    @default("PENDING") // PENDING | CONFIRMED | REJECTED
  requestedBy    String
  requestedAt    DateTime  @default(now())
  confirmedBy    String?
  confirmedAt    DateTime?
  rejectedBy     String?
  rejectedAt     DateTime?
  rejectedReason String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([warehouseId, status])
  @@map("production_receipts")
}

model MaterialAllocation {
  id           String   @id @default(cuid())
  workOrderId  String
  partId       String
  requiredQty  Int
  allocatedQty Int      @default(0)
  issuedQty    Int      @default(0)
  returnedQty  Int      @default(0)
  status       String   @default("pending")
  warehouseId  String?
  lotNumber    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  part      Part      @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, partId])
  @@index([workOrderId])
  @@index([partId])
  @@index([status])
  @@map("material_allocations")
}

// ============ AI FORECASTS ============
model DemandForecast {
  id          String   @id @default(cuid())
  productId   String
  period      String // "2024-Q1", "2024-02", etc.
  periodType  String // "monthly", "quarterly", "yearly"
  forecastQty Int
  lowerBound  Int // Confidence interval lower
  upperBound  Int // Confidence interval upper
  confidence  Float // 0-1 confidence score
  actualQty   Int? // Filled when period ends
  accuracy    Float? // Calculated after actual
  model       String   @default("moving_average") // Algorithm used
  factors     Json? // Contributing factors
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, period, periodType])
  @@index([productId])
  @@map("demand_forecasts")
}

model LeadTimePrediction {
  id            String   @id @default(cuid())
  supplierId    String
  partId        String?
  predictedDays Int
  confidence    Float
  minDays       Int
  maxDays       Int
  factors       Json? // { season, quantity, supplier_load }
  historicalAvg Float?
  lastUpdated   DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  part     Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@unique([supplierId, partId])
  @@index([supplierId])
  @@index([partId])
  @@map("lead_time_predictions")
}

model SupplierRiskScore {
  id           String @id @default(cuid())
  supplierId   String @unique
  overallScore Int // 0-100
  riskLevel    String // LOW, MEDIUM, HIGH, CRITICAL

  // Factor scores (0-100 each)
  deliveryScore      Int
  qualityScore       Int
  financialScore     Int
  geographicScore    Int
  communicationScore Int

  // Trends
  trend         String // IMPROVING, STABLE, DECLINING
  previousScore Int?

  // Details
  strengths       Json? // Array of strength points
  risks           Json? // Array of risk points
  recommendations Json? // Array of recommendations

  lastCalculated DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([riskLevel])
  @@index([overallScore])
  @@map("supplier_risk_scores")
}

model AiRecommendation {
  id              String  @id @default(cuid())
  type            String // REORDER, SUPPLIER_CHANGE, SAFETY_STOCK, EXPEDITE
  priority        String // HIGH, MEDIUM, LOW
  category        String // inventory, purchasing, production, supplier
  title           String
  description     String
  impact          String? // Potential impact description
  savingsEstimate Float? // Estimated cost savings
  confidence      Float

  // Related entities
  partId     String?
  supplierId String?
  productId  String?
  orderId    String?

  // Status
  status        String    @default("active") // active, dismissed, implemented
  dismissedAt   DateTime?
  implementedAt DateTime?

  // Metadata
  modelVersion String?
  factors      Json?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?

  @@index([status, priority])
  @@index([category])
  @@map("ai_recommendations")
}

model AiModelLog {
  id         String   @id @default(cuid())
  modelName  String
  version    String
  runType    String // forecast, risk_score, recommendation
  inputData  Json?
  outputData Json?
  accuracy   Float?
  duration   Int? // milliseconds
  status     String // success, failed
  error      String?
  createdAt  DateTime @default(now())

  @@index([modelName, createdAt])
  @@map("ai_model_logs")
}

// ============ PHASE 4: AUDIT & ACTIVITY ============
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // CREATE, UPDATE, DELETE, VIEW, EXPORT, IMPORT
  entityType String // Part, Supplier, SalesOrder, etc.
  entityId   String
  entityName String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  type        String // order_created, stock_alert, po_received
  title       String
  description String?
  icon        String?
  color       String?
  link        String?
  isRead      Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============ NOTIFICATIONS ============
model NotificationSetting {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  emailOnOrder Boolean  @default(true)
  emailOnStock Boolean  @default(true)
  emailOnPO    Boolean  @default(true)
  emailOnMRP   Boolean  @default(false)
  emailDigest  String   @default("daily")
  inAppEnabled Boolean  @default(true)
  inAppOnOrder Boolean  @default(true)
  inAppOnStock Boolean  @default(true)
  inAppOnPO    Boolean  @default(true)
  inAppOnMRP   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("notification_settings")
}

model Notification {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     String // stock_alert, order_update, po_received, mention, reply, thread_update
  title    String
  message  String  @db.Text
  priority String  @default("normal")
  link     String?

  // Source reference
  sourceType String? // 'message', 'thread', 'task', etc.
  sourceId   String?

  // Mention specific
  mentionedBy     String? // User ID who mentioned
  mentionedByName String? // User name for display
  threadId        String?
  messageId       String?

  // Context for navigation
  contextType String? // 'PART', 'BOM', 'WORK_ORDER', etc.
  contextId   String?
  contextUrl  String? // Direct URL to navigate

  // Status
  isRead      Boolean   @default(false)
  readAt      DateTime?
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
  @@index([createdAt])
  @@map("notifications")
}

// ============ SAVED REPORTS ============
model SavedReport {
  id             String    @id @default(cuid())
  userId         String
  name           String
  description    String?
  type           String // inventory, orders, purchasing, supplier, production, quality, financial, custom
  category       String? // Category for grouping reports
  filters        Json
  columns        Json?
  visualizations Json? // Chart/visualization configurations
  isPublic       Boolean   @default(false)
  isFavorite     Boolean   @default(false)
  schedule       String? // Deprecated: use ReportSchedule instead
  recipients     Json? // Deprecated: use ReportSchedule instead
  lastRunAt      DateTime?
  viewCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules ReportSchedule[]
  instances ReportInstance[]

  @@index([userId])
  @@index([type])
  @@index([isPublic])
  @@map("saved_reports")
}

// ============ IMPORT/EXPORT JOBS (Phase 10 Enhanced) ============
model ImportJob {
  id                String    @id @default(cuid())
  userId            String
  type              String // parts, suppliers, inventory, products, customers, bom
  fileName          String
  fileSize          Int
  status            String    @default("pending") // pending, validating, mapping, processing, completed, failed, cancelled
  totalRows         Int?
  processedRows     Int       @default(0)
  successRows       Int       @default(0)
  errorRows         Int       @default(0)
  skippedRows       Int       @default(0)
  errors            Json? // Array of error details
  warnings          Json? // Array of warning details
  mapping           Json? // Column mapping configuration
  options           Json? // Import options (update mode, skip duplicates, etc.)
  validationResults Json? // Pre-import validation results
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  rows ImportRow[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("import_jobs")
}

model ImportRow {
  id          String    @id @default(cuid())
  importJobId String
  rowNumber   Int
  status      String    @default("pending") // pending, valid, invalid, imported, skipped, error
  rawData     Json // Original row data
  mappedData  Json? // Data after mapping
  errors      Json? // Row-level errors
  warnings    Json? // Row-level warnings
  entityId    String? // ID of created/updated entity
  processedAt DateTime?

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId, status])
  @@index([importJobId, rowNumber])
  @@map("import_rows")
}

model ExportJob {
  id             String    @id @default(cuid())
  userId         String
  type           String // parts, suppliers, inventory, products, customers, orders, bom, full_backup
  format         String // xlsx, csv
  filters        Json? // Export filters
  columns        Json? // Selected columns to export
  options        Json? // Export options (include headers, date format, etc.)
  status         String    @default("pending") // pending, processing, completed, failed
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  totalRecords   Int?
  exportedAt     DateTime?
  expiresAt      DateTime?
  downloadCount  Int       @default(0)
  lastDownloadAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("export_jobs")
}

model ExcelTemplate {
  id          String  @id @default(cuid())
  name        String
  type        String // parts, suppliers, inventory, products, customers, bom
  description String?
  version     String  @default("1.0")

  // Template structure
  columns      Json // Column definitions with headers, types, validation
  sampleData   Json? // Sample data rows
  instructions String? // Usage instructions

  // Validation rules
  validationRules Json? // Custom validation rules

  // File info
  fileName String
  fileUrl  String?
  fileSize Int?

  // Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  // Usage tracking
  downloadCount  Int       @default(0)
  lastDownloadAt DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, version])
  @@index([type, isActive])
  @@map("excel_templates")
}

model SyncSchedule {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?

  // Sync configuration
  type       String // import, export, bidirectional
  entityType String // parts, suppliers, inventory, etc.
  direction  String // inbound, outbound, both

  // Source/Target
  sourceType String // file_watch, api, manual
  sourcePath String? // File path or API endpoint
  targetType String?
  targetPath String?

  // Schedule
  frequency      String // manual, hourly, daily, weekly, monthly
  cronExpression String? // For custom schedules
  timezone       String  @default("UTC")

  // Options
  mapping Json? // Field mapping configuration
  options Json? // Sync options

  // Status
  status String @default("active") // active, paused, disabled

  // Execution tracking
  lastRunAt     DateTime?
  lastRunStatus String?
  lastRunError  String?
  nextRunAt     DateTime?
  runCount      Int       @default(0)
  successCount  Int       @default(0)
  failureCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
  @@map("sync_schedules")
}

model MigrationBatch {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?

  // Migration type
  type         String // legacy_import, system_migration, data_cleanup
  sourceSystem String? // Name of source system

  // Status
  status String @default("pending") // pending, in_progress, completed, failed, rolled_back

  // Progress
  totalEntities     Int @default(0)
  processedEntities Int @default(0)
  successEntities   Int @default(0)
  errorEntities     Int @default(0)

  // Details
  entityTypes     Json? // Array of entity types being migrated
  mapping         Json? // Migration mapping configuration
  transformations Json? // Data transformation rules

  // Results
  results Json? // Detailed migration results
  errors  Json? // Migration errors

  // Timestamps
  startedAt   DateTime?
  completedAt DateTime?

  // Rollback
  canRollback  Boolean   @default(true)
  rollbackData Json? // Data needed for rollback
  rolledBackAt DateTime?
  rolledBackBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("migration_batches")
}

// ═══════════════════════════════════════════════════════════════════
//                    QUALITY MANAGEMENT MODELS (Phase 5)
// ═══════════════════════════════════════════════════════════════════

// ============ INSPECTION PLANS ============
model InspectionPlan {
  id            String    @id @default(cuid())
  planNumber    String    @unique
  name          String
  description   String?
  type          String // RECEIVING, IN_PROCESS, FINAL
  status        String    @default("draft") // draft, active, obsolete
  version       Int       @default(1)
  effectiveDate DateTime?
  obsoleteDate  DateTime?

  partId     String?
  productId  String?
  supplierId String?

  sampleSize   String? // "100%", "AQL 1.0", "First 5", etc.
  sampleMethod String? // RANDOM, FIRST_ARTICLE, SKIP_LOT

  createdBy  String
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  part     Part?     @relation(fields: [partId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  characteristics InspectionCharacteristic[]
  inspections     Inspection[]

  @@index([type, status])
  @@index([partId])
  @@map("inspection_plans")
}

model InspectionCharacteristic {
  id          String  @id @default(cuid())
  planId      String
  sequence    Int
  name        String
  description String?
  type        String // VISUAL, DIMENSIONAL, FUNCTIONAL, DOCUMENTATION

  specification String? // "10.00 ± 0.05 mm"
  nominalValue  Float?
  upperLimit    Float?
  lowerLimit    Float?
  unitOfMeasure String?

  acceptanceCriteria String?
  referenceDocs      String?

  isCritical   Boolean @default(false)
  isMajor      Boolean @default(false)
  gageRequired String?

  // SPC fields
  subgroupSize       Int?
  samplingFrequency  String?
  chartType          String?
  code               String?

  createdAt DateTime @default(now())

  plan    InspectionPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  results InspectionResult[]
  qualityAlerts QualityAlert[]

  @@index([planId])
  @@map("inspection_characteristics")
}

// ============ INSPECTIONS ============
model Inspection {
  id               String  @id @default(cuid())
  inspectionNumber String  @unique
  type             String // RECEIVING, IN_PROCESS, FINAL
  status           String  @default("pending") // pending, in_progress, completed, on_hold
  result           String? // PASS, FAIL, CONDITIONAL
  sourceType       String? // PO, NON_PO, PRODUCTION (for RECEIVING type)

  planId    String?
  partId    String?
  productId String?

  poLineId     String?
  workOrderId  String?
  salesOrderId String?

  lotNumber         String?
  serialNumbers     Json?
  quantityReceived  Int?
  quantityInspected Int?
  quantityAccepted  Int?
  quantityRejected  Int?

  inspectedBy String
  inspectedAt DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?

  warehouseId String?
  workCenter  String?

  notes       String?
  attachments Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan      InspectionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  part      Part?           @relation(fields: [partId], references: [id], onDelete: SetNull)
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  workOrder WorkOrder?      @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  results      InspectionResult[]
  ncrs         NCR[]
  certificates CertificateOfConformance[]

  @@index([type, status])
  @@index([sourceType])
  @@index([lotNumber])
  @@index([partId])
  @@index([workOrderId])
  @@map("inspections")
}

model InspectionResult {
  id               String @id @default(cuid())
  inspectionId     String
  characteristicId String

  result            String // PASS, FAIL, N/A
  measuredValue     Float?
  measuredValues    Json?
  findings          String?
  imageUrl          String?
  defectCode        String?
  defectDescription String?

  // SPC fields
  sampleNumber Int?
  subgroupId   String?
  machineId    String?
  mean         Float?
  range        Float?
  stdDev       Float?

  inspectedBy String
  inspectedAt DateTime @default(now())

  inspection     Inspection               @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  characteristic InspectionCharacteristic @relation(fields: [characteristicId], references: [id], onDelete: Cascade)

  @@unique([inspectionId, characteristicId])
  @@index([inspectionId])
  @@index([result])
  @@map("inspection_results")
}

// ============ NON-CONFORMANCE REPORTS ============
model NCR {
  id        String @id @default(cuid())
  ncrNumber String @unique
  status    String @default("open")
  // open, under_review, pending_disposition, disposition_approved,
  // in_rework, pending_verification, completed, closed, voided

  priority String @default("medium") // low, medium, high, critical

  source       String // RECEIVING, IN_PROCESS, FINAL, CUSTOMER, AUDIT
  inspectionId String?

  partId       String?
  productId    String?
  workOrderId  String?
  salesOrderId String?
  poId         String?

  lotNumber        String?
  serialNumbers    Json?
  quantityAffected Int

  title          String
  description    String
  defectCode     String?
  defectCategory String? // DIMENSIONAL, VISUAL, FUNCTIONAL, DOCUMENTATION, CONTAMINATION

  preliminaryCause String?

  containmentAction String?
  containedBy       String?
  containedAt       DateTime?

  disposition           String? // USE_AS_IS, REWORK, REPAIR, SCRAP, RETURN_TO_VENDOR, SORT
  dispositionReason     String?
  dispositionBy         String?
  dispositionAt         DateTime?
  dispositionApprovedBy String?
  dispositionApprovedAt DateTime?

  reworkInstructions String?
  reworkWorkOrderId  String?

  laborCost    Float?
  materialCost Float?
  totalCost    Float?

  customerNotified   Boolean   @default(false)
  customerNotifiedAt DateTime?

  closedBy     String?
  closedAt     DateTime?
  closureNotes String?

  capaId      String?
  attachments Json?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspection Inspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  part       Part?       @relation(fields: [partId], references: [id], onDelete: SetNull)
  product    Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  workOrder  WorkOrder?  @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  capa       CAPA?       @relation(fields: [capaId], references: [id], onDelete: SetNull)

  history NCRHistory[]

  @@index([status])
  @@index([priority])
  @@index([lotNumber])
  @@index([partId])
  @@map("ncrs")
}

model NCRHistory {
  id         String   @id @default(cuid())
  ncrId      String
  action     String // STATUS_CHANGE, DISPOSITION_SET, COMMENT, ATTACHMENT
  fromStatus String?
  toStatus   String?
  comment    String?
  userId     String
  createdAt  DateTime @default(now())

  ncr NCR @relation(fields: [ncrId], references: [id], onDelete: Cascade)

  @@index([ncrId])
  @@map("ncr_history")
}

// ============ CAPA (Corrective & Preventive Action) ============
model CAPA {
  id         String @id @default(cuid())
  capaNumber String @unique
  type       String // CORRECTIVE, PREVENTIVE
  status     String @default("open")
  // open, root_cause_analysis, action_planning, implementation,
  // verification, completed, closed

  priority String @default("medium") // low, medium, high, critical

  source          String // NCR, AUDIT, CUSTOMER_COMPLAINT, INTERNAL, SUPPLIER
  sourceReference String?

  title       String
  description String

  affectedParts     Json?
  affectedProducts  Json?
  affectedProcesses Json?

  ownerId     String
  teamMembers Json?

  rcaMethod      String? // 5_WHY, FISHBONE, 8D, FAULT_TREE
  rcaFindings    String?
  rcaCompletedBy String?
  rcaCompletedAt DateTime?
  rootCause      String?

  immediateAction   String?
  immediateActionBy String?
  immediateActionAt DateTime?

  targetDate         DateTime?
  originalTargetDate DateTime?

  verificationMethod  String?
  verificationResults String?
  verifiedBy          String?
  verifiedAt          DateTime?
  effectivenessScore  Int?

  closedBy     String?
  closedAt     DateTime?
  closureNotes String?

  estimatedCost Float?
  actualCost    Float?
  attachments   Json?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ncrs    NCR[]
  actions CAPAAction[]
  history CAPAHistory[]

  @@index([status])
  @@index([type])
  @@index([ownerId])
  @@map("capas")
}

model CAPAAction {
  id              String    @id @default(cuid())
  capaId          String
  sequence        Int
  type            String // CORRECTIVE, PREVENTIVE, CONTAINMENT
  description     String
  assigneeId      String
  dueDate         DateTime?
  status          String    @default("pending") // pending, in_progress, completed, overdue
  completedAt     DateTime?
  completionNotes String?
  verifiedBy      String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  capa CAPA @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@index([assigneeId, status])
  @@map("capa_actions")
}

model CAPAHistory {
  id         String   @id @default(cuid())
  capaId     String
  action     String
  fromStatus String?
  toStatus   String?
  comment    String?
  userId     String
  createdAt  DateTime @default(now())

  capa CAPA @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([capaId])
  @@map("capa_history")
}

// ============ LOT TRACEABILITY ============
model LotTransaction {
  id              String @id @default(cuid())
  lotNumber       String
  transactionType String
  // RECEIVED, INSPECTED, ISSUED, CONSUMED, PRODUCED, SHIPPED, ADJUSTED, SCRAPPED

  partId    String?
  productId String?

  quantity    Int
  previousQty Int?
  newQty      Int?

  poId         String?
  poLineNumber Int?
  workOrderId  String?
  salesOrderId String?
  soLineNumber Int?
  inspectionId String?
  ncrId        String?

  fromWarehouseId String?
  toWarehouseId   String?
  fromLocation    String?
  toLocation      String?

  parentLots Json?

  notes     String?
  userId    String
  createdAt DateTime @default(now())

  part    Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([lotNumber])
  @@index([partId, lotNumber])
  @@index([transactionType])
  @@index([createdAt])
  @@map("lot_transactions")
}

// ============ SYSTEM SETTINGS (Feature Flags) ============
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("system_settings")
}

// ============ SCRAP DISPOSAL (Quality) ============
model ScrapDisposal {
  id                String   @id @default(cuid())
  partId            String
  part              Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  lotNumber         String?
  quantity          Int
  unitCost          Float
  totalValue        Float
  disposalMethod    String // PHYSICAL_DESTRUCTION, RECYCLING, HAZARDOUS_WASTE, OTHER
  disposalReference String?
  notes             String?
  disposedBy        String
  disposedAt        DateTime
  createdAt         DateTime @default(now())

  @@index([partId])
  @@index([disposedAt])
  @@map("scrap_disposals")
}

// ============ CERTIFICATES ============
model CertificateOfConformance {
  id                String @id @default(cuid())
  certificateNumber String @unique

  salesOrderId     String
  salesOrderLineId String?
  productId        String

  lotNumbers    Json
  serialNumbers Json?
  quantity      Int

  inspectionId String?

  specifications Json?
  testResults    Json?

  preparedBy String
  preparedAt DateTime
  approvedBy String?
  approvedAt DateTime?

  pdfUrl String?

  status     String    @default("draft") // draft, approved, issued, voided
  issuedAt   DateTime?
  voidedAt   DateTime?
  voidReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrder SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inspection Inspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)

  @@index([salesOrderId])
  @@map("certificates_of_conformance")
}

// ============ DEFECT CODES ============
model DefectCode {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String // DIMENSIONAL, VISUAL, FUNCTIONAL, DOCUMENTATION, CONTAMINATION
  description String?
  severity    String   @default("minor") // minor, major, critical
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([severity])
  @@index([isActive])
  @@map("defect_codes")
}

// ═══════════════════════════════════════════════════════════════════
//                    PRODUCTION ENHANCEMENT MODELS (Phase 6)
// ═══════════════════════════════════════════════════════════════════

// ============ WORK CENTERS ============
model WorkCenter {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  type        String // MACHINE, ASSEMBLY, TESTING, PACKAGING, LABOR_ONLY

  // Location
  department String?
  location   String?

  // Capacity
  capacityType      String @default("hours") // hours, units, weight
  capacityPerDay    Float // Standard capacity per day
  capacityPerHour   Float? // Capacity per hour (if applicable)
  efficiency        Float  @default(100) // Efficiency percentage
  utilizationTarget Float  @default(85) // Target utilization %

  // Scheduling
  workingHoursStart String @default("08:00")
  workingHoursEnd   String @default("17:00")
  breakMinutes      Int    @default(60) // Break time per day
  workingDays       Json   @default("[1,2,3,4,5]") // Mon-Fri

  // Costs
  hourlyRate       Float? // Cost per hour
  setupCostPerHour Float? // Setup cost per hour
  overheadRate     Float? // Overhead percentage

  // Constraints
  maxConcurrentJobs  Int     @default(1) // How many jobs can run simultaneously
  requiresOperator   Boolean @default(true)
  operatorSkillLevel String? // Required skill level

  // Status
  status     String  @default("active") // active, maintenance, inactive
  currentJob String? // Current operation ID

  // Maintenance
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  maintenanceInterval Int? // Days between maintenance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  operations         RoutingOperation[]
  scheduledOps       ScheduledOperation[]
  laborEntries       LaborEntry[]
  downtimeRecords    DowntimeRecord[]
  capacityRecords    CapacityRecord[]
  woOperations       WorkOrderOperation[]
  equipment          Equipment[]
  workCenterCapacity WorkCenterCapacity[]
  defaultProducts    Product[]            @relation("ProductDefaultWorkCenter")
  workOrders         WorkOrder[]          @relation("WorkOrderWorkCenter")

  @@index([status])
  @@index([type])
  @@map("work_centers")
}

// ============ ROUTING ============
model Routing {
  id            String  @id @default(cuid())
  routingNumber String  @unique
  name          String
  description   String?

  // Link to product
  productId String

  // Version control
  version       Int       @default(1)
  status        String    @default("draft") // draft, active, obsolete
  effectiveDate DateTime?
  obsoleteDate  DateTime?

  // Totals (calculated)
  totalSetupTime Float? // Total setup time in minutes
  totalRunTime   Float? // Total run time per unit in minutes
  totalLaborTime Float? // Total labor time per unit
  totalCost      Float? // Total cost per unit

  createdBy  String
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  product    Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  operations RoutingOperation[]

  @@unique([productId, version])
  @@index([productId, status])
  @@map("routings")
}

model RoutingOperation {
  id        String @id @default(cuid())
  routingId String

  // Sequence
  operationNumber Int // 10, 20, 30... (allows inserting)
  name            String
  description     String?

  // Work Center
  workCenterId         String
  alternateWorkCenters Json? // Array of alternate work center IDs

  // Times (in minutes)
  setupTime      Float @default(0) // Setup time per batch
  runTimePerUnit Float // Run time per unit
  waitTime       Float @default(0) // Queue/wait time
  moveTime       Float @default(0) // Move to next operation

  // Labor
  laborTimePerUnit  Float? // Labor time (may differ from machine time)
  operatorsRequired Int     @default(1)
  skillRequired     String?

  // Overlap/Parallel
  overlapPercent Float   @default(0) // Can start next op when this % complete
  canRunParallel Boolean @default(false) // Can run parallel with previous

  // Quality
  inspectionRequired Boolean @default(false)
  inspectionPlanId   String?

  // Instructions
  workInstructions String?
  toolsRequired    Json? // Array of tool IDs/names

  // Subcontracting
  isSubcontracted Boolean @default(false)
  supplierId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routing      Routing              @relation(fields: [routingId], references: [id], onDelete: Cascade)
  workCenter   WorkCenter           @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  woOperations WorkOrderOperation[]

  @@unique([routingId, operationNumber])
  @@index([routingId])
  @@index([workCenterId])
  @@map("routing_operations")
}

// ============ WORK ORDER OPERATIONS ============
model WorkOrderOperation {
  id                 String  @id @default(cuid())
  workOrderId        String
  routingOperationId String? // Link to routing template

  // Sequence
  operationNumber Int
  name            String

  // Work Center
  workCenterId String

  // Planned times
  plannedSetupTime Float
  plannedRunTime   Float // Total run time for WO quantity
  plannedStartDate DateTime?
  plannedEndDate   DateTime?

  // Actual times
  actualSetupTime Float?
  actualRunTime   Float?
  actualStartDate DateTime?
  actualEndDate   DateTime?

  // Quantities
  quantityPlanned   Int
  quantityCompleted Int @default(0)
  quantityScrapped  Int @default(0)

  // Status
  status String @default("pending")
  // pending, scheduled, ready, in_progress, paused, completed, cancelled

  // Scheduling
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  schedulePriority Int       @default(50) // 1-100, higher = more urgent

  // Execution
  startedBy   String?
  completedBy String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrder        WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  routingOperation RoutingOperation?   @relation(fields: [routingOperationId], references: [id], onDelete: SetNull)
  workCenter       WorkCenter          @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  scheduledOp      ScheduledOperation?
  laborEntries     LaborEntry[]

  @@unique([workOrderId, operationNumber])
  @@index([workOrderId])
  @@index([status])
  @@index([workCenterId, status])
  @@map("work_order_operations")
}

// ============ SCHEDULING ============
model ScheduledOperation {
  id                   String @id @default(cuid())
  workOrderOperationId String @unique
  workCenterId         String

  // Scheduled times
  scheduledStart DateTime
  scheduledEnd   DateTime

  // Sequence on work center
  sequence Int // Order on the work center for that day

  // Status
  status String @default("scheduled") // scheduled, in_progress, completed

  // Locked (manual override)
  isLocked Boolean   @default(false)
  lockedBy String?
  lockedAt DateTime?

  // Conflicts
  hasConflict    Boolean @default(false)
  conflictReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrderOperation WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id], onDelete: Cascade)
  workCenter         WorkCenter         @relation(fields: [workCenterId], references: [id], onDelete: Cascade)

  @@index([workCenterId, scheduledStart])
  @@index([scheduledStart])
  @@map("scheduled_operations")
}

// ============ CAPACITY ============
model CapacityRecord {
  id           String   @id @default(cuid())
  workCenterId String
  date         DateTime @db.Date

  // Available capacity
  availableHours Float
  availableUnits Float?

  // Planned/Scheduled
  plannedHours   Float @default(0)
  scheduledHours Float @default(0)

  // Actual
  actualHours Float @default(0)

  // Utilization
  utilization Float? // Calculated: scheduled/available * 100

  // Adjustments
  overtimeHours Float @default(0)
  downtimeHours Float @default(0)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workCenter WorkCenter @relation(fields: [workCenterId], references: [id], onDelete: Cascade)

  @@unique([workCenterId, date])
  @@index([workCenterId, date])
  @@map("capacity_records")
}

// ============ LABOR TRACKING ============
model LaborEntry {
  id                   String  @id @default(cuid())
  userId               String
  workOrderOperationId String?
  workCenterId         String?

  // Type
  type String // DIRECT, INDIRECT, SETUP, REWORK, IDLE

  // Time
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Float? // Calculated or manual entry

  // Quantities (for direct labor)
  quantityProduced Int?
  quantityScrapped Int?

  // Cost
  hourlyRate Float?
  totalCost  Float? // Calculated

  // Notes
  notes String?

  // Approval
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workOrderOperation WorkOrderOperation? @relation(fields: [workOrderOperationId], references: [id], onDelete: SetNull)
  workCenter         WorkCenter?         @relation(fields: [workCenterId], references: [id], onDelete: SetNull)

  @@index([userId, startTime])
  @@index([workOrderOperationId])
  @@index([workCenterId, startTime])
  @@map("labor_entries")
}

// ============ DOWNTIME TRACKING ============
model DowntimeRecord {
  id           String @id @default(cuid())
  workCenterId String

  // Time
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Float?

  // Categorization
  type     String // PLANNED, UNPLANNED, MAINTENANCE, BREAKDOWN, CHANGEOVER
  reason   String
  category String? // Equipment, Material, Labor, Quality, etc.

  // Impact
  scheduledOpsAffected Json? // Array of affected operation IDs

  // Resolution
  resolvedBy String?
  resolution String?

  // Cost
  estimatedCost Float?

  reportedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workCenter WorkCenter @relation(fields: [workCenterId], references: [id], onDelete: Cascade)

  @@index([workCenterId, startTime])
  @@index([type])
  @@map("downtime_records")
}

// ═══════════════════════════════════════════════════════════════════
//                    COMPLIANCE & SECURITY MODELS (Phase 9)
// ═══════════════════════════════════════════════════════════════════

// ============ ELECTRONIC SIGNATURES (21 CFR Part 11) ============
model ElectronicSignature {
  id     String @id @default(cuid())
  userId String

  // What was signed
  entityType String // WorkOrder, NCR, CAPA, Inspection, etc.
  entityId   String
  action     String // APPROVE, REJECT, REVIEW, RELEASE, VERIFY

  // Signature details
  signatureHash String // SHA-256 hash of (userId + timestamp + meaning + entityHash)
  meaning       String // "I approve this document", "I have reviewed", etc.

  // Verification
  verificationMethod String // password, mfa_totp, biometric
  ipAddress          String?
  userAgent          String?

  // Audit chain
  previousSignatureId String?
  chainHash           String? // Hash linking to previous signature

  // Timestamps
  signedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([signedAt])
  @@map("electronic_signatures")
}

// ============ ENHANCED AUDIT TRAIL (Tamper-Proof) ============
model AuditTrailEntry {
  id String @id @default(cuid())

  // Event details
  userId     String?
  userName   String? // Denormalized for history
  action     String // CREATE, READ, UPDATE, DELETE, EXPORT, LOGIN, etc.
  entityType String
  entityId   String?

  // What changed
  fieldName     String?
  oldValue      String?
  newValue      String?
  changeSummary String? // Human-readable description

  // Request context
  ipAddress String?
  userAgent String?
  sessionId String?
  requestId String? // Correlation ID

  // Tamper-proof chain
  previousEntryId String?
  entryHash       String // SHA-256 hash of entry data
  chainHash       String // Hash including previous entry hash

  // Timestamps
  timestamp  DateTime @default(now())
  serverTime DateTime @default(now())

  // Compliance flags
  isSecurityEvent   Boolean @default(false)
  isComplianceEvent Boolean @default(false)
  retentionCategory String  @default("standard") // standard, extended, permanent

  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
  @@index([isSecurityEvent])
  @@map("audit_trail_entries")
}

// ============ MFA DEVICES ============
model MFADevice {
  id     String @id @default(cuid())
  userId String

  // Device info
  name String // "iPhone", "Authenticator App", etc.
  type String // totp, sms, email, hardware_key

  // TOTP specific
  totpSecret String? // Encrypted TOTP secret

  // SMS/Email specific
  phoneNumber  String? // Encrypted phone number
  emailAddress String?

  // Hardware key specific
  credentialId String? // WebAuthn credential ID
  publicKey    String? // WebAuthn public key

  // Status
  isVerified Boolean   @default(false)
  isPrimary  Boolean   @default(false)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenges MFAChallenge[]

  @@index([userId])
  @@map("mfa_devices")
}

// ============ MFA CHALLENGES ============
model MFAChallenge {
  id       String  @id @default(cuid())
  userId   String
  deviceId String?

  // Challenge details
  type String // totp, sms, email
  code String? // Encrypted challenge code (for SMS/email)

  // Status
  status      String @default("pending") // pending, verified, expired, failed
  attempts    Int    @default(0)
  maxAttempts Int    @default(3)

  // Context
  purpose   String // login, signature, sensitive_action
  ipAddress String?

  // Timestamps
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device MFADevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([expiresAt])
  @@map("mfa_challenges")
}

// ============ USER SESSIONS ============
model UserSession {
  id     String @id @default(cuid())
  userId String

  // Session info
  sessionToken String @unique

  // Device/Location
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  location          String? // Geolocation if available

  // Status
  isActive       Boolean  @default(true)
  lastActivityAt DateTime @default(now())

  // Timestamps
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([sessionToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ============ PASSWORD HISTORY ============
model PasswordHistory {
  id     String @id @default(cuid())
  userId String

  passwordHash String // Hashed password
  changedAt    DateTime @default(now())
  changedBy    String? // User who changed it (for admin resets)
  changeReason String? // user_initiated, admin_reset, expired, compromised

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@map("password_history")
}

// ============ PASSWORD POLICY ============
model PasswordPolicy {
  id        String  @id @default(cuid())
  name      String  @unique
  isDefault Boolean @default(false)

  // Length requirements
  minLength Int @default(12)
  maxLength Int @default(128)

  // Character requirements
  requireUppercase Boolean @default(true)
  requireLowercase Boolean @default(true)
  requireNumbers   Boolean @default(true)
  requireSpecial   Boolean @default(true)

  // History requirements
  preventReuse Int @default(12) // Number of previous passwords to check

  // Expiration
  maxAgeDays           Int @default(90) // 0 = never expires
  warnDaysBeforeExpiry Int @default(14)

  // Lockout
  maxFailedAttempts      Int @default(5)
  lockoutDurationMinutes Int @default(30)

  // Additional rules
  preventUsername        Boolean @default(true)
  preventCommonPasswords Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDefault])
  @@map("password_policies")
}

// ============ DATA RETENTION POLICY ============
model DataRetentionPolicy {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  // What to retain
  entityType String // AuditLog, NCR, Inspection, etc.

  // Retention period
  retentionDays    Int // 0 = forever
  archiveAfterDays Int? // Days before archiving (null = don't archive)

  // Actions
  actionOnExpiry String @default("archive") // archive, delete, anonymize

  // Compliance
  regulatoryBasis String? // "21 CFR Part 11", "ITAR", etc.

  // Status
  isActive Boolean @default(true)

  // Execution tracking
  lastExecutedAt  DateTime?
  nextExecutionAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType])
  @@map("data_retention_policies")
}

// ============ ITAR CONTROLLED ITEMS ============
model ITARControlledItem {
  id String @id @default(cuid())

  // What is controlled
  entityType String // Part, Product, Document, etc.
  entityId   String

  // ITAR classification
  usmlCategory  String? // USML category (e.g., "Category XI")
  eccn          String? // Export Control Classification Number
  controlReason String? // Reason for control

  // Marking
  markingRequired Boolean @default(true)
  markingText     String? // Required marking text

  // Access control
  requiresUsPersonVerification Boolean @default(true)
  additionalRestrictions       Json? // Array of additional restrictions

  // Status
  status String @default("active") // active, declassified, superseded

  // Audit
  classifiedBy String
  classifiedAt DateTime  @default(now())
  reviewDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessLogs ITARAccessLog[]

  @@unique([entityType, entityId])
  @@index([usmlCategory])
  @@index([status])
  @@map("itar_controlled_items")
}

// ============ ITAR ACCESS LOG ============
model ITARAccessLog {
  id               String @id @default(cuid())
  userId           String
  controlledItemId String

  // Access details
  accessType    String // VIEW, DOWNLOAD, EXPORT, MODIFY
  accessGranted Boolean
  denialReason  String?

  // Verification at time of access
  usPersonVerified   Boolean
  verificationMethod String? // certification, documentation, etc.

  // Context
  ipAddress String?
  userAgent String?
  purpose   String? // Why access was needed

  // Timestamps
  accessedAt DateTime @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  controlledItem ITARControlledItem @relation(fields: [controlledItemId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([controlledItemId])
  @@index([accessedAt])
  @@map("itar_access_logs")
}

// ═══════════════════════════════════════════════════════════════════
//                    FINANCIAL MODULE MODELS (Phase 11)
// ═══════════════════════════════════════════════════════════════════

// ============ CHART OF ACCOUNTS ============
model GLAccount {
  id            String  @id @default(cuid())
  accountNumber String  @unique
  name          String
  description   String?

  // Classification
  accountType     AccountType // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  accountCategory String // Cash, AR, AP, Inventory, COGS, etc.

  // Hierarchy
  parentId String?
  parent   GLAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children GLAccount[] @relation("AccountHierarchy")

  // Settings
  isActive        Boolean @default(true)
  isSystemAccount Boolean @default(false)
  normalBalance   String  @default("DEBIT") // DEBIT or CREDIT

  // Currency
  currencyCode String @default("USD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  journalLines JournalLine[]
  costTypes    CostType[]

  @@index([accountType])
  @@index([accountCategory])
  @@map("gl_accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// ============ COST STRUCTURE ============
model CostType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  category CostCategory // MATERIAL, LABOR, OVERHEAD, SUBCONTRACT

  // GL Mapping
  glAccountId String?
  glAccount   GLAccount? @relation(fields: [glAccountId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partCosts      PartCostComponent[]
  workOrderCosts WorkOrderCost[]

  @@index([category])
  @@index([isActive])
  @@map("cost_types")
}

enum CostCategory {
  MATERIAL
  LABOR
  OVERHEAD
  SUBCONTRACT
  OTHER
}

// Standard costs for parts
model PartCostComponent {
  id     String @id @default(cuid())
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  costTypeId String
  costType   CostType @relation(fields: [costTypeId], references: [id], onDelete: Cascade)

  // Cost values
  standardCost     Float
  currentCost      Float // Latest actual
  lastPurchaseCost Float?
  averageCost      Float?

  // Effective dates for standard cost changes
  effectiveDate DateTime  @default(now())
  expiryDate    DateTime?

  // Audit
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, costTypeId, effectiveDate])
  @@index([partId])
  @@map("part_cost_components")
}

// Rolled-up costs for assemblies
model PartCostRollup {
  id     String @id @default(cuid())
  partId String @unique
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  // Cost breakdown
  materialCost    Float @default(0)
  laborCost       Float @default(0)
  overheadCost    Float @default(0)
  subcontractCost Float @default(0)
  otherCost       Float @default(0)

  // Totals
  totalStandardCost Float @default(0)
  totalCurrentCost  Float @default(0)

  // BOM level (0 = purchased, 1+ = manufactured)
  bomLevel Int @default(0)

  // Last rollup
  lastRollupAt DateTime?
  rollupStatus String    @default("PENDING") // PENDING, CURRENT, STALE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rollupStatus])
  @@map("part_cost_rollups")
}

// Actual costs on Work Orders
model WorkOrderCost {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  costTypeId String
  costType   CostType @relation(fields: [costTypeId], references: [id], onDelete: Cascade)

  // Cost details
  description String?
  quantity    Float   @default(1)
  unitCost    Float
  totalCost   Float

  // Source reference
  sourceType String? // MATERIAL_ISSUE, LABOR_ENTRY, PO_RECEIPT, MANUAL
  sourceId   String?

  // Timing
  transactionDate DateTime @default(now())

  createdBy String?
  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([transactionDate])
  @@map("work_order_costs")
}

// ============ ACCOUNTS PAYABLE ============
model PurchaseInvoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  // Supplier
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Reference
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  vendorInvoiceNo String? // Supplier's invoice number

  // Dates
  invoiceDate  DateTime
  dueDate      DateTime
  receivedDate DateTime @default(now())

  // Amounts
  subtotal       Float
  taxAmount      Float @default(0)
  shippingAmount Float @default(0)
  discountAmount Float @default(0)
  totalAmount    Float

  // Currency
  currencyCode String @default("USD")
  exchangeRate Float  @default(1)

  // Payment
  paymentTerms String?
  paidAmount   Float   @default(0)
  balanceDue   Float

  // Status
  status     InvoiceStatus @default(DRAFT)
  approvedBy String?
  approvedAt DateTime?

  // GL
  glPosted   Boolean   @default(false)
  glPostedAt DateTime?

  notes String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lines    PurchaseInvoiceLine[]
  payments PurchasePayment[]

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id        String          @id @default(cuid())
  invoiceId String
  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  lineNumber Int

  // Item
  partId      String?
  part        Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)
  description String

  // Quantities
  quantity  Float
  uom       String @default("EA")
  unitPrice Float

  // Amounts
  lineAmount  Float
  taxAmount   Float @default(0)
  totalAmount Float

  // GL Account
  glAccountId String?

  // Reference
  poLineId String? // Link to PO line

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@map("purchase_invoice_lines")
}

model PurchasePayment {
  id        String          @id @default(cuid())
  invoiceId String
  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  paymentNumber String   @unique
  paymentDate   DateTime

  amount          Float
  paymentMethod   String // CHECK, WIRE, ACH, CREDIT_CARD
  referenceNumber String? // Check number, transaction ID

  // GL
  bankAccountId String?
  glPosted      Boolean @default(false)

  notes String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([paymentDate])
  @@map("purchase_payments")
}

// ============ ACCOUNTS RECEIVABLE ============
model SalesInvoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  // Customer
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Reference
  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  // Dates
  invoiceDate DateTime
  dueDate     DateTime
  shipDate    DateTime?

  // Addresses
  billToAddress Json?
  shipToAddress Json?

  // Amounts
  subtotal       Float
  taxAmount      Float @default(0)
  shippingAmount Float @default(0)
  discountAmount Float @default(0)
  totalAmount    Float

  // Currency
  currencyCode String @default("USD")
  exchangeRate Float  @default(1)

  // Payment
  paymentTerms   String?
  receivedAmount Float   @default(0)
  balanceDue     Float

  // Status
  status InvoiceStatus @default(DRAFT)
  sentAt DateTime?

  // GL
  glPosted   Boolean   @default(false)
  glPostedAt DateTime?

  // Cost tracking
  totalCost     Float? // COGS
  grossMargin   Float?
  marginPercent Float?

  notes              String?
  termsAndConditions String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lines    SalesInvoiceLine[]
  payments SalesPayment[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id        String       @id @default(cuid())
  invoiceId String
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  lineNumber Int

  // Item
  partId      String?
  part        Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  description String

  // Quantities
  quantity  Float
  uom       String @default("EA")
  unitPrice Float

  // Amounts
  lineAmount      Float
  discountPercent Float @default(0)
  discountAmount  Float @default(0)
  taxAmount       Float @default(0)
  totalAmount     Float

  // Cost (for margin calculation)
  unitCost  Float?
  totalCost Float?

  // GL Account
  revenueAccountId String?

  // Reference
  soLineId String? // Link to SO line

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@map("sales_invoice_lines")
}

model SalesPayment {
  id        String       @id @default(cuid())
  invoiceId String
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  paymentNumber String   @unique
  paymentDate   DateTime

  amount          Float
  paymentMethod   String // CHECK, WIRE, ACH, CREDIT_CARD
  referenceNumber String?

  // GL
  depositAccountId String?
  glPosted         Boolean @default(false)

  notes String?

  createdBy String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([paymentDate])
  @@map("sales_payments")
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  VOID
}

// ============ GENERAL LEDGER ============
model JournalEntry {
  id          String @id @default(cuid())
  entryNumber String @unique

  // Dates
  entryDate   DateTime
  postingDate DateTime

  // Classification
  entryType String // STANDARD, ADJUSTING, CLOSING, REVERSING
  source    String // MANUAL, AP_INVOICE, AR_INVOICE, INVENTORY, PAYROLL
  sourceId  String? // Reference to source document

  // Description
  description String
  reference   String?

  // Status
  status   JournalStatus @default(DRAFT)
  postedBy String?
  postedAt DateTime?

  // Totals
  totalDebit  Float
  totalCredit Float

  // Reversal
  reversalOf String? // ID of entry being reversed
  reversedBy String? // ID of reversing entry

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines JournalLine[]

  @@index([entryDate])
  @@index([source, sourceId])
  @@index([status])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  lineNumber Int

  // Account
  accountId String
  account   GLAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Description
  description String?

  // Amounts (one should be 0)
  debitAmount  Float @default(0)
  creditAmount Float @default(0)

  // Dimensions (for reporting)
  departmentId String?
  projectId    String?
  costCenterId String?

  createdAt DateTime @default(now())

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  VOID
}

// ============ VARIANCE TRACKING ============
model CostVariance {
  id String @id @default(cuid())

  // Reference
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  partId      String?
  part        Part?      @relation(fields: [partId], references: [id], onDelete: SetNull)

  // Period
  periodYear  Int
  periodMonth Int

  // Variance type
  varianceType String // MATERIAL_PRICE, MATERIAL_USAGE, LABOR_RATE, LABOR_EFFICIENCY, OVERHEAD

  // Amounts
  standardAmount  Float
  actualAmount    Float
  varianceAmount  Float
  variancePercent Float

  // Analysis
  favorableFlag Boolean // True if variance is favorable
  explanation   String?

  // GL posting
  glPosted       Boolean @default(false)
  journalEntryId String?

  calculatedAt DateTime @default(now())

  @@index([workOrderId])
  @@index([partId])
  @@index([periodYear, periodMonth])
  @@index([varianceType])
  @@map("cost_variances")
}

// ============ CURRENCY ============
model Currency {
  id     String @id @default(cuid())
  code   String @unique // USD, EUR, VND
  name   String
  symbol String // $, €, ₫

  decimalPlaces  Int     @default(2)
  isBaseCurrency Boolean @default(false)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exchangeRates ExchangeRate[]

  @@index([isActive])
  @@map("currencies")
}

model ExchangeRate {
  id             String   @id @default(cuid())
  fromCurrencyId String
  fromCurrency   Currency @relation(fields: [fromCurrencyId], references: [id], onDelete: Cascade)
  toCurrencyCode String // Usually base currency

  rate          Float
  effectiveDate DateTime
  expiryDate    DateTime?

  source String? // MANUAL, API, BANK

  createdAt DateTime @default(now())

  @@unique([fromCurrencyId, toCurrencyCode, effectiveDate])
  @@index([effectiveDate])
  @@map("exchange_rates")
}

// ═══════════════════════════════════════════════════════════════════
//                    MOBILE & BARCODE MODELS
// ═══════════════════════════════════════════════════════════════════

// Barcode/QR Code definitions
model BarcodeDefinition {
  id String @id @default(cuid())

  // What this barcode represents
  entityType String // PART, LOCATION, WORK_ORDER, PO, LOT, SERIAL
  entityId   String

  // Barcode data
  barcodeType  String // CODE128, CODE39, QR, DATAMATRIX, EAN13
  barcodeValue String @unique

  // For serialized items
  serialNumber String?
  lotNumber    String?

  // Status
  isActive   Boolean   @default(true)
  printedAt  DateTime?
  printCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([barcodeValue])
  @@map("barcode_definitions")
}

// Scan history for audit trail
model ScanLog {
  id String @id @default(cuid())

  // What was scanned
  barcodeValue String
  barcodeType  String?

  // Resolution
  resolvedType String? // PART, LOCATION, etc. or NULL if not found
  resolvedId   String?

  // Context
  scanContext String // INVENTORY, RECEIVING, PICKING, WORKORDER, LOOKUP
  actionTaken String? // What happened after scan

  // Device info
  deviceId   String?
  deviceType String? // MOBILE, TABLET, SCANNER

  // User
  scannedBy String
  scannedAt DateTime @default(now())

  // Location (GPS if available)
  latitude  Float?
  longitude Float?

  @@index([scannedBy])
  @@index([scannedAt])
  @@index([barcodeValue])
  @@map("scan_logs")
}

// Offline operation queue
model OfflineOperation {
  id String @id @default(cuid())

  // Operation details
  operationType String // INVENTORY_ADJUST, TRANSFER, RECEIVE, PICK, TIME_ENTRY
  operationData Json // Full operation payload

  // Status
  status       String  @default("PENDING") // PENDING, SYNCING, COMPLETED, FAILED
  errorMessage String?
  retryCount   Int     @default(0)

  // Timestamps
  createdAt DateTime  @default(now())
  queuedAt  DateTime  @default(now())
  syncedAt  DateTime?

  // Device
  deviceId String
  userId   String

  @@index([status])
  @@index([userId, status])
  @@map("offline_operations")
}

// Mobile device registration
model MobileDevice {
  id String @id @default(cuid())

  deviceId   String  @unique
  deviceName String?
  deviceType String // IOS, ANDROID, WEB

  // Push notifications
  pushToken   String?
  pushEnabled Boolean @default(false)

  // User
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Status
  lastActiveAt DateTime?
  isActive     Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("mobile_devices")
}

// Label templates
model LabelTemplate {
  id String @id @default(cuid())

  name        String
  description String?

  // Template type
  labelType String // PART, LOCATION, LOT, SERIAL, SHELF, BIN

  // Dimensions (mm)
  width  Int @default(50)
  height Int @default(25)

  // Template definition
  template       Json // ZPL, HTML, or structured template
  templateFormat String @default("HTML") // ZPL, HTML, PDF

  // Barcode settings
  barcodeType String  @default("CODE128")
  includeQR   Boolean @default(true)

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([labelType])
  @@index([isActive])
  @@map("label_templates")
}

// Pick List for mobile picking
model PickList {
  id String @id @default(cuid())

  pickListNumber String @unique

  // Source
  sourceType String // SALES_ORDER, WORK_ORDER, TRANSFER
  sourceId   String

  // Assignment
  assignedTo String?
  assignedAt DateTime?

  // Status
  status String @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED

  // Priority
  priority Int       @default(5) // 1-10, 1 = highest
  dueDate  DateTime?

  // Progress
  totalLines     Int @default(0)
  completedLines Int @default(0)

  // Timing
  startedAt   DateTime?
  completedAt DateTime?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines PickListLine[]

  @@index([status])
  @@index([assignedTo])
  @@map("pick_lists")
}

model PickListLine {
  id         String   @id @default(cuid())
  pickListId String
  pickList   PickList @relation(fields: [pickListId], references: [id], onDelete: Cascade)

  lineNumber Int

  // Item to pick
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  // Location
  warehouseId  String?
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  locationCode String?

  // Quantities
  requestedQty Decimal @db.Decimal(15, 4)
  pickedQty    Decimal @default(0) @db.Decimal(15, 4)

  // Lot/Serial tracking
  lotNumber     String?
  serialNumbers Json? // Array of serial numbers

  // Status
  status String @default("PENDING") // PENDING, PICKED, SHORT, SKIPPED

  // Timing
  pickedAt DateTime?
  pickedBy String?

  notes String?

  @@index([pickListId])
  @@index([partId])
  @@map("pick_list_lines")
}

// ═══════════════════════════════════════════════════════════════════
//                    ADVANCED MRP MODELS - PHASE 13
// ═══════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────
// MULTI-SITE
// ─────────────────────────────────────────────────────────────────────

model Site {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Location
  address  String?
  city     String?
  country  String?
  timezone String  @default("UTC")

  // Type
  siteType String @default("MANUFACTURING")
  // MANUFACTURING, WAREHOUSE, DISTRIBUTION, HEADQUARTERS

  // Planning settings
  isPlanningSite  Boolean @default(true)
  defaultLeadTime Int     @default(0) // Inter-site lead time

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  warehouses     Warehouse[]
  inventorySites InventorySite[]
  supplyOrders   PlannedOrder[]  @relation("SupplySite")
  demandOrders   PlannedOrder[]  @relation("DemandSite")
  transfersFrom  TransferOrder[] @relation("FromSite")
  transfersTo    TransferOrder[] @relation("ToSite")

  @@index([siteType])
  @@map("sites")
}

// Site-specific inventory settings
model InventorySite {
  id String @id @default(cuid())

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Site-specific settings
  reorderPoint Decimal? @db.Decimal(15, 4)
  safetyStock  Decimal? @db.Decimal(15, 4)
  minOrderQty  Decimal? @db.Decimal(15, 4)
  maxOrderQty  Decimal? @db.Decimal(15, 4)
  leadTime     Int? // Override part lead time

  // Planning flags
  isPlanned      Boolean @default(true)
  planningMethod String  @default("MRP") // MRP, REORDER_POINT, KANBAN

  // Sourcing
  preferredSource String? // MAKE, BUY, TRANSFER
  sourceSupplier  String? // Supplier ID if BUY
  sourceSite      String? // Site ID if TRANSFER

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partId, siteId])
  @@index([siteId])
  @@map("inventory_sites")
}

// Inter-site transfer orders
model TransferOrder {
  id             String @id @default(cuid())
  transferNumber String @unique

  // Sites
  fromSiteId String
  fromSite   Site   @relation("FromSite", fields: [fromSiteId], references: [id], onDelete: Cascade)
  toSiteId   String
  toSite     Site   @relation("ToSite", fields: [toSiteId], references: [id], onDelete: Cascade)

  // Dates
  requestDate  DateTime
  shipDate     DateTime?
  expectedDate DateTime
  receivedDate DateTime?

  // Status
  status String @default("DRAFT")
  // DRAFT, APPROVED, IN_TRANSIT, RECEIVED, CANCELLED

  // Reference
  sourceType String? // MRP, MANUAL
  sourceId   String? // Planned order ID if from MRP

  notes String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines TransferOrderLine[]

  @@index([status])
  @@index([fromSiteId])
  @@index([toSiteId])
  @@map("transfer_orders")
}

model TransferOrderLine {
  id              String        @id @default(cuid())
  transferOrderId String
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)

  lineNumber Int

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  quantity    Decimal @db.Decimal(15, 4)
  shippedQty  Decimal @default(0) @db.Decimal(15, 4)
  receivedQty Decimal @default(0) @db.Decimal(15, 4)

  // From location
  fromLocationId String?

  // To location
  toLocationId String?

  notes String?

  createdAt DateTime @default(now())

  @@index([transferOrderId])
  @@map("transfer_order_lines")
}

// ─────────────────────────────────────────────────────────────────────
// PEGGING
// ─────────────────────────────────────────────────────────────────────

model PeggingRecord {
  id String @id @default(cuid())

  // Demand side
  demandType   String // SALES_ORDER, WORK_ORDER, FORECAST, SAFETY_STOCK, TRANSFER
  demandId     String
  demandLineId String?
  demandPartId String
  demandQty    Decimal  @db.Decimal(15, 4)
  demandDate   DateTime

  // Supply side
  supplyType   String // PURCHASE_ORDER, WORK_ORDER, INVENTORY, PLANNED_ORDER, TRANSFER
  supplyId     String
  supplyLineId String?
  supplyPartId String
  supplyQty    Decimal  @db.Decimal(15, 4)
  supplyDate   DateTime

  // Pegged quantity (may be partial)
  peggedQty Decimal @db.Decimal(15, 4)

  // Site
  siteId String?

  // Status
  status String @default("ACTIVE") // ACTIVE, CONSUMED, CANCELLED

  // MRP run that created this
  mrpRunId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([demandType, demandId])
  @@index([supplyType, supplyId])
  @@index([demandPartId])
  @@index([supplyPartId])
  @@map("pegging_records")
}

// ─────────────────────────────────────────────────────────────────────
// FIRM PLANNED ORDERS
// ─────────────────────────────────────────────────────────────────────

model PlannedOrder {
  id          String @id @default(cuid())
  orderNumber String @unique

  // Part
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  // Site
  siteId       String?
  supplySite   Site?   @relation("SupplySite", fields: [siteId], references: [id], onDelete: SetNull)
  demandSiteId String?
  demandSite   Site?   @relation("DemandSite", fields: [demandSiteId], references: [id], onDelete: SetNull)

  // Order details
  orderType String // PURCHASE, PRODUCTION, TRANSFER
  quantity  Decimal @db.Decimal(15, 4)

  // Dates
  startDate DateTime
  dueDate   DateTime

  // Firm status
  isFirm     Boolean   @default(false)
  firmedAt   DateTime?
  firmedBy   String?
  firmReason String?

  // Time fence
  insideTimeFence Boolean @default(false)

  // Status
  status String @default("PLANNED")
  // PLANNED, FIRM, RELEASED, CANCELLED

  // Reference to actual order (when released)
  releasedOrderType String?
  releasedOrderId   String?

  // MRP info
  mrpRunId      String?
  exceptionType String? // If has exception
  exceptionMsg  String?

  // Priority
  priority Int @default(500) // 1-999, lower = higher priority

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partId])
  @@index([siteId])
  @@index([status])
  @@index([dueDate])
  @@index([isFirm])
  @@map("planned_orders")
}

// ─────────────────────────────────────────────────────────────────────
// MRP EXCEPTIONS
// ─────────────────────────────────────────────────────────────────────

model MRPException {
  id String @id @default(cuid())

  // Exception type
  exceptionType String
  // RESCHEDULE_IN, RESCHEDULE_OUT, EXPEDITE, DEFER, CANCEL
  // PAST_DUE, SHORTAGE, EXCESS, LEAD_TIME_VIOLATION

  severity String @default("WARNING") // INFO, WARNING, CRITICAL

  // Affected entity
  entityType String // PLANNED_ORDER, PURCHASE_ORDER, WORK_ORDER
  entityId   String

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  siteId String?

  // Details
  message       String
  currentDate   DateTime?
  suggestedDate DateTime?
  quantity      Decimal?  @db.Decimal(15, 4)

  // Resolution
  status     String    @default("OPEN") // OPEN, ACKNOWLEDGED, RESOLVED, IGNORED
  resolvedAt DateTime?
  resolvedBy String?
  resolution String? // What action was taken

  // MRP run
  mrpRunId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([exceptionType])
  @@index([status])
  @@index([partId])
  @@index([severity])
  @@map("mrp_exceptions")
}

// ─────────────────────────────────────────────────────────────────────
// WHAT-IF SIMULATION
// ─────────────────────────────────────────────────────────────────────

model Simulation {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Type
  simulationType String @default("MRP")
  // MRP, CAPACITY, DEMAND, SUPPLY, COMBINED

  // Status
  status String @default("DRAFT")
  // DRAFT, RUNNING, COMPLETED, FAILED

  // Parameters (JSON)
  parameters Json

  // Baseline comparison
  baselineRunId String? // Compare against this MRP run

  // Results summary (JSON)
  resultsSummary Json?

  // Timing
  startedAt   DateTime?
  completedAt DateTime?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results SimulationResult[]

  @@index([status])
  @@index([createdBy])
  @@map("simulations")
}

model SimulationResult {
  id           String     @id @default(cuid())
  simulationId String
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  // Result type
  resultType String // PLANNED_ORDER, SHORTAGE, EXCESS, CAPACITY_ISSUE

  partId       String?
  workCenterId String?
  siteId       String?

  // Dates
  periodStart DateTime
  periodEnd   DateTime

  // Values
  quantity    Decimal? @db.Decimal(15, 4)
  baselineQty Decimal? @db.Decimal(15, 4) // For comparison
  variance    Decimal? @db.Decimal(15, 4)

  // Details (JSON)
  details Json?

  createdAt DateTime @default(now())

  @@index([simulationId])
  @@index([partId])
  @@map("simulation_results")
}

// ─────────────────────────────────────────────────────────────────────
// ATP/CTP
// ─────────────────────────────────────────────────────────────────────

model ATPRecord {
  id String @id @default(cuid())

  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  siteId String?

  // Time bucket
  bucketDate DateTime // Start of bucket
  bucketType String   @default("DAILY") // DAILY, WEEKLY, MONTHLY

  // Quantities
  beginningQty  Decimal @default(0) @db.Decimal(15, 4)
  supplyQty     Decimal @default(0) @db.Decimal(15, 4)
  demandQty     Decimal @default(0) @db.Decimal(15, 4)
  atpQty        Decimal @default(0) @db.Decimal(15, 4)
  cumulativeATP Decimal @default(0) @db.Decimal(15, 4)

  // Last calculated
  calculatedAt DateTime @default(now())

  @@unique([partId, siteId, bucketDate, bucketType])
  @@index([partId])
  @@index([bucketDate])
  @@map("atp_records")
}

// ─────────────────────────────────────────────────────────────────────
// PLANNING SETTINGS
// ─────────────────────────────────────────────────────────────────────

model PlanningSettings {
  id String @id @default(cuid())

  siteId String? @unique // null = global settings

  // Time fences (in days)
  demandTimeFence   Int @default(7) // No changes inside this
  planningTimeFence Int @default(30) // MRP planning horizon
  frozenZone        Int @default(3) // Absolutely no changes

  // Planning buckets
  bucketType String @default("DAILY") // DAILY, WEEKLY

  // Safety stock calculation
  safetyStockMethod String @default("FIXED") // FIXED, DAYS_OF_SUPPLY, STATISTICAL
  safetyStockDays   Int    @default(7)

  // Order sizing
  orderSizingRule String @default("LOT_FOR_LOT")
  // LOT_FOR_LOT, FIXED_ORDER_QTY, PERIODS_OF_SUPPLY, EOQ
  periodsOfSupply Int    @default(1)

  // Rescheduling
  rescheduleInDays  Int @default(3) // Reschedule in if early by this many days
  rescheduleOutDays Int @default(5) // Reschedule out if late by this many days

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("planning_settings")
}

// ─────────────────────────────────────────────────────────────────────
// SUBSTITUTE PARTS
// ─────────────────────────────────────────────────────────────────────

model PartSubstitute {
  id String @id @default(cuid())

  primaryPartId String
  primaryPart   Part   @relation("PrimaryPart", fields: [primaryPartId], references: [id], onDelete: Cascade)

  substitutePartId String
  substitutePart   Part   @relation("SubstitutePart", fields: [substitutePartId], references: [id], onDelete: Cascade)

  // Priority (1 = first choice)
  priority Int @default(1)

  // Conversion
  conversionFactor Decimal @default(1) @db.Decimal(10, 4) // How many substitutes per primary

  // Validity
  effectiveDate DateTime  @default(now())
  expiryDate    DateTime?

  // Flags
  isAutoSubstitute Boolean @default(false) // Auto-substitute if primary unavailable
  requiresApproval Boolean @default(true) // Requires approval to use

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([primaryPartId, substitutePartId])
  @@index([primaryPartId])
  @@map("part_substitutes")
}

// ═══════════════════════════════════════════════════════════════════
//                    PHASE 3: RESOURCE & CAPACITY MANAGEMENT
// ═══════════════════════════════════════════════════════════════════

// ============ EQUIPMENT (OEE Tracking) ============
model Equipment {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Classification
  type         String // CNC, ASSEMBLY, TESTING, PACKAGING, etc.
  category     String? // Primary, Secondary, Support
  manufacturer String?
  model        String?
  serialNumber String? @unique

  // Location
  workCenterId String
  workCenter   WorkCenter @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  location     String?

  // Specifications
  capacity   Float? // Units per hour
  powerKw    Float?
  weightKg   Float?
  dimensions String? // LxWxH in mm

  // Dates
  purchaseDate   DateTime?
  installDate    DateTime?
  warrantyExpiry DateTime?

  // Costs
  purchaseCost     Float?
  depreciationRate Float? // Annual percentage
  currentValue     Float?
  hourlyRunCost    Float?

  // OEE Metrics (Overall Equipment Effectiveness)
  targetOee     Float     @default(85) // Target OEE %
  currentOee    Float? // Latest calculated OEE
  availability  Float? // Availability %
  performance   Float? // Performance %
  quality       Float? // Quality %
  lastOeeUpdate DateTime?

  // Status
  status      String @default("operational") // operational, maintenance, breakdown, retired
  criticality String @default("medium") // low, medium, high, critical

  // Maintenance
  lastMaintenanceDate     DateTime?
  nextMaintenanceDate     DateTime?
  maintenanceIntervalDays Int?
  totalDowntimeHours      Float     @default(0)
  operatingHours    Float? // Current operating hours
  designLifeHours   Float? // Design life in hours
  mtbf                    Float? // Mean Time Between Failures (hours)
  mttr                    Float? // Mean Time To Repair (hours)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maintenanceSchedules MaintenanceSchedule[]
  maintenanceOrders    MaintenanceOrder[]

  @@index([workCenterId])
  @@index([status])
  @@index([type])
  @@map("equipment")
}

// ============ MAINTENANCE SCHEDULE (PM - Preventive Maintenance) ============
model MaintenanceSchedule {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Equipment
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  // Schedule Type
  type          String // PREVENTIVE, PREDICTIVE, CALIBRATION, INSPECTION
  frequency     String // DAILY, WEEKLY, MONTHLY, QUARTERLY, ANNUALLY, HOURS_BASED
  intervalValue Int // Every X days/hours
  intervalUnit  String @default("days") // days, hours, cycles

  // Estimated times
  estimatedDuration Float // Duration in hours
  requiredSkills    Json? // Array of skill IDs required

  // Instructions
  checklistItems Json? // Array of checklist items
  instructions   String?
  safetyNotes    String?
  partsRequired  Json? // Array of part IDs and quantities

  // Scheduling
  lastExecutedAt    DateTime?
  nextDueDate       DateTime?
  advanceNoticeDays Int       @default(7) // Notify X days before

  // Costs
  estimatedCost    Float?
  laborCostPerHour Float?

  // Status
  isActive Boolean @default(true)
  priority String  @default("medium") // low, medium, high, critical

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maintenanceOrders MaintenanceOrder[]

  @@index([equipmentId])
  @@index([nextDueDate])
  @@index([isActive])
  @@map("maintenance_schedules")
}

// ============ MAINTENANCE ORDER (Work Order for Maintenance) ============
model MaintenanceOrder {
  id          String @id @default(cuid())
  orderNumber String @unique

  // Equipment
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  // Schedule (if PM)
  scheduleId String?
  schedule   MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  // Type
  type     String // PM (Preventive), CM (Corrective), EM (Emergency), CAL (Calibration)
  priority String @default("medium") // low, medium, high, critical, emergency

  // Description
  title           String
  description     String?
  problemReported String? // For corrective/emergency
  rootCause       String?

  // Planning
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  estimatedDuration Float? // Hours

  // Execution
  actualStartDate DateTime?
  actualEndDate   DateTime?
  actualDuration  Float? // Hours

  // Assignment
  assignedTo   String? // Employee ID
  assignedTeam Json? // Array of employee IDs

  // Status
  status String @default("pending")
  // pending, scheduled, in_progress, waiting_parts, completed, cancelled

  // Completion
  workPerformed   String?
  partsUsed       Json? // Array of {partId, qty, cost}
  findings        String?
  recommendations String?

  // Costs
  laborCost    Float @default(0)
  partsCost    Float @default(0)
  externalCost Float @default(0) // External contractors
  totalCost    Float @default(0)

  // Approval
  requestedBy String?
  approvedBy  String?
  approvedAt  DateTime?
  completedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([equipmentId])
  @@index([status])
  @@index([type])
  @@index([plannedStartDate])
  @@map("maintenance_orders")
}

// ============ EMPLOYEE (Production Workers) ============
model Employee {
  id           String @id @default(cuid())
  employeeCode String @unique

  // Personal Info
  firstName String
  lastName  String
  email     String? @unique
  phone     String?

  // User Account (optional link)
  userId String? @unique

  // Employment
  department      String?
  position        String?
  employmentType  String    @default("full_time") // full_time, part_time, contract, temp
  hireDate        DateTime?
  terminationDate DateTime?

  // Work Info
  defaultWorkCenterId String?
  shiftPattern        String? // Default shift pattern
  hourlyRate          Float?
  overtimeRate        Float?

  // Certifications
  certifications Json? // Array of {name, issuedDate, expiryDate}

  // Status
  status String @default("active") // active, on_leave, suspended, terminated

  // Contact
  emergencyContact String?
  emergencyPhone   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills           EmployeeSkill[]
  shiftAssignments ShiftAssignment[]

  @@index([department])
  @@index([status])
  @@map("employees")
}

// ============ SKILL (Skill Matrix) ============
model Skill {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Classification
  category       String // MACHINE_OPERATION, QUALITY, SAFETY, TECHNICAL, SOFT_SKILL
  workCenterType String? // Applicable work center type

  // Requirements
  trainingRequired      Boolean @default(true)
  certificationRequired Boolean @default(false)
  recertificationDays   Int? // Days until recertification needed

  // Levels
  hasLevels Boolean @default(true) // If skill has proficiency levels
  maxLevel  Int     @default(5) // Maximum proficiency level

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeSkills EmployeeSkill[]

  @@index([category])
  @@map("skills")
}

// ============ EMPLOYEE SKILL (Skill Assignment) ============
model EmployeeSkill {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  // Proficiency
  level       Int    @default(1) // 1-5 typically
  proficiency String @default("beginner") // beginner, intermediate, advanced, expert

  // Training/Certification
  trainedDate         DateTime?
  trainedBy           String?
  certifiedDate       DateTime?
  certificationExpiry DateTime?
  certificateNumber   String?

  // Assessment
  lastAssessedDate DateTime?
  assessedBy       String?
  assessmentScore  Float? // 0-100

  // Status
  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, skillId])
  @@index([employeeId])
  @@index([skillId])
  @@map("employee_skills")
}

// ============ SHIFT (Work Shifts) ============
model Shift {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Timing
  startTime     String // HH:mm format, e.g., "06:00"
  endTime       String // HH:mm format, e.g., "14:00"
  durationHours Float // Total shift duration

  // Breaks
  breakMinutes  Int   @default(0) // Total break time
  breakSchedule Json? // Array of {startTime, endTime, type}

  // Working Days
  workingDays Json @default("[1,2,3,4,5]") // 0=Sun, 1=Mon, ...

  // Overtime
  overtimeAfterHours Float? // Overtime kicks in after X hours
  overtimeRate       Float  @default(1.5) // Multiplier

  // Capacity Impact
  efficiencyFactor Float @default(1.0) // Night shift might be 0.9

  // Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ShiftAssignment[]

  @@index([isActive])
  @@map("shifts")
}

// ============ SHIFT ASSIGNMENT (Employee Shift Scheduling & Attendance) ============
model ShiftAssignment {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  // Date
  date DateTime @db.Date

  // Assignment Type
  assignmentType String @default("regular") // regular, overtime, on_call, training

  // Status
  status String @default("scheduled")
  // scheduled, checked_in, checked_out, absent, leave, holiday

  // Attendance
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime? // Clock in
  actualEnd    DateTime? // Clock out

  // Hours
  regularHours  Float @default(0)
  overtimeHours Float @default(0)
  breakMinutes  Int   @default(0)

  // Leave
  leaveType       String? // sick, vacation, personal, unpaid
  leaveApprovedBy String?

  // Notes
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, shiftId, date])
  @@index([employeeId, date])
  @@index([shiftId, date])
  @@index([date, status])
  @@map("shift_assignments")
}

// ============ WORK CENTER CAPACITY (Daily Capacity Planning) ============
model WorkCenterCapacity {
  id String @id @default(cuid())

  workCenterId String
  workCenter   WorkCenter @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date

  // Base Capacity
  baseCapacityHours Float // Standard available hours

  // Adjustments
  shiftHours       Float @default(0) // Hours from shift assignments
  maintenanceHours Float @default(0) // Planned maintenance
  downtimeHours    Float @default(0) // Unplanned downtime
  holidayHours     Float @default(0) // Holiday reduction

  // Net Available
  availableHours Float // = base - maintenance - downtime - holiday

  // Loaded
  scheduledHours Float @default(0) // Hours scheduled from WO
  actualHours    Float @default(0) // Hours actually worked

  // Utilization
  utilization Float? // = scheduled / available * 100
  efficiency  Float? // = actual / scheduled * 100 (if completed)

  // Staffing
  plannedHeadcount Int @default(0)
  actualHeadcount  Int @default(0)

  // Status
  isLocked Boolean @default(false) // Manual override
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workCenterId, date])
  @@index([workCenterId, date])
  @@index([date])
  @@map("work_center_capacity")
}

// =============================================================================
// RTR MRP - TENANT & MULTI-TENANCY MODELS
// Add these to the end of your prisma/schema.prisma file
// =============================================================================

// =============================================================================
// TENANT MANAGEMENT
// =============================================================================

model Tenant {
  id String @id @default(cuid())

  // Identity
  code   String  @unique // e.g., "acme", "samsung"
  name   String // "ACME Corporation"
  slug   String  @unique // URL-friendly: acme-corp
  domain String? @unique // Custom domain: acme.rtr-mrp.com

  // Contact
  email   String
  phone   String?
  address String?
  city    String?
  country String  @default("Vietnam")
  taxCode String?

  // Branding
  logo           String?
  primaryColor   String? @default("#3B82F6")
  secondaryColor String? @default("#1E40AF")

  // Subscription
  plan          TenantPlan @default(TRIAL)
  planStartDate DateTime   @default(now())
  planEndDate   DateTime?
  trialEndsAt   DateTime?

  // Limits based on plan
  maxUsers    Int    @default(5)
  maxStorage  BigInt @default(1073741824) // 1GB in bytes
  maxApiCalls Int    @default(10000) // per month
  maxParts    Int    @default(1000)
  maxOrders   Int    @default(500) // per month

  // Current usage
  currentUsers    Int    @default(0)
  currentStorage  BigInt @default(0)
  currentApiCalls Int    @default(0)
  currentParts    Int    @default(0)

  // Features (JSON for flexibility)
  features Json? // { "mrp": true, "quality": true, "oee": false }
  settings Json? // Tenant-specific settings

  // Billing
  billingEmail   String?
  billingAddress String?
  currency       String  @default("USD")

  // Status
  status          TenantStatus @default(ACTIVE)
  suspendedAt     DateTime?
  suspendedReason String?

  // Relations
  users         User[]
  subscriptions TenantSubscription[]
  invitations   TenantInvitation[]
  apiKeys       TenantApiKey[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([slug])
  @@index([domain])
  @@index([status])
}

enum TenantPlan {
  TRIAL // 14 days free, 5 users, limited features
  STARTER // $49/mo, 10 users, 5GB, basic features
  PROFESSIONAL // $149/mo, 50 users, 25GB, all features
  ENTERPRISE // Custom pricing, unlimited users, priority support
}

enum TenantStatus {
  PENDING // Awaiting verification
  ACTIVE // Normal operation
  SUSPENDED // Payment issue or violation
  CANCELLED // Subscription ended
  DELETED // Soft deleted
}

// =============================================================================
// TENANT SUBSCRIPTION HISTORY
// =============================================================================

model TenantSubscription {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Plan details
  plan         TenantPlan
  priceMonthly Float
  priceYearly  Float?
  currency     String       @default("USD")
  billingCycle BillingCycle @default(MONTHLY)

  // Period
  startDate   DateTime
  endDate     DateTime?
  cancelledAt DateTime?

  // Payment
  paymentMethod   String? // "credit_card", "bank_transfer", "paypal"
  paymentStatus   PaymentStatus @default(PENDING)
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?

  // Invoice reference
  invoiceNumber String?
  invoiceUrl    String?

  // Discount
  discountPercent Float   @default(0)
  discountReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([plan])
  @@index([paymentStatus])
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

// =============================================================================
// TENANT INVITATIONS
// =============================================================================

model TenantInvitation {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Invitation details
  email      String
  role       String  @default("viewer")
  department String?

  // Sender
  invitedById   String
  invitedByName String?

  // Token for verification
  token String @unique

  // Status
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?

  // Message
  message String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([email])
  @@index([token])
  @@index([status])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// =============================================================================
// TENANT API KEYS (for integrations)
// =============================================================================

model TenantApiKey {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Key info
  name        String // "Production API Key"
  description String?
  keyHash     String  @unique // Hashed API key
  keyPrefix   String // First 8 chars for identification (e.g., "rtr_live_")

  // Creator
  createdById   String
  createdByName String?

  // Permissions
  permissions String[] // ["read:parts", "write:orders"]
  scopes      String[] // ["inventory", "sales"]

  // Rate limiting
  rateLimit      Int @default(1000) // requests per hour
  rateLimitBurst Int @default(100) // burst limit

  // IP whitelist (optional)
  allowedIps String[]

  // Validity
  expiresAt  DateTime?
  lastUsedAt DateTime?
  lastUsedIp String?

  // Usage tracking
  totalRequests BigInt @default(0)

  // Status
  isActive      Boolean   @default(true)
  revokedAt     DateTime?
  revokedById   String?
  revokedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([keyHash])
  @@index([keyPrefix])
  @@index([isActive])
}

// =============================================================================
// TENANT WEBHOOKS
// =============================================================================

model TenantWebhook {
  id String @id @default(cuid())

  tenantId String

  // Webhook config
  name   String
  url    String
  secret String // For signature verification

  // Events to trigger
  events String[] // ["order.created", "inventory.low"]

  // Headers (JSON)
  headers Json?

  // Retry config
  maxRetries Int @default(3)
  retryDelay Int @default(60) // seconds

  // Status
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  lastStatus      Int? // Last HTTP status code
  failureCount    Int       @default(0)

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([isActive])
}

// =============================================================================
// TENANT USAGE LOGS (for billing)
// =============================================================================

model TenantUsageLog {
  id String @id @default(cuid())

  tenantId String

  // Usage period
  periodStart DateTime
  periodEnd   DateTime

  // Metrics
  apiCalls         Int    @default(0)
  storageBytes     BigInt @default(0)
  activeUsers      Int    @default(0)
  partsCount       Int    @default(0)
  ordersCount      Int    @default(0)
  reportsGenerated Int    @default(0)

  // Compute usage (for MRP runs, etc.)
  computeMinutes Int @default(0)

  createdAt DateTime @default(now())

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([periodStart])
}

// =============================================================================
// CONTEXTUAL CHAT - PHASE 1 MVP
// =============================================================================

// Context types - các loại record có thể gắn thread
enum ContextType {
  WORK_ORDER
  BOM
  PART
  INVENTORY
  QC_REPORT
  MRP_RUN
  PURCHASE_ORDER
  SUPPLIER
  CUSTOMER
  SALES_ORDER
  GENERAL
}

// Thread status
enum ThreadStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  ARCHIVED
}

// Priority levels
enum ThreadPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Mention type
enum MentionType {
  USER
  ROLE
}

// =============================================================================
// CONVERSATION THREAD
// =============================================================================

model ConversationThread {
  id String @id @default(cuid())

  // CONTEXT - Bắt buộc
  contextType  ContextType
  contextId    String // ID của record liên quan
  contextTitle String? // Cache title để hiển thị nhanh

  // Thread info
  title    String? // Tiêu đề thread (optional)
  status   ThreadStatus   @default(OPEN)
  priority ThreadPriority @default(NORMAL)

  // Creator
  createdById String
  createdBy   User   @relation("ThreadCreator", fields: [createdById], references: [id], onDelete: Cascade)

  // Relations
  messages     Message[]
  participants ThreadParticipant[]

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime? // Cache để sort
  resolvedAt    DateTime?
  resolvedById  String?

  // Indexes
  @@index([contextType, contextId])
  @@index([status])
  @@index([createdById])
  @@index([lastMessageAt])
  @@map("conversation_threads")
}

// =============================================================================
// MESSAGE
// =============================================================================

model Message {
  id String @id @default(cuid())

  // Thread reference
  threadId String
  thread   ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  // Sender
  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  // Content
  content         String  @db.Text // Text content
  isSystemMessage Boolean @default(false) // Auto-generated messages

  // Edit tracking
  isEdited Boolean   @default(false)
  editedAt DateTime?

  // Relations
  mentions    Mention[]
  attachments MessageAttachment[]
  editHistory MessageEditHistory[]
  entityLinks EntityLink[]

  // Timestamps
  createdAt DateTime @default(now())

  // Indexes
  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// =============================================================================
// THREAD PARTICIPANT
// =============================================================================

model ThreadParticipant {
  id String @id @default(cuid())

  threadId String
  thread   ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Participation info
  role     String? // Role khi join (QA, Planner, etc.)
  joinedAt DateTime @default(now())

  // Read tracking
  lastReadAt        DateTime?
  lastReadMessageId String?

  // Notifications
  isMuted Boolean @default(false)

  @@unique([threadId, userId])
  @@index([userId])
  @@map("thread_participants")
}

// =============================================================================
// MENTION
// =============================================================================

model Mention {
  id String @id @default(cuid())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Mention target
  mentionType MentionType
  userId      String? // If mentioning specific user
  user        User?       @relation("MentionedUser", fields: [userId], references: [id], onDelete: Cascade)
  roleName    String? // If mentioning role (@planner)

  // Position in message for highlighting
  startIndex Int?
  endIndex   Int?

  // Acknowledgment
  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([roleName])
  @@map("mentions")
}

// =============================================================================
// MESSAGE ATTACHMENT
// =============================================================================

enum AttachmentType {
  IMAGE // Screenshot, photo
  DOCUMENT // PDF, Excel, Word
  FILE // Other files
}

model MessageAttachment {
  id String @id @default(cuid())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // File info
  type     AttachmentType
  filename String // Original filename
  fileUrl  String // Storage URL
  fileSize Int // Size in bytes
  mimeType String // MIME type

  // Image metadata (for screenshots)
  width        Int? // Image width
  height       Int? // Image height
  thumbnailUrl String? // Thumbnail for preview

  // Context metadata (where was this captured from)
  capturedContext String? @db.Text // JSON: { page: "work-orders", id: "wo-123", title: "WO Details" }

  // Upload info
  uploadedById String
  uploadedAt   DateTime @default(now())

  @@index([messageId])
  @@index([type])
  @@index([uploadedById])
  @@map("message_attachments")
}

// =============================================================================
// MESSAGE EDIT HISTORY (Audit Trail)
// =============================================================================

model MessageEditHistory {
  id String @id @default(cuid())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Previous content
  previousContent String @db.Text // Content before edit

  // Edit info
  editedById String
  editedAt   DateTime @default(now())

  // Edit reason (optional)
  reason String? // Why the edit was made

  @@index([messageId])
  @@index([editedById])
  @@index([editedAt])
  @@map("message_edit_history")
}

// =============================================================================
// ENTITY LINK (Link to business entities from messages)
// =============================================================================

enum LinkedEntityType {
  PART
  BOM
  WORK_ORDER
  PURCHASE_ORDER
  SALES_ORDER
  SUPPLIER
  CUSTOMER
  INVENTORY
  QC_REPORT
  MRP_RUN
}

model EntityLink {
  id String @id @default(cuid())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Entity reference
  entityType LinkedEntityType
  entityId   String // ID of the linked entity

  // Cached display info (for quick rendering)
  entityTitle    String // Cached title (e.g., "Part: PN-12345 - Resistor 10K")
  entitySubtitle String? // Cached subtitle (e.g., "In Stock: 500 units")
  entityIcon     String? // Icon name to display
  entityStatus   String? // Current status for badge

  // Link position in message
  startIndex Int? // Where in message content this link starts
  endIndex   Int? // Where in message content this link ends

  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([entityType, entityId])
  @@index([entityType])
  @@map("entity_links")
}

// =============================================================================
// WORKFLOW AUTOMATION - Configurable Approval Chains
// =============================================================================

enum WorkflowEntityType {
  PURCHASE_ORDER
  SALES_ORDER
  WORK_ORDER
  NCR
  CAPA
  INVENTORY_ADJUSTMENT
  ENGINEERING_CHANGE
}

enum WorkflowStatus {
  DRAFT
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  ESCALATED
}

enum WorkflowStepType {
  APPROVAL
  REVIEW
  NOTIFICATION
  CONDITIONAL
  PARALLEL
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  ESCALATED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

// Workflow Definition - Template for approval workflows
model WorkflowDefinition {
  id          String             @id @default(cuid())
  name        String // e.g., "PO Approval", "NCR Review"
  code        String             @unique // e.g., "PO_APPROVAL", "NCR_REVIEW"
  description String?
  entityType  WorkflowEntityType
  isActive    Boolean            @default(true)
  version     Int                @default(1)

  // Trigger conditions (JSON for flexibility)
  triggerConditions Json? // { "amount_gt": 10000, "priority": "high" }

  // SLA settings
  defaultSlaHours   Int? // Default time to complete
  escalationEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  steps     WorkflowStep[]
  instances WorkflowInstance[]

  @@index([entityType])
  @@index([isActive])
  @@map("workflow_definitions")
}

// Workflow Step - Individual step in a workflow
model WorkflowStep {
  id         String             @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  stepNumber Int // Order in the workflow
  name       String // e.g., "Manager Approval"
  type       WorkflowStepType @default(APPROVAL)

  // Approver configuration
  approverRole      String? // Role required (e.g., "manager", "finance", "director")
  approverUserId    String? // Specific user (if not role-based)
  approverCondition Json? // Dynamic approver rules { "department": "same_as_requester" }

  // Step conditions
  conditions Json? // When to execute this step { "amount_gt": 5000 }
  isRequired Boolean @default(true)

  // SLA
  slaHours     Int? // Hours to complete this step
  autoEscalate Boolean @default(false)
  escalateTo   String? // Role or user ID to escalate to

  // Next steps
  nextStepOnApprove Int? // Step number if approved
  nextStepOnReject  Int? // Step number if rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvals WorkflowApproval[]

  @@unique([workflowId, stepNumber])
  @@index([workflowId])
  @@map("workflow_steps")
}

// Workflow Instance - Running instance of a workflow
model WorkflowInstance {
  id         String             @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Restrict)

  // Entity reference
  entityType WorkflowEntityType
  entityId   String // ID of the entity (PO, NCR, etc.)

  // Status
  status            WorkflowStatus @default(PENDING)
  currentStepNumber Int            @default(1)

  // Context data
  contextData Json? // Snapshot of entity data at workflow start

  // Timing
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  dueDate     DateTime? // Based on SLA

  // Initiator
  initiatedBy     String
  initiatedByUser User?  @relation("WorkflowInitiator", fields: [initiatedBy], references: [id], onDelete: SetNull)

  // Final outcome
  finalDecision ApprovalDecision?
  finalComments String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvals     WorkflowApproval[]
  history       WorkflowHistory[]
  notifications WorkflowNotification[]

  @@index([workflowId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([initiatedBy])
  @@index([dueDate])
  @@map("workflow_instances")
}

// Workflow Approval - Individual approval decision
model WorkflowApproval {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  stepId String
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Restrict)

  // Approver
  approverId String
  approver   User   @relation("WorkflowApprover", fields: [approverId], references: [id], onDelete: Cascade)

  // Decision
  decision ApprovalDecision @default(PENDING)
  comments String?          @db.Text

  // Delegation
  delegatedTo      String?
  delegatedToUser  User?   @relation("WorkflowDelegate", fields: [delegatedTo], references: [id], onDelete: SetNull)
  delegationReason String?

  // Timing
  requestedAt DateTime  @default(now())
  respondedAt DateTime?
  dueDate     DateTime?

  // Reminder tracking
  reminderCount  Int       @default(0)
  lastReminderAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instanceId])
  @@index([stepId])
  @@index([approverId])
  @@index([decision])
  @@index([dueDate])
  @@map("workflow_approvals")
}

// Workflow History - Audit trail of all workflow actions
model WorkflowHistory {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  // Action info
  action     String // STARTED, APPROVED, REJECTED, ESCALATED, DELEGATED, COMMENTED, CANCELLED
  stepNumber Int?

  // Actor
  performedBy String
  performer   User   @relation("WorkflowHistoryActor", fields: [performedBy], references: [id], onDelete: Cascade)

  // Details
  previousStatus String?
  newStatus      String?
  comments       String? @db.Text
  metadata       Json? // Additional action-specific data

  createdAt DateTime @default(now())

  @@index([instanceId])
  @@index([performedBy])
  @@index([action])
  @@index([createdAt])
  @@map("workflow_history")
}

// Workflow Notification - Notifications sent for workflow events
model WorkflowNotification {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  // Recipient
  recipientId String
  recipient   User   @relation("WorkflowNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  // Notification content
  type    String // APPROVAL_REQUEST, REMINDER, ESCALATION, COMPLETED, REJECTED
  channel NotificationChannel @default(IN_APP)
  title   String
  message String              @db.Text

  // Delivery status
  sentAt         DateTime?
  readAt         DateTime?
  deliveryStatus String    @default("pending") // pending, sent, delivered, failed

  // Action link
  actionUrl String?

  createdAt DateTime @default(now())

  @@index([instanceId])
  @@index([recipientId])
  @@index([deliveryStatus])
  @@index([createdAt])
  @@map("workflow_notifications")
}

// ═══════════════════════════════════════════════════════════════════
//                    ADVANCED ANALYTICS MODELS (Phase 10)
// ═══════════════════════════════════════════════════════════════════

// ============ ANALYTICS DASHBOARDS ============
model AnalyticsDashboard {
  id           String    @id @default(cuid())
  userId       String
  name         String
  description  String?
  layout       Json // Grid layout config
  isPublic     Boolean   @default(false)
  isDefault    Boolean   @default(false)
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets DashboardWidget[]

  @@index([userId])
  @@index([isPublic])
  @@map("analytics_dashboards")
}

// ============ DASHBOARD WIDGETS ============
model DashboardWidget {
  id              String   @id @default(cuid())
  dashboardId     String
  widgetType      String // kpi, chart-line, chart-bar, chart-pie, chart-area, table, gauge
  title           String
  titleVi         String?
  dataSource      String // inventory, sales, production, quality, financial, supplier
  metric          String? // Specific metric to display
  queryConfig     Json // filters, aggregations, groupBy
  displayConfig   Json // colors, formatters, thresholds
  gridX           Int      @default(0)
  gridY           Int      @default(0)
  gridW           Int      @default(4)
  gridH           Int      @default(3)
  refreshInterval Int? // Auto-refresh in seconds
  drillDownConfig Json? // Configuration for drill-down behavior
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dashboard AnalyticsDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("dashboard_widgets")
}

// ============ KPI DEFINITIONS ============
model KPIDefinition {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  nameVi             String
  description        String?
  descriptionVi      String?
  category           String // inventory, sales, production, quality, financial, supplier
  formula            String // Formula or calculation method
  dataSource         String // Table or view to query
  aggregation        String // SUM, AVG, COUNT, MIN, MAX, CUSTOM
  unit               String? // %, VND, pcs, days, etc.
  format             String   @default("number") // number, currency, percent, decimal
  precision          Int      @default(2)
  warningThreshold   Float? // Threshold for warning state
  criticalThreshold  Float? // Threshold for critical state
  targetValue        Float? // Target/goal value
  thresholdDirection String   @default("higher_is_better") // higher_is_better, lower_is_better
  trendPeriod        String   @default("month") // day, week, month, quarter, year
  isActive           Boolean  @default(true)
  isSystem           Boolean  @default(true) // System KPIs cannot be deleted
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("kpi_definitions")
}

// ============ REPORT SCHEDULES ============
model ReportSchedule {
  id            String    @id @default(cuid())
  reportId      String
  name          String?
  frequency     String // daily, weekly, biweekly, monthly, quarterly
  dayOfWeek     Int? // 0-6 for weekly reports
  dayOfMonth    Int? // 1-31 for monthly reports
  time          String // HH:mm format
  timezone      String    @default("Asia/Ho_Chi_Minh")
  recipients    Json // Array of {email, name, type: 'to'|'cc'|'bcc'}
  outputFormat  String    @default("pdf") // pdf, xlsx, csv
  parameters    Json? // Report parameters/filters
  emailSubject  String?
  emailBody     String?
  isActive      Boolean   @default(true)
  lastRunAt     DateTime?
  lastRunStatus String? // success, failed, partial
  nextRunAt     DateTime?
  runCount      Int       @default(0)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  report    SavedReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  instances ReportInstance[]

  @@index([reportId])
  @@index([nextRunAt])
  @@index([isActive])
  @@map("report_schedules")
}

// ============ REPORT INSTANCES ============
model ReportInstance {
  id             String    @id @default(cuid())
  scheduleId     String?
  reportId       String
  generatedAt    DateTime  @default(now())
  generatedBy    String
  parameters     Json // Parameters used for generation
  format         String // pdf, xlsx, csv
  fileUrl        String? // URL to download the file
  fileName       String?
  fileSize       Int? // Size in bytes
  status         String    @default("pending") // pending, generating, completed, failed
  error          String? // Error message if failed
  expiresAt      DateTime? // When the file will be deleted
  downloadCount  Int       @default(0)
  lastDownloadAt DateTime?
  recipients     Json? // Actual recipients the report was sent to
  deliveryStatus String? // pending, sent, partial, failed

  schedule ReportSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  report   SavedReport     @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([scheduleId])
  @@index([status])
  @@index([generatedAt])
  @@map("report_instances")
}

// ============ DASHBOARD TEMPLATES ============
model DashboardTemplate {
  id          String   @id @default(cuid())
  name        String
  nameVi      String?
  description String?
  category    String // executive, operations, quality, finance
  thumbnail   String? // Preview image URL
  layout      Json // Default layout configuration
  widgets     Json // Default widget configurations
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  usageCount  Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("dashboard_templates")
}

// ═══════════════════════════════════════════════════════════════════
//                    SPRINT 3 MODELS
// ═══════════════════════════════════════════════════════════════════

// ============ AI SMART IMPORT ============

// Import Session - Track import sessions
model ImportSession {
  id               String    @id @default(cuid())
  fileName         String
  fileSize         Int
  fileType         String // xlsx, csv, xls
  detectedType     String // PARTS, BOM, SUPPLIERS, INVENTORY, PURCHASE_ORDERS, UNKNOWN
  confidence       Float // 0.0 - 1.0
  status           String // ANALYZING, MAPPED, VALIDATING, IMPORTING, COMPLETED, FAILED, ROLLED_BACK
  totalRows        Int       @default(0)
  successRows      Int       @default(0)
  failedRows       Int       @default(0)
  skippedRows      Int       @default(0)
  columnMapping    Json // { excelCol: systemField, ... }
  validationErrors Json? // Array of { row, col, message }
  importedBy       String // userId
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  rollbackAt       DateTime?

  logs ImportLog[]
  user User        @relation("ImportSessionUser", fields: [importedBy], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([importedBy])
  @@index([status])
  @@index([detectedType])
  @@index([createdAt])
  @@map("import_sessions")
}

// Import Log - Detailed import log entries
model ImportLog {
  id         String        @id @default(cuid())
  sessionId  String
  session    ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rowNumber  Int
  status     String // SUCCESS, FAILED, SKIPPED, DUPLICATE, MERGED
  entityType String // Part, Supplier, BOM, etc.
  entityId   String? // Created/updated record ID
  data       Json // Original row data
  errors     Json? // Error details if failed
  createdAt  DateTime      @default(now())

  @@index([sessionId])
  @@index([status])
  @@index([entityType])
  @@map("import_logs")
}

// Import Mapping - Saved column mappings for reuse
model ImportMapping {
  id         String    @id @default(cuid())
  name       String // User-given name: "NCC ABC format"
  targetType String // PARTS, BOM, SUPPLIERS, etc.
  mapping    Json // Saved column mapping
  usageCount Int       @default(0)
  lastUsedAt DateTime?
  createdBy  String

  user User @relation("ImportMappingUser", fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType])
  @@index([createdBy])
  @@index([usageCount])
  @@map("import_mappings")
}

// ============ BACKUP & RECOVERY ============

// Backup - Track database backups
model Backup {
  id        String   @id @default(cuid())
  name      String // "Auto backup 2026-02-04 07:00"
  type      String // AUTO, MANUAL, PRE_UPDATE
  status    String // IN_PROGRESS, COMPLETED, FAILED
  filePath  String? // Path to backup file
  fileSize  Int? // Bytes
  tables    Int? // Number of tables backed up
  records   Int? // Total records
  duration  Int? // Seconds taken
  error     String?
  createdBy String // userId or "SYSTEM"
  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("backups")
}

// Backup Schedule - Auto-backup configuration
model BackupSchedule {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(true)
  frequency String // DAILY, WEEKLY
  timeOfDay String // "02:00" (run at 2 AM)
  retention Int      @default(30) // Keep last N backups
  updatedBy String
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@map("backup_schedules")
}

// ============ SAVED VIEWS / FILTERS ============

// Saved View - User-saved filter configurations
model SavedView {
  id        String  @id @default(cuid())
  name      String // "PO chờ duyệt tháng này"
  entity    String // parts, purchase_orders, work_orders, etc.
  filters   Json // { status: 'pending', dateRange: [...] }
  columns   Json? // Which columns visible + order
  sortBy    String?
  sortOrder String? // ASC, DESC
  isDefault Boolean @default(false)
  isShared  Boolean @default(false) // Visible to all users
  createdBy String

  user User @relation("SavedViewUser", fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity])
  @@index([createdBy])
  @@index([isShared])
  @@map("saved_views")
}

// ============ REPORT HISTORY (Extended) ============

// Report History - Track generated reports
model ReportHistory {
  id          String    @id @default(cuid())
  scheduleId  String?
  templateId  String
  generatedBy String // userId or "SYSTEM"
  format      String // PDF, EXCEL, BOTH
  fileUrl     String? // Stored file path
  fileSize    Int?
  recipients  Json? // Email recipients
  sentAt      DateTime?
  status      String // GENERATED, SENT, FAILED
  error       String?
  createdAt   DateTime  @default(now())

  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@map("report_history")
}


// ============ SPC QUALITY ALERTS ============
model QualityAlert {
  id               String @id @default(cuid())
  characteristicId String

  type        String // OUT_OF_CONTROL, TREND, SHIFT, RULE_VIOLATION
  severity    String // LOW, MEDIUM, HIGH, CRITICAL
  status      String @default("open") // open, acknowledged, resolved, dismissed
  title       String
  description String?
  violation   Json? // Details of the SPC rule violation

  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characteristic InspectionCharacteristic @relation(fields: [characteristicId], references: [id], onDelete: Cascade)

  @@index([characteristicId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@map("quality_alerts")
}

// ============ WORK SESSION TRACKING ============
enum WorkSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

model WorkSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  entityType   String // PO, SO, MRP_RUN, WORK_ORDER, INVENTORY, PART, BOM
  entityId     String
  entityNumber String

  status WorkSessionStatus @default(ACTIVE)

  workflowStep      Int    @default(1)
  workflowTotalSteps Int   @default(1)
  workflowStepName  String @default("")

  contextSummary String @default("")
  contextJson    Json   @default("{}")

  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  pausedAt       DateTime?
  completedAt    DateTime?
  totalActiveTime Int      @default(0) // seconds

  resumeUrl       String @default("")
  resumeStateJson Json?

  activities SessionActivity[]

  @@index([userId, status])
  @@index([userId, lastActivityAt])
  @@index([entityType, entityId])
  @@map("work_sessions")
}

model SessionActivity {
  id        String      @id @default(cuid())
  sessionId String
  session   WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  action      String
  description String
  timestamp   DateTime @default(now())
  metadataJson Json?

  @@index([sessionId, timestamp])
  @@map("session_activities")
}

// ============ COST OPTIMIZATION & MANUFACTURING AUTONOMY ============

enum CostTargetStatus {
  DRAFT
  ACTIVE
  ON_TRACK
  AT_RISK
  ACHIEVED
  CANCELLED
}

enum PhaseStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum ActionType {
  MAKE_VS_BUY
  SUBSTITUTE
  SUPPLIER_OPTIMIZE
  PROCESS_IMPROVE
  DESIGN_CHANGE
  LOCALIZE
}

enum ActionStatus {
  IDEA
  APPROVED
  IN_PROGRESS_ACTION
  TESTING_ACTION
  COMPLETED_ACTION
  CANCELLED_ACTION
  ON_HOLD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AutonomyStatus {
  MAKE
  IN_DEVELOPMENT
  EVALUATE
  BUY_STRATEGIC
  BUY_REQUIRED
}

enum SourceType {
  MAKE_SOURCE
  BUY_SOURCE
  HYBRID
}

enum MakeVsBuyRecommendation {
  STRONG_MAKE
  CONSIDER_MAKE
  NEUTRAL
  CONSIDER_BUY
  STRONG_BUY
}

enum MakeVsBuyDecision {
  DECIDE_MAKE
  DECIDE_BUY
  DECIDE_HYBRID
  DECIDE_DEFER
}

enum CostAnalysisStatus {
  ANALYSIS_DRAFT
  ANALYSIS_SUBMITTED
  ANALYSIS_UNDER_REVIEW
  ANALYSIS_DECIDED
  ANALYSIS_ARCHIVED
}

enum CostTestStatus {
  NOT_STARTED
  SAMPLE_ORDERED
  COST_TESTING
  TEST_PASSED
  TEST_FAILED
}

enum SubstituteStatus {
  IDENTIFIED
  EVALUATING
  SUB_TESTING
  SUB_APPROVED
  SUB_REJECTED
  IMPLEMENTED
}

enum SavingsSource {
  SAVINGS_MAKE_VS_BUY
  SAVINGS_SUBSTITUTE
  SUPPLIER_NEGOTIATION
  CONSOLIDATION
  PROCESS_IMPROVEMENT
  SAVINGS_DESIGN_CHANGE
  SAVINGS_OTHER
}

model CostTarget {
  id          String           @id @default(cuid())
  productId   String
  product     Product          @relation(fields: [productId], references: [id])

  name        String
  currentCost Float
  targetCost  Float
  targetDate  DateTime

  status      CostTargetStatus @default(DRAFT)

  phases      CostReductionPhase[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdById String
  createdBy   User             @relation("CostTargetCreator", fields: [createdById], references: [id])

  @@index([productId])
  @@index([status])
  @@map("cost_targets")
}

model CostReductionPhase {
  id           String     @id @default(cuid())
  costTargetId String
  costTarget   CostTarget @relation(fields: [costTargetId], references: [id], onDelete: Cascade)

  name         String
  targetCost   Float
  targetDate   DateTime

  status       PhaseStatus @default(PLANNED)

  actions      CostReductionAction[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([costTargetId])
  @@map("cost_reduction_phases")
}

model CostReductionAction {
  id          String             @id @default(cuid())
  phaseId     String
  phase       CostReductionPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  type        ActionType
  partId      String?
  part        Part?              @relation("CostReductionActionPart", fields: [partId], references: [id])

  description String

  currentCost    Float
  targetCost     Float
  savingsPerUnit Float
  annualVolume   Int
  annualSavings  Float

  investmentRequired Float  @default(0)
  breakEvenUnits     Int    @default(0)
  roiMonths          Int    @default(0)

  startDate            DateTime?
  targetCompletionDate DateTime
  actualCompletionDate DateTime?

  status          ActionStatus @default(IDEA)
  progressPercent Int          @default(0)

  riskLevel RiskLevel @default(LOW)
  riskNotes String?
  notes     String?

  ownerId String
  owner   User   @relation("CostReductionActionOwner", fields: [ownerId], references: [id])

  dependsOnIds String[]

  savingsRecords SavingsRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
  @@index([status])
  @@index([partId])
  @@map("cost_reduction_actions")
}

model PartAutonomyStatus {
  id     String @id @default(cuid())
  partId String @unique
  part   Part   @relation(fields: [partId], references: [id])

  status AutonomyStatus @default(BUY_REQUIRED)

  currentSource      SourceType @default(BUY_SOURCE)
  currentCost        Float
  currentLeadTimeDays Int

  makeCapabilityPercent Int    @default(0)
  makeTargetDate        DateTime?
  makeCostEstimate      Float?
  makeInvestmentRequired Float?

  rdProgressPercent Int?
  rdBlockers        String[]

  ndaaCompliant  Boolean @default(false)
  itarControlled Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("part_autonomy_statuses")
}

model MakeVsBuyAnalysis {
  id     String @id @default(cuid())
  partId String
  part   Part   @relation("MakeVsBuyAnalysisPart", fields: [partId], references: [id])

  buyPrice        Float
  buyMOQ          Int
  buyLeadTimeDays Int
  buyRisks        String[]

  makeCostEstimate       Float
  makeInvestmentRequired Float
  makeLeadTimeDays       Int
  makeTimelineMonths     Int
  makeCapabilityGapsJson Json?

  savingsPerUnit       Float
  annualVolumeEstimate Int
  annualSavings        Float
  breakEvenUnits       Int
  breakEvenMonths      Int
  npv3Year             Float

  financialScore  Float
  capabilityScore Float
  strategicScore  Float
  overallScore    Float

  recommendation          MakeVsBuyRecommendation
  recommendationRationale String
  conditions              String[]

  status     CostAnalysisStatus @default(ANALYSIS_DRAFT)
  decision   MakeVsBuyDecision?
  decisionDate DateTime?
  decisionById String?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("MakeVsBuyAnalysisCreator", fields: [createdById], references: [id])

  @@index([partId])
  @@index([status])
  @@map("make_vs_buy_analyses")
}

model SubstituteEvaluation {
  id               String @id @default(cuid())
  originalPartId   String
  originalPart     Part   @relation("SubEvalOriginalPart", fields: [originalPartId], references: [id])

  substitutePartId String
  substitutePart   Part   @relation("SubEvalSubstitutePart", fields: [substitutePartId], references: [id])

  originalPrice   Float
  substitutePrice Float
  savingsPercent  Float

  compatibilityScore  Float
  specsComparisonJson Json?

  ndaaCompliant Boolean
  itarCompliant Boolean

  riskLevel   RiskLevel
  riskFactors String[]

  sampleOrdered   Boolean        @default(false)
  sampleOrderDate DateTime?
  testStatus      CostTestStatus @default(NOT_STARTED)
  testResults     String?
  testDate        DateTime?

  status          SubstituteStatus @default(IDENTIFIED)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?

  implementedAt DateTime?
  actualSavings Float?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("SubstituteEvaluationCreator", fields: [createdById], references: [id])

  @@index([originalPartId])
  @@index([status])
  @@map("substitute_evaluations")
}

model SavingsRecord {
  id       String               @id @default(cuid())
  actionId String?
  action   CostReductionAction? @relation(fields: [actionId], references: [id])

  source SavingsSource

  partId     String?
  supplierId String?

  description String

  savingsPerUnit Float
  unitsAffected  Int
  totalSavings   Float

  periodStart DateTime
  periodEnd   DateTime

  verified     Boolean   @default(false)
  verifiedById String?
  verifiedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([source])
  @@index([periodStart, periodEnd])
  @@map("savings_records")
}