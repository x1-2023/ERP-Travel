{
  "name": "vierp-mrp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3005 ts-node --project tsconfig.server.json server.ts",
    "dev:next": "next dev",
    "build": "npx prisma generate && next build && npx tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server.js",
    "start:next": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:add-demo": "tsx scripts/add-demo-user.ts",
    "load:smoke": "k6 run load-testing/k6/main.js --env SCENARIO=smoke",
    "load:test": "k6 run load-testing/k6/main.js",
    "load:stress": "k6 run load-testing/k6/main.js --env SCENARIO=stress",
    "load:api": "k6 run load-testing/k6/api-tests.js",
    "clean": "rm -rf .next public/sw.js public/workbox-*.js public/fallback-*.js",
    "artillery:smoke": "artillery run load-testing/artillery/smoke.yml",
    "artillery:main": "artillery run load-testing/artillery/main.yml",
    "artillery:stress": "artillery run load-testing/artillery/stress.yml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:desktop": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:auth": "playwright test e2e/auth/",
    "test:e2e:parts": "playwright test e2e/parts/",
    "test:e2e:bom": "playwright test e2e/bom/",
    "test:e2e:production": "playwright test e2e/production/",
    "test:e2e:discussions": "playwright test e2e/discussions/",
    "test:e2e:perf": "playwright test e2e/performance/",
    "test:e2e:cost-opt": "playwright test e2e/cost-optimization/"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
