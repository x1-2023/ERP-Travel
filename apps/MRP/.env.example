# ═══════════════════════════════════════════════════════════════════════════════
#                         VietERP MRP SYSTEM
#                    Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
#
# ═══════════════════════════════════════════════════════════════════════════════

# ==================== Database ====================
# For Docker deployment:
DATABASE_URL="postgresql://rtr:your-secure-password@db:5432/rtr_mrp?schema=public"

# For local development:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rtr_mrp?schema=public"

# Docker-specific database config
POSTGRES_USER=rtr
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=rtr_mrp

# ==================== Redis Cache ====================
# For Docker deployment:
REDIS_URL=redis://redis:6379

# For local development:
# REDIS_URL=redis://localhost:6379

# ==================== Authentication ====================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
# Generate with: openssl rand -base64 32

# ==================== Application ====================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV=production
APP_PORT=3000
SERVICE_NAME=vierp-mrp

# ==================== Demo Mode ====================
# Set to "true" to enable demo endpoints (/api/demo/*) and demo UI components
# In production, leave empty or set to "false" to disable demo features
NEXT_PUBLIC_DEMO_MODE=false

# ==================== Monitoring ====================
# Sentry error tracking (optional)
SENTRY_DSN=

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ==================== Backup ====================
BACKUP_RETENTION_DAYS=30

# ==================== Optional: AWS S3 Backup ====================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# ==================== Optional: Slack Notifications ====================
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx

# ==================== Optional: AI Features ====================
# OPENAI_API_KEY=sk-xxx

# ==================== ML Service ====================
ML_SERVICE_URL=http://ml-service:8000

# ==================== Docker Compose Ports ====================
DB_PORT=5432
REDIS_PORT=6379
ML_SERVICE_PORT=8000

# === AI/LLM ===
# Anthropic Claude API key (used by src/lib/ai-service.ts, src/lib/ai/provider.ts)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Google AI / Gemini API keys (used by src/lib/ai/forecast/ai-enhancer.ts, src/lib/ai/email-parser-service.ts)
# GOOGLE_AI_API_KEY=your-google-ai-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# API base URLs (override for proxies or self-hosted endpoints)
# OPENAI_API_BASE_URL=https://api.openai.com
# GOOGLE_AI_API_BASE_URL=https://generativelanguage.googleapis.com

# === Email/SMTP ===
# Email sender configuration (used by src/lib/email/email-service.ts)
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=VietERP MRP
# EMAIL_PROVIDER=smtp

# SMTP server settings (used by src/lib/reports/email-sender.ts, src/lib/export/export-service.ts, src/lib/email/email-service.ts)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_SECURE=true
# SMTP_FROM=noreply@example.com

# Resend email provider API key (used by src/lib/email/email-service.ts)
# RESEND_API_KEY=re_your-resend-api-key-here

# SendGrid email provider API key (used by src/lib/email/email-service.ts)
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# AWS SES credentials for email sending (used by src/lib/email/email-service.ts)
# AWS_SES_ACCESS_KEY_ID=your-ses-access-key-id
# AWS_SES_SECRET_ACCESS_KEY=your-ses-secret-access-key

# === Infrastructure ===
# Directory for database backups (used by src/lib/backup/backup-service.ts, scripts/backup/)
# BACKUP_DIR=/var/backups/vierp-mrp

# Secret token for authenticating cron job requests (used by src/app/api/cron/inventory-alerts/route.ts)
# CRON_SECRET=your-cron-secret-here

# Log output format: json or text (used by src/lib/monitoring/logger.ts)
# LOG_FORMAT=json

# Remote log aggregation service URL (used by src/lib/logger.ts)
# LOG_SERVICE_URL=https://logs.example.com/ingest

# Enable performance profiling (used by src/lib/performance/profiler.ts)
# ENABLE_PROFILING=false

# Enable Supabase SSO authentication (used by src/lib/auth.ts, src/middleware.ts)
# ENABLE_SUPABASE_SSO=false

# Upstash Redis REST API for rate limiting (used by src/lib/rate-limit.ts, src/app/api/health/route.ts)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# =============================================================================
# VietERP MRP - Multi-tenancy Environment Variables
# =============================================================================

# Redis (for caching & queues)
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# AWS S3 (for file storage)
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET="vierp-files-mrp"

# Database (with connection pool)
DATABASE_URL="postgresql://user:pass@localhost:5432/rtr_mrp?connection_limit=20&pool_timeout=10"
