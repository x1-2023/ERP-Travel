# ═══════════════════════════════════════════════════════════════════════════════
#                    VietERP MRP SYSTEM — PRODUCTION ENVIRONMENT
#                         Server: mrp.vierp.com
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env on the VPS and fill in the values
#   cp .env.production.example .env
#
# Generate secrets:
#   NEXTAUTH_SECRET: openssl rand -base64 32
#   POSTGRES_PASSWORD: openssl rand -hex 32
#
# ═══════════════════════════════════════════════════════════════════════════════

# ==================== Application ====================
NODE_ENV=production
DOCKER=true

# ==================== URLs ====================
NEXTAUTH_URL=https://mrp.vierp.com
NEXT_PUBLIC_APP_URL=https://mrp.vierp.com

# ==================== Authentication ====================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl
AUTH_SECRET=change-me-generate-with-openssl

# ==================== Database ====================
POSTGRES_USER=rtr
POSTGRES_PASSWORD=change-me-generate-with-openssl
POSTGRES_DB=rtr_mrp
DATABASE_URL=postgresql://rtr:change-me-generate-with-openssl@db:5432/rtr_mrp?schema=public

# ==================== Redis ====================
REDIS_URL=redis://redis:6379

# ==================== ML Service ====================
ML_SERVICE_URL=http://ml-service:8000

# ==================== Logging ====================
LOG_LEVEL=info

# ==================== Backup ====================
BACKUP_RETENTION_DAYS=30

# ==================== Optional: AI Features ====================
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GOOGLE_AI_API_KEY=xxx

# ==================== Optional: Monitoring ====================
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ==================== Optional: Email ====================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
