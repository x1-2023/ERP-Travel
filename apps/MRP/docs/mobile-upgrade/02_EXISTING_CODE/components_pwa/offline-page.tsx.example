'use client';

import React from 'react';
import { WifiOff, RefreshCw, Home, Database, Clock } from 'lucide-react';

// =============================================================================
// RTR MRP - OFFLINE PAGE
// Shown when user is offline and page is not cached
// =============================================================================

export function OfflinePage() {
  const handleRetry = () => {
    window.location.reload();
  };

  const handleGoHome = () => {
    window.location.href = '/';
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 flex items-center justify-center p-4">
      <div className="max-w-md w-full text-center">
        {/* Icon */}
        <div className="relative mb-8">
          <div className="w-32 h-32 mx-auto bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center">
            <WifiOff className="w-16 h-16 text-gray-400 dark:text-gray-500" />
          </div>
          <div className="absolute -bottom-2 left-1/2 -translate-x-1/2 px-4 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full text-sm font-medium">
            Offline
          </div>
        </div>

        {/* Title */}
        <h1 className="text-2xl font-bold text-gray-900 dark:text-white mb-3">
          Không có kết nối mạng
        </h1>
        <p className="text-gray-600 dark:text-gray-400 mb-8">
          Vui lòng kiểm tra kết nối Internet của bạn và thử lại. 
          Một số tính năng vẫn hoạt động offline.
        </p>

        {/* Actions */}
        <div className="flex flex-col sm:flex-row gap-3 justify-center mb-8">
          <button
            onClick={handleRetry}
            className="flex items-center justify-center gap-2 px-6 py-3 bg-purple-600 text-white rounded-xl font-medium hover:bg-purple-700 transition-colors"
          >
            <RefreshCw className="w-5 h-5" />
            Thử lại
          </button>
          <button
            onClick={handleGoHome}
            className="flex items-center justify-center gap-2 px-6 py-3 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-xl font-medium border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
          >
            <Home className="w-5 h-5" />
            Về trang chủ
          </button>
        </div>

        {/* Offline Features */}
        <div className="bg-white dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
          <h3 className="font-semibold text-gray-900 dark:text-white mb-4 text-left">
            Tính năng khả dụng offline:
          </h3>
          <ul className="space-y-3 text-left">
            <li className="flex items-center gap-3 text-gray-600 dark:text-gray-400">
              <div className="p-1.5 bg-green-100 dark:bg-green-900/30 rounded-lg">
                <Database className="w-4 h-4 text-green-600 dark:text-green-400" />
              </div>
              <span>Xem dữ liệu đã cache</span>
            </li>
            <li className="flex items-center gap-3 text-gray-600 dark:text-gray-400">
              <div className="p-1.5 bg-blue-100 dark:bg-blue-900/30 rounded-lg">
                <Clock className="w-4 h-4 text-blue-600 dark:text-blue-400" />
              </div>
              <span>Tạo bản nháp (tự động lưu)</span>
            </li>
            <li className="flex items-center gap-3 text-gray-600 dark:text-gray-400">
              <div className="p-1.5 bg-purple-100 dark:bg-purple-900/30 rounded-lg">
                <RefreshCw className="w-4 h-4 text-purple-600 dark:text-purple-400" />
              </div>
              <span>Đồng bộ khi có mạng trở lại</span>
            </li>
          </ul>
        </div>

        {/* Tips */}
        <p className="text-xs text-gray-500 dark:text-gray-500 mt-6">
          💡 Tip: Cài đặt ứng dụng để có trải nghiệm offline tốt hơn
        </p>
      </div>
    </div>
  );
}

export default OfflinePage;
