/* ═══════════════════════════════════════════════════════════════════════════
   MOBILE RESPONSIVE STYLES
   Production-grade responsive system for excelAI on mobile devices
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── Tablet & Mobile (max 768px) ──────────────────────────────────────── */

@media (max-width: 768px) {
  /* Hide desktop toolbar/ribbon, show mobile toolbar */
  .desktop-toolbar,
  .ribbon-container,
  .ribbon-tabs,
  .ribbon-content,
  .desktop-only {
    display: none !important;
  }

  .mobile-only {
    display: flex !important;
  }

  .mobile-toolbar-root {
    display: block !important;
  }

  /* Header adjustments */
  .app-header,
  .workbook-header {
    height: 44px !important;
    min-height: 44px !important;
    padding: 0 8px !important;
  }

  .app-header h1,
  .workbook-header h1,
  .app-title {
    font-size: 14px !important;
    line-height: 1.2 !important;
  }

  /* Formula bar - full width on mobile */
  .formula-bar,
  .formula-bar-container {
    width: 100% !important;
    max-width: 100% !important;
    padding: 4px 8px !important;
    font-size: 13px !important;
    min-height: 36px !important;
  }

  .formula-bar input,
  .formula-bar textarea,
  .formula-bar-input {
    font-size: 14px !important; /* Prevent iOS zoom on focus */
    min-height: 32px !important;
  }

  /* Name box / cell reference */
  .name-box,
  .cell-reference {
    min-width: 60px !important;
    max-width: 80px !important;
    font-size: 12px !important;
  }

  /* Touch-friendly button sizing */
  button,
  [role="button"],
  .btn,
  .toolbar-btn {
    min-height: 44px;
    min-width: 44px;
  }

  /* Don't enforce min size on inline/icon-only buttons that are explicitly small */
  .btn-xs,
  .btn-icon-sm {
    min-height: 32px;
    min-width: 32px;
  }

  /* Sheet tabs - optimized scrolling */
  .sheet-tabs,
  .sheet-tab-bar {
    overflow-x: auto !important;
    -webkit-overflow-scrolling: touch !important;
    scrollbar-width: none !important;
    white-space: nowrap !important;
  }

  .sheet-tabs::-webkit-scrollbar,
  .sheet-tab-bar::-webkit-scrollbar {
    display: none !important;
  }

  .sheet-tab {
    flex-shrink: 0 !important;
    padding: 6px 12px !important;
    font-size: 12px !important;
    min-height: 36px !important;
  }

  /* Grid container adjustments for mobile bottom toolbar */
  .grid-container,
  .canvas-grid-wrapper {
    /* Reserve space for mobile toolbar (56px) + sheet tabs (40px) + safe area */
    padding-bottom: calc(96px + env(safe-area-inset-bottom, 0px)) !important;
  }

  /* Sidebar panels: full-screen overlay on mobile */
  .sidebar-panel,
  .side-panel,
  .panel-overlay {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 100% !important;
    max-width: 100% !important;
    z-index: 60 !important;
  }

  /* Context menus: bottom-sheet style on mobile */
  .context-menu,
  .dropdown-menu {
    position: fixed !important;
    bottom: 0 !important;
    left: 0 !important;
    right: 0 !important;
    top: auto !important;
    max-height: 60vh !important;
    border-radius: 16px 16px 0 0 !important;
    overflow-y: auto !important;
  }

  .context-menu-item,
  .dropdown-item {
    min-height: 44px !important;
    padding: 10px 16px !important;
    font-size: 14px !important;
  }

  /* Dialog adjustments */
  .dialog,
  .modal-content,
  [role="dialog"] {
    width: calc(100vw - 16px) !important;
    max-width: 100% !important;
    margin: 8px !important;
    max-height: calc(100vh - 80px) !important;
    overflow-y: auto !important;
  }

  /* Status bar */
  .status-bar,
  .statusbar {
    font-size: 11px !important;
    padding: 2px 8px !important;
    min-height: 24px !important;
  }

  /* Floating AI button - reposition for mobile */
  .floating-ai-button {
    bottom: 110px !important;
    right: 12px !important;
  }

  /* Scrollbar hiding for touch devices */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }

  .scrollbar-none {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  /* Prevent text selection during touch interactions */
  .touch-none {
    touch-action: none;
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    user-select: none;
  }

  /* Prevent pull-to-refresh on the grid area */
  .grid-area,
  .canvas-grid-wrapper {
    overscroll-behavior: contain;
  }

  /* Safe area support for notched devices */
  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .safe-area-top {
    padding-top: env(safe-area-inset-top, 0px);
  }
}

/* ── Small Phones (max 480px) ─────────────────────────────────────────── */

@media (max-width: 480px) {
  /* Even more compact header */
  .app-header,
  .workbook-header {
    height: 40px !important;
    min-height: 40px !important;
    padding: 0 4px !important;
  }

  .app-header h1,
  .workbook-header h1,
  .app-title {
    font-size: 13px !important;
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Hide non-essential header elements */
  .header-actions .btn-text,
  .header-subtitle,
  .breadcrumb,
  .version-badge,
  .connection-status-text,
  .zoom-controls-desktop {
    display: none !important;
  }

  /* Compact formula bar */
  .formula-bar,
  .formula-bar-container {
    padding: 2px 4px !important;
    min-height: 32px !important;
  }

  .name-box,
  .cell-reference {
    min-width: 50px !important;
    max-width: 60px !important;
    font-size: 11px !important;
  }

  /* Sheet tabs - even more compact */
  .sheet-tab {
    padding: 4px 8px !important;
    font-size: 11px !important;
    min-height: 32px !important;
  }

  /* Smaller buttons on very small screens (still touch-friendly) */
  .mobile-toolbar-root button {
    min-height: 44px;
    min-width: 40px;
  }

  /* Grid container - slightly more space */
  .grid-container,
  .canvas-grid-wrapper {
    padding-bottom: calc(92px + env(safe-area-inset-bottom, 0px)) !important;
  }

  /* Full-width modals */
  .dialog,
  .modal-content,
  [role="dialog"] {
    width: 100vw !important;
    margin: 0 !important;
    border-radius: 16px 16px 0 0 !important;
    position: fixed !important;
    bottom: 0 !important;
    max-height: 85vh !important;
  }

  /* Reduce padding in mobile panels */
  .mobile-toolbar-root .grid {
    gap: 2px !important;
    padding: 8px !important;
  }

  /* Compact toast notifications */
  .toast-container,
  .toast-wrapper {
    bottom: 100px !important;
    left: 8px !important;
    right: 8px !important;
  }

  /* Hide collaboration avatars on very small screens */
  .collab-avatars,
  .presence-indicators {
    display: none !important;
  }

  /* Comments panel: full screen */
  .comments-panel {
    position: fixed !important;
    inset: 0 !important;
    width: 100% !important;
    z-index: 70 !important;
  }
}

/* ── Landscape orientation on mobile ──────────────────────────────────── */

@media (max-width: 768px) and (orientation: landscape) {
  /* Reduce header height in landscape */
  .app-header,
  .workbook-header {
    height: 36px !important;
    min-height: 36px !important;
  }

  /* Mobile toolbar: more compact in landscape */
  .mobile-toolbar-root .mobile-toolbar-bar,
  .mobile-toolbar-root [data-testid="mobile-toolbar-bar"] {
    height: 48px !important;
  }

  /* Slide-up panels: side layout in landscape */
  .mobile-toolbar-root [data-testid^="mobile-panel-"] {
    max-height: 40vh !important;
  }

  /* Sheet tabs */
  .mobile-sheet-tabs {
    height: 32px !important;
  }
}

/* ── Touch device helpers ─────────────────────────────────────────────── */

@media (hover: none) and (pointer: coarse) {
  /* Increase tap targets on touch devices regardless of screen size */
  .clickable,
  .interactive {
    min-height: 44px;
    min-width: 44px;
  }

  /* Remove hover effects that cause sticky states on touch */
  .hover-effect:hover {
    background-color: inherit !important;
  }

  /* Ensure inputs don't zoom on focus (iOS) */
  input,
  textarea,
  select {
    font-size: 16px !important;
  }

  /* Smooth scrolling for touch */
  .scroll-container {
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
  }
}

/* ── Print: hide mobile UI ────────────────────────────────────────────── */

@media print {
  .mobile-toolbar-root,
  .mobile-sheet-tabs,
  .floating-ai-button {
    display: none !important;
  }
}
