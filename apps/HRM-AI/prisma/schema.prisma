  effectiveDate  DateTime?               @map("effective_date")
  endDate        DateTime?               @map("end_date")
  employerAmount Decimal?                @map("employer_amount") @db.Decimal(18, 2)
  employeeAmount Decimal?                @map("employee_amount") @db.Decimal(18, 2)
  notes          String?

