// prisma/schema.prisma
// Lac Viet HR - Sprint 1: Foundation + Core HR

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR_MANAGER
  HR_STAFF
  VIEWER
}

enum EmployeeStatus {
  ACTIVE
  PROBATION
  ON_LEAVE
  RESIGNED
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContractType {
  PROBATION
  DEFINITE_TERM
  INDEFINITE_TERM
  SEASONAL
  PART_TIME
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum SalaryType {
  GROSS
  NET
}

enum RelationshipType {
  SPOUSE
  CHILD
  PARENT
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  IMPORT
  EXPORT
  APPROVE
  REJECT
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.0: COMPLIANCE & INTEGRATION ENUMS
// ═══════════════════════════════════════════════════════════════

enum InsuranceReportType {
  D02_TS // Báo cáo tăng lao động
  D03_TS // Báo cáo giảm lao động
  C12_TS // Bảng kê đóng BHXH, BHYT, BHTN
  TK1_TS // Tờ khai tham gia BHXH
}

enum InsuranceReportStatus {
  DRAFT
  PENDING_REVIEW
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum DeviceType {
  FINGERPRINT
  FACE_RECOGNITION
  CARD_READER
  GPS_CHECKIN
  QR_CODE
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ERROR
}

enum PaymentBatchStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentTransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

enum SignatureStatus {
  PENDING
  SIGNED
  REJECTED
  EXPIRED
  REVOKED
}

enum CertificateStatus {
  ACTIVE
  EXPIRED
  REVOKED
  PENDING_RENEWAL
}

// ═══════════════════════════════════════════════════════════════
// TENANT & AUTH
// ═══════════════════════════════════════════════════════════════

model Tenant {
  id               String   @id @default(cuid())
  name             String
  code             String   @unique
  taxCode          String?  @map("tax_code")
  address          String?
  phone            String?
  email            String?
  logo             String?
  settings         Json?    @default("{}")
  subscriptionTier String   @default("basic") @map("subscription_tier")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  users       User[]
  employees   Employee[]
  departments Department[]
  positions   Position[]
  branches    Branch[]
  contracts   Contract[]
  auditLogs   AuditLog[]

  // Sprint 2: Time & Attendance
  shifts              Shift[]
  workSchedules       WorkSchedule[]
  holidays            Holiday[]
  attendances         Attendance[]
  overtimeRequests    OvertimeRequest[]
  attendanceSummaries AttendanceSummary[]
  attendanceAnomalies AttendanceAnomaly[]

  // Sprint 3: Payroll
  payrollConfigs     PayrollConfig[]
  salaryComponents   SalaryComponent[]
  payrollPeriods     PayrollPeriod[]
  payrolls           Payroll[]
  payrollAdjustments PayrollAdjustment[]
  bankPaymentBatches BankPaymentBatch[]

  // Sprint 4: ESS + Workflow
  leavePolicies         LeavePolicy[]
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]
  workflowDefinitions   WorkflowDefinition[]
  workflowInstances     WorkflowInstance[]
  delegations           Delegation[]
  notifications         Notification[]
  profileUpdateRequests ProfileUpdateRequest[]

  // Sprint 5: AI Copilot
  knowledgeArticles KnowledgeArticle[]
  aiConversations   AIConversation[]
  insights          Insight[]
  savedReports      SavedReport[]

  // Sprint 6: Integrations
  emailQueue     EmailQueue[]
  emailTemplates EmailTemplate[]
  importJobs     ImportJob[]
  apiKeys        ApiKey[]
  webhooks       Webhook[]
  systemConfigs  SystemConfig[]

  // Sprint 7: Analytics
  analyticsMetrics    AnalyticsMetric[]
  turnoverPredictions TurnoverPrediction[]
  dashboards          Dashboard[]
  analyticsReports    AnalyticsReport[]
  salaryBenchmarks    SalaryBenchmark[]

  // Sprint 8: Recruitment & Onboarding
  jobRequisitions      JobRequisition[]
  jobPostings          JobPosting[]
  candidates           Candidate[]
  applications         Application[]
  interviews           Interview[]
  candidateEvaluations CandidateEvaluation[]
  offers               Offer[]
  onboardingTemplates  OnboardingTemplate[]
  onboardings          Onboarding[]

  // Sprint 9: Performance Management
  goals                       Goal[]
  reviewCycles                ReviewCycle[]
  performanceReviews          PerformanceReview[]
  competencyFrameworks        CompetencyFramework[]
  positionCompetencies        PositionCompetency[]
  coreValues                  CoreValue[]
  feedbackRequests            FeedbackRequest[]
  feedbacks                   Feedback[]
  calibrationSessions         CalibrationSession[]
  checkIns                    CheckIn[]
  oneOnOnes                   OneOnOne[]
  performanceImprovementPlans PerformanceImprovementPlan[]

  // Sprint 10: Learning & Development
  skillCategories         SkillCategory[]
  skills                  Skill[]
  employeeSkills          EmployeeSkill[]
  positionSkills          PositionSkill[]
  courseCategories        CourseCategory[]
  courses                 Course[]
  trainingProviders       TrainingProvider[]
  trainingSessions        TrainingSession[]
  enrollments             Enrollment[]
  trainingRequests        TrainingRequest[]
  learningPaths           LearningPath[]
  learningPathEnrollments LearningPathEnrollment[]
  certificationTypes      CertificationType[]
  employeeCertifications  EmployeeCertification[]
  assessments             Assessment[]
  assessmentAttempts      AssessmentAttempt[]
  trainingBudgets         TrainingBudget[]

  // Sprint 11: Compensation & Benefits
  salaryGrades           SalaryGrade[]
  meritMatrices          MeritMatrix[]
  compensationCycles     CompensationCycle[]
  compensationReviews    CompensationReview[]
  compensationChanges    CompensationChange[]
  compensationBudgets    CompensationBudget[]
  employeeCompensations  EmployeeCompensation[]
  benefitPlans           BenefitPlan[]
  benefitEnrollments     BenefitEnrollment[]
  allowanceTypes         AllowanceType[]
  employeeAllowances     EmployeeAllowance[]
  totalRewardsStatements TotalRewardsStatement[]
  payEquityAnalyses      PayEquityAnalysis[]
  compensationBenchmarks CompensationBenchmark[]
  compensationHistories  CompensationHistory[]

  // Phase 3.0: Compliance & Integration
  employeeInsurances   EmployeeInsurance[]
  insuranceReports     InsuranceReport[]
  taxSettlements       TaxSettlement[]
  attendanceDevices    AttendanceDevice[]
  officeLocations      OfficeLocation[]
  deviceSyncLogs       DeviceSyncLog[]
  rawPunchLogs         RawPunchLog[]
  bankConfigurations   BankConfiguration[]
  paymentBatches       PaymentBatch[]
  signatureProviders   SignatureProvider[]
  employeeCertificates EmployeeCertificate[]
  signableDocuments    SignableDocument[]

  // Phase 3.3: Employee Experience
  surveys               Survey[]
  recognitionCategories RecognitionCategory[]
  recognitions          Recognition[]
  companyPosts          CompanyPost[]
  companyEvents         CompanyEvent[]
  offboardingInstances  OffboardingInstance[]

  // Phase 5.0: Advanced Analytics
  analyticsSnapshots AnalyticsSnapshot[]
  predictiveModels   PredictiveModel[]
  predictions        Prediction[]
  customReports      CustomReport[]
  reportExports      ReportExport[]
  analyticsAlerts    AnalyticsAlert[]

  // Phase 7: Custom Roles, GDPR, Retention
  customRoles       CustomRole[]
  erasureRequests   ErasureRequest[]
  retentionPolicies RetentionPolicy[]

  // Phase 8: Internal Marketplace
  internalJobPostings  InternalJobPosting[]
  internalApplications InternalApplication[]
  careerProfiles       CareerProfile[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(VIEWER)
  employeeId   String?   @unique @map("employee_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employee  Employee?  @relation(fields: [employeeId], references: [id])
  auditLogs AuditLog[]

  // Sprint 2: Time & Attendance
  approvedOvertimes OvertimeRequest[] @relation("OTApprover")

  // Sprint 3: Payroll
  approvedPeriods     PayrollPeriod[]     @relation("PeriodApprover")
  approvedAdjustments PayrollAdjustment[] @relation("AdjustmentApprover")
  createdAdjustments  PayrollAdjustment[] @relation("AdjustmentCreator")
  processedPayments   BankPaymentBatch[]  @relation("PaymentProcessor")

  // Sprint 4: ESS + Workflow
  workflowInstances   WorkflowInstance[] @relation("WorkflowRequester")
  approvalSteps       ApprovalStep[]     @relation("ApprovalApprover")
  delegatedApprovals  ApprovalStep[]     @relation("ApprovalDelegator")
  delegationsGiven    Delegation[]       @relation("DelegatorUser")
  delegationsReceived Delegation[]       @relation("DelegateUser")
  notifications       Notification[]

  // Sprint 5: AI Copilot
  aiConversations AIConversation[]
  savedReports    SavedReport[]

  // Sprint 6: Integrations
  importJobs ImportJob[]

  // Sprint 7: Analytics
  dashboards       Dashboard[]
  analyticsReports AnalyticsReport[]

  // Sprint 8: Recruitment & Onboarding
  requisitionsRequested    JobRequisition[]      @relation("RequisitionRequestedBy")
  requisitionsApproved     JobRequisition[]      @relation("RequisitionApprovedBy")
  applicationsAssigned     Application[]         @relation("ApplicationAssignedTo")
  applicationsRejected     Application[]         @relation("ApplicationRejectedBy")
  applicationsHired        Application[]         @relation("ApplicationHiredBy")
  applicationActivities    ApplicationActivity[]
  candidateEvaluations     CandidateEvaluation[]
  offersSent               Offer[]               @relation("OfferSentBy")
  offersApproved           Offer[]               @relation("OfferApprovedBy")
  onboardingsHrContact     Onboarding[]
  onboardingTasksAssigned  OnboardingTask[]      @relation("OnboardingTaskAssignee")
  onboardingTasksCompleted OnboardingTask[]      @relation("OnboardingTaskCompletedBy")

  // Sprint 9: Performance Management
  goalsCreated                   Goal[]
  reviewCyclesCreated            ReviewCycle[]
  goalUpdates                    GoalUpdate[]
  keyResultUpdates               KeyResultUpdate[]
  feedbackRequestsSent           FeedbackRequest[]            @relation("FeedbackRequester")
  feedbackRequestsReceived       FeedbackRequest[]            @relation("FeedbackProvider")
  feedbacksGiven                 Feedback[]                   @relation("FeedbackGiver")
  calibrationSessionsFacilitated CalibrationSession[]
  calibrationDecisionsMade       CalibrationDecision[]
  pipsAsHrContact                PerformanceImprovementPlan[]
  pipCheckIns                    PIPCheckIn[]

  // Sprint 10: Learning & Development
  coursesCreated                  Course[]
  trainingSessionsCreated         TrainingSession[]
  enrollmentApprovals             Enrollment[]
  learningPathsCreated            LearningPath[]
  learningPathAssignments         LearningPathEnrollment[]
  trainingRequestsManagerApproved TrainingRequest[]        @relation("TrainingRequestManagerApproval")
  trainingRequestsHRApproved      TrainingRequest[]        @relation("TrainingRequestHRApproval")
  trainingRequestsRejected        TrainingRequest[]        @relation("TrainingRequestRejection")
  assessmentsCreated              Assessment[]
  questionResponsesGraded         QuestionResponse[]
  employeeSkillAssessments        EmployeeSkill[]
  certificationsVerified          EmployeeCertification[]

  // Sprint 11: Compensation & Benefits
  compensationReviewApprovals CompensationReview[]
  compensationChangeApprovals CompensationChange[] @relation("CompChangeApprover")

  // Phase 5.0: Advanced Analytics
  customReports          CustomReport[]
  reportExports          ReportExport[]
  analyticsAlertsCreated AnalyticsAlert[]
  alertsAcknowledged     AlertTriggerHistory[] @relation("AlertAcknowledgedBy")
  alertsResolved         AlertTriggerHistory[] @relation("AlertResolvedBy")

  // Phase 7: Custom Roles
  customRoles UserCustomRole[]

  @@unique([tenantId, email])
  @@map("users")
}

// ═══════════════════════════════════════════════════════════════
// ORGANIZATION STRUCTURE
// ═══════════════════════════════════════════════════════════════

model Department {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  name           String
  code           String
  description    String?
  parentId       String?  @map("parent_id")
  managerId      String?  @map("manager_id")
  costCenterCode String?  @map("cost_center_code")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  manager   Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  employees Employee[]

  // Sprint 2: Time & Attendance
  workSchedules WorkSchedule[]

  // Sprint 7: Analytics
  analyticsMetrics AnalyticsMetric[]

  // Sprint 8: Recruitment & Onboarding
  jobRequisitions     JobRequisition[]
  onboardingTemplates OnboardingTemplate[]
  offers              Offer[]

  // Sprint 9: Performance Management
  goals               Goal[]               @relation("GoalDepartment")
  calibrationSessions CalibrationSession[]

  // Sprint 10: Learning & Development
  trainingBudgets TrainingBudget[]

  // Sprint 11: Compensation & Benefits
  compensationBudgets CompensationBudget[] @relation("CompBudgetDept")
  payEquityAnalyses   PayEquityAnalysis[]  @relation("PayEquityDept")

  // Phase 5.0: Advanced Analytics
  analyticsAlerts AnalyticsAlert[]

  // Phase 8: Internal Marketplace
  internalJobPostings InternalJobPosting[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Position {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  level       Int      @default(1)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  // Phase 8: Internal Marketplace
  internalJobPostings InternalJobPosting[]

  @@unique([tenantId, code])
  @@map("positions")
}

model Branch {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  name           String
  code           String
  address        String?
  phone          String?
  email          String?
  isHeadquarters Boolean  @default(false) @map("is_headquarters")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, code])
  @@map("branches")
}

// ═══════════════════════════════════════════════════════════════
// EMPLOYEE
// ═══════════════════════════════════════════════════════════════

model Employee {
  id String @id @default(cuid())

  tenantId     String @map("tenant_id")
  employeeCode String @map("employee_code")

  // Personal Info
  fullName     String    @map("full_name")
  dateOfBirth  DateTime? @map("date_of_birth")
  gender       Gender?
  idNumber     String?   @map("id_number") // CCCD/CMND
  idIssueDate  DateTime? @map("id_issue_date")
  idIssuePlace String?   @map("id_issue_place")

  // Tax & Insurance
  taxCode               String?   @map("tax_code") // MST ca nhan
  socialInsuranceNumber String?   @map("social_insurance_number") // So so BHXH
  socialInsuranceDate   DateTime? @map("social_insurance_date") // Ngay tham gia BHXH

  // Contact
  phone         String?
  personalEmail String? @map("personal_email")
  workEmail     String? @map("work_email")

  // Address
  permanentAddress String? @map("permanent_address")
  currentAddress   String? @map("current_address")

  // Bank
  bankAccount String? @map("bank_account")
  bankName    String? @map("bank_name")
  bankBranch  String? @map("bank_branch")

  // Organization
  departmentId    String? @map("department_id")
  positionId      String? @map("position_id")
  branchId        String? @map("branch_id")
  directManagerId String? @map("direct_manager_id")

  // Employment
  hireDate          DateTime       @map("hire_date")
  probationEndDate  DateTime?      @map("probation_end_date")
  status            EmployeeStatus @default(ACTIVE)
  resignationDate   DateTime?      @map("resignation_date")
  resignationReason String?        @map("resignation_reason")

  // Metadata
  avatar    String?
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  // Relations
  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  department         Department?             @relation(fields: [departmentId], references: [id])
  position           Position?               @relation(fields: [positionId], references: [id])
  branch             Branch?                 @relation(fields: [branchId], references: [id])
  directManager      Employee?               @relation("EmployeeManager", fields: [directManagerId], references: [id])
  subordinates       Employee[]              @relation("EmployeeManager")
  user               User?
  contracts          Contract[]
  dependents         Dependent[]
  changeHistory      EmployeeChangeHistory[]
  managedDepartments Department[]            @relation("DepartmentManager")

  // Sprint 2: Time & Attendance
  shiftAssignments    ShiftAssignment[]
  attendances         Attendance[]
  overtimeRequests    OvertimeRequest[]
  attendanceSummaries AttendanceSummary[]
  attendanceAnomalies AttendanceAnomaly[]

  // Sprint 3: Payroll
  payrolls           Payroll[]
  payrollAdjustments PayrollAdjustment[]

  // Sprint 4: ESS + Workflow
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]
  profileUpdateRequests ProfileUpdateRequest[]

  // Sprint 7: Analytics
  turnoverPredictions TurnoverPrediction[]

  // Sprint 8: Recruitment & Onboarding
  requisitionsReportingTo JobRequisition[] @relation("RequisitionReportingTo")
  candidateReferrals      Candidate[]
  offersReportingTo       Offer[]
  onboardings             Onboarding[]
  onboardingBuddyFor      Onboarding[]     @relation("OnboardingBuddy")

  // Sprint 9: Performance Management
  goals                Goal[]
  performanceReviews   PerformanceReview[]
  managedReviews       PerformanceReview[]          @relation("ReviewManager")
  feedbackRequests     FeedbackRequest[]
  feedbacksReceived    Feedback[]                   @relation("FeedbackReceiver")
  checkIns             CheckIn[]
  checkInsAsManager    CheckIn[]                    @relation("CheckInManager")
  oneOnOnesAsEmployee  OneOnOne[]                   @relation("OneOnOneEmployee")
  oneOnOnesAsManager   OneOnOne[]                   @relation("OneOnOneManager")
  pips                 PerformanceImprovementPlan[]
  pipsAsManager        PerformanceImprovementPlan[] @relation("PIPManager")
  calibrationDecisions CalibrationDecision[]

  // Sprint 10: Learning & Development
  employeeSkills          EmployeeSkill[]
  enrollments             Enrollment[]
  sessionAttendances      SessionAttendance[]
  trainingRequests        TrainingRequest[]
  learningPathEnrollments LearningPathEnrollment[]
  employeeCertifications  EmployeeCertification[]
  assessmentAttempts      AssessmentAttempt[]

  // Sprint 11: Compensation & Benefits
  compensationReviews    CompensationReview[]
  compensationChanges    CompensationChange[]
  employeeCompensations  EmployeeCompensation[]
  benefitEnrollments     BenefitEnrollment[]
  employeeAllowances     EmployeeAllowance[]
  totalRewardsStatements TotalRewardsStatement[]
  compensationHistories  CompensationHistory[]

  // Phase 3.0: Compliance & Integration
  employeeInsurances         EmployeeInsurance[]
  taxSettlements             TaxSettlement[]
  rawPunchLogs               RawPunchLog[]
  paymentTransactions        PaymentTransaction[]
  employeeCertificatesPhase3 EmployeeCertificate[]
  documentSignatures         DocumentSignature[]

  // Phase 3.3: Employee Experience (Surveys, Recognition, Feed, Offboarding)
  surveyResponses          SurveyResponse[]
  recognitionsGiven        Recognition[]         @relation("RecognitionGiver")
  recognitionsReceived     Recognition[]         @relation("RecognitionReceiver")
  recognitionReactions     RecognitionReaction[]
  recognitionComments      RecognitionComment[]  @relation("RecognitionCommentAuthor")
  employeePoints           EmployeePoints?
  postsAuthored            CompanyPost[]         @relation("PostAuthor")
  postReactions            PostReaction[]
  postComments             PostComment[]         @relation("PostCommentAuthor")
  postsRead                PostRead[]
  eventsOrganized          CompanyEvent[]        @relation("EventOrganizer")
  eventAttendances         EventAttendee[]
  offboardingInstance      OffboardingInstance?
  offboardingTasksAssigned OffboardingTask[]     @relation("OffboardingTaskAssignee")

  // Phase 7: GDPR Erasure
  erasureRequests ErasureRequest[]

  // Phase 8: Internal Marketplace
  jobPostingsCreated         InternalJobPosting[]    @relation("PostingCreator")
  jobPostingsAsHiringManager InternalJobPosting[]    @relation("PostingHiringManager")
  internalApplications       InternalApplication[]
  careerProfile              CareerProfile?

  @@unique([tenantId, employeeCode])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, fullName])
  @@map("employees")
}

model Dependent {
  id                String           @id @default(cuid())
  employeeId        String           @map("employee_id")
  fullName          String           @map("full_name")
  relationship      RelationshipType
  dateOfBirth       DateTime?        @map("date_of_birth")
  idNumber          String?          @map("id_number")
  taxDeductionFrom  DateTime?        @map("tax_deduction_from")
  taxDeductionTo    DateTime?        @map("tax_deduction_to")
  deductionDocument String?          @map("deduction_document") // So giay to chung minh
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("dependents")
}

// ═══════════════════════════════════════════════════════════════
// CONTRACT
// ═══════════════════════════════════════════════════════════════

model Contract {
  id             String       @id @default(cuid())
  tenantId       String       @map("tenant_id")
  employeeId     String       @map("employee_id")
  contractNumber String       @map("contract_number")
  contractType   ContractType @map("contract_type")

  // Dates
  signedDate DateTime? @map("signed_date")
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")

  // Salary
  baseSalary      Decimal    @map("base_salary") @db.Decimal(15, 0)
  salaryType      SalaryType @default(GROSS) @map("salary_type")
  insuranceSalary Decimal?   @map("insurance_salary") @db.Decimal(15, 0) // Luong dong BHXH

  // Allowances & Benefits (JSONB for flexibility)
  allowances   Json?   @default("[]") // [{name, amount, taxable}]
  workSchedule String? @map("work_schedule") // e.g., "Mon-Fri 8:00-17:00"

  // Status
  status            ContractStatus @default(DRAFT)
  terminationDate   DateTime?      @map("termination_date")
  terminationReason String?        @map("termination_reason")

  // Attachment
  attachmentUrl String? @map("attachment_url")
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contractNumber])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("contracts")
}

// ═══════════════════════════════════════════════════════════════
// AUDIT & HISTORY
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  userId     String?     @map("user_id")
  userEmail  String?     @map("user_email")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  entityName String?     @map("entity_name")
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  changes    Json?
  metadata   Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, action])
  @@map("audit_logs")
}

model EmployeeChangeHistory {
  id            String    @id @default(cuid())
  employeeId    String    @map("employee_id")
  fieldName     String    @map("field_name")
  oldValue      String?   @map("old_value")
  newValue      String?   @map("new_value")
  changedBy     String    @map("changed_by") // User ID
  changedAt     DateTime  @default(now()) @map("changed_at")
  reason        String?
  effectiveDate DateTime? @map("effective_date")

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, changedAt])
  @@map("employee_change_history")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 2: TIME & ATTENDANCE ENUMS
// ═══════════════════════════════════════════════════════════════

enum ShiftType {
  STANDARD // Ca hanh chinh
  MORNING // Ca sang
  AFTERNOON // Ca chieu
  NIGHT // Ca dem
  FLEXIBLE // Ca linh hoat
  ROTATING // Ca xoay vong
}

enum DayType {
  NORMAL // Ngay thuong
  WEEKEND // Cuoi tuan
  HOLIDAY // Ngay le
  COMPENSATORY // Ngay bu
}

enum AttendanceStatus {
  PRESENT // Co mat
  ABSENT // Vang mat
  LATE // Di tre
  EARLY_LEAVE // Ve som
  LATE_AND_EARLY // Di tre va ve som
  ON_LEAVE // Nghi phep
  BUSINESS_TRIP // Cong tac
  WORK_FROM_HOME // Lam tai nha
  HOLIDAY // Nghi le
}

enum AttendanceSource {
  MANUAL // Nhap tay
  WEB_CLOCK // Cham cong web
  MOBILE_APP // Ung dung mobile
  FINGERPRINT // Van tay
  FACE_ID // Nhan dien khuon mat
  CARD // The tu
  IMPORT // Import tu file
}

enum OTStatus {
  PENDING // Cho duyet
  APPROVED // Da duyet
  REJECTED // Tu choi
  CANCELLED // Da huy
}

enum AnomalyType {
  MISSING_CHECKOUT // Thieu checkout
  MISSING_CHECKIN // Thieu checkin
  EARLY_CHECKIN // Check in qua som
  LATE_CHECKOUT // Check out qua muon
  LOCATION_MISMATCH // Vi tri khong khop
  DUPLICATE_RECORD // Ban ghi trung lap
  OVERTIME_NO_REQUEST // Tang ca khong co don
  MANUAL_ADJUSTMENT // Dieu chinh thu cong
}

enum AnomalySeverity {
  LOW // Thap
  MEDIUM // Trung binh
  HIGH // Cao
  CRITICAL // Nghiem trong
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 2: TIME & ATTENDANCE MODELS
// ═══════════════════════════════════════════════════════════════

model Shift {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  name      String // e.g., "Ca hành chính", "Ca sáng"
  code      String // e.g., "HC", "CS"
  shiftType ShiftType @default(STANDARD) @map("shift_type")

  // Time settings
  startTime      String  @map("start_time") // "08:00"
  endTime        String  @map("end_time") // "17:00"
  breakStartTime String? @map("break_start_time") // "12:00"
  breakEndTime   String? @map("break_end_time") // "13:00"
  breakMinutes   Int     @default(60) @map("break_minutes")

  // Work hours
  workHoursPerDay Decimal @default(8) @map("work_hours_per_day") @db.Decimal(4, 2)

  // Grace period (minutes)
  lateGrace  Int @default(15) @map("late_grace") // Cho phep di tre (phut)
  earlyGrace Int @default(15) @map("early_grace") // Cho phep ve som (phut)

  // Overtime settings
  otStartAfter    Int     @default(30) @map("ot_start_after") // Tinh OT sau X phut
  nightShiftStart String? @map("night_shift_start") // "22:00" - bat dau ca dem
  nightShiftEnd   String? @map("night_shift_end") // "06:00" - ket thuc ca dem

  // Cross midnight shift
  isOvernight Boolean @default(false) @map("is_overnight") // Ca qua dem

  // Colors for UI
  color String @default("#3B82F6") // Màu hiển thị

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  assignments ShiftAssignment[]
  attendances Attendance[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("shifts")
}

model ShiftAssignment {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  shiftId    String @map("shift_id")

  // Assignment period
  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date") // null = vo thoi han

  // Recurring pattern (for rotating shifts)
  isRecurring Boolean @default(false) @map("is_recurring")
  daysOfWeek  Int[]   @default([1, 2, 3, 4, 5]) @map("days_of_week") // 0=CN, 1=T2...6=T7

  isPrimary Boolean @default(true) @map("is_primary") // Ca chinh cua nhan vien
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, shiftId])
  @@index([startDate, endDate])
  @@map("shift_assignments")
}

model WorkSchedule {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  name        String // "Lịch làm việc chuẩn"
  description String?

  // Weekly schedule as JSON
  // { "monday": { "shiftId": "...", "isWorkDay": true }, ... }
  weeklySchedule Json @default("{}") @map("weekly_schedule")

  // Department/Branch assignment
  departmentId String? @map("department_id")
  branchId     String? @map("branch_id")

  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@index([tenantId, isActive])
  @@map("work_schedules")
}

model Holiday {
  id       String    @id @default(cuid())
  tenantId String    @map("tenant_id")
  name     String // "Tết Nguyên đán"
  date     DateTime // Ngay le
  endDate  DateTime? @map("end_date") // Ket thuc (neu nhieu ngay)

  dayType DayType @default(HOLIDAY) @map("day_type")

  // Compensatory day info
  compensatoryDate DateTime? @map("compensatory_date") // Ngày làm bù

  isRecurring Boolean @default(false) @map("is_recurring") // Lap lai hang nam
  isNational  Boolean @default(true) @map("is_national") // Le quoc gia
  year        Int // Nam ap dung

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, year])
  @@index([tenantId, date])
  @@map("holidays")
}

model Attendance {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  employeeId String  @map("employee_id")
  shiftId    String? @map("shift_id")

  // Date
  date    DateTime // Ngay cham cong
  dayType DayType  @default(NORMAL) @map("day_type")

  // Check in/out times
  checkIn  DateTime? @map("check_in")
  checkOut DateTime? @map("check_out")

  // Source info
  checkInSource  AttendanceSource? @map("check_in_source")
  checkOutSource AttendanceSource? @map("check_out_source")

  // Location (GPS)
  checkInLat      Decimal? @map("check_in_lat") @db.Decimal(10, 7)
  checkInLng      Decimal? @map("check_in_lng") @db.Decimal(10, 7)
  checkOutLat     Decimal? @map("check_out_lat") @db.Decimal(10, 7)
  checkOutLng     Decimal? @map("check_out_lng") @db.Decimal(10, 7)
  checkInAddress  String?  @map("check_in_address")
  checkOutAddress String?  @map("check_out_address")

  // Status
  status AttendanceStatus @default(PRESENT)

  // Calculated hours
  workHours  Decimal? @map("work_hours") @db.Decimal(5, 2) // Gio lam viec
  otHours    Decimal? @map("ot_hours") @db.Decimal(5, 2) // Gio tang ca
  nightHours Decimal? @map("night_hours") @db.Decimal(5, 2) // Gio lam dem

  // Late/Early minutes
  lateMinutes  Int? @map("late_minutes") // Phut di tre
  earlyMinutes Int? @map("early_minutes") // Phut ve som

  // Manual adjustments
  isManualEntry  Boolean @default(false) @map("is_manual_entry")
  adjustedBy     String? @map("adjusted_by") // User ID nguoi dieu chinh
  adjustmentNote String? @map("adjustment_note")

  // Leave reference (if on leave)
  leaveRequestId String? @map("leave_request_id") // Sprint 3

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  employee  Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift     Shift?              @relation(fields: [shiftId], references: [id])
  anomalies AttendanceAnomaly[]

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
  @@index([tenantId, employeeId, date])
  @@index([tenantId, status])
  @@map("attendances")
}

model OvertimeRequest {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  // OT period
  date      DateTime // Ngay tang ca
  startTime DateTime @map("start_time") // Gio bat dau
  endTime   DateTime @map("end_time") // Gio ket thuc

  // Calculated
  plannedHours Decimal  @map("planned_hours") @db.Decimal(5, 2) // So gio du kien
  actualHours  Decimal? @map("actual_hours") @db.Decimal(5, 2) // So gio thuc te

  // Type
  dayType      DayType @default(NORMAL) @map("day_type")
  isNightShift Boolean @default(false) @map("is_night_shift")

  // Multiplier (calculated based on dayType + nightShift)
  multiplier Decimal @default(1.5) @db.Decimal(3, 2) // He so luong

  // Reason & status
  reason String // Ly do tang ca
  status OTStatus @default(PENDING)

  // Approval
  approvedBy      String?   @map("approved_by") // User ID nguoi duyet
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")

  // Attachment
  attachmentUrl String? @map("attachment_url")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver User?    @relation("OTApprover", fields: [approvedBy], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("overtime_requests")
}

model AttendanceSummary {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  // Period
  year  Int
  month Int

  // Working days
  workingDays    Int     @map("working_days") // Tong ngay cong chuan
  actualWorkDays Decimal @map("actual_work_days") @db.Decimal(5, 2) // Ngay cong thuc te
  presentDays    Int     @map("present_days") // So ngay di lam
  absentDays     Int     @map("absent_days") // So ngay vang

  // Leave days (Sprint 3 integration)
  paidLeaveDays   Decimal @default(0) @map("paid_leave_days") @db.Decimal(5, 2)
  unpaidLeaveDays Decimal @default(0) @map("unpaid_leave_days") @db.Decimal(5, 2)
  sickLeaveDays   Decimal @default(0) @map("sick_leave_days") @db.Decimal(5, 2)

  // Hours
  totalWorkHours Decimal @map("total_work_hours") @db.Decimal(7, 2)
  standardHours  Decimal @map("standard_hours") @db.Decimal(7, 2) // Gio cong chuan

  // Overtime breakdown
  otWeekdayHours Decimal @default(0) @map("ot_weekday_hours") @db.Decimal(7, 2) // OT ngay thuong
  otWeekendHours Decimal @default(0) @map("ot_weekend_hours") @db.Decimal(7, 2) // OT cuoi tuan
  otHolidayHours Decimal @default(0) @map("ot_holiday_hours") @db.Decimal(7, 2) // OT ngay le
  otNightHours   Decimal @default(0) @map("ot_night_hours") @db.Decimal(7, 2) // OT dem
  totalOtHours   Decimal @default(0) @map("total_ot_hours") @db.Decimal(7, 2)

  // Late/Early
  lateTimes         Int @default(0) @map("late_times") // So lan di tre
  earlyLeaveTimes   Int @default(0) @map("early_leave_times") // So lan ve som
  totalLateMinutes  Int @default(0) @map("total_late_minutes")
  totalEarlyMinutes Int @default(0) @map("total_early_minutes")

  // Anomalies
  anomalyCount        Int @default(0) @map("anomaly_count")
  unresolvedAnomalies Int @default(0) @map("unresolved_anomalies")

  // Status
  isLocked Boolean   @default(false) @map("is_locked") // Khoa ky cong
  lockedAt DateTime? @map("locked_at")
  lockedBy String?   @map("locked_by")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, year, month])
  @@index([tenantId, year, month])
  @@map("attendance_summaries")
}

model AttendanceAnomaly {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  attendanceId String @map("attendance_id")
  employeeId   String @map("employee_id")

  // Anomaly info
  type        AnomalyType
  severity    AnomalySeverity @default(MEDIUM)
  description String // Mo ta chi tiet

  // Detection
  detectedAt DateTime @default(now()) @map("detected_at")
  detectedBy String?  @map("detected_by") // "SYSTEM" or User ID

  // Resolution
  isResolved Boolean   @default(false) @map("is_resolved")
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by")
  resolution String? // Cach xu ly

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, isResolved])
  @@index([tenantId, employeeId])
  @@index([attendanceId])
  @@map("attendance_anomalies")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 3: PAYROLL VN ENGINE - ENUMS
// ═══════════════════════════════════════════════════════════════

enum PayrollStatus {
  DRAFT // Nháp
  CALCULATING // Đang tính
  SIMULATED // Đã mô phỏng
  PENDING_APPROVAL // Chờ duyệt
  APPROVED // Đã duyệt
  PAID // Đã thanh toán
  CANCELLED // Đã hủy
}

enum PayrollItemType {
  EARNING // Khoản thu nhập
  DEDUCTION // Khoản khấu trừ
  EMPLOYER_COST // Chi phí công ty
}

enum PayrollComponentCategory {
  BASE_SALARY // Lương cơ bản
  ALLOWANCE_TAXABLE // Phụ cấp chịu thuế
  ALLOWANCE_NON_TAXABLE // Phụ cấp không chịu thuế
  OVERTIME // Tăng ca
  BONUS // Thưởng
  COMMISSION // Hoa hồng
  INSURANCE_EMPLOYEE // BHXH/BHYT/BHTN (NLĐ)
  INSURANCE_EMPLOYER // BHXH/BHYT/BHTN (Công ty)
  PIT // Thuế TNCN
  ADVANCE // Tạm ứng
  LOAN // Khoản vay
  OTHER_DEDUCTION // Khấu trừ khác
  OTHER_EARNING // Thu nhập khác
}

enum BankCode {
  VCB // Vietcombank
  TCB // Techcombank
  ACB // ACB
  BIDV // BIDV
  VTB // Vietinbank
  MB // MB Bank
  VPB // VPBank
  TPB // TPBank
  STB // Sacombank
  SHB // SHB
  MSB // MSB
  OCB // OCB
  OTHER // Ngân hàng khác
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 3: PAYROLL VN ENGINE - MODELS
// ═══════════════════════════════════════════════════════════════

// Cấu hình bảng lương - Tham số tính lương VN
model PayrollConfig {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  // Effective period
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  // ═══════ BHXH/BHYT/BHTN Rates ═══════
  bhxhEmployeeRate Decimal @default(0.08) @map("bhxh_employee_rate") @db.Decimal(5, 4) // 8%
  bhxhEmployerRate Decimal @default(0.175) @map("bhxh_employer_rate") @db.Decimal(5, 4) // 17.5%
  bhytEmployeeRate Decimal @default(0.015) @map("bhyt_employee_rate") @db.Decimal(5, 4) // 1.5%
  bhytEmployerRate Decimal @default(0.03) @map("bhyt_employer_rate") @db.Decimal(5, 4) // 3%
  bhtnEmployeeRate Decimal @default(0.01) @map("bhtn_employee_rate") @db.Decimal(5, 4) // 1%
  bhtnEmployerRate Decimal @default(0.01) @map("bhtn_employer_rate") @db.Decimal(5, 4) // 1%

  // Insurance salary cap
  insuranceSalaryCap Decimal @default(46800000) @map("insurance_salary_cap") @db.Decimal(15, 0) // 20 x lương cơ sở

  // ═══════ PIT Deductions ═══════
  personalDeduction  Decimal @default(11000000) @map("personal_deduction") @db.Decimal(15, 0) // 11tr/tháng
  dependentDeduction Decimal @default(4400000) @map("dependent_deduction") @db.Decimal(15, 0) // 4.4tr/người/tháng

  // ═══════ PIT Brackets (stored as JSON for flexibility) ═══════
  // Format: [{ "from": 0, "to": 5000000, "rate": 0.05 }, ...]
  pitBrackets Json @default("[]") @map("pit_brackets")

  // ═══════ OT Rates ═══════
  otWeekdayRate Decimal @default(1.5) @map("ot_weekday_rate") @db.Decimal(3, 2) // 150%
  otWeekendRate Decimal @default(2.0) @map("ot_weekend_rate") @db.Decimal(3, 2) // 200%
  otHolidayRate Decimal @default(3.0) @map("ot_holiday_rate") @db.Decimal(3, 2) // 300%
  otNightBonus  Decimal @default(0.3) @map("ot_night_bonus") @db.Decimal(3, 2) // +30%

  // ═══════ Work Settings ═══════
  standardWorkDays  Int     @default(22) @map("standard_work_days") // Ngày công chuẩn/tháng
  standardWorkHours Decimal @default(8) @map("standard_work_hours") @db.Decimal(4, 2) // Giờ công/ngày

  isActive  Boolean  @default(true) @map("is_active")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, effectiveFrom])
  @@index([tenantId, isActive])
  @@map("payroll_configs")
}

// Thành phần lương - Các khoản cấu thành lương
model SalaryComponent {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name     String // "Lương cơ bản", "Phụ cấp ăn trưa"
  code     String // "BASE", "LUNCH_ALLOWANCE"
  category PayrollComponentCategory
  itemType PayrollItemType          @map("item_type") // Earning/Deduction

  // Calculation
  defaultAmount  Decimal? @map("default_amount") @db.Decimal(15, 0)
  isPercentage   Boolean  @default(false) @map("is_percentage") // Tính theo %
  percentageBase String?  @map("percentage_base") // Field cơ sở tính % (e.g., "baseSalary")

  // Tax settings
  isTaxable       Boolean @default(true) @map("is_taxable") // Chịu thuế TNCN
  isInsuranceable Boolean @default(false) @map("is_insuranceable") // Đóng BHXH

  // UI
  sortOrder Int     @default(0) @map("sort_order")
  isSystem  Boolean @default(false) @map("is_system") // Không được xóa
  isActive  Boolean @default(true) @map("is_active")

  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  payrollItems PayrollItem[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, category])
  @@map("salary_components")
}

// Kỳ lương - Quản lý kỳ tính lương
model PayrollPeriod {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  // Period info
  name        String // "Tháng 01/2025"
  year        Int
  month       Int
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  // Status workflow: DRAFT → CALCULATING → SIMULATED → PENDING_APPROVAL → APPROVED → PAID
  status PayrollStatus @default(DRAFT)

  // Processing info
  calculatedAt DateTime? @map("calculated_at")
  approvedAt   DateTime? @map("approved_at")
  approvedBy   String?   @map("approved_by")
  paidAt       DateTime? @map("paid_at")

  // Totals (calculated)
  totalEmployees    Int     @default(0) @map("total_employees")
  totalGross        Decimal @default(0) @map("total_gross") @db.Decimal(18, 0)
  totalDeductions   Decimal @default(0) @map("total_deductions") @db.Decimal(18, 0)
  totalNet          Decimal @default(0) @map("total_net") @db.Decimal(18, 0)
  totalEmployerCost Decimal @default(0) @map("total_employer_cost") @db.Decimal(18, 0)

  // Lock
  isLocked Boolean   @default(false) @map("is_locked")
  lockedAt DateTime? @map("locked_at")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  approver       User?              @relation("PeriodApprover", fields: [approvedBy], references: [id])
  payrolls       Payroll[]
  bankPayments   BankPaymentBatch[]
  paymentBatches PaymentBatch[] // Phase 3.0

  @@unique([tenantId, year, month])
  @@index([tenantId, status])
  @@index([tenantId, year, month])
  @@map("payroll_periods")
}

// Bảng lương nhân viên - Chi tiết lương từng người
model Payroll {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  periodId   String @map("period_id")
  employeeId String @map("employee_id")

  // Snapshot employee info at calculation time
  employeeCode   String  @map("employee_code")
  employeeName   String  @map("employee_name")
  departmentName String? @map("department_name")
  positionName   String? @map("position_name")

  // Contract info snapshot
  baseSalary      Decimal @map("base_salary") @db.Decimal(15, 0)
  insuranceSalary Decimal @map("insurance_salary") @db.Decimal(15, 0) // Lương đóng BHXH

  // Attendance data from Sprint 2
  workDays       Decimal @map("work_days") @db.Decimal(5, 2) // Ngày công thực tế
  standardDays   Int     @map("standard_days") // Ngày công chuẩn
  otHoursWeekday Decimal @default(0) @map("ot_hours_weekday") @db.Decimal(7, 2)
  otHoursWeekend Decimal @default(0) @map("ot_hours_weekend") @db.Decimal(7, 2)
  otHoursHoliday Decimal @default(0) @map("ot_hours_holiday") @db.Decimal(7, 2)
  otHoursNight   Decimal @default(0) @map("ot_hours_night") @db.Decimal(7, 2)

  // ═══════ Calculated amounts ═══════
  // Gross
  grossSalary Decimal @map("gross_salary") @db.Decimal(15, 0) // Tổng thu nhập

  // Insurance (employee portion)
  bhxhEmployee           Decimal @default(0) @map("bhxh_employee") @db.Decimal(15, 0)
  bhytEmployee           Decimal @default(0) @map("bhyt_employee") @db.Decimal(15, 0)
  bhtnEmployee           Decimal @default(0) @map("bhtn_employee") @db.Decimal(15, 0)
  totalInsuranceEmployee Decimal @default(0) @map("total_insurance_employee") @db.Decimal(15, 0)

  // PIT
  taxableIncome      Decimal @default(0) @map("taxable_income") @db.Decimal(15, 0) // Thu nhập chịu thuế
  personalDeduction  Decimal @default(0) @map("personal_deduction") @db.Decimal(15, 0)
  dependentDeduction Decimal @default(0) @map("dependent_deduction") @db.Decimal(15, 0)
  dependentCount     Int     @default(0) @map("dependent_count") // Số người phụ thuộc
  assessableIncome   Decimal @default(0) @map("assessable_income") @db.Decimal(15, 0) // Thu nhập tính thuế
  pit                Decimal @default(0) @db.Decimal(15, 0) // Thuế TNCN

  // Other deductions
  otherDeductions Decimal @default(0) @map("other_deductions") @db.Decimal(15, 0)

  // Net
  totalDeductions Decimal @map("total_deductions") @db.Decimal(15, 0) // Tổng khấu trừ
  netSalary       Decimal @map("net_salary") @db.Decimal(15, 0) // Thực lãnh

  // Employer cost (for reporting)
  bhxhEmployer      Decimal @default(0) @map("bhxh_employer") @db.Decimal(15, 0)
  bhytEmployer      Decimal @default(0) @map("bhyt_employer") @db.Decimal(15, 0)
  bhtnEmployer      Decimal @default(0) @map("bhtn_employer") @db.Decimal(15, 0)
  totalEmployerCost Decimal @default(0) @map("total_employer_cost") @db.Decimal(15, 0)

  // Bank info snapshot
  bankAccount String?   @map("bank_account")
  bankName    String?   @map("bank_name")
  bankCode    BankCode? @map("bank_code")

  // Status
  status PayrollStatus @default(DRAFT)
  isPaid Boolean       @default(false) @map("is_paid")
  paidAt DateTime?     @map("paid_at")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  period   PayrollPeriod @relation(fields: [periodId], references: [id])
  employee Employee      @relation(fields: [employeeId], references: [id])
  items    PayrollItem[]

  @@unique([periodId, employeeId])
  @@index([tenantId, periodId])
  @@index([tenantId, employeeId])
  @@index([periodId, status])
  @@map("payrolls")
}

// Chi tiết khoản lương - Từng dòng trong bảng lương
model PayrollItem {
  id          String  @id @default(cuid())
  payrollId   String  @map("payroll_id")
  componentId String? @map("component_id")

  // Item info
  name     String // "Lương cơ bản", "BHXH"
  code     String // "BASE", "BHXH_EE"
  category PayrollComponentCategory
  itemType PayrollItemType          @map("item_type")

  // Amount
  amount     Decimal  @db.Decimal(15, 0) // Số tiền
  quantity   Decimal? @db.Decimal(10, 2) // Số lượng (giờ OT, ngày công)
  rate       Decimal? @db.Decimal(15, 0) // Đơn giá
  multiplier Decimal? @db.Decimal(3, 2) // Hệ số (OT 150%, 200%...)

  // Flags
  isTaxable       Boolean @default(true) @map("is_taxable")
  isInsuranceable Boolean @default(false) @map("is_insuranceable")

  // For manual adjustments
  isManual     Boolean @default(false) @map("is_manual")
  adjustmentId String? @map("adjustment_id")

  sortOrder Int      @default(0) @map("sort_order")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  payroll   Payroll          @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  component SalaryComponent? @relation(fields: [componentId], references: [id])

  @@index([payrollId])
  @@index([payrollId, itemType])
  @@map("payroll_items")
}

// Điều chỉnh lương - Các khoản điều chỉnh thủ công
model PayrollAdjustment {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  // Period
  year  Int
  month Int

  // Adjustment details
  name     String // "Thưởng KPI", "Khấu trừ tạm ứng"
  category PayrollComponentCategory
  itemType PayrollItemType          @map("item_type")
  amount   Decimal                  @db.Decimal(15, 0)

  // Tax settings
  isTaxable Boolean @default(true) @map("is_taxable")

  // Approval
  status          PayrollStatus @default(PENDING_APPROVAL)
  createdBy       String        @map("created_by")
  approvedBy      String?       @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  rejectionReason String?       @map("rejection_reason")

  reason        String // Lý do điều chỉnh
  attachmentUrl String?  @map("attachment_url")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  creator  User     @relation("AdjustmentCreator", fields: [createdBy], references: [id])
  approver User?    @relation("AdjustmentApprover", fields: [approvedBy], references: [id])

  @@index([tenantId, year, month])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("payroll_adjustments")
}

// Đợt thanh toán ngân hàng - Xuất file chuyển khoản
model BankPaymentBatch {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  periodId String @map("period_id")

  // Batch info
  batchNumber String   @map("batch_number") // "PAY-2025-01-001"
  bankCode    BankCode @map("bank_code")
  bankName    String   @map("bank_name")

  // Totals
  totalRecords Int     @map("total_records")
  totalAmount  Decimal @map("total_amount") @db.Decimal(18, 0)

  // File info
  fileName   String? @map("file_name")
  fileUrl    String? @map("file_url")
  fileFormat String? @map("file_format") // "VCB_CSV", "TCB_TXT", "GENERIC"

  // Processing
  status      PayrollStatus @default(DRAFT)
  generatedAt DateTime?     @map("generated_at")
  processedAt DateTime?     @map("processed_at")
  processedBy String?       @map("processed_by")

  // Bank response
  bankReference    String? @map("bank_reference")
  successCount     Int?    @map("success_count")
  failedCount      Int?    @map("failed_count")
  bankResponseFile String? @map("bank_response_file")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  period    PayrollPeriod @relation(fields: [periodId], references: [id])
  processor User?         @relation("PaymentProcessor", fields: [processedBy], references: [id])

  @@unique([tenantId, batchNumber])
  @@index([tenantId, periodId])
  @@index([tenantId, status])
  @@map("bank_payment_batches")
}

