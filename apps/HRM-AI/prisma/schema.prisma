  @@index([expiryDate])
  @@map("employee_certifications")
}

// ═══════════════════════════════════════════════════════════════
// ASSESSMENTS
// ═══════════════════════════════════════════════════════════════

model Assessment {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  courseId String? @map("course_id")

  title        String
  description  String?
  instructions String? @db.Text

  assessmentType AssessmentType @map("assessment_type")

  timeLimitMinutes Int? @map("time_limit_minutes")

  passingScore Decimal @map("passing_score") @db.Decimal(5, 2)
  totalPoints  Decimal @map("total_points") @db.Decimal(8, 2)

  maxAttempts Int @default(1) @map("max_attempts")

  availableFrom  DateTime? @map("available_from")
  availableUntil DateTime? @map("available_until")

  isActive           Boolean @default(true) @map("is_active")
  shuffleQuestions   Boolean @default(false) @map("shuffle_questions")
  showCorrectAnswers Boolean @default(true) @map("show_correct_answers")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  course    Course? @relation(fields: [courseId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]

  @@index([tenantId, courseId])
  @@map("assessments")
}

model AssessmentQuestion {
  id           String @id @default(cuid())
  assessmentId String @map("assessment_id")

  questionText String       @map("question_text") @db.Text
  questionType QuestionType @map("question_type")

  options Json?

  correctAnswer String? @map("correct_answer") @db.Text

  points Decimal @db.Decimal(6, 2)

  explanation String? @db.Text

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  responses  QuestionResponse[]

  @@index([assessmentId])
  @@map("assessment_questions")
}

model AssessmentAttempt {
  id           String  @id @default(cuid())
  tenantId     String  @map("tenant_id")
  assessmentId String  @map("assessment_id")
  employeeId   String  @map("employee_id")
  enrollmentId String? @map("enrollment_id")

  attemptNumber Int @map("attempt_number")

  startedAt   DateTime  @map("started_at")
  submittedAt DateTime? @map("submitted_at")

  score           Decimal? @db.Decimal(8, 2)
  percentageScore Decimal? @map("percentage_score") @db.Decimal(5, 2)
  passed          Boolean?

  timeSpentMinutes Int? @map("time_spent_minutes")

  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  assessment Assessment  @relation(fields: [assessmentId], references: [id])
  employee   Employee    @relation(fields: [employeeId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  responses QuestionResponse[]

  @@index([assessmentId, employeeId])
  @@map("assessment_attempts")
}

model QuestionResponse {
  id         String @id @default(cuid())
  attemptId  String @map("attempt_id")
  questionId String @map("question_id")

  response        String? @db.Text
  selectedOptions Json?   @map("selected_options")

  isCorrect    Boolean? @map("is_correct")
  pointsEarned Decimal? @map("points_earned") @db.Decimal(6, 2)

  gradedById     String?   @map("graded_by_id")
  gradedAt       DateTime? @map("graded_at")
  graderComments String?   @map("grader_comments")

  createdAt DateTime @default(now()) @map("created_at")

  attempt  AssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question AssessmentQuestion @relation(fields: [questionId], references: [id])
  gradedBy User?              @relation(fields: [gradedById], references: [id])

  @@unique([attemptId, questionId])
  @@map("question_responses")
}

