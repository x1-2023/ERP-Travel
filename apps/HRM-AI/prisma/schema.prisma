  BEREAVEMENT // Nghỉ tang
  UNPAID // Không lương
  COMPENSATORY // Nghỉ bù
  OTHER // Khác
}

enum RequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum WorkflowType {
  LEAVE_REQUEST
  OT_REQUEST
  PROFILE_UPDATE
  RESIGNATION
  CUSTOM
}

enum ApproverType {
