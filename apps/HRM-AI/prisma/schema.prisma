// ═══════════════════════════════════════════════════════════════
// PHASE 3.0: COMPLIANCE - INSURANCE (BHXH/BHYT/BHTN)
// ═══════════════════════════════════════════════════════════════

model EmployeeInsurance {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  // Insurance Numbers
  socialInsuranceNumber String  @map("social_insurance_number")
  healthInsuranceNumber String? @map("health_insurance_number")
  unemploymentNumber    String? @map("unemployment_number")

  // Registration
  registrationDate DateTime  @map("registration_date")
  terminationDate  DateTime? @map("termination_date")

  // Salary Base
  insuranceSalaryBase Decimal   @map("insurance_salary_base") @db.Decimal(18, 2)
  effectiveFrom       DateTime  @map("effective_from")
  effectiveTo         DateTime? @map("effective_to")

  // Contribution Rates (stored for history)
  employeeRate Decimal @map("employee_rate") @db.Decimal(5, 2) // 10.5%
  employerRate Decimal @map("employer_rate") @db.Decimal(5, 2) // 21.5%

  // Hospital
  registeredHospital String? @map("registered_hospital")
  hospitalCode       String? @map("hospital_code")

  // Status
  isActive Boolean @default(true) @map("is_active")
  notes    String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  employee      Employee                @relation(fields: [employeeId], references: [id])
  reportDetails InsuranceReportDetail[]

  @@unique([tenantId, employeeId])
  @@index([tenantId, socialInsuranceNumber])
  @@map("employee_insurances")
}

model InsuranceReport {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  reportType  InsuranceReportType @map("report_type")
  reportCode  String              @map("report_code") // Auto-generated
  reportMonth Int                 @map("report_month")
  reportYear  Int                 @map("report_year")

  // Totals
  totalEmployees       Int     @default(0) @map("total_employees")
  totalInsuranceSalary Decimal @default(0) @map("total_insurance_salary") @db.Decimal(18, 2)
  totalEmployeeAmount  Decimal @default(0) @map("total_employee_amount") @db.Decimal(18, 2)
  totalEmployerAmount  Decimal @default(0) @map("total_employer_amount") @db.Decimal(18, 2)
  totalAmount          Decimal @default(0) @map("total_amount") @db.Decimal(18, 2)

  // Status
  status          InsuranceReportStatus @default(DRAFT)
  submittedAt     DateTime?             @map("submitted_at")
  submittedBy     String?               @map("submitted_by")
  approvedAt      DateTime?             @map("approved_at")
  approvedBy      String?               @map("approved_by")
  rejectionReason String?               @map("rejection_reason")

  // XML/File export
  exportedFile String?   @map("exported_file")
  exportedAt   DateTime? @map("exported_at")

  notes    String?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant                  @relation(fields: [tenantId], references: [id])
  details InsuranceReportDetail[]

  @@unique([tenantId, reportType, reportMonth, reportYear])
  @@index([tenantId, reportMonth, reportYear])
  @@map("insurance_reports")
}

model InsuranceReportDetail {
  id                  String @id @default(cuid())
  reportId            String @map("report_id")
  employeeInsuranceId String @map("employee_insurance_id")

  // Employee info snapshot
  employeeCode String   @map("employee_code")
  employeeName String   @map("employee_name")
  dateOfBirth  DateTime @map("date_of_birth")
  gender       Gender
  idNumber     String   @map("id_number")

  // Insurance details
  insuranceSalary Decimal @map("insurance_salary") @db.Decimal(18, 2)
  employeeAmount  Decimal @map("employee_amount") @db.Decimal(18, 2)
  employerAmount  Decimal @map("employer_amount") @db.Decimal(18, 2)
  totalAmount     Decimal @map("total_amount") @db.Decimal(18, 2)

  // For D02/D03 reports
  changeType    String?   @map("change_type") // INCREASE, DECREASE, ADJUST
  effectiveDate DateTime? @map("effective_date")
  reason        String?

  createdAt DateTime @default(now()) @map("created_at")

  report            InsuranceReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  employeeInsurance EmployeeInsurance @relation(fields: [employeeInsuranceId], references: [id])

  @@index([reportId])
  @@map("insurance_report_details")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.0: COMPLIANCE - TAX (TNCN)
// ═══════════════════════════════════════════════════════════════

model TaxSettlement {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  settlementYear Int @map("settlement_year")

  // Income summary
  totalGrossIncome        Decimal @map("total_gross_income") @db.Decimal(18, 2)
  totalInsuranceDeduction Decimal @map("total_insurance_deduction") @db.Decimal(18, 2)
  personalDeduction       Decimal @map("personal_deduction") @db.Decimal(18, 2) // 11M/month
  dependentDeduction      Decimal @map("dependent_deduction") @db.Decimal(18, 2) // 4.4M/dependent/month
  otherDeductions         Decimal @default(0) @map("other_deductions") @db.Decimal(18, 2)

  // Tax calculation
  taxableIncome Decimal @map("taxable_income") @db.Decimal(18, 2)
  taxAmount     Decimal @map("tax_amount") @db.Decimal(18, 2)
  taxPaid       Decimal @map("tax_paid") @db.Decimal(18, 2)
  taxRefund     Decimal @default(0) @map("tax_refund") @db.Decimal(18, 2)
  taxOwed       Decimal @default(0) @map("tax_owed") @db.Decimal(18, 2)

  // Dependents
  dependentCount Int   @default(0) @map("dependent_count")
  dependentsData Json? @map("dependents_data") // Snapshot of dependents

  // Status
  status      String    @default("DRAFT") // DRAFT, FINALIZED, SUBMITTED
  finalizedAt DateTime? @map("finalized_at")
  submittedAt DateTime? @map("submitted_at")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, settlementYear])
  @@index([tenantId, settlementYear])
  @@map("tax_settlements")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.0: ATTENDANCE DEVICE INTEGRATION
// ═══════════════════════════════════════════════════════════════

model AttendanceDevice {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  deviceCode   String     @map("device_code")
  deviceName   String     @map("device_name")
  deviceType   DeviceType @map("device_type")
  manufacturer String? // ZKTeco, HikVision, Suprema, etc.
  model        String?
  serialNumber String?    @map("serial_number")

  // Connection
  ipAddress      String? @map("ip_address")
  port           Int?
  connectionType String? @map("connection_type") // TCP, HTTP, SDK

  // Location
  officeLocationId     String? @map("office_location_id")
  installationLocation String? @map("installation_location")

  // SDK Configuration
  sdkConfig Json? @map("sdk_config")

  // Status
  status        DeviceStatus @default(OFFLINE)
  lastSyncAt    DateTime?    @map("last_sync_at")
  lastHeartbeat DateTime?    @map("last_heartbeat")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  officeLocation OfficeLocation? @relation(fields: [officeLocationId], references: [id])
  syncLogs       DeviceSyncLog[]
  punchLogs      RawPunchLog[]

  @@unique([tenantId, deviceCode])
  @@index([tenantId, status])
  @@map("attendance_devices")
}

model OfficeLocation {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  locationCode String  @map("location_code")
  locationName String  @map("location_name")
  address      String?

  // GPS Coordinates
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  radiusMeters Int      @default(100) @map("radius_meters") // Allowed check-in radius

  // WiFi based location
  allowedWifiSSIDs String[] @map("allowed_wifi_ssids")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant             @relation(fields: [tenantId], references: [id])
  devices AttendanceDevice[]

  @@unique([tenantId, locationCode])
  @@map("office_locations")
}

model DeviceSyncLog {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  deviceId String @map("device_id")

  syncType    String    @map("sync_type") // MANUAL, SCHEDULED, REALTIME
  syncStartAt DateTime  @map("sync_start_at")
  syncEndAt   DateTime? @map("sync_end_at")

  recordsFetched   Int @default(0) @map("records_fetched")
  recordsProcessed Int @default(0) @map("records_processed")
  recordsFailed    Int @default(0) @map("records_failed")

  status       String  @default("IN_PROGRESS") // IN_PROGRESS, SUCCESS, FAILED
  errorMessage String? @map("error_message")
  errorDetails Json?   @map("error_details")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  device AttendanceDevice @relation(fields: [deviceId], references: [id])

  @@index([tenantId, deviceId])
  @@index([deviceId, createdAt])
  @@map("device_sync_logs")
}

model RawPunchLog {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  deviceId String @map("device_id")

  // Raw data from device
  deviceUserId String   @map("device_user_id") // User ID on device
  punchTime    DateTime @map("punch_time")
  punchType    Int      @map("punch_type") // 0: Check-in, 1: Check-out, etc.
  verifyType   Int?     @map("verify_type") // 0: Password, 1: Fingerprint, 2: Card, 3: Face

  // Matched employee
  employeeId String? @map("employee_id")

  // GPS data (for mobile check-in)
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  accuracy  Decimal? @db.Decimal(10, 2) // in meters

  // Processing
  isProcessed  Boolean   @default(false) @map("is_processed")
  processedAt  DateTime? @map("processed_at")
  attendanceId String?   @map("attendance_id") // Link to Attendance record

  // Raw data backup
  rawData Json? @map("raw_data")

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  device   AttendanceDevice @relation(fields: [deviceId], references: [id])
  employee Employee?        @relation(fields: [employeeId], references: [id])

  @@index([tenantId, punchTime])
  @@index([deviceId, punchTime])
  @@index([employeeId, punchTime])
  @@index([isProcessed])
  @@map("raw_punch_logs")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.0: BANKING PAYMENT INTEGRATION
// ═══════════════════════════════════════════════════════════════

model BankConfiguration {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  bankCode String @map("bank_code") // VCB, TCB, MB, etc.
  bankName String @map("bank_name")

  // Company Account
  accountNumber String  @map("account_number")
  accountName   String  @map("account_name")
  branchCode    String? @map("branch_code")
  branchName    String? @map("branch_name")

  // API Configuration
  apiEndpoint     String? @map("api_endpoint")
  apiVersion      String? @map("api_version")
  clientId        String? @map("client_id")
  encryptedSecret String? @map("encrypted_secret") // Encrypted API secret
  certificatePath String? @map("certificate_path")

  // Settings
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  paymentBatches PaymentBatch[]

  @@unique([tenantId, bankCode, accountNumber])
  @@map("bank_configurations")
}

model PaymentBatch {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  bankConfigId String @map("bank_config_id")

  batchCode String @map("batch_code")
  batchName String @map("batch_name")
  batchType String @map("batch_type") // SALARY, BONUS, REIMBURSEMENT

  // Period reference
  payrollPeriodId String? @map("payroll_period_id")

  // Totals
  totalTransactions Int     @default(0) @map("total_transactions")
  totalAmount       Decimal @default(0) @map("total_amount") @db.Decimal(18, 2)
  successCount      Int     @default(0) @map("success_count")
  failedCount       Int     @default(0) @map("failed_count")

  // Status
  status      PaymentBatchStatus @default(DRAFT)
  submittedAt DateTime?          @map("submitted_at")
  submittedBy String?            @map("submitted_by")
  approvedAt  DateTime?          @map("approved_at")
  approvedBy  String?            @map("approved_by")
  processedAt DateTime?          @map("processed_at")
  completedAt DateTime?          @map("completed_at")

  // Bank response
  bankReferenceId  String? @map("bank_reference_id")
  bankResponseData Json?   @map("bank_response_data")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  bankConfig    BankConfiguration    @relation(fields: [bankConfigId], references: [id])
  payrollPeriod PayrollPeriod?       @relation(fields: [payrollPeriodId], references: [id])
  transactions  PaymentTransaction[]

  @@unique([tenantId, batchCode])
  @@index([tenantId, status])
  @@map("payment_batches")
}

model PaymentTransaction {
  id         String @id @default(cuid())
  batchId    String @map("batch_id")
  employeeId String @map("employee_id")

  // Recipient details
  recipientName    String  @map("recipient_name")
  recipientBank    String  @map("recipient_bank")
  recipientAccount String  @map("recipient_account")
  recipientBranch  String? @map("recipient_branch")

  // Payment details
  amount      Decimal @map("amount") @db.Decimal(18, 2)
  currency    String  @default("VND")
  description String?

  // Status
  status      PaymentTransactionStatus @default(PENDING)
  processedAt DateTime?                @map("processed_at")

  // Bank response
  bankTransactionId   String? @map("bank_transaction_id")
  bankResponseCode    String? @map("bank_response_code")
  bankResponseMessage String? @map("bank_response_message")

  // Retry info
  retryCount Int     @default(0) @map("retry_count")
  lastError  String? @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  batch    PaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id])

  @@index([batchId])
  @@index([employeeId])
  @@map("payment_transactions")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.0: E-SIGNATURE INTEGRATION
// ═══════════════════════════════════════════════════════════════

model SignatureProvider {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  providerCode String @map("provider_code") // VNPT_CA, VIETTEL_CA, FPT_CA
  providerName String @map("provider_name")

  // API Configuration
  apiEndpoint     String  @map("api_endpoint")
  apiVersion      String? @map("api_version")
  clientId        String? @map("client_id")
  encryptedSecret String? @map("encrypted_secret")

  // Settings
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  certificates EmployeeCertificate[]

  @@unique([tenantId, providerCode])
  @@map("signature_providers")
}

model EmployeeCertificate {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  providerId String @map("provider_id")

  certificateSerial  String  @map("certificate_serial")
  certificateSubject String? @map("certificate_subject")

  issuedAt  DateTime @map("issued_at")
  expiresAt DateTime @map("expires_at")

  status        CertificateStatus @default(ACTIVE)
  revokedAt     DateTime?         @map("revoked_at")
  revokedReason String?           @map("revoked_reason")

  // USB Token info (if applicable)
  tokenSerial String? @map("token_serial")
  tokenType   String? @map("token_type")

  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  employee   Employee            @relation(fields: [employeeId], references: [id])
  provider   SignatureProvider   @relation(fields: [providerId], references: [id])
  signatures DocumentSignature[]

  @@index([tenantId, employeeId])
  @@index([employeeId, status])
  @@map("employee_certificates")
}

model SignableDocument {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  documentType String @map("document_type") // CONTRACT, DECISION, REPORT, etc.
  documentCode String @map("document_code")
  documentName String @map("document_name")

  // Source reference
  sourceType String? @map("source_type") // CONTRACT, PAYROLL, etc.
  sourceId   String? @map("source_id")

  // File
  originalFile String  @map("original_file")
  signedFile   String? @map("signed_file")

  // Required signers
  requiredSigners Json @map("required_signers") // Array of {employeeId, order, role}

  // Status
  status      String    @default("PENDING") // PENDING, PARTIAL, COMPLETED, CANCELLED
  completedAt DateTime? @map("completed_at")

  // Expiry
  expiresAt DateTime? @map("expires_at")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  signatures DocumentSignature[]

  @@unique([tenantId, documentCode])
  @@index([tenantId, status])
  @@map("signable_documents")
}

model DocumentSignature {
  id            String @id @default(cuid())
  documentId    String @map("document_id")
  certificateId String @map("certificate_id")
  signerId      String @map("signer_id")

  signatureOrder Int     @map("signature_order")
  signerRole     String? @map("signer_role") // CREATOR, APPROVER, WITNESS

  // Signature data
  signedAt      DateTime? @map("signed_at")
  signatureData String?   @map("signature_data") // Base64 signature
  signatureHash String?   @map("signature_hash")

  // Location (if visible)
  signatureX    Decimal? @map("signature_x") @db.Decimal(10, 2)
  signatureY    Decimal? @map("signature_y") @db.Decimal(10, 2)
  signaturePage Int?     @map("signature_page")

  // Status
  status         SignatureStatus @default(PENDING)
  rejectedAt     DateTime?       @map("rejected_at")
  rejectedReason String?         @map("rejected_reason")

  // Provider response
  providerTransactionId String? @map("provider_transaction_id")
  providerResponse      Json?   @map("provider_response")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  document    SignableDocument    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  certificate EmployeeCertificate @relation(fields: [certificateId], references: [id])
  signer      Employee            @relation(fields: [signerId], references: [id])

  @@index([documentId])
  @@index([signerId])
  @@map("document_signatures")
}

