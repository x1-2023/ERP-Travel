  department Department?       @relation("CompBudgetDept", fields: [departmentId], references: [id])

  @@unique([cycleId, departmentId])
  @@index([tenantId, cycleId])
  @@map("compensation_budgets")
}

model EmployeeCompensation {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  baseSalary    Decimal    @map("base_salary") @db.Decimal(18, 2)
  currency      String     @default("VND")
  gradeId       String?    @map("grade_id")
  effectiveDate DateTime   @map("effective_date")
  salaryType    SalaryType @default(GROSS) @map("salary_type")
  payFrequency  String     @default("MONTHLY") @map("pay_frequency")
