// ═══════════════════════════════════════════════════════════════
// SKILL MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model SkillCategory {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  parentId String? @map("parent_id")

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  parent   SkillCategory?  @relation("SkillCategoryHierarchy", fields: [parentId], references: [id])
  children SkillCategory[] @relation("SkillCategoryHierarchy")
  skills   Skill[]

  @@index([tenantId])
  @@map("skill_categories")
}

model Skill {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  categoryId String? @map("category_id")

  name        String
  description String? @db.Text

  levels Json

  isActive Boolean @default(true) @map("is_active")
  order    Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  category SkillCategory? @relation(fields: [categoryId], references: [id])

  employeeSkills EmployeeSkill[]
  positionSkills PositionSkill[]
  courseSkills   CourseSkill[]

  @@unique([tenantId, name])
  @@index([tenantId, categoryId])
  @@map("skills")
}

model EmployeeSkill {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  skillId    String @map("skill_id")

  currentLevel Int  @map("current_level")
  targetLevel  Int? @map("target_level")

  selfAssessment    Int? @map("self_assessment")
  managerAssessment Int? @map("manager_assessment")

  assessedAt   DateTime? @map("assessed_at")
  assessedById String?   @map("assessed_by_id")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
  skill      Skill    @relation(fields: [skillId], references: [id])
  assessedBy User?    @relation(fields: [assessedById], references: [id])

  @@unique([employeeId, skillId])
  @@index([tenantId, employeeId])
  @@map("employee_skills")
}

model PositionSkill {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  skillId  String @map("skill_id")

  position      String
  requiredLevel Int     @map("required_level")
  isRequired    Boolean @default(true) @map("is_required")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  skill  Skill  @relation(fields: [skillId], references: [id])

  @@unique([tenantId, skillId, position])
  @@map("position_skills")
}

// ═══════════════════════════════════════════════════════════════
// COURSE MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model CourseCategory {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?
  code        String?

  parentId String? @map("parent_id")

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  parent   CourseCategory?  @relation("CourseCategoryHierarchy", fields: [parentId], references: [id])
  children CourseCategory[] @relation("CourseCategoryHierarchy")
  courses  Course[]

  @@index([tenantId])
  @@map("course_categories")
}

model Course {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  categoryId String? @map("category_id")

  code        String
  title       String
  description String? @db.Text
  objectives  String? @db.Text

  courseType CourseType  @map("course_type")
  level      CourseLevel @default(BEGINNER)

  durationHours Decimal @map("duration_hours") @db.Decimal(6, 2)

  contentUrl  String? @map("content_url")
  contentType String? @map("content_type")

  maxParticipants Int? @map("max_participants")
  minParticipants Int? @map("min_participants")

  providerId     String? @map("provider_id")
  instructorName String? @map("instructor_name")

  costPerPerson Decimal? @map("cost_per_person") @db.Decimal(18, 2)
  currency      String   @default("VND")

  prerequisites  String? @db.Text
  targetAudience String? @map("target_audience") @db.Text

  isMandatory           Boolean @default(false) @map("is_mandatory")
  mandatoryForPositions Json?   @map("mandatory_for_positions")
  recertificationMonths Int?    @map("recertification_months")

  thumbnailUrl String? @map("thumbnail_url")

  status CourseStatus @default(DRAFT)

  publishedAt DateTime? @map("published_at")
  archivedAt  DateTime? @map("archived_at")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  category  CourseCategory?   @relation(fields: [categoryId], references: [id])
  provider  TrainingProvider? @relation(fields: [providerId], references: [id])
  createdBy User              @relation(fields: [createdById], references: [id])

  modules             CourseModule[]
  skills              CourseSkill[]
  sessions            TrainingSession[]
  enrollments         Enrollment[]
  learningPathCourses LearningPathCourse[]
  assessments         Assessment[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@map("courses")
}

model CourseModule {
  id       String @id @default(cuid())
  courseId String @map("course_id")

  title       String
  description String?

  contentUrl  String? @map("content_url")
  contentType String? @map("content_type")

  durationMinutes Int @map("duration_minutes")

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions ModuleCompletion[]

  @@index([courseId])
  @@map("course_modules")
}

model CourseSkill {
  id       String @id @default(cuid())
  courseId String @map("course_id")
  skillId  String @map("skill_id")

  skillLevelGained Int @map("skill_level_gained")

  createdAt DateTime @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id])

  @@unique([courseId, skillId])
  @@map("course_skills")
}

model TrainingProvider {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name String
  code String?

  type String

  contactName  String? @map("contact_name")
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")

  website String?
  address String?

  notes String? @db.Text

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  courses  Course[]
  sessions TrainingSession[]

  @@index([tenantId])
  @@map("training_providers")
}

// ═══════════════════════════════════════════════════════════════
// TRAINING SESSIONS & ENROLLMENT
// ═══════════════════════════════════════════════════════════════

model TrainingSession {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  courseId String @map("course_id")

  sessionCode String  @map("session_code")
  title       String?

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  location    String?
  room        String?
  isVirtual   Boolean @default(false) @map("is_virtual")
  virtualLink String? @map("virtual_link")

  providerId      String? @map("provider_id")
  instructorName  String? @map("instructor_name")
  instructorEmail String? @map("instructor_email")

  maxParticipants Int  @map("max_participants")
  minParticipants Int? @map("min_participants")

  totalCost     Decimal? @map("total_cost") @db.Decimal(18, 2)
  costPerPerson Decimal? @map("cost_per_person") @db.Decimal(18, 2)

  enrollmentDeadline DateTime? @map("enrollment_deadline")
  autoConfirm        Boolean   @default(false) @map("auto_confirm")

  status SessionStatus @default(SCHEDULED)

  cancellationReason String? @map("cancellation_reason")

  notes String? @db.Text

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  course    Course            @relation(fields: [courseId], references: [id])
  provider  TrainingProvider? @relation(fields: [providerId], references: [id])
  createdBy User              @relation(fields: [createdById], references: [id])

  enrollments Enrollment[]
  attendance  SessionAttendance[]

  @@unique([tenantId, sessionCode])
  @@index([tenantId, startDate])
  @@index([tenantId, status])
  @@map("training_sessions")
}

model Enrollment {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  employeeId String  @map("employee_id")
  courseId   String  @map("course_id")
  sessionId  String? @map("session_id")

  status EnrollmentStatus @default(PENDING)

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  progress    Int       @default(0)

  score  Decimal? @db.Decimal(5, 2)
  passed Boolean?

  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")

  actualCost Decimal? @map("actual_cost") @db.Decimal(18, 2)

  rating   Int?
  feedback String? @db.Text

  certificateIssued Boolean @default(false) @map("certificate_issued")
  certificateUrl    String? @map("certificate_url")

  requestId String? @map("request_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  employee   Employee         @relation(fields: [employeeId], references: [id])
  course     Course           @relation(fields: [courseId], references: [id])
  session    TrainingSession? @relation(fields: [sessionId], references: [id])
  approvedBy User?            @relation(fields: [approvedById], references: [id])
  request    TrainingRequest? @relation(fields: [requestId], references: [id])

  moduleCompletions  ModuleCompletion[]
  assessmentAttempts AssessmentAttempt[]

  @@unique([employeeId, courseId, sessionId])
  @@index([tenantId, employeeId])
  @@index([tenantId, courseId])
  @@index([tenantId, status])
  @@map("enrollments")
}

model ModuleCompletion {
  id           String @id @default(cuid())
  enrollmentId String @map("enrollment_id")
  moduleId     String @map("module_id")

  completedAt      DateTime @default(now()) @map("completed_at")
  timeSpentMinutes Int?     @map("time_spent_minutes")

  createdAt DateTime @default(now()) @map("created_at")

  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module     CourseModule @relation(fields: [moduleId], references: [id])

  @@unique([enrollmentId, moduleId])
  @@map("module_completions")
}

model SessionAttendance {
  id         String @id @default(cuid())
  sessionId  String @map("session_id")
  employeeId String @map("employee_id")

  date DateTime

  attended     Boolean   @default(false)
  checkInTime  DateTime? @map("check_in_time")
  checkOutTime DateTime? @map("check_out_time")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")

  session  TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id])

  @@unique([sessionId, employeeId, date])
  @@map("session_attendance")
}

// ═══════════════════════════════════════════════════════════════
// TRAINING REQUESTS
// ═══════════════════════════════════════════════════════════════

model TrainingRequest {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  requestCode String @map("request_code")

  courseId           String? @map("course_id")
  externalCourseName String? @map("external_course_name")
  externalProvider   String? @map("external_provider")
  externalUrl        String? @map("external_url")

  reason          String  @db.Text
  expectedOutcome String? @map("expected_outcome") @db.Text

  preferredStartDate DateTime? @map("preferred_start_date")
  preferredEndDate   DateTime? @map("preferred_end_date")

  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(18, 2)

  status TrainingRequestStatus @default(DRAFT)

  managerApprovedById String?   @map("manager_approved_by_id")
  managerApprovedAt   DateTime? @map("manager_approved_at")
  managerComments     String?   @map("manager_comments")

  hrApprovedById String?   @map("hr_approved_by_id")
  hrApprovedAt   DateTime? @map("hr_approved_at")
  hrComments     String?   @map("hr_comments")

  rejectedById    String?   @map("rejected_by_id")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  employee          Employee @relation(fields: [employeeId], references: [id])
  managerApprovedBy User?    @relation("TrainingRequestManagerApproval", fields: [managerApprovedById], references: [id])
  hrApprovedBy      User?    @relation("TrainingRequestHRApproval", fields: [hrApprovedById], references: [id])
  rejectedBy        User?    @relation("TrainingRequestRejection", fields: [rejectedById], references: [id])

  enrollments Enrollment[]

  @@unique([tenantId, requestCode])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("training_requests")
}

// ═══════════════════════════════════════════════════════════════
// LEARNING PATHS
// ═══════════════════════════════════════════════════════════════

model LearningPath {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String? @db.Text

  targetPosition String? @map("target_position")
  targetLevel    String? @map("target_level")

  estimatedMonths Int?     @map("estimated_months")
  totalHours      Decimal? @map("total_hours") @db.Decimal(8, 2)

  thumbnailUrl String? @map("thumbnail_url")

  isActive Boolean @default(true) @map("is_active")
  isPublic Boolean @default(true) @map("is_public")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation(fields: [createdById], references: [id])

  stages      LearningPathStage[]
  enrollments LearningPathEnrollment[]

  @@index([tenantId])
  @@map("learning_paths")
}

model LearningPathStage {
  id     String @id @default(cuid())
  pathId String @map("path_id")

  name        String
  description String?

  order Int @default(0)

  targetMonths Int? @map("target_months")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  path    LearningPath         @relation(fields: [pathId], references: [id], onDelete: Cascade)
  courses LearningPathCourse[]

  @@index([pathId])
  @@map("learning_path_stages")
}

model LearningPathCourse {
  id       String @id @default(cuid())
  stageId  String @map("stage_id")
  courseId String @map("course_id")

  isRequired Boolean @default(true) @map("is_required")
  order      Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  stage  LearningPathStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  course Course            @relation(fields: [courseId], references: [id])

  @@unique([stageId, courseId])
  @@map("learning_path_courses")
}

model LearningPathEnrollment {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  pathId     String @map("path_id")

  status LearningPathStatus @default(NOT_STARTED)

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  currentStageId String? @map("current_stage_id")
  progress       Int     @default(0)

  targetCompletionDate DateTime? @map("target_completion_date")

  assignedById String? @map("assigned_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  employee   Employee     @relation(fields: [employeeId], references: [id])
  path       LearningPath @relation(fields: [pathId], references: [id])
  assignedBy User?        @relation(fields: [assignedById], references: [id])

  @@unique([employeeId, pathId])
  @@index([tenantId, employeeId])
  @@map("learning_path_enrollments")
}

// ═══════════════════════════════════════════════════════════════
// CERTIFICATIONS
// ═══════════════════════════════════════════════════════════════

model CertificationType {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  provider String?

  validityMonths Int? @map("validity_months")

  isExternal Boolean @default(true) @map("is_external")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  certifications EmployeeCertification[]

  @@index([tenantId])
  @@map("certification_types")
}

model EmployeeCertification {
  id                  String @id @default(cuid())
  tenantId            String @map("tenant_id")
  employeeId          String @map("employee_id")
  certificationTypeId String @map("certification_type_id")

  certificateNumber String?   @map("certificate_number")
  issuedDate        DateTime  @map("issued_date")
  expiryDate        DateTime? @map("expiry_date")

  status CertificationStatus @default(ACTIVE)

  documentUrl String? @map("document_url")

  cost          Decimal? @db.Decimal(18, 2)
  paidByCompany Boolean  @default(true) @map("paid_by_company")

  renewalReminderSent Boolean   @default(false) @map("renewal_reminder_sent")
  renewalRequestedAt  DateTime? @map("renewal_requested_at")

  notes String?

  verifiedById String?   @map("verified_by_id")
  verifiedAt   DateTime? @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  employee          Employee          @relation(fields: [employeeId], references: [id])
  certificationType CertificationType @relation(fields: [certificationTypeId], references: [id])
  verifiedBy        User?             @relation(fields: [verifiedById], references: [id])

  @@index([tenantId, employeeId])
