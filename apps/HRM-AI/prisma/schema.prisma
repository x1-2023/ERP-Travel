// ═══════════════════════════════════════════════════════════════
// SPRINT 11: COMPENSATION & BENEFITS
// ═══════════════════════════════════════════════════════════════

model SalaryGrade {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  code        String // G1, G2, etc.
  name        String // Entry Level, Junior, etc.
  level       Int // 1-8
  minSalary   Decimal @map("min_salary") @db.Decimal(18, 2)
  midSalary   Decimal @map("mid_salary") @db.Decimal(18, 2)
  maxSalary   Decimal @map("max_salary") @db.Decimal(18, 2)
  currency    String  @default("VND")
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  employeeCompensations EmployeeCompensation[]
  previousGradeChanges  CompensationChange[]   @relation("PreviousGrade")
  newGradeChanges       CompensationChange[]   @relation("NewGrade")

  @@unique([tenantId, code])
  @@index([tenantId, level])
  @@map("salary_grades")
}

model MeritMatrix {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  performanceRating    Int     @map("performance_rating") // 1-5
  compaRatioMin        Decimal @map("compa_ratio_min") @db.Decimal(5, 2)
  compaRatioMax        Decimal @map("compa_ratio_max") @db.Decimal(5, 2)
  meritIncreasePercent Decimal @map("merit_increase_percent") @db.Decimal(5, 2)
  compaRatioLabel      String? @map("compa_ratio_label")

  effectiveYear Int     @map("effective_year")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, effectiveYear, performanceRating, compaRatioMin])
  @@index([tenantId, effectiveYear])
  @@map("merit_matrices")
}

model CompensationCycle {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name          String
  year          Int
  status        CompensationCycleStatus @default(PLANNING)
  startDate     DateTime                @map("start_date")
  endDate       DateTime                @map("end_date")
  budgetPercent Decimal?                @map("budget_percent") @db.Decimal(5, 2)
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant               @relation(fields: [tenantId], references: [id])
  reviews CompensationReview[]
  budgets CompensationBudget[]

  @@unique([tenantId, year, name])
  @@index([tenantId, year])
  @@map("compensation_cycles")
}

model CompensationReview {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  cycleId    String @map("cycle_id")
  employeeId String @map("employee_id")

  status            CompensationReviewStatus @default(DRAFT)
  currentSalary     Decimal                  @map("current_salary") @db.Decimal(18, 2)
  proposedSalary    Decimal?                 @map("proposed_salary") @db.Decimal(18, 2)
  approvedSalary    Decimal?                 @map("approved_salary") @db.Decimal(18, 2)
  changeType        CompensationChangeType?  @map("change_type")
  changePercent     Decimal?                 @map("change_percent") @db.Decimal(5, 2)
  performanceRating Int?                     @map("performance_rating")
  compaRatio        Decimal?                 @map("compa_ratio") @db.Decimal(5, 2)
  justification     String?
  managerComments   String?                  @map("manager_comments")
  hrComments        String?                  @map("hr_comments")
  effectiveDate     DateTime?                @map("effective_date")

  submittedAt  DateTime? @map("submitted_at")
  approvedAt   DateTime? @map("approved_at")
  approvedById String?   @map("approved_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  cycle      CompensationCycle @relation(fields: [cycleId], references: [id])
  employee   Employee          @relation(fields: [employeeId], references: [id])
  approvedBy User?             @relation(fields: [approvedById], references: [id])

  @@unique([cycleId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, cycleId])
  @@map("compensation_reviews")
}

model CompensationChange {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  changeType      CompensationChangeType @map("change_type")
  effectiveDate   DateTime               @map("effective_date")
  previousSalary  Decimal                @map("previous_salary") @db.Decimal(18, 2)
  newSalary       Decimal                @map("new_salary") @db.Decimal(18, 2)
  changePercent   Decimal                @map("change_percent") @db.Decimal(5, 2)
  previousGradeId String?                @map("previous_grade_id")
  newGradeId      String?                @map("new_grade_id")
  reason          String?
  approvedById    String?                @map("approved_by_id")

  createdAt DateTime @default(now()) @map("created_at")

  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  employee      Employee     @relation(fields: [employeeId], references: [id])
  previousGrade SalaryGrade? @relation("PreviousGrade", fields: [previousGradeId], references: [id])
  newGrade      SalaryGrade? @relation("NewGrade", fields: [newGradeId], references: [id])
  approvedBy    User?        @relation("CompChangeApprover", fields: [approvedById], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, effectiveDate])
  @@map("compensation_changes")
}

model CompensationBudget {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  cycleId  String @map("cycle_id")

  departmentId    String? @map("department_id")
  totalBudget     Decimal @map("total_budget") @db.Decimal(18, 2)
