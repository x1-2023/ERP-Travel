// ═══════════════════════════════════════════════════════════════
// SPRINT 4: LEAVE MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model LeavePolicy {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name      String
  code      String
  leaveType LeaveType @map("leave_type")

  daysPerYear           Decimal @map("days_per_year") @db.Decimal(5, 2)
  maxCarryOver          Decimal @default(0) @map("max_carry_over") @db.Decimal(5, 2)
  carryOverExpireMonths Int     @default(3) @map("carry_over_expire_months")

  minDaysPerRequest    Decimal  @default(0.5) @map("min_days_per_request") @db.Decimal(3, 2)
  maxDaysPerRequest    Decimal? @map("max_days_per_request") @db.Decimal(5, 2)
  advanceNoticeDays    Int      @default(0) @map("advance_notice_days")
  allowHalfDay         Boolean  @default(true) @map("allow_half_day")
  allowNegativeBalance Boolean  @default(false) @map("allow_negative_balance")

  probationEligible Boolean @default(false) @map("probation_eligible")
  minTenureMonths   Int     @default(0) @map("min_tenure_months")

  isPaid      Boolean @default(true) @map("is_paid")
  isActive    Boolean @default(true) @map("is_active")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  balances LeaveBalance[]
  requests LeaveRequest[]

  @@unique([tenantId, code])
  @@map("leave_policies")
}

model LeaveBalance {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  policyId   String @map("policy_id")
  year       Int

  entitlement Decimal @db.Decimal(5, 2)
  carryOver   Decimal @default(0) @db.Decimal(5, 2)
  adjustment  Decimal @default(0) @db.Decimal(5, 2)
  used        Decimal @default(0) @db.Decimal(5, 2)
  pending     Decimal @default(0) @db.Decimal(5, 2)
  available   Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  employee Employee    @relation(fields: [employeeId], references: [id])
  policy   LeavePolicy @relation(fields: [policyId], references: [id])

  @@unique([tenantId, employeeId, policyId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  policyId   String @map("policy_id")

  requestCode String   @unique @map("request_code")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  totalDays   Decimal  @map("total_days") @db.Decimal(5, 2)

  startHalf String? @map("start_half")
  endHalf   String? @map("end_half")

  reason        String
  handoverTo    String? @map("handover_to")
  handoverNotes String? @map("handover_notes")
  attachments   Json?

  status             RequestStatus @default(DRAFT)
  workflowInstanceId String?       @map("workflow_instance_id")

  cancelledAt  DateTime? @map("cancelled_at")
  cancelledBy  String?   @map("cancelled_by")
  cancelReason String?   @map("cancel_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  employee         Employee          @relation(fields: [employeeId], references: [id])
  policy           LeavePolicy       @relation(fields: [policyId], references: [id])
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("leave_requests")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 4: WORKFLOW ENGINE
// ═══════════════════════════════════════════════════════════════

model WorkflowDefinition {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name         String
  code         String
  workflowType WorkflowType @map("workflow_type")
  description  String?

  isActive Boolean @default(true) @map("is_active")
  version  Int     @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  steps     WorkflowStep[]
  instances WorkflowInstance[]

  @@unique([tenantId, code])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id           String @id @default(cuid())
  definitionId String @map("definition_id")

  stepOrder Int    @map("step_order")
  name      String

  approverType   ApproverType @map("approver_type")
  specificUserId String?      @map("specific_user_id")
  specificRole   String?      @map("specific_role")

  conditions Json?
  slaHours   Int?    @map("sla_hours")
  canSkip    Boolean @default(false) @map("can_skip")

  // P2-19: Parallel approval support
  approvalMode      ApprovalMode @default(SEQUENTIAL) @map("approval_mode")
  requiredApprovals Int          @default(1) @map("required_approvals") // For QUORUM mode: how many must approve
  approverUserIds   String[]     @default([]) @map("approver_user_ids") // For PARALLEL/QUORUM: multiple approvers

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  approvals  ApprovalStep[]

  @@map("workflow_steps")
}

model WorkflowInstance {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  definitionId String @map("definition_id")

  referenceType String @map("reference_type")
  referenceId   String @map("reference_id")
  requesterId   String @map("requester_id")

  status           RequestStatus @default(PENDING)
  currentStepOrder Int           @default(1) @map("current_step_order")
  context          Json?         @default("{}") // Workflow context for condition evaluation

  startedAt   DateTime        @default(now()) @map("started_at")
  completedAt DateTime?       @map("completed_at")
  finalStatus ApprovalStatus? @map("final_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  definition    WorkflowDefinition @relation(fields: [definitionId], references: [id])
  requester     User               @relation("WorkflowRequester", fields: [requesterId], references: [id])
  approvalSteps ApprovalStep[]
  leaveRequests LeaveRequest[]

  @@index([tenantId, status])
  @@index([referenceType, referenceId])
  @@map("workflow_instances")
}

model ApprovalStep {
  id         String @id @default(cuid())
  instanceId String @map("instance_id")
  stepId     String @map("step_id")

  approverId      String  @map("approver_id")
  delegatedFromId String? @map("delegated_from_id")

  status      ApprovalStatus @default(PENDING)
  respondedAt DateTime?      @map("responded_at")
  comments    String?

  dueAt     DateTime? @map("due_at")
  isOverdue Boolean   @default(false) @map("is_overdue")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  instance      WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step          WorkflowStep     @relation(fields: [stepId], references: [id])
  approver      User             @relation("ApprovalApprover", fields: [approverId], references: [id])
  delegatedFrom User?            @relation("ApprovalDelegator", fields: [delegatedFromId], references: [id])

  @@index([instanceId, status])
  @@index([approverId, status])
  @@map("approval_steps")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 4: DELEGATION
// ═══════════════════════════════════════════════════════════════

model Delegation {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  delegatorId String @map("delegator_id")
  delegateId  String @map("delegate_id")

  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date

  workflowTypes Json?   @map("workflow_types")
  reason        String?
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  delegator User   @relation("DelegatorUser", fields: [delegatorId], references: [id])
  delegate  User   @relation("DelegateUser", fields: [delegateId], references: [id])

  @@index([tenantId, delegatorId])
  @@map("delegations")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 4: NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════

model Notification {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  type    NotificationType
  title   String
  message String

  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")
  actionUrl     String? @map("action_url")

  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 4: PROFILE UPDATE REQUEST
// ═══════════════════════════════════════════════════════════════

model ProfileUpdateRequest {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  requestCode String  @unique @map("request_code")
  changes     Json
  reason      String?

  status             RequestStatus @default(PENDING)
  workflowInstanceId String?       @map("workflow_instance_id")

  appliedAt DateTime? @map("applied_at")
  appliedBy String?   @map("applied_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
