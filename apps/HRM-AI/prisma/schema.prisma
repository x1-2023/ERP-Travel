// ═══════════════════════════════════════════════════════════════
// PHASE 3.3: SURVEY & FEEDBACK MODELS
// ═══════════════════════════════════════════════════════════════

model Survey {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  title       String  @db.VarChar(200)
  description String? @db.Text

  type SurveyType

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  isRecurring    Boolean @default(false) @map("is_recurring")
  recurrenceRule String? @map("recurrence_rule")

  targetType        SurveyTargetType @default(ALL) @map("target_type")
  targetDepartments String[]         @map("target_departments")
  targetPositions   String[]         @map("target_positions")

  isAnonymous         Boolean @default(true) @map("is_anonymous")
  allowComments       Boolean @default(true) @map("allow_comments")
  requireAllQuestions Boolean @default(false) @map("require_all_questions")

  status SurveyStatus @default(DRAFT)

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("surveys")
}

model SurveyQuestion {
  id       String @id @default(cuid())
  surveyId String @map("survey_id")

  questionText String             @map("question_text") @db.Text
  questionType SurveyQuestionType @map("question_type")

  scaleMin      Int?    @default(1) @map("scale_min")
  scaleMax      Int?    @default(5) @map("scale_max")
  scaleMinLabel String? @map("scale_min_label")
  scaleMaxLabel String? @map("scale_max_label")

  options       String[]
  allowMultiple Boolean  @default(false) @map("allow_multiple")

  isENPS Boolean @default(false) @map("is_enps")

  isRequired Boolean @default(true) @map("is_required")
  sortOrder  Int     @default(0) @map("sort_order")

  category String? @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at")

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@index([surveyId])
  @@map("survey_questions")
}

model SurveyResponse {
  id       String @id @default(cuid())
  surveyId String @map("survey_id")

  respondentId   String? @map("respondent_id")
  anonymousToken String? @map("anonymous_token")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  deviceType String? @map("device_type")

  survey     Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  respondent Employee?      @relation(fields: [respondentId], references: [id])
  answers    SurveyAnswer[]

  @@unique([surveyId, respondentId])
  @@index([surveyId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id         String @id @default(cuid())
  responseId String @map("response_id")
  questionId String @map("question_id")

  scaleValue      Int?
  selectedOptions String[] @map("selected_options")
  textValue       String?  @map("text_value") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@map("survey_answers")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.3: RECOGNITION & KUDOS MODELS
// ═══════════════════════════════════════════════════════════════

model RecognitionCategory {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String  @db.VarChar(50)
  nameVi      String  @map("name_vi") @db.VarChar(50)
  description String? @db.VarChar(200)

  icon  String? @db.VarChar(50)
  color String? @db.VarChar(20)

  pointsValue Int @default(10) @map("points_value")

  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  recognitions Recognition[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("recognition_categories")
}

model Recognition {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  giverId    String @map("giver_id")
  receiverId String @map("receiver_id")
  categoryId String @map("category_id")

  message String @db.Text

  isPublic      Boolean @default(true) @map("is_public")
  pointsAwarded Int     @default(0) @map("points_awarded")

  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant                @relation(fields: [tenantId], references: [id])
  giver     Employee              @relation("RecognitionGiver", fields: [giverId], references: [id])
  receiver  Employee              @relation("RecognitionReceiver", fields: [receiverId], references: [id])
  category  RecognitionCategory   @relation(fields: [categoryId], references: [id])
  reactions RecognitionReaction[]
  comments  RecognitionComment[]

  @@index([tenantId, createdAt])
  @@index([receiverId])
  @@index([giverId])
  @@map("recognitions")
}

model RecognitionReaction {
  id            String @id @default(cuid())
  recognitionId String @map("recognition_id")
  employeeId    String @map("employee_id")

  emoji String @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at")

  recognition Recognition @relation(fields: [recognitionId], references: [id], onDelete: Cascade)
  employee    Employee    @relation(fields: [employeeId], references: [id])

  @@unique([recognitionId, employeeId])
  @@map("recognition_reactions")
}

model RecognitionComment {
  id            String @id @default(cuid())
  recognitionId String @map("recognition_id")
  authorId      String @map("author_id")

  content String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  recognition Recognition @relation(fields: [recognitionId], references: [id], onDelete: Cascade)
  author      Employee    @relation("RecognitionCommentAuthor", fields: [authorId], references: [id])

  @@index([recognitionId])
  @@map("recognition_comments")
}

model EmployeePoints {
  id         String @id @default(cuid())
  employeeId String @unique @map("employee_id")

  totalEarned    Int @default(0) @map("total_earned")
  totalSpent     Int @default(0) @map("total_spent")
  currentBalance Int @default(0) @map("current_balance")

  monthlyAllowance Int       @default(100) @map("monthly_allowance")
  monthlyUsed      Int       @default(0) @map("monthly_used")
  allowanceResetAt DateTime? @map("allowance_reset_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  employee     Employee           @relation(fields: [employeeId], references: [id])
  transactions PointTransaction[]

  @@map("employee_points")
}

model PointTransaction {
  id               String @id @default(cuid())
  employeePointsId String @map("employee_points_id")

  type   PointTransactionType
  amount Int

  description String @db.VarChar(200)

  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")

  createdAt DateTime @default(now()) @map("created_at")

  employeePoints EmployeePoints @relation(fields: [employeePointsId], references: [id])

  @@index([employeePointsId])
  @@map("point_transactions")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.3: COMPANY FEED & ANNOUNCEMENTS
// ═══════════════════════════════════════════════════════════════

model CompanyPost {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  authorId String @map("author_id")

  type PostType

  title   String? @db.VarChar(200)
  content String  @db.Text

  mediaUrls String[] @map("media_urls")

  isPinned     Boolean   @default(false) @map("is_pinned")
  pinExpiresAt DateTime? @map("pin_expires_at")

  visibility        PostVisibility @default(ALL)
  targetDepartments String[]       @map("target_departments")

  status      PostStatus @default(PUBLISHED)
  publishedAt DateTime?  @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  author    Employee       @relation("PostAuthor", fields: [authorId], references: [id])
  reactions PostReaction[]
  comments  PostComment[]
  readBy    PostRead[]

  @@index([tenantId, status, publishedAt])
  @@index([tenantId, isPinned])
  @@map("company_posts")
}

model PostReaction {
  id         String @id @default(cuid())
  postId     String @map("post_id")
  employeeId String @map("employee_id")

  emoji String @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at")

  post     CompanyPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id])

  @@unique([postId, employeeId])
  @@map("post_reactions")
}

model PostComment {
  id       String @id @default(cuid())
  postId   String @map("post_id")
  authorId String @map("author_id")

  content String @db.Text

  parentId String? @map("parent_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    CompanyPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Employee      @relation("PostCommentAuthor", fields: [authorId], references: [id])
  parent  PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies PostComment[] @relation("CommentReplies")

  @@index([postId])
  @@map("post_comments")
}

model PostRead {
  id         String @id @default(cuid())
  postId     String @map("post_id")
  employeeId String @map("employee_id")

  readAt DateTime @default(now()) @map("read_at")

  post     CompanyPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id])

  @@unique([postId, employeeId])
  @@map("post_reads")
}

model CompanyEvent {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  title       String  @db.VarChar(200)
  description String? @db.Text

  type EventType

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isAllDay  Boolean  @default(false) @map("is_all_day")

  location    String? @db.VarChar(200)
  isVirtual   Boolean @default(false) @map("is_virtual")
  virtualLink String? @map("virtual_link")

  maxAttendees Int? @map("max_attendees")

  requiresRsvp Boolean   @default(false) @map("requires_rsvp")
  rsvpDeadline DateTime? @map("rsvp_deadline")

  postId String? @map("post_id")

  organizerId String @map("organizer_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  organizer Employee        @relation("EventOrganizer", fields: [organizerId], references: [id])
  attendees EventAttendee[]

  @@index([tenantId, startDate])
  @@map("company_events")
}

model EventAttendee {
  id         String @id @default(cuid())
  eventId    String @map("event_id")
  employeeId String @map("employee_id")

  status      RsvpStatus @default(PENDING)
  respondedAt DateTime?  @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")

  event    CompanyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id])

  @@unique([eventId, employeeId])
  @@map("event_attendees")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 3.3: OFFBOARDING MODELS
// ═══════════════════════════════════════════════════════════════

model OffboardingInstance {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  employeeId String @unique @map("employee_id")

  noticeDate     DateTime @map("notice_date")
  lastWorkingDay DateTime @map("last_working_day")

  separationType SeparationType @map("separation_type")
  reason         String?        @db.Text
  isVoluntary    Boolean        @default(true) @map("is_voluntary")

  status OffboardingStatus @default(INITIATED)

  exitSurveyId       String?   @map("exit_survey_id")
  exitInterviewDate  DateTime? @map("exit_interview_date")
  exitInterviewNotes String?   @map("exit_interview_notes") @db.Text

  eligibleForRehire Boolean? @map("eligible_for_rehire")
  rehireNotes       String?  @map("rehire_notes") @db.Text

  knowledgeTransferTo String? @map("knowledge_transfer_to")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  employee Employee          @relation(fields: [employeeId], references: [id])
  tasks    OffboardingTask[]

  @@index([tenantId, status])
  @@index([tenantId, lastWorkingDay])
  @@map("offboarding_instances")
}

model OffboardingTask {
  id         String @id @default(cuid())
  instanceId String @map("instance_id")

  title       String  @db.VarChar(200)
  description String? @db.Text

  category OffboardingCategory

  assigneeId String? @map("assignee_id")

  status      OnboardingTaskStatus @default(PENDING)
  completedAt DateTime?            @map("completed_at")
  completedBy String?              @map("completed_by")

  notes String? @db.Text

  dueDate   DateTime? @map("due_date")
  sortOrder Int       @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  instance OffboardingInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  assignee Employee?           @relation("OffboardingTaskAssignee", fields: [assigneeId], references: [id])

  @@index([instanceId])
  @@index([assigneeId, status])
  @@map("offboarding_tasks")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 5.0: ADVANCED ANALYTICS - ENUMS
// ═══════════════════════════════════════════════════════════════

enum SnapshotType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PredictionModelType {
  TURNOVER_RISK
  PROMOTION_READINESS
  PERFORMANCE_TREND
  SKILL_GAP
  COMPENSATION_EQUITY
  HEADCOUNT_FORECAST
}

enum PredictionStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum ReportExportFormat {
  PDF
  EXCEL
  CSV
  JSON
}

enum ReportExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ═══════════════════════════════════════════════════════════════
// PHASE 5.0: ADVANCED ANALYTICS - MODELS
// ═══════════════════════════════════════════════════════════════

model AnalyticsSnapshot {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  snapshotType SnapshotType @map("snapshot_type")
  snapshotDate DateTime     @map("snapshot_date")

  // Headcount metrics
  totalHeadcount        Int @default(0) @map("total_headcount")
  activeEmployees       Int @default(0) @map("active_employees")
  probationEmployees    Int @default(0) @map("probation_employees")
  newHires              Int @default(0) @map("new_hires")
  terminations          Int @default(0) @map("terminations")
  voluntaryTerminations Int @default(0) @map("voluntary_terminations")

  // Turnover metrics
  turnoverRate          Decimal @default(0) @map("turnover_rate") @db.Decimal(5, 2)
  voluntaryTurnoverRate Decimal @default(0) @map("voluntary_turnover_rate") @db.Decimal(5, 2)
  retentionRate         Decimal @default(0) @map("retention_rate") @db.Decimal(5, 2)

  // Attendance metrics
  avgAttendanceRate  Decimal @default(0) @map("avg_attendance_rate") @db.Decimal(5, 2)
  totalAbsentDays    Int     @default(0) @map("total_absent_days")
  totalLeaveDays     Int     @default(0) @map("total_leave_days")
  totalOvertimeHours Decimal @default(0) @map("total_overtime_hours") @db.Decimal(10, 2)

  // Compensation metrics
  totalPayrollCost    Decimal @default(0) @map("total_payroll_cost") @db.Decimal(18, 2)
  avgSalary           Decimal @default(0) @map("avg_salary") @db.Decimal(18, 2)
  laborCostPercentage Decimal @default(0) @map("labor_cost_percentage") @db.Decimal(5, 2)

  // Recruitment metrics
  openPositions     Int @default(0) @map("open_positions")
  totalApplications Int @default(0) @map("total_applications")
  hiredCount        Int @default(0) @map("hired_count")
  avgTimeToHire     Int @default(0) @map("avg_time_to_hire")

  // Performance metrics
  avgPerformanceScore Decimal @default(0) @map("avg_performance_score") @db.Decimal(3, 1)
  highPerformers      Int     @default(0) @map("high_performers")
  lowPerformers       Int     @default(0) @map("low_performers")
  goalsCompletionRate Decimal @default(0) @map("goals_completion_rate") @db.Decimal(5, 2)

  // Learning metrics
  avgTrainingHours     Decimal @default(0) @map("avg_training_hours") @db.Decimal(6, 2)
  courseCompletionRate Decimal @default(0) @map("course_completion_rate") @db.Decimal(5, 2)
  certifiedEmployees   Int     @default(0) @map("certified_employees")

  // Breakdown by department
  departmentBreakdown Json? @map("department_breakdown")

  // Raw data for drill-down
  rawData Json? @map("raw_data")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotType, snapshotDate])
  @@index([tenantId, snapshotType])
  @@index([tenantId, snapshotDate])
  @@map("analytics_snapshots")
}

model PredictiveModel {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  modelType PredictionModelType @map("model_type")

  // Model configuration
  config     Json
  features   Json // Feature names and weights
  thresholds Json? // Thresholds for risk levels

  // Model performance metrics
  accuracy  Decimal? @db.Decimal(5, 4)
  precision Decimal? @db.Decimal(5, 4)
  recall    Decimal? @db.Decimal(5, 4)
  f1Score   Decimal? @map("f1_score") @db.Decimal(5, 4)

  // Training info
  trainedAt        DateTime? @map("trained_at")
  trainingDataSize Int?      @map("training_data_size")
  lastEvaluatedAt  DateTime? @map("last_evaluated_at")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  predictions Prediction[]

  @@index([tenantId, modelType])
  @@index([tenantId, isActive])
  @@map("predictive_models")
}

model Prediction {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  modelId  String @map("model_id")

  entityType String @map("entity_type") // 'employee', 'department', 'organization'
  entityId   String @map("entity_id")

  predictionType PredictionModelType @map("prediction_type")

  score      Decimal   @db.Decimal(5, 2)
  riskLevel  RiskLevel @map("risk_level")
  confidence Decimal   @db.Decimal(5, 2)

  factors         Json // Contributing factors
  recommendations Json? // Action recommendations

  status PredictionStatus @default(COMPLETED)

  predictedAt DateTime @default(now()) @map("predicted_at")
  validUntil  DateTime @map("valid_until")

  // Outcome tracking
  actualOutcome     String?   @map("actual_outcome")
  outcomeRecordedAt DateTime? @map("outcome_recorded_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  model  PredictiveModel @relation(fields: [modelId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, predictionType, riskLevel])
  @@index([tenantId, validUntil])
  @@map("predictions")
}

model CustomReport {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  name        String
  description String?
  category    String?

  // Data source configuration
  primarySource String @map("primary_source") // Main data source
  joinedSources Json?  @map("joined_sources") // Additional joined tables

  // Column definitions with advanced options
  columns Json // Array of column configs with formatting, calculations

  // Filter configuration
  filters    Json? // Static filters
  parameters Json? // Dynamic parameters with prompts

  // Sorting and grouping
  sorting      Json?
  grouping     Json?
  aggregations Json?

  // Visualization config
  chartType   String? @map("chart_type")
  chartConfig Json?   @map("chart_config")

  // Layout and styling
  layout     Json?
  formatting Json?

  // Sharing
  isPublic   Boolean @default(false) @map("is_public")
  sharedWith Json?   @map("shared_with") // User/role IDs

  // Scheduling
  isScheduled Boolean   @default(false) @map("is_scheduled")
  schedule    Json?
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  recipients  Json? // Email recipients for scheduled reports

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  user    User           @relation(fields: [userId], references: [id])
  exports ReportExport[]

  @@index([tenantId, userId])
  @@index([tenantId, category])
  @@index([tenantId, isScheduled])
  @@map("custom_reports")
}

model ReportExport {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  reportId String @map("report_id")
  userId   String @map("user_id")

  format   ReportExportFormat
  fileName String             @map("file_name")
  fileUrl  String?            @map("file_url")
  fileSize Int?               @map("file_size")

  status       ReportExportStatus @default(PENDING)
  errorMessage String?            @map("error_message")

  // Export parameters
  parameters Json?
  dateRange  Json? @map("date_range")
  rowCount   Int?  @map("row_count")

  requestedAt DateTime  @default(now()) @map("requested_at")
  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime? @map("expires_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  report CustomReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id])

  @@index([tenantId, reportId])
  @@index([tenantId, userId])
  @@index([status])
  @@map("report_exports")
}

model AnalyticsAlert {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  // Alert condition
  metricType  String  @map("metric_type")
  condition   String // 'gt', 'lt', 'eq', 'gte', 'lte', 'change_percent'
  threshold   Decimal @db.Decimal(18, 4)
  compareWith String? @map("compare_with") // 'previous_period', 'same_period_last_year', 'fixed_value'

  severity AlertSeverity

  // Scope
  departmentId String? @map("department_id")

  // Current state
  status          AlertStatus @default(ACTIVE)
  lastTriggeredAt DateTime?   @map("last_triggered_at")
  lastValue       Decimal?    @map("last_value") @db.Decimal(18, 4)
  triggerCount    Int         @default(0) @map("trigger_count")

  // Notification settings
  notifyUsers     Json?   @map("notify_users") // User IDs to notify
  notifyRoles     Json?   @map("notify_roles") // Role names to notify
  notifyEmail     Boolean @default(true) @map("notify_email")
  notifyInApp     Boolean @default(true) @map("notify_in_app")
  cooldownMinutes Int     @default(60) @map("cooldown_minutes")

  isActive Boolean @default(true) @map("is_active")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  department Department?           @relation(fields: [departmentId], references: [id])
  createdBy  User                  @relation(fields: [createdById], references: [id])
  history    AlertTriggerHistory[]

  @@index([tenantId, metricType])
  @@index([tenantId, status])
  @@index([tenantId, isActive])
  @@map("analytics_alerts")
}

model AlertTriggerHistory {
  id      String @id @default(cuid())
  alertId String @map("alert_id")

  triggeredAt DateTime @default(now()) @map("triggered_at")

  metricValue    Decimal @map("metric_value") @db.Decimal(18, 4)
  thresholdValue Decimal @map("threshold_value") @db.Decimal(18, 4)

  message String

  acknowledgedById String?   @map("acknowledged_by_id")
  acknowledgedAt   DateTime? @map("acknowledged_at")

  resolvedById String?   @map("resolved_by_id")
  resolvedAt   DateTime? @map("resolved_at")
  resolution   String?

  alert          AnalyticsAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  acknowledgedBy User?          @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  resolvedBy     User?          @relation("AlertResolvedBy", fields: [resolvedById], references: [id])

  @@index([alertId, triggeredAt])
  @@map("alert_trigger_history")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 7: CUSTOM ROLE ENGINE (P2-17)
// ═══════════════════════════════════════════════════════════════

enum ApprovalMode {
  SEQUENTIAL // Duyệt tuần tự (mặc định hiện tại)
  PARALLEL   // Duyệt song song (tất cả cùng lúc)
  QUORUM     // Duyệt đa số (N/M người duyệt)
}

model CustomRole {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String // "Trưởng phòng Kế toán"
  code        String // "ACCOUNTING_MANAGER"
  description String?

  // Base role level for hierarchy (100=admin, 10=viewer)
  level Int @default(50)

  // Whether this is a system-default role (cannot be deleted)
  isSystem Boolean @default(false) @map("is_system")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  fieldPermissions FieldPermission[]
  users       UserCustomRole[]

  @@unique([tenantId, code])
  @@map("custom_roles")
}

model RolePermission {
  id     String @id @default(cuid())
  roleId String @map("role_id")

  resource String // "employees", "payroll", "leave", etc.
  action   String // "read", "create", "update", "delete", "approve", "export"

  // Optional scope restriction
  // "own" = only own data, "department" = same department, "all" = everything
  scope String @default("all")

  createdAt DateTime @default(now()) @map("created_at")

  role CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

// Junction table: User ↔ CustomRole (a user can have multiple custom roles)
model UserCustomRole {
  id     String @id @default(cuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  assignedAt DateTime @default(now()) @map("assigned_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_custom_roles")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 7: FIELD-LEVEL PERMISSIONS (P2-18)
// ═══════════════════════════════════════════════════════════════

model FieldPermission {
  id     String @id @default(cuid())
  roleId String @map("role_id")

  // Target entity and field
  entity    String // "employee", "payroll", "contract"
  fieldName String @map("field_name") // "baseSalary", "idNumber", "bankAccount"

  // Permission level: "hidden" | "masked" | "read" | "write"
  access String @default("hidden")

  createdAt DateTime @default(now()) @map("created_at")

  role CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, entity, fieldName])
  @@map("field_permissions")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 7: GDPR ERASURE (P2-20)
// ═══════════════════════════════════════════════════════════════

enum ErasureStatus {
  REQUESTED   // Yêu cầu mới
  REVIEWING   // Đang xem xét
  APPROVED    // Đã duyệt
  PROCESSING  // Đang xử lý xóa
  COMPLETED   // Đã xóa xong
  REJECTED    // Từ chối
}

model ErasureRequest {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  // Subject of erasure
  employeeId String @map("employee_id")
  requestedBy String @map("requested_by") // User ID

  // Request details
  reason     String
  legalBasis String? @map("legal_basis") // GDPR article reference

  // What to erase (JSON array of field groups)
  // e.g., ["personal", "contact", "bank", "medical"]
  scopeFields Json @default("[]") @map("scope_fields")

  // Status tracking
  status      ErasureStatus @default(REQUESTED)
  reviewedBy  String?       @map("reviewed_by")
  reviewedAt  DateTime?     @map("reviewed_at")
  reviewNotes String?       @map("review_notes")

  // Execution
  executedAt DateTime? @map("executed_at")
  executedBy String?   @map("executed_by")

  // Audit - what was actually erased
  erasureLog Json? @map("erasure_log")

  // Retention exception (some data must be kept for legal reasons)
  retentionExceptions Json? @map("retention_exceptions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, employeeId])
  @@map("erasure_requests")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 7: DATA RETENTION POLICY (P2-21)
// ═══════════════════════════════════════════════════════════════

model RetentionPolicy {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String // "Chính sách lưu trữ bảng lương"
  entityType  String @map("entity_type") // "payroll", "attendance", "audit_log", etc.
  description String?

  // Retention period
  retentionDays Int @map("retention_days") // Số ngày lưu trữ
  // e.g., payroll: 3650 (10 years), attendance: 1825 (5 years), audit: 2555 (7 years)

  // Action when expired
  // "archive" = move to archive table, "anonymize" = strip PII, "delete" = hard delete
  action String @default("archive")

  // Conditions (JSON) for when policy applies
  // e.g., { "status": "PAID" } - only archive paid payrolls
  conditions Json? @default("{}")

  isActive Boolean @default(true) @map("is_active")

  // Last execution
  lastRunAt     DateTime? @map("last_run_at")
  lastRunCount  Int?      @map("last_run_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType])
  @@map("retention_policies")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 8: INTERNAL JOB MARKETPLACE
// ═══════════════════════════════════════════════════════════════

enum MarketplacePostingStatus {
  DRAFT
  PENDING_APPROVAL
  OPEN
  CLOSED
  FILLED
  CANCELLED
}

enum InternalJobType {
  TRANSFER
  PROMOTION
  ROTATION
  PROJECT
  TEMPORARY
}

enum InternalApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  MANAGER_APPROVED
  MANAGER_REJECTED
  SHORTLISTED
  INTERVIEW
  OFFERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MarketplaceVisibility {
  ALL
  DEPARTMENT
  SELECTED_DEPARTMENTS
  INTERNAL_ONLY
}

model InternalJobPosting {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  title       String @db.VarChar(200)
  description String @db.Text

  jobType    InternalJobType        @map("job_type")
  visibility MarketplaceVisibility  @default(ALL)
  status     MarketplacePostingStatus @default(DRAFT)

  departmentId String @map("department_id")
  positionId   String? @map("position_id")

  requirements    Json?    @default("[]")
  preferredSkills String[] @map("preferred_skills")

  minExperienceYears Int? @map("min_experience_years")

  applicationDeadline DateTime? @map("application_deadline")

  visibleToDepartmentIds String[] @map("visible_to_department_ids")

  hiringManagerId String @map("hiring_manager_id")
  createdById     String @map("created_by_id")

  viewCount        Int @default(0) @map("view_count")
  applicationCount Int @default(0) @map("application_count")

  closedAt     DateTime? @map("closed_at")
  closedReason String?   @map("closed_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  department     Department   @relation(fields: [departmentId], references: [id])
  position       Position?    @relation(fields: [positionId], references: [id])
  hiringManager  Employee     @relation("PostingHiringManager", fields: [hiringManagerId], references: [id])
  createdBy      Employee     @relation("PostingCreator", fields: [createdById], references: [id])
  applications   InternalApplication[]

  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, createdAt])
  @@map("internal_job_postings")
}

model InternalApplication {
  id        String @id @default(cuid())
  tenantId  String @map("tenant_id")
  postingId String @map("posting_id")
  applicantId String @map("applicant_id")

  status InternalApplicationStatus @default(SUBMITTED)

  coverLetter String? @map("cover_letter") @db.Text
  resumeUrl   String? @map("resume_url")

  managerApproval   Boolean?  @map("manager_approval")
  managerApprovalAt DateTime? @map("manager_approval_at")
  managerNotes      String?   @map("manager_notes") @db.Text

  interviewNotes String? @map("interview_notes") @db.Text
  rejectionReason String? @map("rejection_reason") @db.Text

  withdrawnAt     DateTime? @map("withdrawn_at")
  withdrawnReason String?   @map("withdrawn_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  posting   InternalJobPosting  @relation(fields: [postingId], references: [id], onDelete: Cascade)
  applicant Employee            @relation(fields: [applicantId], references: [id])

  @@unique([postingId, applicantId])
  @@index([tenantId, applicantId])
  @@index([tenantId, status])
  @@map("internal_applications")
}

model CareerProfile {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @unique @map("employee_id")

  headline     String? @db.VarChar(200)
  summary      String? @db.Text
  skills       String[]
  interests    String[]
  careerGoals  String? @map("career_goals") @db.Text

  openToOpportunities Boolean @default(true) @map("open_to_opportunities")
  preferredJobTypes   String[] @map("preferred_job_types")
  preferredDepartments String[] @map("preferred_departments")

  bookmarkedPostings String[] @map("bookmarked_postings")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@map("career_profiles")
}
