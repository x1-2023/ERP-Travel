// ═══════════════════════════════════════════════════════════════
// OFFER
// ═══════════════════════════════════════════════════════════════

model Offer {
  id            String @id @default(cuid())
  tenantId      String @map("tenant_id")
  applicationId String @map("application_id")

  offerCode String @unique @map("offer_code")

  position      String
  departmentId  String  @map("department_id")
  reportingToId String? @map("reporting_to_id")

  jobType  JobType  @map("job_type")
  workMode WorkMode @map("work_mode")
  location String?

  baseSalary Decimal @map("base_salary") @db.Decimal(18, 2)
  allowances Json?
  bonus      String?
  benefits   String? @db.Text

  startDate       DateTime @map("start_date")
  probationMonths Int      @default(2) @map("probation_months")

  status OfferStatus @default(DRAFT)

  expiresAt DateTime @map("expires_at")

  sentAt   DateTime? @map("sent_at")
  sentById String?   @map("sent_by_id")

  respondedAt  DateTime? @map("responded_at")
  responseNote String?   @map("response_note")

  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
  department  Department  @relation(fields: [departmentId], references: [id])
  reportingTo Employee?   @relation(fields: [reportingToId], references: [id])
  sentBy      User?       @relation("OfferSentBy", fields: [sentById], references: [id])
  approvedBy  User?       @relation("OfferApprovedBy", fields: [approvedById], references: [id])

  @@index([tenantId, status])
  @@index([applicationId])
  @@map("offers")
}

// ═══════════════════════════════════════════════════════════════
// ONBOARDING
// ═══════════════════════════════════════════════════════════════

model OnboardingTemplate {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  departmentId  String? @map("department_id")
  positionLevel String? @map("position_level")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  department  Department?              @relation(fields: [departmentId], references: [id])
  tasks       OnboardingTemplateTask[]
  onboardings Onboarding[]

  @@index([tenantId])
  @@map("onboarding_templates")
}

model OnboardingTemplateTask {
  id         String @id @default(cuid())
  templateId String @map("template_id")

  title       String
  description String? @db.Text

  category   String
  daysOffset Int    @map("days_offset")

  assigneeType String @map("assignee_type")

  isRequired Boolean @default(true) @map("is_required")
  order      Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("onboarding_template_tasks")
}

model Onboarding {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  employeeId String  @map("employee_id")
  templateId String? @map("template_id")

  status OnboardingStatus @default(NOT_STARTED)

  startDate       DateTime  @map("start_date")
  expectedEndDate DateTime  @map("expected_end_date")
  completedAt     DateTime? @map("completed_at")

  buddyId     String? @map("buddy_id")
  hrContactId String? @map("hr_contact_id")

  progress Int @default(0)

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  employee  Employee            @relation(fields: [employeeId], references: [id])
  template  OnboardingTemplate? @relation(fields: [templateId], references: [id])
  buddy     Employee?           @relation("OnboardingBuddy", fields: [buddyId], references: [id])
  hrContact User?               @relation(fields: [hrContactId], references: [id])
  tasks     OnboardingTask[]

  @@index([tenantId, status])
  @@index([employeeId])
  @@map("onboardings")
}

model OnboardingTask {
  id           String @id @default(cuid())
  onboardingId String @map("onboarding_id")

  title       String
  description String? @db.Text

  category String
  dueDate  DateTime @map("due_date")

  assigneeId   String? @map("assignee_id")
  assigneeType String  @map("assignee_type")

  status        OnboardingTaskStatus @default(PENDING)
  completedAt   DateTime?            @map("completed_at")
  completedById String?              @map("completed_by_id")

  notes       String?
  attachments Json?

  isRequired Boolean @default(true) @map("is_required")
  order      Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  onboarding  Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  assignee    User?      @relation("OnboardingTaskAssignee", fields: [assigneeId], references: [id])
  completedBy User?      @relation("OnboardingTaskCompletedBy", fields: [completedById], references: [id])

  @@index([onboardingId, status])
  @@map("onboarding_tasks")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 9: PERFORMANCE MANAGEMENT - ENUMS
// ═══════════════════════════════════════════════════════════════

enum GoalType {
  COMPANY
  DEPARTMENT
  TEAM
  INDIVIDUAL
}

enum GoalStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReviewCycleType {
  ANNUAL
  SEMI_ANNUAL
  QUARTERLY
  PROBATION
  PROJECT
  AD_HOC
}

enum ReviewCycleStatus {
  DRAFT
  GOAL_SETTING
  IN_PROGRESS
  SELF_REVIEW
  MANAGER_REVIEW
  CALIBRATION
  COMPLETED
  CANCELLED
}

enum ReviewStatus {
  NOT_STARTED
  SELF_REVIEW_PENDING
  SELF_REVIEW_DONE
  MANAGER_REVIEW_PENDING
  MANAGER_REVIEW_DONE
  CALIBRATION_PENDING
  COMPLETED
  ACKNOWLEDGED
}

enum FeedbackType {
  CONTINUOUS
  REVIEW_360
  PEER
  UPWARD
  RECOGNITION
}

enum FeedbackRequestStatus {
  REQUESTED
  PENDING
  SUBMITTED
  DECLINED
}

enum PIPStatus {
  DRAFT
  ACTIVE
  EXTENDED
  COMPLETED_SUCCESS
  COMPLETED_FAIL
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════
// GOAL MANAGEMENT (OKR/KPI)
// ═══════════════════════════════════════════════════════════════

model Goal {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  title       String
  description String? @db.Text

  goalType GoalType @map("goal_type")
  category String?

  ownerId      String? @map("owner_id")
  departmentId String? @map("department_id")

  parentGoalId String? @map("parent_goal_id")

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  targetValue  Decimal? @map("target_value") @db.Decimal(18, 4)
  currentValue Decimal? @map("current_value") @db.Decimal(18, 4)
  unit         String?

  weight Decimal @default(100) @db.Decimal(5, 2)

  status   GoalStatus   @default(DRAFT)
  priority GoalPriority @default(MEDIUM)

  progress Int      @default(0)
  score    Decimal? @db.Decimal(3, 1)

  reviewCycleId String? @map("review_cycle_id")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  owner       Employee?    @relation(fields: [ownerId], references: [id])
  department  Department?  @relation("GoalDepartment", fields: [departmentId], references: [id])
  parentGoal  Goal?        @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  childGoals  Goal[]       @relation("GoalHierarchy")
  reviewCycle ReviewCycle? @relation(fields: [reviewCycleId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])

  keyResults  KeyResult[]
  updates     GoalUpdate[]
  reviewGoals ReviewGoal[]

  @@index([tenantId, goalType])
  @@index([tenantId, ownerId])
  @@index([tenantId, reviewCycleId])
  @@map("goals")
}

model KeyResult {
  id     String @id @default(cuid())
  goalId String @map("goal_id")

  title       String
  description String?

  targetValue  Decimal @map("target_value") @db.Decimal(18, 4)
  currentValue Decimal @default(0) @map("current_value") @db.Decimal(18, 4)
  unit         String?

  weight   Decimal @default(100) @db.Decimal(5, 2)
  progress Int     @default(0)

  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  goal    Goal              @relation(fields: [goalId], references: [id], onDelete: Cascade)
  updates KeyResultUpdate[]

  @@index([goalId])
  @@map("key_results")
}

model GoalUpdate {
  id     String @id @default(cuid())
  goalId String @map("goal_id")

  previousValue    Decimal? @map("previous_value") @db.Decimal(18, 4)
  newValue         Decimal? @map("new_value") @db.Decimal(18, 4)
  previousProgress Int?     @map("previous_progress")
  newProgress      Int?     @map("new_progress")

  notes String? @db.Text

  updatedById String   @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  goal      Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  updatedBy User @relation(fields: [updatedById], references: [id])

  @@index([goalId, createdAt])
  @@map("goal_updates")
}

model KeyResultUpdate {
  id          String @id @default(cuid())
  keyResultId String @map("key_result_id")

  previousValue Decimal? @map("previous_value") @db.Decimal(18, 4)
  newValue      Decimal  @map("new_value") @db.Decimal(18, 4)

  notes String?

  updatedById String   @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  keyResult KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  updatedBy User      @relation(fields: [updatedById], references: [id])

  @@index([keyResultId])
  @@map("key_result_updates")
}

// ═══════════════════════════════════════════════════════════════
// REVIEW CYCLE
// ═══════════════════════════════════════════════════════════════

model ReviewCycle {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  cycleType ReviewCycleType @map("cycle_type")
  year      Int

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  goalSettingStart   DateTime? @map("goal_setting_start")
  goalSettingEnd     DateTime? @map("goal_setting_end")
  selfReviewStart    DateTime? @map("self_review_start")
  selfReviewEnd      DateTime? @map("self_review_end")
  managerReviewStart DateTime? @map("manager_review_start")
  managerReviewEnd   DateTime? @map("manager_review_end")
  calibrationStart   DateTime? @map("calibration_start")
  calibrationEnd     DateTime? @map("calibration_end")

  goalWeight       Decimal @default(40) @map("goal_weight") @db.Decimal(5, 2)
  competencyWeight Decimal @default(30) @map("competency_weight") @db.Decimal(5, 2)
  valuesWeight     Decimal @default(20) @map("values_weight") @db.Decimal(5, 2)
  feedbackWeight   Decimal @default(10) @map("feedback_weight") @db.Decimal(5, 2)

  allowSelfReview    Boolean @default(true) @map("allow_self_review")
  allow360Feedback   Boolean @default(true) @map("allow_360_feedback")
  requireCalibration Boolean @default(true) @map("require_calibration")

  status ReviewCycleStatus @default(DRAFT)

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation(fields: [createdById], references: [id])

  goals               Goal[]
  reviews             PerformanceReview[]
  calibrationSessions CalibrationSession[]

  @@index([tenantId, year])
  @@index([tenantId, status])
  @@map("review_cycles")
}

// ═══════════════════════════════════════════════════════════════
// PERFORMANCE REVIEW
// ═══════════════════════════════════════════════════════════════

model PerformanceReview {
  id            String @id @default(cuid())
  tenantId      String @map("tenant_id")
  reviewCycleId String @map("review_cycle_id")
  employeeId    String @map("employee_id")
  managerId     String @map("manager_id")

  status ReviewStatus @default(NOT_STARTED)

  goalScore       Decimal? @map("goal_score") @db.Decimal(3, 1)
  competencyScore Decimal? @map("competency_score") @db.Decimal(3, 1)
  valuesScore     Decimal? @map("values_score") @db.Decimal(3, 1)
  feedbackScore   Decimal? @map("feedback_score") @db.Decimal(3, 1)

  overallScore Decimal? @map("overall_score") @db.Decimal(3, 1)

  selfRating       Int? @map("self_rating")
  managerRating    Int? @map("manager_rating")
  calibratedRating Int? @map("calibrated_rating")
  finalRating      Int? @map("final_rating")

  selfComments     String? @map("self_comments") @db.Text
  managerComments  String? @map("manager_comments") @db.Text
  employeeComments String? @map("employee_comments") @db.Text

  strengths        String? @db.Text
  developmentAreas String? @map("development_areas") @db.Text

  developmentPlan Json? @map("development_plan")

  selfReviewAt    DateTime? @map("self_review_at")
  managerReviewAt DateTime? @map("manager_review_at")
  calibratedAt    DateTime? @map("calibrated_at")
  acknowledgedAt  DateTime? @map("acknowledged_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  reviewCycle ReviewCycle @relation(fields: [reviewCycleId], references: [id])
  employee    Employee    @relation(fields: [employeeId], references: [id])
  manager     Employee    @relation("ReviewManager", fields: [managerId], references: [id])

  goals            ReviewGoal[]
  competencies     ReviewCompetency[]
  values           ReviewValue[]
  feedbackRequests FeedbackRequest[]

  @@unique([reviewCycleId, employeeId])
  @@index([tenantId, reviewCycleId])
  @@index([employeeId])
  @@map("performance_reviews")
}

model ReviewGoal {
  id       String @id @default(cuid())
  reviewId String @map("review_id")
  goalId   String @map("goal_id")

  selfScore    Decimal? @map("self_score") @db.Decimal(3, 1)
  selfComments String?  @map("self_comments") @db.Text

  managerScore    Decimal? @map("manager_score") @db.Decimal(3, 1)
  managerComments String?  @map("manager_comments") @db.Text

  finalScore Decimal? @map("final_score") @db.Decimal(3, 1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  goal   Goal              @relation(fields: [goalId], references: [id])

  @@unique([reviewId, goalId])
  @@map("review_goals")
}

// ═══════════════════════════════════════════════════════════════
// COMPETENCY FRAMEWORK
// ═══════════════════════════════════════════════════════════════

model CompetencyFramework {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  competencies Competency[]

  @@index([tenantId])
  @@map("competency_frameworks")
}

model Competency {
  id          String @id @default(cuid())
  frameworkId String @map("framework_id")

  name        String
  description String? @db.Text
  category    String?

  levels Json

  isCore Boolean @default(false) @map("is_core")

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  framework            CompetencyFramework  @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  positionCompetencies PositionCompetency[]
  reviewCompetencies   ReviewCompetency[]

  @@index([frameworkId])
  @@map("competencies")
}

model PositionCompetency {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  competencyId String @map("competency_id")

  position      String
  requiredLevel Int    @map("required_level")

  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, competencyId, position])
  @@map("position_competencies")
}

model ReviewCompetency {
  id           String @id @default(cuid())
  reviewId     String @map("review_id")
  competencyId String @map("competency_id")

  requiredLevel Int @map("required_level")

  selfRating   Int?    @map("self_rating")
  selfComments String? @map("self_comments")

  managerRating   Int?    @map("manager_rating")
  managerComments String? @map("manager_comments")

  finalRating Int? @map("final_rating")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review     PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  competency Competency        @relation(fields: [competencyId], references: [id])

  @@unique([reviewId, competencyId])
  @@map("review_competencies")
}

// ═══════════════════════════════════════════════════════════════
// CORE VALUES
// ═══════════════════════════════════════════════════════════════

model CoreValue {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name        String
  description String? @db.Text

  indicators Json

  isActive Boolean @default(true) @map("is_active")
  order    Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  reviewValues ReviewValue[]

  @@index([tenantId])
  @@map("core_values")
}

model ReviewValue {
  id          String @id @default(cuid())
  reviewId    String @map("review_id")
  coreValueId String @map("core_value_id")

  selfRating   Int?    @map("self_rating")
  selfComments String? @map("self_comments")

  managerRating   Int?    @map("manager_rating")
  managerComments String? @map("manager_comments")

  peerRating Decimal? @map("peer_rating") @db.Decimal(3, 1)

  finalRating Int? @map("final_rating")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review    PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  coreValue CoreValue         @relation(fields: [coreValueId], references: [id])

  @@unique([reviewId, coreValueId])
  @@map("review_values")
}

// ═══════════════════════════════════════════════════════════════
// FEEDBACK (360 & CONTINUOUS)
// ═══════════════════════════════════════════════════════════════

model FeedbackRequest {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  reviewId String? @map("review_id")

  requesterId String @map("requester_id")
  providerId  String @map("provider_id")
  subjectId   String @map("subject_id")

  feedbackType FeedbackType          @map("feedback_type")
  status       FeedbackRequestStatus @default(REQUESTED)

  dueDate DateTime? @map("due_date")

  questions Json?

  requestedAt DateTime  @default(now()) @map("requested_at")
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  review    PerformanceReview? @relation(fields: [reviewId], references: [id])
  requester User               @relation("FeedbackRequester", fields: [requesterId], references: [id])
  provider  User               @relation("FeedbackProvider", fields: [providerId], references: [id])
  subject   Employee           @relation(fields: [subjectId], references: [id])

  response Feedback?

  @@index([tenantId, subjectId])
  @@index([providerId, status])
  @@map("feedback_requests")
}

model Feedback {
  id        String  @id @default(cuid())
  tenantId  String  @map("tenant_id")
  requestId String? @unique @map("request_id")

  providerId String @map("provider_id")
  subjectId  String @map("subject_id")

  feedbackType FeedbackType @map("feedback_type")

  overallRating Int?  @map("overall_rating")
  ratings       Json?

  strengths           String? @db.Text
  areasForImprovement String? @map("areas_for_improvement") @db.Text
  comments            String? @db.Text

  recognitionType String? @map("recognition_type")
  isPublic        Boolean @default(false) @map("is_public")

  isAnonymous Boolean @default(false) @map("is_anonymous")

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  request  FeedbackRequest? @relation(fields: [requestId], references: [id])
  provider User             @relation("FeedbackGiver", fields: [providerId], references: [id])
  subject  Employee         @relation("FeedbackReceiver", fields: [subjectId], references: [id])

  @@index([tenantId, subjectId])
  @@index([tenantId, providerId])
  @@map("feedbacks")
}

// ═══════════════════════════════════════════════════════════════
// CALIBRATION
// ═══════════════════════════════════════════════════════════════

model CalibrationSession {
  id            String @id @default(cuid())
  tenantId      String @map("tenant_id")
  reviewCycleId String @map("review_cycle_id")

  name        String
  description String?

  departmentId String? @map("department_id")

  scheduledAt DateTime  @map("scheduled_at")
  completedAt DateTime? @map("completed_at")

  facilitatorId  String @map("facilitator_id")
  participantIds Json   @map("participant_ids")

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  reviewCycle ReviewCycle @relation(fields: [reviewCycleId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  facilitator User        @relation(fields: [facilitatorId], references: [id])

  decisions CalibrationDecision[]

  @@index([tenantId, reviewCycleId])
  @@map("calibration_sessions")
}

model CalibrationDecision {
  id         String @id @default(cuid())
  sessionId  String @map("session_id")
  employeeId String @map("employee_id")

  originalRating   Int @map("original_rating")
  calibratedRating Int @map("calibrated_rating")

  reason String? @db.Text

  decidedById String   @map("decided_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  session   CalibrationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee  Employee           @relation(fields: [employeeId], references: [id])
  decidedBy User               @relation(fields: [decidedById], references: [id])

  @@unique([sessionId, employeeId])
  @@map("calibration_decisions")
}

// ═══════════════════════════════════════════════════════════════
// CHECK-INS & 1-ON-1s
// ═══════════════════════════════════════════════════════════════

model CheckIn {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  managerId  String @map("manager_id")

  checkInDate DateTime @map("check_in_date")

  accomplishments String? @db.Text
  challenges      String? @db.Text
  priorities      String? @db.Text
  supportNeeded   String? @map("support_needed") @db.Text

  moodRating Int? @map("mood_rating")

  managerNotes String? @map("manager_notes") @db.Text
  actionItems  Json?   @map("action_items")

  isCompleted Boolean @default(false) @map("is_completed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  manager  Employee @relation("CheckInManager", fields: [managerId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, managerId])
  @@map("check_ins")
}

model OneOnOne {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")
  managerId  String @map("manager_id")

  scheduledAt DateTime @map("scheduled_at")
  duration    Int      @default(30)

  agenda Json?

  employeeNotes String? @map("employee_notes") @db.Text
  managerNotes  String? @map("manager_notes") @db.Text

  actionItems Json? @map("action_items")

  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation("OneOnOneEmployee", fields: [employeeId], references: [id])
  manager  Employee @relation("OneOnOneManager", fields: [managerId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, managerId])
  @@map("one_on_ones")
}

// ═══════════════════════════════════════════════════════════════
// PERFORMANCE IMPROVEMENT PLAN (PIP)
// ═══════════════════════════════════════════════════════════════

model PerformanceImprovementPlan {
  id          String  @id @default(cuid())
  tenantId    String  @map("tenant_id")
  employeeId  String  @map("employee_id")
  managerId   String  @map("manager_id")
  hrContactId String? @map("hr_contact_id")

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  performanceIssues String  @map("performance_issues") @db.Text
  impactDescription String? @map("impact_description") @db.Text

  expectedOutcomes String @map("expected_outcomes") @db.Text

  supportProvided String? @map("support_provided") @db.Text
  resources       String? @db.Text

  status PIPStatus @default(DRAFT)

  outcome     String?   @db.Text
  completedAt DateTime? @map("completed_at")

  employeeAcknowledgedAt DateTime? @map("employee_acknowledged_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  employee  Employee @relation(fields: [employeeId], references: [id])
  manager   Employee @relation("PIPManager", fields: [managerId], references: [id])
  hrContact User?    @relation(fields: [hrContactId], references: [id])

  milestones PIPMilestone[]
  checkIns   PIPCheckIn[]

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("performance_improvement_plans")
}

model PIPMilestone {
  id    String @id @default(cuid())
  pipId String @map("pip_id")

  title       String
  description String? @db.Text

  dueDate     DateTime  @map("due_date")
  completedAt DateTime? @map("completed_at")

  status String @default("PENDING")

  notes String?

  order Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pip PerformanceImprovementPlan @relation(fields: [pipId], references: [id], onDelete: Cascade)

  @@index([pipId])
  @@map("pip_milestones")
}

model PIPCheckIn {
  id    String @id @default(cuid())
  pipId String @map("pip_id")

  checkInDate DateTime @map("check_in_date")

  progressNotes     String  @map("progress_notes") @db.Text
  managerAssessment String? @map("manager_assessment") @db.Text

  isOnTrack Boolean @map("is_on_track")

  nextSteps String? @map("next_steps") @db.Text

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  pip       PerformanceImprovementPlan @relation(fields: [pipId], references: [id], onDelete: Cascade)
  createdBy User                       @relation(fields: [createdById], references: [id])

  @@index([pipId])
  @@map("pip_check_ins")
}

