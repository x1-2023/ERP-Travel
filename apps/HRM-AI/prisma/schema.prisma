model BenefitPlan {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  name                 String
  code                 String
  type                 BenefitType
  description          String?
  employerContribution Decimal?    @map("employer_contribution") @db.Decimal(18, 2)
  employeeContribution Decimal?    @map("employee_contribution") @db.Decimal(18, 2)
  contributionPercent  Decimal?    @map("contribution_percent") @db.Decimal(5, 2)
