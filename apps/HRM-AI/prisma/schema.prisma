// ═══════════════════════════════════════════════════════════════
// JOB REQUISITION
// ═══════════════════════════════════════════════════════════════

model JobRequisition {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  requisitionCode String  @unique @map("requisition_code")
  title           String
  departmentId    String  @map("department_id")
  reportingToId   String? @map("reporting_to_id")

  jobType  JobType  @default(FULL_TIME) @map("job_type")
  workMode WorkMode @default(ONSITE) @map("work_mode")
  location String?

  headcount   Int @default(1)
  filledCount Int @default(0) @map("filled_count")

  salaryMin     Decimal? @map("salary_min") @db.Decimal(18, 2)
  salaryMax     Decimal? @map("salary_max") @db.Decimal(18, 2)
  salaryDisplay String?  @map("salary_display")

  description  String? @db.Text
  requirements String? @db.Text
  benefits     String? @db.Text

  priority       String    @default("NORMAL")
  targetHireDate DateTime? @map("target_hire_date")

  status       RequisitionStatus @default(DRAFT)
  approvalNote String?           @map("approval_note")

  requestedById String    @map("requested_by_id")
  approvedById  String?   @map("approved_by_id")
  approvedAt    DateTime? @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  department  Department @relation(fields: [departmentId], references: [id])
  reportingTo Employee?  @relation("RequisitionReportingTo", fields: [reportingToId], references: [id])
  requestedBy User       @relation("RequisitionRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?      @relation("RequisitionApprovedBy", fields: [approvedById], references: [id])

  jobPostings  JobPosting[]
  applications Application[]

  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@map("job_requisitions")
}

// ═══════════════════════════════════════════════════════════════
// JOB POSTING
// ═══════════════════════════════════════════════════════════════

model JobPosting {
  id            String @id @default(cuid())
  tenantId      String @map("tenant_id")
  requisitionId String @map("requisition_id")

  title String
  slug  String

  description  String  @db.Text
  requirements String  @db.Text
  benefits     String? @db.Text

  location      String?
  jobType       JobType  @default(FULL_TIME) @map("job_type")
  workMode      WorkMode @default(ONSITE) @map("work_mode")
  salaryDisplay String?  @map("salary_display")

  isInternal Boolean @default(false) @map("is_internal")
  isPublic   Boolean @default(true) @map("is_public")

  status JobPostingStatus @default(DRAFT)

  publishedAt DateTime? @map("published_at")
  expiresAt   DateTime? @map("expires_at")

  viewCount        Int @default(0) @map("view_count")
  applicationCount Int @default(0) @map("application_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  requisition  JobRequisition @relation(fields: [requisitionId], references: [id])
  applications Application[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, isPublic, status])
  @@map("job_postings")
}

// ═══════════════════════════════════════════════════════════════
// CANDIDATE & APPLICATION
// ═══════════════════════════════════════════════════════════════

model Candidate {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")

  email    String
  phone    String?
  fullName String  @map("full_name")

  dateOfBirth DateTime? @map("date_of_birth")
  gender      String?
  address     String?

  cvUrl        String? @map("cv_url")
  cvFileName   String? @map("cv_file_name")
  portfolioUrl String? @map("portfolio_url")
  linkedinUrl  String? @map("linkedin_url")

  currentCompany  String?  @map("current_company")
  currentPosition String?  @map("current_position")
  currentSalary   Decimal? @map("current_salary") @db.Decimal(18, 2)
  expectedSalary  Decimal? @map("expected_salary") @db.Decimal(18, 2)

  yearsOfExperience Int?  @map("years_of_experience")
  skills            Json?
  education         Json?
  workHistory       Json? @map("work_history")

  notes String? @db.Text
  tags  Json?

  source       ApplicationSource @default(CAREERS_PAGE)
  referredById String?           @map("referred_by_id")

  isBlacklisted   Boolean @default(false) @map("is_blacklisted")
  blacklistReason String? @map("blacklist_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  referredBy   Employee?     @relation(fields: [referredById], references: [id])
  applications Application[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("candidates")
}

model Application {
  id            String  @id @default(cuid())
  tenantId      String  @map("tenant_id")
  candidateId   String  @map("candidate_id")
  requisitionId String  @map("requisition_id")
  jobPostingId  String? @map("job_posting_id")

  applicationCode String @unique @map("application_code")

  status ApplicationStatus @default(NEW)
  stage  Int               @default(1)

  screeningScore Int?    @map("screening_score")
  screeningNotes String? @map("screening_notes") @db.Text

  overallRating Decimal? @map("overall_rating") @db.Decimal(3, 1)

  coverLetter String? @map("cover_letter") @db.Text
  answers     Json?

  source ApplicationSource @default(CAREERS_PAGE)

  rejectionReason String?   @map("rejection_reason")
  rejectedAt      DateTime? @map("rejected_at")
  rejectedById    String?   @map("rejected_by_id")

  hiredAt   DateTime? @map("hired_at")
  hiredById String?   @map("hired_by_id")

  assignedToId String? @map("assigned_to_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  candidate   Candidate      @relation(fields: [candidateId], references: [id])
  requisition JobRequisition @relation(fields: [requisitionId], references: [id])
  jobPosting  JobPosting?    @relation(fields: [jobPostingId], references: [id])
  assignedTo  User?          @relation("ApplicationAssignedTo", fields: [assignedToId], references: [id])
  rejectedBy  User?          @relation("ApplicationRejectedBy", fields: [rejectedById], references: [id])
  hiredBy     User?          @relation("ApplicationHiredBy", fields: [hiredById], references: [id])

  interviews  Interview[]
  evaluations CandidateEvaluation[]
  offers      Offer[]
  activities  ApplicationActivity[]

  @@index([tenantId, status])
  @@index([tenantId, requisitionId])
  @@index([tenantId, candidateId])
  @@map("applications")
}

model ApplicationActivity {
  id            String @id @default(cuid())
  applicationId String @map("application_id")

  action      String
  description String
  oldValue    String? @map("old_value")
  newValue    String? @map("new_value")

  performedById String?  @map("performed_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  performedBy User?       @relation(fields: [performedById], references: [id])

  @@index([applicationId, createdAt])
  @@map("application_activities")
}

// ═══════════════════════════════════════════════════════════════
// INTERVIEW
// ═══════════════════════════════════════════════════════════════

model Interview {
  id            String @id @default(cuid())
