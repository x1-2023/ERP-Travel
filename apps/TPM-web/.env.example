# ═══════════════════════════════════════════════════════════════
# PROMO MASTER - Frontend Environment Variables
# Copy this file to .env and update values as needed
# ═══════════════════════════════════════════════════════════════

# API URL - Vite dev server sẽ proxy /api requests tới backend
# Để "/api" nếu chạy qua vite proxy (khuyến nghị cho development)
# Hoặc đặt full URL nếu muốn gọi trực tiếp: http://localhost:3000
VITE_API_URL=/api

# App Info
VITE_APP_NAME=PROMO MASTER
VITE_APP_VERSION=2.0.0

# Mock Data (MSW) - set "true" để dùng demo data không cần backend
VITE_ENABLE_MOCK=false

# MSW toggle (set "true" để bật Mock Service Worker)
VITE_ENABLE_MSW=false

# TPO Engine (Trade Promotion Optimization)
# Local: http://localhost:8001/api/v1
# Remote: https://tpo-engine.onrender.com/api/v1
VITE_TPO_API_URL=https://tpo-engine.onrender.com/api/v1
