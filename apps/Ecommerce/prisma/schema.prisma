// ============================================================
// E-commerce Module — Prisma Schema
// Supports: B2B + B2C, Multi-storefront, Vietnamese market
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/ecommerce-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum StoreStatus {
  ACTIVE
  MAINTENANCE
  SUSPENDED
  CLOSED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  BUNDLE
  SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  RETURNED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  COD           // Cash on delivery — phổ biến VN
  BANK_TRANSFER // Chuyển khoản ngân hàng
  MOMO          // Ví MoMo
  VNPAY         // VNPay gateway
  ZALOPAY       // ZaloPay
  CREDIT_CARD   // Visa/Mastercard
  DEBIT_CARD    // Thẻ ghi nợ
  INSTALLMENT   // Trả góp
  WALLET        // Internal wallet
}

enum ShippingStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  FAILED
}

enum ShippingProvider {
  GHN           // Giao Hàng Nhanh
  GHTK          // Giao Hàng Tiết Kiệm
  VIETTEL_POST  // Viettel Post
  VN_POST       // Vietnam Post
  J_AND_T       // J&T Express
  NINJA_VAN     // Ninja Van
  GRAB_EXPRESS  // GrabExpress
  SELF_DELIVERY // Tự giao
  DIGITAL       // Digital delivery (no shipping)
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  BUNDLE_PRICE
}

enum PromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
  EXPIRED
}

// ─── Storefront ──────────────────────────────────────────────

model Storefront {
  id          String        @id @default(uuid())
  tenantId    String
  name        String        // Tên cửa hàng
  slug        String        @unique
  domain      String?       // Custom domain
  description String?
  logo        String?
  favicon     String?
  status      StoreStatus   @default(ACTIVE)

  // Settings
  currency    String        @default("VND")
  locale      String        @default("vi-VN")
  timezone    String        @default("Asia/Ho_Chi_Minh")
  taxIncluded Boolean       @default(true) // VN: giá đã bao gồm VAT

  // SEO
  metaTitle       String?
  metaDescription String?

  // Theme
  theme       Json?         // { primaryColor, layout, headerStyle, ... }

  products    StorefrontProduct[]
  orders      Order[]
  promotions  Promotion[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([slug])
}

// ─── Product Catalog ─────────────────────────────────────────

model Category {
  id          String     @id @default(uuid())
  tenantId    String
  name        String     // Tên danh mục
  nameEn      String?    // English name
  slug        String
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)

  products    ProductCategory[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, slug])
  @@index([parentId])
}

model Product {
  id             String          @id @default(uuid())
  tenantId       String
  sku            String          // Mã sản phẩm
  barcode        String?         // Mã vạch
  name           String          // Tên sản phẩm
  nameEn         String?
  slug           String
  description    String?
  shortDescription String?
  type           ProductType     @default(PHYSICAL)
  status         ProductStatus   @default(DRAFT)

  // Pricing (VND)
  basePrice      Decimal         @db.Decimal(18, 4) // Giá gốc
  salePrice      Decimal?        @db.Decimal(18, 4) // Giá khuyến mãi
  costPrice      Decimal?        @db.Decimal(18, 4) // Giá vốn
  vatRate        Decimal         @default(10) @db.Decimal(5, 2) // % VAT

  // Inventory
  trackInventory Boolean         @default(true)
  stockQuantity  Int             @default(0)
  lowStockAlert  Int             @default(5)

  // Physical
  weight         Decimal?        @db.Decimal(10, 2) // kg
  length         Decimal?        @db.Decimal(10, 2) // cm
  width          Decimal?        @db.Decimal(10, 2)
  height         Decimal?        @db.Decimal(10, 2)

  // SEO
  metaTitle       String?
  metaDescription String?

  // Master data link
  masterProductId String?        // Link to @erp/master-data Product

  images         ProductImage[]
  variants       ProductVariant[]
  categories     ProductCategory[]
  storefronts    StorefrontProduct[]
  cartItems      CartItem[]
  orderLines     OrderLine[]
  reviews        Review[]
  inventoryLogs  InventoryLog[]
  bundleItems    BundleItem[]    @relation("BundleParent")
  inBundles      BundleItem[]    @relation("BundleChild")

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@unique([tenantId, sku])
  @@unique([tenantId, slug])
  @@index([status])
  @@index([masterProductId])
}

model ProductVariant {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  sku         String
  name        String    // e.g., "Đỏ - XL"

  // Variant attributes
  attributes  Json      // { color: "Đỏ", size: "XL" }

  price       Decimal?  @db.Decimal(18, 4) // Override base price
  costPrice   Decimal?  @db.Decimal(18, 4)
  stock       Int       @default(0)
  barcode     String?
  image       String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)

  cartItems   CartItem[]
  orderLines  OrderLine[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, sku])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)

  createdAt DateTime @default(now())
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])
  sortOrder  Int      @default(0)

  @@id([productId, categoryId])
}

model StorefrontProduct {
  storefrontId String
  productId    String
  storefront   Storefront @relation(fields: [storefrontId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
  isFeatured   Boolean    @default(false)
  sortOrder    Int        @default(0)

  @@id([storefrontId, productId])
}

model BundleItem {
  id          String  @id @default(uuid())
  bundleId    String
  bundle      Product @relation("BundleParent", fields: [bundleId], references: [id])
  productId   String
  product     Product @relation("BundleChild", fields: [productId], references: [id])
  quantity    Int     @default(1)
  sortOrder   Int     @default(0)

  @@unique([bundleId, productId])
}

// ─── Shopping Cart ───────────────────────────────────────────

model Cart {
  id          String     @id @default(uuid())
  tenantId    String
  customerId  String?    // Null for guest cart
  sessionId   String?    // Guest session tracking
  status      CartStatus @default(ACTIVE)

  // Totals (recalculated on change)
  subtotal    Decimal    @default(0) @db.Decimal(18, 4)
  taxAmount   Decimal    @default(0) @db.Decimal(18, 4)
  shippingFee Decimal    @default(0) @db.Decimal(18, 4)
  discount    Decimal    @default(0) @db.Decimal(18, 4)
  total       Decimal    @default(0) @db.Decimal(18, 4)

  couponCode  String?

  items       CartItem[]

  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId, customerId])
  @@index([sessionId])
}

model CartItem {
  id         String          @id @default(uuid())
  cartId     String
  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int
  unitPrice  Decimal         @db.Decimal(18, 4)

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([cartId, productId, variantId])
}

// ─── Orders ──────────────────────────────────────────────────

model Order {
  id            String        @id @default(uuid())
  tenantId      String
  storefrontId  String
  storefront    Storefront    @relation(fields: [storefrontId], references: [id])
  orderNumber   String        @unique // DH-2026-000001
  customerId    String
  status        OrderStatus   @default(PENDING)

  // Customer snapshot (denormalized)
  customerName  String
  customerEmail String?
  customerPhone String

  // Addresses
  shippingAddress Json        // { street, ward, district, city, province, postalCode }
  billingAddress  Json?

  // Totals (VND)
  subtotal      Decimal       @db.Decimal(18, 4)
  taxAmount     Decimal       @db.Decimal(18, 4)
  shippingFee   Decimal       @db.Decimal(18, 4)
  discount      Decimal       @default(0) @db.Decimal(18, 4)
  total         Decimal       @db.Decimal(18, 4)

  // Currency
  currency      String        @default("VND")
  exchangeRate  Decimal       @default(1) @db.Decimal(18, 6)

  couponCode    String?
  notes         String?       // Ghi chú đơn hàng
  internalNotes String?

  // Timestamps
  confirmedAt   DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?

  // Accounting link
  journalEntryId String?     // Link to Accounting GL
  invoiceId      String?     // Link to AR Invoice

  lines         OrderLine[]
  payments      Payment[]
  shipments     Shipment[]
  timeline      OrderTimeline[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderLine {
  id          String          @id @default(uuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  // Snapshot at order time
  productName String
  sku         String

  quantity    Int
  unitPrice   Decimal         @db.Decimal(18, 4)
  discount    Decimal         @default(0) @db.Decimal(18, 4)
  taxRate     Decimal         @db.Decimal(5, 2)
  taxAmount   Decimal         @db.Decimal(18, 4)
  lineTotal   Decimal         @db.Decimal(18, 4)

  createdAt   DateTime        @default(now())
}

model OrderTimeline {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  note      String?
  actor     String?  // userId or "system"
  metadata  Json?

  createdAt DateTime @default(now())
}

// ─── Payments ────────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  transactionId   String?       @unique // Gateway transaction ID
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)

  amount          Decimal       @db.Decimal(18, 4)
  currency        String        @default("VND")

  // Gateway response
  gatewayProvider String?       // vnpay, momo, zalopay
  gatewayResponse Json?         // Raw response from gateway
  gatewayUrl      String?       // Redirect URL for payment

  // Refund
  refundAmount    Decimal?      @db.Decimal(18, 4)
  refundReason    String?
  refundedAt      DateTime?

  paidAt          DateTime?
  expiresAt       DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([transactionId])
}

// ─── Shipping ────────────────────────────────────────────────

model Shipment {
  id              String           @id @default(uuid())
  orderId         String
  order           Order            @relation(fields: [orderId], references: [id])
  provider        ShippingProvider
  trackingNumber  String?
  trackingUrl     String?
  status          ShippingStatus   @default(PENDING)

  // Shipping details
  weight          Decimal?         @db.Decimal(10, 2)
  shippingFee     Decimal          @db.Decimal(18, 4)
  codAmount       Decimal?         @db.Decimal(18, 4) // COD collection amount

  estimatedDelivery DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  // Provider response
  providerResponse  Json?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([orderId])
  @@index([trackingNumber])
}

// ─── Promotions & Coupons ────────────────────────────────────

model Promotion {
  id              String          @id @default(uuid())
  tenantId        String
  storefrontId    String?
  storefront      Storefront?     @relation(fields: [storefrontId], references: [id])
  name            String
  description     String?
  code            String?         @unique // Coupon code
  type            DiscountType
  status          PromotionStatus @default(DRAFT)

  // Discount value
  value           Decimal         @db.Decimal(18, 4) // % or fixed amount
  maxDiscount     Decimal?        @db.Decimal(18, 4) // Cap for percentage

  // Conditions
  minOrderAmount  Decimal?        @db.Decimal(18, 4)
  minQuantity     Int?
  applicableProducts Json?        // Product IDs or category IDs
  applicableCustomers Json?       // Customer group IDs

  // Limits
  usageLimit      Int?            // Total uses allowed
  usageCount      Int             @default(0)
  perCustomerLimit Int?           // Uses per customer

  // Schedule
  startDate       DateTime
  endDate         DateTime

  // Buy X Get Y
  buyQuantity     Int?
  getQuantity     Int?
  getProductIds   Json?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId])
  @@index([code])
  @@index([status, startDate, endDate])
}

// ─── Reviews ─────────────────────────────────────────────────

model Review {
  id          String       @id @default(uuid())
  tenantId    String
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  customerId  String
  orderId     String?      // Verified purchase
  rating      Int          // 1-5
  title       String?
  comment     String?
  images      Json?        // Array of image URLs
  status      ReviewStatus @default(PENDING)

  // Seller response
  reply       String?
  repliedAt   DateTime?
  repliedBy   String?

  isVerified  Boolean      @default(false) // Verified purchase

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([productId, status])
  @@index([customerId])
}

// ─── Inventory Log ───────────────────────────────────────────

model InventoryLog {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  variantId   String?

  type        String   // ORDER, RETURN, ADJUSTMENT, RESTOCK, SYNC
  quantity    Int      // Positive = in, Negative = out
  previousQty Int
  newQty      Int

  reference   String?  // Order ID, adjustment note, etc.
  actor       String?  // userId or "system"

  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([tenantId, createdAt])
}
