{
  "name": "vierp-hrm-testing",
  "version": "1.0.0",
  "description": "LAC VIET HR - Comprehensive E2E and Stress Testing Suite",
  "author": "LAC VIET",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    
    "test:chrome": "playwright test --project=chrome",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    
    "test:auth": "playwright test tests/e2e/auth/",
    "test:employees": "playwright test tests/e2e/employees/",
    "test:leave": "playwright test tests/e2e/leave/",
    "test:recruitment": "playwright test tests/e2e/recruitment/",
    "test:performance": "playwright test tests/e2e/performance/",
    "test:attendance": "playwright test tests/e2e/attendance/",
    "test:payroll": "playwright test tests/e2e/payroll/",
    "test:workflow": "playwright test tests/e2e/workflow/",
    "test:dashboard": "playwright test tests/e2e/dashboard/",
    
    "test:smoke": "playwright test --grep @smoke",
    "test:critical": "playwright test --grep @critical",
    "test:regression": "playwright test --grep @regression",
    
    "stress": "k6 run tests/stress/k6-comprehensive-stress.js",
    "stress:smoke": "k6 run --vus 3 --duration 1m tests/stress/k6-comprehensive-stress.js",
    "stress:load": "k6 run -e SCENARIO=load tests/stress/k6-comprehensive-stress.js",
    "stress:spike": "k6 run -e SCENARIO=spike tests/stress/k6-comprehensive-stress.js",
    "stress:soak": "k6 run -e SCENARIO=soak tests/stress/k6-comprehensive-stress.js",
    "stress:breakpoint": "k6 run -e SCENARIO=breakpoint tests/stress/k6-comprehensive-stress.js",
    
    "stress:employee": "k6 run -e MODULE=employee tests/stress/k6-module-stress.js",
    "stress:leave": "k6 run -e MODULE=leave tests/stress/k6-module-stress.js",
    "stress:recruitment": "k6 run -e MODULE=recruitment tests/stress/k6-module-stress.js",
    "stress:attendance": "k6 run -e MODULE=attendance tests/stress/k6-module-stress.js",
    "stress:payroll": "k6 run -e MODULE=payroll tests/stress/k6-module-stress.js",
    "stress:all-modules": "k6 run tests/stress/k6-module-stress.js",

    "stress:write": "k6 run tests/stress/k6-write-operations.js",
    "stress:write:creates": "k6 run -e SCENARIO=concurrent_creates tests/stress/k6-write-operations.js",
    "stress:write:updates": "k6 run -e SCENARIO=concurrent_updates tests/stress/k6-write-operations.js",
    "stress:write:mixed": "k6 run -e SCENARIO=mixed_workload tests/stress/k6-write-operations.js",
    "stress:write:transactions": "k6 run -e SCENARIO=transaction_heavy tests/stress/k6-write-operations.js",
    
    "report": "playwright show-report",
    "report:open": "open reports/html/index.html",
    
    "codegen": "playwright codegen",
    "codegen:mobile": "playwright codegen --device='iPhone 13'",
    
    "clean": "rm -rf test-results reports .auth",
    "ci": "CI=true playwright test"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.0",
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
