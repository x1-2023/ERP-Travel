# ============================================
# LAC VIET HR - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.local and update values
# ============================================

# Database (Required)
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vierp_hr?schema=public"

# Authentication (Required)
# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-in-production"
AUTH_SECRET="your-super-secret-key-min-32-chars-change-in-production"

# App Configuration (Required)
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Your Company HR"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Configuration (Optional - for AI features)
ANTHROPIC_API_KEY="sk-ant-xxxxx"

# Email Configuration (Optional)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-password"
SMTP_FROM="noreply@your-domain.com"

# Redis Configuration (Optional - for caching)
REDIS_URL="redis://localhost:6379"

# File Storage (Optional)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Field-Level Encryption (Optional - for PII data at rest)
# 32-byte hex key for AES-256-GCM encryption of sensitive fields (CCCD, bank account)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=""

# Monitoring (Optional - Production)
SENTRY_DSN=""
LOG_LEVEL="info"

# ============================================
# PRODUCTION NOTES:
# - Always change NEXTAUTH_SECRET and AUTH_SECRET
# - Use strong, unique secrets (min 32 characters)
# - Set NODE_ENV="production"
# - Use proper database credentials
# - Enable SENTRY_DSN for error tracking
# ============================================
