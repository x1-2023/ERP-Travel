# ════════════════════════════════════════════════════════════════════════════════
# LAC VIET HR - SECURITY ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ════════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# JWT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────

# Main JWT secret (minimum 32 characters, use a strong random string)
# Generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Separate secret for refresh tokens (optional but recommended)
JWT_REFRESH_SECRET=your-refresh-token-secret-also-32-plus-characters

# ─────────────────────────────────────────────────────────────────────────────────
# CSRF PROTECTION
# ─────────────────────────────────────────────────────────────────────────────────

# CSRF secret (minimum 32 characters)
# Falls back to JWT_SECRET if not set
CSRF_SECRET=your-csrf-secret-key-minimum-32-characters

# ─────────────────────────────────────────────────────────────────────────────────
# SESSION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────

# Session encryption key
SESSION_SECRET=your-session-secret-key-minimum-32-characters

# Session duration in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# Inactivity timeout in seconds (default: 1800 = 30 minutes)
SESSION_INACTIVITY_TIMEOUT=1800

# Maximum concurrent sessions per user (default: 5)
MAX_CONCURRENT_SESSIONS=5

# ─────────────────────────────────────────────────────────────────────────────────
# REDIS (for production session/rate-limit storage)
# ─────────────────────────────────────────────────────────────────────────────────

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis password (if required)
REDIS_PASSWORD=

# Redis key prefix
REDIS_PREFIX=vierp-hrm:

# ─────────────────────────────────────────────────────────────────────────────────
# PASSWORD POLICY
# ─────────────────────────────────────────────────────────────────────────────────

# Minimum password length (default: 12)
PASSWORD_MIN_LENGTH=12

# Password expiry in days (default: 90, set to 0 to disable)
PASSWORD_EXPIRY_DAYS=90

# Number of previous passwords to remember (default: 5)
PASSWORD_HISTORY_COUNT=5

# Bcrypt salt rounds (default: 12, increase for more security at cost of speed)
BCRYPT_SALT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────────
# ACCOUNT LOCKOUT
# ─────────────────────────────────────────────────────────────────────────────────

# Maximum failed login attempts before lockout (default: 5)
MAX_LOGIN_ATTEMPTS=5

# Lockout window in minutes (default: 15)
LOGIN_ATTEMPT_WINDOW_MINUTES=15

# Initial lockout duration in minutes (default: 5)
INITIAL_LOCKOUT_MINUTES=5

# ─────────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────────

# API rate limit per minute (default: 100)
API_RATE_LIMIT=100

# Authentication rate limit per 15 minutes (default: 5)
AUTH_RATE_LIMIT=5

# Heavy operations rate limit per minute (default: 10)
HEAVY_RATE_LIMIT=10

# ─────────────────────────────────────────────────────────────────────────────────
# MFA CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────

# MFA issuer name (shown in authenticator apps)
MFA_ISSUER=LAC VIET HR

# Number of backup codes to generate (default: 10)
MFA_BACKUP_CODES_COUNT=10

# ─────────────────────────────────────────────────────────────────────────────────
# AUDIT LOGGING
# ─────────────────────────────────────────────────────────────────────────────────

# Enable audit logging (default: true)
ENABLE_AUDIT_LOGGING=true

# Audit log retention in days (default: 90)
AUDIT_LOG_RETENTION_DAYS=90

# Log level for console (default: warning in production, debug in development)
AUDIT_LOG_LEVEL=warning

# ─────────────────────────────────────────────────────────────────────────────────
# SECURITY ALERTS
# ─────────────────────────────────────────────────────────────────────────────────

# Slack webhook for security alerts (optional)
SECURITY_ALERT_SLACK_WEBHOOK=

# Email for security alerts (optional)
SECURITY_ALERT_EMAIL=security@your-company.com

# ─────────────────────────────────────────────────────────────────────────────────
# ALLOWED ORIGINS (for CORS and CSRF)
# ─────────────────────────────────────────────────────────────────────────────────

# Application URL
NEXT_PUBLIC_APP_URL=https://vierp-hrm.com

# API URL (if different from app URL)
NEXT_PUBLIC_API_URL=https://api.vierp-hrm.com

# Additional allowed origins (comma-separated)
ALLOWED_ORIGINS=https://www.vierp-hrm.com,https://admin.vierp-hrm.com

# ─────────────────────────────────────────────────────────────────────────────────
# ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────────

# Data encryption key (for encrypting sensitive data at rest)
# Generate with: openssl rand -base64 32
DATA_ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# ─────────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT OVERRIDES (only for local development)
# ─────────────────────────────────────────────────────────────────────────────────

# Disable HTTPS requirement (NEVER in production!)
# DISABLE_HTTPS=true

# Disable CSRF protection (NEVER in production!)
# DISABLE_CSRF=true

# Disable rate limiting (NEVER in production!)
# DISABLE_RATE_LIMITING=true
