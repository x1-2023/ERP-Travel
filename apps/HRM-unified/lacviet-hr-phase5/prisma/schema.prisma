// ═══════════════════════════════════════════════════════════════════════════════
// LAC VIET HR - PHASE 5: COMPENSATION & SUCCESSION PLANNING
// Prisma Schema Extension
// ═══════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────────
// COMPENSATION PLANNING
// ─────────────────────────────────────────────────────────────────────────────────

/// Salary Grade - Job grades with salary ranges
model SalaryGrade {
  id              String   @id @default(cuid())
  code            String   @unique // G1, G2, L1, L2, M1
  name            String   // Junior, Senior, Lead, Manager
  level           Int      // 1-10 for sorting
  description     String?
  
  // Salary range
  minSalary       Decimal  @db.Decimal(15, 2)
  midSalary       Decimal  @db.Decimal(15, 2)
  maxSalary       Decimal  @db.Decimal(15, 2)
  currency        String   @default("VND")
  
  // Compa-ratio thresholds
  minCompaRatio   Decimal  @default(0.80) @db.Decimal(5, 2)
  maxCompaRatio   Decimal  @default(1.20) @db.Decimal(5, 2)
  
  isActive        Boolean  @default(true)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String
  
  positions       Position[]
  employees       EmployeeCompensation[]
  salaryBands     SalaryBand[]
  
  @@index([code])
  @@index([level])
  @@map("salary_grades")
}

/// Salary Band - Salary ranges by job family
model SalaryBand {
  id              String   @id @default(cuid())
  gradeId         String
  jobFamilyId     String?
  name            String
  
  minimum         Decimal  @db.Decimal(15, 2)
  firstQuartile   Decimal  @db.Decimal(15, 2)
  midpoint        Decimal  @db.Decimal(15, 2)
  thirdQuartile   Decimal  @db.Decimal(15, 2)
  maximum         Decimal  @db.Decimal(15, 2)
  
  marketMedian    Decimal? @db.Decimal(15, 2)
  marketSource    String?
  marketDate      DateTime?
  
  currency        String   @default("VND")
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  grade           SalaryGrade @relation(fields: [gradeId], references: [id])
  jobFamily       JobFamily?  @relation(fields: [jobFamilyId], references: [id])
  
  @@unique([gradeId, jobFamilyId])
  @@map("salary_bands")
}

/// Job Family - Grouping of similar jobs
model JobFamily {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  parent      JobFamily?  @relation("JobFamilyHierarchy", fields: [parentId], references: [id])
  children    JobFamily[] @relation("JobFamilyHierarchy")
  salaryBands SalaryBand[]
  positions   Position[]
  
  @@map("job_families")
}

/// Employee Compensation - Current and historical compensation
model EmployeeCompensation {
  id                  String   @id @default(cuid())
  employeeId          String
  
  baseSalary          Decimal  @db.Decimal(15, 2)
  currency            String   @default("VND")
  payFrequency        PayFrequency @default(MONTHLY)
  
  gradeId             String?
  compaRatio          Decimal? @db.Decimal(5, 4)
  rangePosition       Decimal? @db.Decimal(5, 2)
  marketRatio         Decimal? @db.Decimal(5, 4)
  
  bonusTargetPercent  Decimal? @db.Decimal(5, 2)
  allowances          Json?
  totalAllowances     Decimal? @db.Decimal(15, 2)
  totalCash           Decimal? @db.Decimal(15, 2)
  
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  isCurrent           Boolean  @default(true)
  
  changeReason        CompChangeReason?
  changePercent       Decimal? @db.Decimal(5, 2)
  previousSalary      Decimal? @db.Decimal(15, 2)
  approvedById        String?
  approvedAt          DateTime?
  notes               String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  employee            Employee    @relation(fields: [employeeId], references: [id])
  grade               SalaryGrade? @relation(fields: [gradeId], references: [id])
  
  @@index([employeeId])
  @@index([isCurrent])
  @@map("employee_compensations")
}

enum PayFrequency {
  HOURLY
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  ANNUALLY
}

enum CompChangeReason {
  NEW_HIRE
  PROMOTION
  MERIT_INCREASE
  MARKET_ADJUSTMENT
  EQUITY_ADJUSTMENT
  DEMOTION
  TRANSFER
  ANNUAL_REVIEW
  RETENTION
  CORRECTION
  OTHER
}

/// Compensation Review Cycle
model CompReviewCycle {
  id                  String   @id @default(cuid())
  name                String
  fiscalYear          Int
  
  totalBudget         Decimal  @db.Decimal(18, 2)
  meritPoolPercent    Decimal  @db.Decimal(5, 2)
  promoPoolPercent    Decimal  @db.Decimal(5, 2)
  equityPoolPercent   Decimal  @db.Decimal(5, 2)
  
  allocatedBudget     Decimal? @db.Decimal(18, 2)
  spentBudget         Decimal? @db.Decimal(18, 2)
  
  meritMatrixId       String?
  guidelines          Json?
  
  planningStart       DateTime
  managerInputStart   DateTime
  managerInputEnd     DateTime
  hrReviewStart       DateTime
  hrReviewEnd         DateTime
  calibrationStart    DateTime
  calibrationEnd      DateTime
  approvalDeadline    DateTime
  effectiveDate       DateTime
  
  status              ReviewCycleStatus @default(DRAFT)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String
  
  meritMatrix         MeritMatrix? @relation(fields: [meritMatrixId], references: [id])
  recommendations     CompRecommendation[]
  deptBudgets         DeptBudget[]
  
  @@index([fiscalYear])
  @@index([status])
  @@map("comp_review_cycles")
}

enum ReviewCycleStatus {
  DRAFT
  PLANNING
  MANAGER_INPUT
  HR_REVIEW
  CALIBRATION
  APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  CANCELLED
}

/// Merit Matrix
model MeritMatrix {
  id          String   @id @default(cuid())
  name        String
  description String?
  fiscalYear  Int
  matrixData  Json     // { performance: { compaRange: percent } }
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  
  cycles      CompReviewCycle[]
  
  @@map("merit_matrices")
}

/// Department Budget
model DeptBudget {
  id              String   @id @default(cuid())
  cycleId         String
  departmentId    String
  
  totalBudget     Decimal  @db.Decimal(18, 2)
  meritBudget     Decimal  @db.Decimal(18, 2)
  promoBudget     Decimal  @db.Decimal(18, 2)
  equityBudget    Decimal  @db.Decimal(18, 2)
  
  meritSpent      Decimal  @default(0) @db.Decimal(18, 2)
  promoSpent      Decimal  @default(0) @db.Decimal(18, 2)
  equitySpent     Decimal  @default(0) @db.Decimal(18, 2)
  
  eligibleCount   Int
  totalPayroll    Decimal? @db.Decimal(18, 2)
  avgCompaRatio   Decimal? @db.Decimal(5, 4)
  
  isApproved      Boolean  @default(false)
  approvedById    String?
  approvedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  cycle           CompReviewCycle @relation(fields: [cycleId], references: [id])
  department      Department @relation(fields: [departmentId], references: [id])
  
  @@unique([cycleId, departmentId])
  @@map("dept_budgets")
}

/// Compensation Recommendation
model CompRecommendation {
  id                    String   @id @default(cuid())
  cycleId               String
  employeeId            String
  
  currentSalary         Decimal  @db.Decimal(15, 2)
  currentGradeId        String?
  currentCompaRatio     Decimal? @db.Decimal(5, 4)
  performanceRating     String?
  
  recommendationType    RecommendationType
  proposedSalary        Decimal  @db.Decimal(15, 2)
  proposedGradeId       String?
  increaseAmount        Decimal  @db.Decimal(15, 2)
  increasePercent       Decimal  @db.Decimal(5, 2)
  
  meritPercent          Decimal? @db.Decimal(5, 2)
  promoPercent          Decimal? @db.Decimal(5, 2)
  equityPercent         Decimal? @db.Decimal(5, 2)
  
  newCompaRatio         Decimal? @db.Decimal(5, 4)
  
  status                RecommendationStatus @default(DRAFT)
  
  managerId             String?
  managerComments       String?
  managerSubmittedAt    DateTime?
  
  hrReviewerId          String?
  hrComments            String?
  hrReviewedAt          DateTime?
  
  isCalibrated          Boolean  @default(false)
  calibrationNotes      String?
  
  approvedById          String?
  approvedAt            DateTime?
  
  isException           Boolean  @default(false)
  exceptionReason       String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  cycle                 CompReviewCycle @relation(fields: [cycleId], references: [id])
  employee              Employee @relation(fields: [employeeId], references: [id])
  
  @@unique([cycleId, employeeId])
  @@index([status])
  @@map("comp_recommendations")
}

enum RecommendationType {
  NO_CHANGE
  MERIT_ONLY
  PROMOTION
  MARKET_ADJUSTMENT
  EQUITY_ADJUSTMENT
  COMBINED
  LUMP_SUM
}

enum RecommendationStatus {
  DRAFT
  SUBMITTED
  HR_REVIEW
  CALIBRATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PROCESSED
}

/// Total Rewards Statement
model TotalRewardsStatement {
  id                  String   @id @default(cuid())
  employeeId          String
  fiscalYear          Int
  generatedAt         DateTime @default(now())
  
  baseSalary          Decimal  @db.Decimal(15, 2)
  bonusPaid           Decimal? @db.Decimal(15, 2)
  overtimePaid        Decimal? @db.Decimal(15, 2)
  allowancesPaid      Decimal? @db.Decimal(15, 2)
  totalCash           Decimal  @db.Decimal(15, 2)
  
  healthInsurance     Decimal? @db.Decimal(15, 2)
  socialInsurance     Decimal? @db.Decimal(15, 2)
  otherBenefits       Decimal? @db.Decimal(15, 2)
  totalBenefits       Decimal? @db.Decimal(15, 2)
  
  totalRewards        Decimal  @db.Decimal(15, 2)
  
  breakdownJson       Json?
  pdfUrl              String?
  viewedAt            DateTime?
  acknowledgedAt      DateTime?
  
  employee            Employee @relation(fields: [employeeId], references: [id])
  
  @@unique([employeeId, fiscalYear])
  @@map("total_rewards_statements")
}

// ─────────────────────────────────────────────────────────────────────────────────
// SUCCESSION PLANNING
// ─────────────────────────────────────────────────────────────────────────────────

/// Key Position - Critical positions requiring succession
model KeyPosition {
  id                  String   @id @default(cuid())
  positionId          String   @unique
  
  criticalityLevel    CriticalityLevel
  criticalityScore    Int      // 1-100
  criticalityFactors  Json?
  
  vacancyRisk         RiskLevel
  readinessRisk       RiskLevel
  overallRisk         RiskLevel
  riskScore           Int      // 1-100
  
  businessImpact      String?
  revenueImpact       Decimal? @db.Decimal(18, 2)
  
  minSuccessors       Int      @default(2)
  idealSuccessors     Int      @default(3)
  keyCompetencies     Json?
  keyExperiences      Json?
  
  incumbentId         String?
  incumbentTenure     Int?     // months
  incumbentRetireDate DateTime?
  incumbentFlightRisk RiskLevel?
  
  planStatus          SuccessionPlanStatus @default(NOT_STARTED)
  emergencySuccessorId String?
  
  lastReviewDate      DateTime?
  nextReviewDate      DateTime?
  
  notes               String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String
  
  position            Position @relation(fields: [positionId], references: [id])
  incumbent           Employee? @relation("KeyPositionIncumbent", fields: [incumbentId], references: [id])
  emergencySuccessor  Employee? @relation("EmergencySuccessor", fields: [emergencySuccessorId], references: [id])
  successors          Successor[]
  actions             SuccessionAction[]
  
  @@index([criticalityLevel])
  @@index([overallRisk])
  @@map("key_positions")
}

enum CriticalityLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum SuccessionPlanStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NEEDS_UPDATE
  AT_RISK
}

/// Successor - Identified successors for key positions
model Successor {
  id                  String   @id @default(cuid())
  keyPositionId       String
  employeeId          String
  
  priority            Int      // 1=primary, 2=secondary
  
  readinessLevel      ReadinessLevel
  readinessScore      Int      // 1-100
  timeToReady         TimeToReady
  estimatedReadyDate  DateTime?
  
  // Assessment (1-5)
  technicalFit        Int
  leadershipFit       Int
  culturalFit         Int
  strategicFit        Int
  performanceHistory  Int
  potentialRating     Int
  overallFit          Decimal  @db.Decimal(3, 2)
  
  competencyGaps      Json?
  experienceGaps      Json?
  
  isWilling           Boolean  @default(true)
  willingnessNotes    String?
  isRelocationReady   Boolean  @default(true)
  mobilityConstraints String?
  
  status              SuccessorStatus @default(IDENTIFIED)
  
  strengths           String?
  developmentAreas    String?
  managerComments     String?
  hrComments          String?
  
  identifiedDate      DateTime @default(now())
  identifiedById      String?
  lastAssessmentDate  DateTime?
  nextAssessmentDate  DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  keyPosition         KeyPosition @relation(fields: [keyPositionId], references: [id], onDelete: Cascade)
  employee            Employee @relation(fields: [employeeId], references: [id])
  devPlans            DevPlan[]
  assessments         SuccessorAssessment[]
  
  @@unique([keyPositionId, employeeId])
  @@index([readinessLevel])
  @@index([status])
  @@map("successors")
}

enum ReadinessLevel {
  READY_NOW
  READY_1_YEAR
  READY_2_YEARS
  READY_3_PLUS
  NOT_READY
}

enum TimeToReady {
  IMMEDIATE
  SHORT_TERM     // 3-6 months
  MEDIUM_TERM    // 6-12 months
  LONG_TERM      // 1-2 years
  EXTENDED       // 2-3 years
  VERY_LONG      // 3+ years
}

enum SuccessorStatus {
  IDENTIFIED
  ASSESSING
  DEVELOPING
  READY
  PROMOTED
  WITHDRAWN
  ON_HOLD
  NOT_SUITABLE
}

/// Successor Assessment History
model SuccessorAssessment {
  id                  String   @id @default(cuid())
  successorId         String
  assessmentPeriod    String
  assessmentDate      DateTime @default(now())
  
  technicalFit        Int
  leadershipFit       Int
  culturalFit         Int
  strategicFit        Int
  performanceHistory  Int
  potentialRating     Int
  overallFit          Decimal  @db.Decimal(3, 2)
  readinessScore      Int
  readinessLevel      ReadinessLevel
  timeToReady         TimeToReady
  
  competencyGaps      Json?
  experienceGaps      Json?
  
  assessorComments    String?
  recommendations     String?
  
  assessedById        String
  
  createdAt           DateTime @default(now())
  
  successor           Successor @relation(fields: [successorId], references: [id], onDelete: Cascade)
  
  @@index([successorId])
  @@map("successor_assessments")
}

/// Development Plan
model DevPlan {
  id              String   @id @default(cuid())
  successorId     String
  
  name            String
  description     String?
  focus           Json?
  objectives      Json?
  
  startDate       DateTime
  targetEndDate   DateTime
  actualEndDate   DateTime?
  
  status          DevPlanStatus @default(NOT_STARTED)
  progressPercent Int      @default(0)
  
  mentorId        String?
  coachId         String?
  sponsorId       String?
  
  budget          Decimal? @db.Decimal(15, 2)
  budgetSpent     Decimal? @db.Decimal(15, 2)
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String
  
  successor       Successor @relation(fields: [successorId], references: [id], onDelete: Cascade)
  mentor          Employee? @relation("DevMentor", fields: [mentorId], references: [id])
  coach           Employee? @relation("DevCoach", fields: [coachId], references: [id])
  sponsor         Employee? @relation("DevSponsor", fields: [sponsorId], references: [id])
  activities      DevActivity[]
  
  @@map("dev_plans")
}

enum DevPlanStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

/// Development Activity
model DevActivity {
  id              String   @id @default(cuid())
  planId          String
  
  type            DevActivityType
  category        String?
  name            String
  description     String?
  
  competencyId    String?
  targetLevel     Int?
  
  startDate       DateTime?
  dueDate         DateTime
  completedDate   DateTime?
  
  status          ActivityStatus @default(NOT_STARTED)
  progressPercent Int      @default(0)
  
  outcome         String?
  effectiveness   Int?     // 1-5
  
  provider        String?
  resourceUrl     String?
  cost            Decimal? @db.Decimal(15, 2)
  hours           Int?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  plan            DevPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  @@map("dev_activities")
}

enum DevActivityType {
  TRAINING
  CERTIFICATION
  STRETCH_ASSIGNMENT
  JOB_ROTATION
  SHADOWING
  MENTORING
  COACHING
  PROJECT_LEAD
  ACTING_ROLE
  CROSS_FUNCTIONAL
  EXTERNAL
  ACADEMIC
  SELF_STUDY
  OTHER
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DEFERRED
}

/// Succession Action
model SuccessionAction {
  id              String   @id @default(cuid())
  keyPositionId   String
  
  actionType      SuccessionActionType
  title           String
  description     String?
  priority        Int      @default(2)
  
  assigneeId      String?
  dueDate         DateTime?
  completedDate   DateTime?
  
  status          ActivityStatus @default(NOT_STARTED)
  outcome         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String
  
  keyPosition     KeyPosition @relation(fields: [keyPositionId], references: [id], onDelete: Cascade)
  assignee        Employee? @relation("ActionAssignee", fields: [assigneeId], references: [id])
  
  @@map("succession_actions")
}

enum SuccessionActionType {
  IDENTIFY_SUCCESSORS
  ASSESS_READINESS
  CREATE_DEV_PLAN
  REVIEW_PROGRESS
  UPDATE_RISK
  CALIBRATION
  PREPARE_TRANSITION
  DOCUMENT_KNOWLEDGE
  BUILD_PIPELINE
  OTHER
}

/// Talent Pool
model TalentPool {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  
  type            TalentPoolType
  level           String?
  targetPositions Json?
  
  entryCriteria   Json?
  minPerformance  String?
  minPotential    String?
  minTenure       Int?
  
  targetSize      Int?
  currentSize     Int      @default(0)
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String
  
  members         TalentPoolMember[]
  
  @@map("talent_pools")
}

enum TalentPoolType {
  EXECUTIVE
  LEADERSHIP
  MANAGEMENT
  TECHNICAL
  SPECIALIST
  HIGH_POTENTIAL
  EMERGING
  DIVERSE
  CUSTOM
}

/// Talent Pool Member
model TalentPoolMember {
  id              String   @id @default(cuid())
  poolId          String
  employeeId      String
  
  nominatedById   String?
  nominationDate  DateTime @default(now())
  entryDate       DateTime?
  cohort          String?
  
  status          TalentMemberStatus @default(NOMINATED)
  
  potentialRating PotentialRating?
  performanceRating String?
  readinessLevel  ReadinessLevel?
  nineBoxPosition String?
  
  careerAspiration String?
  mobilityPref    MobilityPref?
  targetRoles     Json?
  
  devProgress     Int?     // 0-100
  
  exitDate        DateTime?
  exitReason      TalentExitReason?
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  pool            TalentPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id])
  nominatedBy     Employee? @relation("TalentNominator", fields: [nominatedById], references: [id])
  
  @@unique([poolId, employeeId])
  @@index([status])
  @@map("talent_pool_members")
}

enum TalentMemberStatus {
  NOMINATED
  UNDER_REVIEW
  APPROVED
  ACTIVE
  ON_HOLD
  GRADUATED
  EXITED
}

enum PotentialRating {
  EXCEPTIONAL
  HIGH
  PROMOTABLE
  WELL_PLACED
  TOO_NEW
}

enum MobilityPref {
  HIGHLY_MOBILE
  DOMESTIC
  REGIONAL
  LOCAL_ONLY
  REMOTE_FLEX
}

enum TalentExitReason {
  PROMOTED
  GRADUATED
  RESIGNED
  PERFORMANCE
  POTENTIAL_REVISED
  VOLUNTARY
  RESTRUCTURING
  OTHER
}

/// 9-Box Assessment
model NineBoxAssessment {
  id                  String   @id @default(cuid())
  employeeId          String
  assessmentPeriod    String
  
  performanceRating   Int      // 1-3
  potentialRating     Int      // 1-3
  nineBoxPosition     Int      // 1-9
  nineBoxLabel        String
  nineBoxCategory     NineBoxCategory
  
  performanceScore    Decimal? @db.Decimal(3, 1)
  potentialScore      Decimal? @db.Decimal(3, 1)
  
  performanceNotes    String?
  potentialNotes      String?
  overallNotes        String?
  
  developmentFocus    String?
  retentionRisk       RiskLevel?
  recommendedActions  Json?
  
  isCalibrated        Boolean  @default(false)
  calibratedById      String?
  calibratedAt        DateTime?
  preCalibrPerf       Int?
  preCalibrPotential  Int?
  
  assessedById        String
  assessedAt          DateTime @default(now())
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  employee            Employee @relation(fields: [employeeId], references: [id])
  
  @@unique([employeeId, assessmentPeriod])
  @@index([nineBoxCategory])
  @@map("nine_box_assessments")
}

enum NineBoxCategory {
  STAR                // 9 - High Perf, High Potential
  HIGH_PERFORMER      // 6 - High Perf, Med Potential
  TRUSTED_PRO         // 3 - High Perf, Low Potential
  RISING_STAR         // 8 - Med Perf, High Potential
  CORE_PLAYER         // 5 - Med Perf, Med Potential
  EFFECTIVE           // 2 - Med Perf, Low Potential
  ROUGH_DIAMOND       // 7 - Low Perf, High Potential
  INCONSISTENT        // 4 - Low Perf, Med Potential
  UNDERPERFORMER      // 1 - Low Perf, Low Potential
}

/// Succession Snapshot for reporting
model SuccessionSnapshot {
  id                  String   @id @default(cuid())
  snapshotDate        DateTime @default(now())
  snapshotType        String   // MONTHLY, QUARTERLY, ANNUAL
  periodLabel         String
  
  totalKeyPositions   Int
  criticalPositions   Int
  highRiskPositions   Int
  positionsWithSuccessors Int
  positionsFullyCovered Int
  
  totalSuccessors     Int
  avgSuccessors       Decimal  @db.Decimal(3, 1)
  readyNowCount       Int
  ready1YearCount     Int
  ready2YearCount     Int
  ready3PlusCount     Int
  
  criticalRiskCount   Int
  highRiskCount       Int
  mediumRiskCount     Int
  lowRiskCount        Int
  avgRiskScore        Decimal  @db.Decimal(5, 2)
  avgReadinessScore   Decimal  @db.Decimal(5, 2)
  
  detailData          Json?
  
  createdById         String
  createdAt           DateTime @default(now())
  
  @@index([snapshotDate])
  @@map("succession_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────────────
// PLACEHOLDER MODELS (Reference existing models)
// ─────────────────────────────────────────────────────────────────────────────────

model Employee {
  id              String   @id @default(cuid())
  employeeCode    String   @unique
  firstName       String
  lastName        String
  email           String   @unique
  departmentId    String?
  positionId      String?
  managerId       String?
  hireDate        DateTime
  status          String   @default("ACTIVE")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  department      Department? @relation(fields: [departmentId], references: [id])
  position        Position? @relation(fields: [positionId], references: [id])
  manager         Employee? @relation("ManagerRelation", fields: [managerId], references: [id])
  directReports   Employee[] @relation("ManagerRelation")
  
  compensations   EmployeeCompensation[]
  recommendations CompRecommendation[]
  rewardsStatements TotalRewardsStatement[]
  
  asIncumbent     KeyPosition[] @relation("KeyPositionIncumbent")
  asEmergency     KeyPosition[] @relation("EmergencySuccessor")
  successorFor    Successor[]
  
  asMentor        DevPlan[] @relation("DevMentor")
  asCoach         DevPlan[] @relation("DevCoach")
  asSponsor       DevPlan[] @relation("DevSponsor")
  
  poolMemberships TalentPoolMember[]
  nominations     TalentPoolMember[] @relation("TalentNominator")
  
  nineBoxes       NineBoxAssessment[]
  
  actionAssignee  SuccessionAction[] @relation("ActionAssignee")
  
  @@map("employees")
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  parentId    String?
  managerId   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  employees   Employee[]
  positions   Position[]
  budgets     DeptBudget[]
  
  @@map("departments")
}

model Position {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  departmentId    String?
  level           Int?
  gradeId         String?
  jobFamilyId     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  department      Department? @relation(fields: [departmentId], references: [id])
  grade           SalaryGrade? @relation(fields: [gradeId], references: [id])
  jobFamily       JobFamily? @relation(fields: [jobFamilyId], references: [id])
  
  employees       Employee[]
  keyPosition     KeyPosition?
  
  @@map("positions")
}
