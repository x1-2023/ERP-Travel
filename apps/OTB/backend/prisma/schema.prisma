// ============================================================================
// DAFC OTB Planning System - Database Schema
// Tech: PostgreSQL + Prisma ORM
// Updated: 2026-03-03 — Synced from Team BE (DAFC-OTB-BE-NEW), adapted for PostgreSQL
// ============================================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================

model User {
  id            BigInt   @id @default(autoincrement())
  email         String   @unique
  name          String
  password_hash String
  role_id       BigInt
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  store_access  String   @default("[]")
  brand_access  String   @default("[]")

  // Relations
  role                              Role                      @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  created_budgets                   Budget[]                  @relation("CreatedBudgets")
  created_allocate_headers          AllocateHeader[]          @relation("CreatedAllocateHeaders")
  created_planning_headers          PlanningHeader[]          @relation("CreatedPlanningHeaders")
  created_sku_proposal_headers      SKUProposalHeader[]       @relation("CreatedSKUProposalHeaders")
  created_proposal_sizing_headers   ProposalSizingHeader[]    @relation("CreatedProposalSizingHeaders")
  created_tickets                   Ticket[]                  @relation("CreatedTickets")
  approval_workflow_levels          ApprovalWorkflowLevel[]   @relation("ApproverUser")
  ticket_approval_logs              TicketApprovalLog[]       @relation("ApproverLogs")

  @@map("user")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  permissions String   @default("[]")
  created_by  BigInt?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  updated_by  BigInt?

  // Relations
  users User[]

  @@map("role")
}

// ============================================
// BRAND HIERARCHY
// ============================================

model GroupBrand {
  id         BigInt   @id @default(autoincrement())
  code       String
  name       String
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  // Relations
  brands             Brand[]              @relation("GroupBrandToBrand")
  approval_workflows ApprovalWorkflow[]   @relation("GroupBrandToWorkflow")

  @@map("group_brand")
}

model Brand {
  id             BigInt   @id @default(autoincrement())
  code           String
  name           String
  group_brand_id BigInt
  is_active      Boolean  @default(true)
  created_by     BigInt?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  updated_by     BigInt?

  // Relations
  group_brand      GroupBrand       @relation("GroupBrandToBrand", fields: [group_brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products         Product[]        @relation("BrandToProduct")
  allocate_headers AllocateHeader[] @relation("BrandToAllocateHeader")

  @@map("brand")
}

// ============================================
// STORE & LOCATION
// ============================================

model Store {
  id         BigInt   @id @default(autoincrement())
  code       String
  name       String
  region     String?
  location   String?
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  // Relations
  budget_allocates     BudgetAllocate[]     @relation("StoreToBudgetAllocate")
  planning_collections PlanningCollection[] @relation("StoreToPlanningCollection")
  planning_genders     PlanningGender[]     @relation("StoreToPlanningGender")
  sku_allocates        SKUAllocate[]        @relation("StoreToSKUAllocate")

  @@map("store")
}

// ============================================
// PRODUCT TAXONOMY & ATTRIBUTES
// ============================================

model SeasonType {
  id         BigInt   @id @default(autoincrement())
  name       String
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  // Relations
  planning_collections PlanningCollection[] @relation("SeasonTypeToPlanningCollection")

  @@map("collection")
}

model SeasonGroup {
  id         BigInt   @id @default(autoincrement())
  name       String
  year       Int?
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  // Relations
  seasons          Season[]         @relation("SeasonGroupToSeason")
  budget_allocates BudgetAllocate[] @relation("SeasonGroupToBudgetAllocate")
  tickets          Ticket[]         @relation("SeasonGroupToTicket")

  @@map("season_group")
}

model Season {
  id              BigInt   @id @default(autoincrement())
  name            String
  season_group_id BigInt
  is_active       Boolean  @default(true)
  created_by      BigInt?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  updated_by      BigInt?

  // Relations
  season_group     SeasonGroup      @relation("SeasonGroupToSeason", fields: [season_group_id], references: [id], onDelete: Cascade)
  budget_allocates BudgetAllocate[] @relation("SeasonToBudgetAllocate")
  tickets          Ticket[]         @relation("SeasonToTicket")

  @@map("season")
}

model Gender {
  id         BigInt   @id @default(autoincrement())
  name       String
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  // Relations
  categories       Category[]       @relation("GenderToCategory")
  planning_genders PlanningGender[] @relation("GenderToPlanningGender")

  @@map("gender")
}

model Category {
  id         BigInt   @id @default(autoincrement())
  name       String
  gender_id  BigInt
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  // Relations
  gender         Gender        @relation("GenderToCategory", fields: [gender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sub_categories SubCategory[] @relation("CategoryToSubCategory")

  @@map("category")
}

model SubCategory {
  id          BigInt   @id @default(autoincrement())
  name        String
  category_id BigInt
  is_active   Boolean  @default(true)
  created_by  BigInt?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  updated_by  BigInt?

  // Relations
  category            Category             @relation("CategoryToSubCategory", fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products            Product[]            @relation("SubCategoryToProduct")
  subcategory_sizes   SubcategorySize[]    @relation("SubCategoryToSize")
  planning_categories PlanningCategory[]   @relation("SubCategoryToPlanningCategory")

  @@map("sub_category")
}

model SubcategorySize {
  id              BigInt   @id @default(autoincrement())
  name            String
  sub_category_id BigInt
  created_by      BigInt?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  updated_by      BigInt?

  // Relations
  sub_category     SubCategory      @relation("SubCategoryToSize", fields: [sub_category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  proposal_sizings ProposalSizing[] @relation("SizeToProposalSizing")

  @@map("subcategory_size")
}

// ============================================
// PRODUCT CATALOG
// ============================================

model Product {
  id              BigInt   @id @default(autoincrement())
  sku_code        String
  product_name    String
  sub_category_id BigInt
  brand_id        BigInt?
  family          String?
  theme           String?
  color           String?
  composition     String?
  srp             Decimal  @db.Decimal(18, 2)
  image_url       String?
  is_active       Boolean  @default(true)
  created_by      BigInt?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  updated_by      BigInt?

  // Relations
  brand         Brand?        @relation("BrandToProduct", fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sub_category  SubCategory   @relation("SubCategoryToProduct", fields: [sub_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sku_proposals SKUProposal[] @relation("ProductToSKUProposal")

  @@map("product")
}

// ============================================
// BUDGET MANAGEMENT
// ============================================

model Budget {
  id          BigInt   @id @default(autoincrement())
  name        String
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  status      String   @default("DRAFT")
  fiscal_year Int
  created_by  BigInt
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  updated_by  BigInt?

  // Relations
  creator          User             @relation("CreatedBudgets", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allocate_headers AllocateHeader[] @relation("BudgetToAllocateHeader")
  tickets          Ticket[]         @relation("BudgetToTicket")

  @@map("budget")
}

model AllocateHeader {
  id               BigInt   @id @default(autoincrement())
  budget_id        BigInt
  brand_id         BigInt
  version          Int
  is_final_version Boolean  @default(false)
  is_snapshot      Boolean  @default(false)
  ticket_id        BigInt?
  created_by       BigInt
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  updated_by       BigInt?

  // Relations
  budget           Budget           @relation("BudgetToAllocateHeader", fields: [budget_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  brand            Brand            @relation("BrandToAllocateHeader", fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator          User             @relation("CreatedAllocateHeaders", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket           Ticket?          @relation("TicketToSnapshotHeaders", fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  budget_allocates      BudgetAllocate[]    @relation("AllocateHeaderToBudgetAllocate")
  planning_headers      PlanningHeader[]    @relation("AllocateHeaderToPlanningHeader")
  sku_proposal_headers  SKUProposalHeader[] @relation("AllocateHeaderToSKUProposalHeader")

  @@map("allocate_headers")
}

model BudgetAllocate {
  id                 BigInt   @id @default(autoincrement())
  allocate_header_id BigInt
  store_id           BigInt
  season_group_id    BigInt
  season_id          BigInt
  budget_amount      Decimal  @default(0) @db.Decimal(18, 2)
  created_by         BigInt?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  updated_by         BigInt?

  // Relations
  allocate_header AllocateHeader @relation("AllocateHeaderToBudgetAllocate", fields: [allocate_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  store           Store          @relation("StoreToBudgetAllocate", fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season_group    SeasonGroup    @relation("SeasonGroupToBudgetAllocate", fields: [season_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season          Season         @relation("SeasonToBudgetAllocate", fields: [season_id], references: [id], onUpdate: NoAction)

  @@map("budget_allocate")
}

// ============================================
// PLANNING & FORECASTING
// ============================================

model PlanningHeader {
  id                 BigInt   @id @default(autoincrement())
  allocate_header_id BigInt
  version            Int
  status             String   @default("DRAFT")
  is_final_version   Boolean  @default(false)
  created_by         BigInt
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  updated_by         BigInt?

  // Relations
  creator              User                 @relation("CreatedPlanningHeaders", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allocate_header      AllocateHeader       @relation("AllocateHeaderToPlanningHeader", fields: [allocate_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  planning_collections PlanningCollection[] @relation("PlanningHeaderToCollection")
  planning_genders     PlanningGender[]     @relation("PlanningHeaderToGender")
  planning_categories  PlanningCategory[]   @relation("PlanningHeaderToCategory")

  @@map("planning_headers")
}

model PlanningCollection {
  id                  BigInt     @id @default(autoincrement())
  season_type_id      BigInt     @map("collection_id")
  store_id            BigInt
  planning_header_id  BigInt
  actual_buy_pct      Decimal    @default(0) @db.Decimal(18, 2)
  actual_sales_pct    Decimal    @default(0) @db.Decimal(18, 2)
  actual_st_pct       Decimal    @default(0) @db.Decimal(18, 2)
  actual_moc          Decimal    @default(0) @db.Decimal(18, 2)
  proposed_buy_pct    Decimal    @default(0) @db.Decimal(18, 2)
  otb_proposed_amount Decimal    @default(0) @db.Decimal(18, 2)
  pct_var_vs_last     Decimal    @default(0) @db.Decimal(18, 2)
  created_by          BigInt?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt
  updated_by          BigInt?

  // Relations
  season_type     SeasonType     @relation("SeasonTypeToPlanningCollection", fields: [season_type_id], references: [id], onUpdate: NoAction)
  store           Store          @relation("StoreToPlanningCollection", fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  planning_header PlanningHeader @relation("PlanningHeaderToCollection", fields: [planning_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("collection_proposal")
}

model PlanningGender {
  id                  BigInt   @id @default(autoincrement())
  gender_id           BigInt
  store_id            BigInt
  planning_header_id  BigInt
  actual_buy_pct      Decimal  @default(0) @db.Decimal(18, 2)
  actual_sales_pct    Decimal  @default(0) @db.Decimal(18, 2)
  actual_st_pct       Decimal  @default(0) @db.Decimal(18, 2)
  proposed_buy_pct    Decimal  @default(0) @db.Decimal(18, 2)
  otb_proposed_amount Decimal  @default(0) @db.Decimal(18, 2)
  pct_var_vs_last     Decimal  @default(0) @db.Decimal(18, 2)
  created_by          BigInt?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  updated_by          BigInt?

  // Relations
  gender          Gender         @relation("GenderToPlanningGender", fields: [gender_id], references: [id], onUpdate: NoAction)
  store           Store          @relation("StoreToPlanningGender", fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  planning_header PlanningHeader @relation("PlanningHeaderToGender", fields: [planning_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("gender_proposal")
}

model PlanningCategory {
  id                  BigInt      @id @default(autoincrement())
  subcategory_id      BigInt
  planning_header_id  BigInt
  actual_buy_pct      Decimal     @default(0) @db.Decimal(18, 2)
  actual_sales_pct    Decimal     @default(0) @db.Decimal(18, 2)
  actual_st_pct       Decimal     @default(0) @db.Decimal(18, 2)
  proposed_buy_pct    Decimal     @default(0) @db.Decimal(18, 2)
  otb_proposed_amount Decimal     @default(0) @db.Decimal(18, 2)
  var_lastyear_pct    Decimal     @default(0) @db.Decimal(18, 2)
  otb_actual_amount   Decimal     @default(0) @db.Decimal(18, 2)
  otb_actual_buy_pct  Decimal     @default(0) @db.Decimal(18, 2)
  created_by          BigInt?
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt
  updated_by          BigInt?

  // Relations
  subcategory     SubCategory    @relation("SubCategoryToPlanningCategory", fields: [subcategory_id], references: [id], onUpdate: NoAction)
  planning_header PlanningHeader @relation("PlanningHeaderToCategory", fields: [planning_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("category_proposal")
}

// ============================================
// SKU PROPOSAL & ALLOCATION
// ============================================

model SKUProposalHeader {
  id                 BigInt   @id @default(autoincrement())
  allocate_header_id BigInt
  version            Int
  status             String   @default("DRAFT")
  is_final_version   Boolean  @default(false)
  created_by         BigInt
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  updated_by         BigInt?

  // Relations
  allocate_header          AllocateHeader         @relation("AllocateHeaderToSKUProposalHeader", fields: [allocate_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  creator                  User                   @relation("CreatedSKUProposalHeaders", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sku_proposals            SKUProposal[]          @relation("SKUProposalHeaderToSKUProposal")
  proposal_sizing_headers  ProposalSizingHeader[] @relation("SKUProposalHeaderToProposalSizingHeader")

  @@map("sku_proposal_headers")
}

model SKUProposal {
  id                     BigInt   @id @default(autoincrement())
  sku_proposal_header_id BigInt
  product_id             BigInt
  customer_target        String
  unit_cost              Decimal  @default(0) @db.Decimal(18, 2)
  srp                    Decimal  @default(0) @db.Decimal(18, 2)
  created_by             BigInt?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  updated_by             BigInt?

  // Relations
  sku_proposal_header     SKUProposalHeader      @relation("SKUProposalHeaderToSKUProposal", fields: [sku_proposal_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product                 Product                @relation("ProductToSKUProposal", fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sku_allocates           SKUAllocate[]          @relation("SKUProposalToSKUAllocate")
  proposal_sizings        ProposalSizing[]       @relation("SKUProposalToProposalSizing")

  @@map("sku_proposal")
}

model SKUAllocate {
  id              BigInt   @id @default(autoincrement())
  sku_proposal_id BigInt
  store_id        BigInt
  quantity        Decimal  @default(0) @db.Decimal(18, 2)
  created_by      BigInt?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  updated_by      BigInt?

  // Relations
  sku_proposal SKUProposal @relation("SKUProposalToSKUAllocate", fields: [sku_proposal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  store        Store       @relation("StoreToSKUAllocate", fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sku_allocates")
}

model ProposalSizingHeader {
  id                      BigInt   @id @default(autoincrement())
  sku_proposal_header_id  BigInt
  version                 Int
  is_final_version        Boolean  @default(false)
  created_by              BigInt
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  updated_by              BigInt?

  // Relations
  sku_proposal_header SKUProposalHeader @relation("SKUProposalHeaderToProposalSizingHeader", fields: [sku_proposal_header_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator             User              @relation("CreatedProposalSizingHeaders", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proposal_sizings    ProposalSizing[]  @relation("ProposalSizingHeaderToProposalSizing")

  @@map("proposal_sizing_headers")
}

model ProposalSizing {
  id                        BigInt   @id @default(autoincrement())
  proposal_sizing_header_id BigInt
  sku_proposal_id           BigInt
  subcategory_size_id       BigInt
  actual_salesmix_pct       Decimal  @default(0) @db.Decimal(18, 2)
  actual_st_pct             Decimal  @default(0) @db.Decimal(18, 2)
  proposal_quantity         Int
  created_by                BigInt?
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
  updated_by                BigInt?

  // Relations
  proposal_sizing_header ProposalSizingHeader @relation("ProposalSizingHeaderToProposalSizing", fields: [proposal_sizing_header_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sku_proposal           SKUProposal          @relation("SKUProposalToProposalSizing", fields: [sku_proposal_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subcategory_size       SubcategorySize      @relation("SizeToProposalSizing", fields: [subcategory_size_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sizing_proposal")
}

// ============================================
// APPROVAL WORKFLOW & TICKETS
// ============================================

model ApprovalStatus {
  id         BigInt   @id @default(autoincrement())
  name       String
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  @@map("approval_statuses")
}

model Ticket {
  id              BigInt   @id @default(autoincrement())
  budget_id       BigInt
  season_group_id BigInt
  season_id       BigInt
  status          String   @default("PENDING")
  created_by      BigInt
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  updated_by      BigInt?

  // Relations
  budget                    Budget              @relation("BudgetToTicket", fields: [budget_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season_group              SeasonGroup         @relation("SeasonGroupToTicket", fields: [season_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season                    Season              @relation("SeasonToTicket", fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator                   User                @relation("CreatedTickets", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket_approval_logs      TicketApprovalLog[] @relation("TicketToApprovalLog")
  snapshot_allocate_headers AllocateHeader[]    @relation("TicketToSnapshotHeaders")

  @@map("ticket")
}

model ApprovalWorkflow {
  id             BigInt   @id @default(autoincrement())
  group_brand_id BigInt
  workflow_name  String
  created_by     BigInt?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  updated_by     BigInt?

  // Relations
  group_brand              GroupBrand              @relation("GroupBrandToWorkflow", fields: [group_brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approval_workflow_levels ApprovalWorkflowLevel[] @relation("WorkflowToLevel")

  @@map("approval_workflow")
}

model ApprovalWorkflowLevel {
  id                   BigInt   @id @default(autoincrement())
  approval_workflow_id BigInt
  level_order          Int
  level_name           String
  approver_user_id     BigInt
  is_required          Boolean
  created_by           BigInt?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  updated_by           BigInt?

  // Relations
  approval_workflow    ApprovalWorkflow    @relation("WorkflowToLevel", fields: [approval_workflow_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approver_user        User                @relation("ApproverUser", fields: [approver_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket_approval_logs TicketApprovalLog[] @relation("LevelToApprovalLog")

  @@map("approval_workflow_level")
}

model TicketApprovalLog {
  id                         BigInt    @id @default(autoincrement())
  ticket_id                  BigInt
  approval_workflow_level_id BigInt
  approver_user_id           BigInt
  is_approved                Boolean
  comment                    String?
  approved_at                DateTime?
  created_by                 BigInt?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt
  updated_by                 BigInt?

  // Relations
  ticket                  Ticket                @relation("TicketToApprovalLog", fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approval_workflow_level ApprovalWorkflowLevel @relation("LevelToApprovalLog", fields: [approval_workflow_level_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver_user           User                  @relation("ApproverLogs", fields: [approver_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("approval_request_log")
}

// ============================================
// AUDIT & COMPLIANCE (Local extensions)
// ============================================

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  user_id     BigInt?
  action      String
  entity_type String
  entity_id   String
  changes     String?  // JSON string
  ip_address  String?
  created_at  DateTime @default(now())

  @@map("audit_log")
}

model ImportSession {
  id          BigInt   @id @default(autoincrement())
  target      String
  file_name   String
  status      String   @default("PENDING")
  total_rows  Int      @default(0)
  success_rows Int     @default(0)
  error_rows  Int      @default(0)
  error_log   String?  // JSON string
  created_by  BigInt?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  records ImportedRecord[] @relation("SessionToRecord")

  @@map("import_session")
}

model ImportedRecord {
  id         BigInt   @id @default(autoincrement())
  session_id BigInt
  row_number Int
  data       String   // JSON string
  status     String   @default("PENDING")
  error      String?
  created_at DateTime @default(now())

  session ImportSession @relation("SessionToRecord", fields: [session_id], references: [id], onDelete: Cascade)

  @@map("imported_record")
}
