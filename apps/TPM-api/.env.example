# Database
DATABASE_URL="postgresql://user:password@host:5432/promo_master?sslmode=require"

# JWT (REQUIRED - Generate with: openssl rand -base64 32)
JWT_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"
JWT_REFRESH_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (comma-separated additional origins)
CORS_ALLOWED_ORIGINS=""

# Server
NODE_ENV="development"
