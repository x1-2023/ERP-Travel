// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  ADMIN
  MANAGER
  KAM
  FINANCE
}

enum PromotionStatus {
  DRAFT
  PLANNED
  CONFIRMED
  EXECUTING
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  VALIDATING
  VALIDATION_FAILED
  PENDING_MATCH
  MATCHED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  SETTLED
  PARTIALLY_SETTLED
  CANCELLED
  // Backward compat
  PENDING
  DISPUTED
}

// Phase 6: Claims & Settlement enums
enum ClaimType {
  REBATE
  DISCOUNT
  PROMOTION
  LISTING_FEE
  DISPLAY
  COOP_ADVERTISING
  DAMAGE
  SHORTAGE
  PRICE_PROTECTION
  OTHER
}

enum ClaimSource {
  MANUAL
  CUSTOMER_PORTAL
  EDI
  DEDUCTION
  PROMOTION_AUTO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum PaymentMethod {
  BANK_TRANSFER
  CHECK
  CASH
  OFFSET
  CREDIT_NOTE
}

enum SettlementStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum BatchStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
}

enum FundType {
  FIXED // On-Invoice
  VARIABLE // Off-Invoice (performance-based)
}

// Aforza-style Budget Fund Types (for Budget model)
enum BudgetFundType {
  PROMOTIONAL // Quỹ khuyến mãi - gắn với promotion cụ thể
  TACTICAL // Quỹ chiến thuật - linh hoạt, ngắn hạn
  FIXED_INVESTMENT // Đầu tư cố định - dài hạn, theo hợp đồng
  TRADE_SPEND // Chi phí thương mại chung
  LISTING_FEE // Phí niêm yết sản phẩm mới
  DISPLAY // Phí trưng bày
}

// Budget Approval Workflow Status
enum BudgetApprovalStatus {
  DRAFT // Mới tạo, chưa submit
  SUBMITTED // Đã submit, chờ review
  UNDER_REVIEW // Đang review
  APPROVED // Đã duyệt
  REJECTED // Từ chối
  REVISION_NEEDED // Cần sửa đổi
}

enum TransactionType {
  BUDGET_ALLOCATION
  COMMITMENT
  RELEASE
  CLAIM_SETTLEMENT
  ADJUSTMENT
}

enum FileCategory {
  POA
  POP
  INVOICE
  CONTRACT
  REPORT
  OTHER
}

enum POAStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POPStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApprovalRuleType {
  AUTO_APPROVE
  SINGLE_APPROVAL
  MULTI_LEVEL
}

enum TacticType {
  DISCOUNT
  REBATE
  DISPLAY
  LISTING_FEE
  COOP_ADVERTISING
  SAMPLING
  OTHER
}

enum Channel {
  MT // Modern Trade
  GT // General Trade
  ECOMMERCE
  HORECA
  OTHER
}

// Business Planning
enum PeriodType {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BaselineSourceType {
  HISTORICAL
  MANUAL
  IBP_IMPORT
  NIELSEN
  FORECAST
  ADJUSTED
}

enum ADLEntryType {
  INCLUDE // Explicitly allow
  EXCLUDE // Explicitly deny (overrides INCLUDE from parent)
}

enum ADLScope {
  COMPANY // All customers in company
  CHANNEL // All customers in channel (MT, GT, etc.)
  CUSTOMER // Specific customer
}

// ═══════════════════════════════════════════════════════════════
// ACCRUAL ENGINE ENUMS
// ═══════════════════════════════════════════════════════════════

enum FiscalPeriodStatus {
  OPEN // Normal operations
  SOFT_CLOSE // No new transactions, adjustments allowed
  HARD_CLOSE // Fully locked
}

enum AccrualEntryType {
  INITIAL_RESERVE // When promotion confirmed
  MONTHLY_ACCRUAL // Regular monthly accrual
  ADJUSTMENT // Manual adjustment
  TRUE_UP // End of promotion true-up
  REVERSAL // Full or partial reversal
  SETTLEMENT // When claim settled
}

enum AccrualCalculationMethod {
  TIME_BASED // Pro-rata based on days
  EXECUTION_BASED // Based on execution percentage
  CLAIM_BASED // Based on claims submitted
  MANUAL // Manual entry
}

enum AccrualStatus {
  PENDING // Calculated, not posted
  POSTED // Posted to GL
  REVERSED // Has been reversed
  VOIDED // Voided (error correction)
}

enum GLJournalSource {
  ACCRUAL // From accrual engine
  SETTLEMENT // From claim settlement
  ADJUSTMENT // Manual adjustment
  REVERSAL // Reversal entry
  IMPORT // Imported from ERP
}

enum GLJournalStatus {
  DRAFT // Created, not posted
  PENDING_APPROVAL // Awaiting approval
  POSTED // Posted to GL
  REVERSED // Has been reversed
  VOIDED // Voided
}

enum GLAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccrualFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ═══════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════

model Company {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  logo      String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  customers              Customer[]
  products               Product[]
  funds                  Fund[]
  approvalRules          ApprovalRule[]
  adl                    AuthorizedDistributionList[]
  adlEntries             ADLEntry[]                   @relation("ADLEntries")
  promotionTemplates     PromotionTemplate[]
  // Accrual Engine
  fiscalPeriods          FiscalPeriod[]
  accrualEntries         AccrualEntry[]
  glJournals             GLJournal[]
  glAccounts             GLAccount[]
  accrualConfig          AccrualConfig?
  // Deduction Management
  deductions             Deduction[]
  writeOffRules          WriteOffRule[]
  deductionImportBatches DeductionImportBatch[]
  // Security & Compliance
  ssoConfig              SSOConfig?
  mfaConfig              MFAConfig?
  soxControls            SOXControl[]
  soxViolations          SOXViolation[]
  auditLogs              ImmutableAuditLog[]
  sessions               UserSession[]
  // Integration
  erpConnections         ERPConnection[]
  apiKeys                APIKey[]
  webhookSubscriptions   WebhookSubscription[]
  // Phase 4: Enterprise Polish
  dashboards             Dashboard[]
  reportDefinitions      ReportDefinition[]
  notifications          Notification[]
  alertRules             AlertRule[]
  insights               Insight[]
  forecastModels         ForecastModel[]
  // Business Planning
  baselines              Baseline[]
  // Clash Detection
  clashRules             ClashRule[]
  // Phase 5: Budget & Target Integration
  budgets                Budget[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(KAM)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId             String
  company               Company                  @relation(fields: [companyId], references: [id])
  promotions            Promotion[]              @relation("CreatedBy")
  claims                Claim[]                  @relation("ReviewedBy")
  files                 File[]
  aiConversations       AIConversation[]
  adlEntriesCreated     ADLEntry[]
  templatesCreated      PromotionTemplate[]      @relation("TemplatesCreated")
  // Accrual Engine
  periodsClosedBy       FiscalPeriod[]           @relation("PeriodClosedBy")
  accrualsCreatedBy     AccrualEntry[]           @relation("AccrualCreatedBy")
  accrualsPostedBy      AccrualEntry[]           @relation("AccrualPostedBy")
  journalsCreatedBy     GLJournal[]              @relation("JournalCreatedBy")
  journalsPostedBy      GLJournal[]              @relation("JournalPostedBy")
  // Deduction Management
  deductionsCreated     Deduction[]              @relation("DeductionCreatedBy")
  deductionsMatched     Deduction[]              @relation("DeductionMatchedBy")
  deductionsResolved    Deduction[]              @relation("DeductionResolvedBy")
  deductionsWrittenOff  Deduction[]              @relation("DeductionWriteOffBy")
  disputesCreated       DeductionDispute[]       @relation("DisputeCreatedBy")
  disputesResolved      DeductionDispute[]       @relation("DisputeResolvedBy")
  disputesEscalatedTo   DeductionDispute[]       @relation("DisputeEscalatedTo")
  deductionDocuments    DeductionDocument[]
  disputeDocuments      DisputeDocument[]
  deductionComments     DeductionComment[]
  deductionActivities   DeductionActivity[]
  writeOffRules         WriteOffRule[]
  importBatches         DeductionImportBatch[]
  // Security & Compliance
  mfaEnabled            Boolean                  @default(false)
  mfaSecret             String?
  mfaBackupCodes        String[]                 @default([])
  ssoId                 String? // External SSO identifier
  ssoProvider           SSOProvider?
  lastSSOLoginAt        DateTime?
  userMFA               UserMFA[]
  mfaChallenges         MFAChallenge[]
  soxViolations         SOXViolation[]           @relation("SOXViolationUser")
  soxViolationsReviewed SOXViolation[]           @relation("SOXViolationReviewer")
  auditLogs             ImmutableAuditLog[]
  sessions              UserSession[]
  // Integration
  erpConnectionsCreated ERPConnection[]
  apiKeysCreated        APIKey[]
  apiKeysRevoked        APIKey[]                 @relation("APIKeyRevokedBy")
  webhooksCreated       WebhookSubscription[]
  // Phase 4: Enterprise Polish
  dashboards            Dashboard[]
  reportDefinitions     ReportDefinition[]       @relation("ReportDefinitionCreatedBy")
  reportSchedules       ReportSchedule[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference[]
  pushTokens            PushToken[]
  alertRulesCreated     AlertRule[]
  acknowledgedAlerts    TriggeredAlert[]         @relation("AlertAcknowledgedBy")
  offlineQueue          OfflineSyncQueue[]
  devices               UserDevice[]
  // Business Planning
  baselinesCreated      Baseline[]               @relation("BaselineCreatedBy")
  baselinesUpdated      Baseline[]               @relation("BaselineUpdatedBy")
  baselinesLocked       Baseline[]               @relation("BaselineLockedBy")
  // Clash Detection
  clashesResolved       PromotionClash[]         @relation("ClashResolvedBy")
  // Migration Week 1 additions
  scenarios             Scenario[]               @relation("ScenarioCreatedBy")
  aiInsightsCreated     AIInsight[]              @relation("AIInsightUser")
  voiceCommands         VoiceCommand[]           @relation("VoiceCommandUser")

  @@index([companyId])
}

model Customer {
  id         String   @id @default(cuid())
  code       String
  name       String
  channel    Channel  @default(MT)
  subChannel String?
  address    String?
  taxCode    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyId           String
  company             Company                      @relation(fields: [companyId], references: [id])
  funds               Fund[]
  promotions          Promotion[]
  claims              Claim[]
  adl                 AuthorizedDistributionList[]
  adlEntries          ADLEntry[]                   @relation("ADLEntries")
  // Deduction Management
  deductions          Deduction[]
  // Business Planning
  baselines           Baseline[]
  // Migration Week 1 additions
  cheques             ChequebookEntry[]            @relation("ChequePayee")
  deliveryOrders      DeliveryOrder[]              @relation("DeliveryCustomer")
  sellTracking        SellTracking[]               @relation("SellTrackingCustomer")
  inventories         InventorySnapshot[]          @relation("InventoryCustomer")
  // Module 7: Sell Tracking
  sellIns             SellIn[]                     @relation("CustomerSellIns")
  sellOuts            SellOut[]                    @relation("CustomerSellOuts")
  customerInventories CustomerInventory[]          @relation("CustomerInventories")
  // Module 9: Delivery Profile
  deliveryProfile     DeliveryProfile?             @relation("CustomerDeliveryProfile")
  // Pepsi V3: Volume Contracts & AI
  volumeContracts     VolumeContract[]
  promoSuggestions    PromoSuggestion[]
  pepsiStores         PepsiStore[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, channel])
  @@index([companyId, isActive])
}

model Product {
  id        String   @id @default(cuid())
  sku       String
  name      String
  category  String?
  brand     String?
  cogs      Decimal? @db.Decimal(15, 2)
  price     Decimal? @db.Decimal(15, 2)
  unit      String   @default("EA")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId          String
  company            Company                      @relation(fields: [companyId], references: [id])
  tacticItems        TacticItem[]
  adl                AuthorizedDistributionList[]
  adlEntries         ADLEntry[]                   @relation("ADLEntries")
  // Business Planning
  baselines          Baseline[]
  // Migration Week 1 additions
  deliveryLines      DeliveryLine[]               @relation("DeliveryProduct")
  sellTracking       SellTracking[]               @relation("SellTrackingProduct")
  inventories        InventorySnapshot[]          @relation("InventoryProduct")
  // Module 7: Sell Tracking
  productSellIns     SellIn[]                     @relation("ProductSellIns")
  productSellOuts    SellOut[]                    @relation("ProductSellOuts")
  productInventories CustomerInventory[]          @relation("ProductInventories")

  @@unique([companyId, sku])
  @@index([companyId])
}

model Fund {
  id          String   @id @default(cuid())
  code        String
  name        String
  type        FundType @default(FIXED)
  year        Int
  totalBudget Decimal  @db.Decimal(15, 2)
  committed   Decimal  @default(0) @db.Decimal(15, 2)
  available   Decimal  @db.Decimal(15, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  customerId   String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  promotions   Promotion[]
  transactions Transaction[]

  @@unique([companyId, code, year])
  @@index([companyId])
  @@index([customerId])
  @@index([companyId, year, isActive])
  @@index([companyId, type])
}

model Promotion {
  id          String          @id @default(cuid())
  code        String
  name        String
  description String?
  status      PromotionStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  budget      Decimal         @db.Decimal(15, 2)
  actualSpend Decimal?        @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  fundId      String
  fund        Fund     @relation(fields: [fundId], references: [id])
  createdById String
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])

  // Template/Clone tracking
  templateId   String? // If created from template
  clonedFromId String? // If cloned from another promotion

  tactics             Tactic[]
  claims              Claim[]
  transactions        Transaction[]
  poas                POA[]
  // Accrual Engine
  accrualEntries      AccrualEntry[]
  // Deduction Management
  deductions          Deduction[]
  // Clash Detection
  clashesAsA          PromotionClash[]       @relation("ClashPromotionA")
  clashesAsB          PromotionClash[]       @relation("ClashPromotionB")
  // Migration Week 1 additions
  deliveryOrders      DeliveryOrder[]        @relation("DeliveryPromotion")
  // Module 7: Sell Tracking
  sellIns             SellIn[]               @relation("PromotionSellIns")
  sellOuts            SellOut[]              @relation("PromotionSellOuts")
  // Module 9: Delivery Profile
  promotionDeliveries PromotionDelivery[]    @relation("PromotionDeliveries")
  // Pepsi V3: Post-Promotion Analysis
  postAnalysis        PostPromotionAnalysis?
  // Phase 6: Claims Matching
  claimMatches        ClaimPromotionMatch[]

  @@index([customerId])
  @@index([fundId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([customerId, status, startDate])
  @@index([customerId, startDate, endDate])
  @@index([status, startDate, endDate])
}

model Tactic {
  id        String     @id @default(cuid())
  type      TacticType
  mechanic  String?
  value     Decimal?   @db.Decimal(10, 2)
  budget    Decimal    @db.Decimal(15, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  promotionId    String
  promotion      Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  items          TacticItem[]
  // Accrual Engine
  accrualEntries AccrualEntry[]

  @@index([promotionId])
}

model TacticItem {
  id        String   @id @default(cuid())
  quantity  Int?
  discount  Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tacticId  String
  tactic    Tactic  @relation(fields: [tacticId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([tacticId])
  @@index([productId])
}

model Claim {
  id          String      @id @default(cuid())
  code        String
  amount      Decimal     @db.Decimal(15, 2)
  status      ClaimStatus @default(DRAFT)
  claimDate   DateTime
  description String?
  documents   Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Phase 6: Enhanced fields
  companyId        String?
  type             ClaimType?
  source           ClaimSource?
  claimedAmount    Decimal?     @db.Decimal(18, 2)
  validatedAmount  Decimal?     @db.Decimal(18, 2)
  approvedAmount   Decimal?     @db.Decimal(18, 2)
  settledAmount    Decimal?     @db.Decimal(18, 2)
  claimPeriodStart DateTime?
  claimPeriodEnd   DateTime?
  dueDate          DateTime?
  priority         Int          @default(0)
  validationScore  Float?
  validationNotes  String?
  validationErrors Json?
  invoiceNumber    String?
  invoiceDate      DateTime?
  invoiceAmount    Decimal?     @db.Decimal(18, 2)
  submittedBy      String?
  submittedAt      DateTime?
  approvedBy       String?
  approvedAt       DateTime?
  internalNotes    String?
  customerNotes    String?
  rejectionReason  String?
  createdBy        String?

  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  promotionId  String?
  promotion    Promotion? @relation(fields: [promotionId], references: [id])
  reviewedById String?
  reviewedBy   User?      @relation("ReviewedBy", fields: [reviewedById], references: [id])

  // Phase 6: New relations
  lineItems        ClaimLineItem[]
  claimDocuments   ClaimDocument[]
  approvals        ClaimApproval[]
  auditLogs        ClaimAuditLog[]
  settlements      Settlement[]
  promotionMatches ClaimPromotionMatch[]

  transactions Transaction[]
  pops         POP[]
  // Deduction Management
  deductions   Deduction[]
  // Migration Week 1 additions
  cheques      ChequebookEntry[] @relation("ChequeClaim")
  // Pepsi V3: AI Claims Processing
  aiMatch      ClaimAIMatch?

  @@index([customerId])
  @@index([promotionId])
  @@index([status])
  @@index([status, claimDate])
  @@index([customerId, status])
  @@index([companyId])
}

model Settlement {
  id            String   @id @default(cuid())
  code          String?  @unique
  settledAmount Decimal  @db.Decimal(15, 2)
  amount        Decimal? @db.Decimal(18, 2)
  variance      Decimal? @db.Decimal(15, 2)
  notes         String?
  settledAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Phase 6: Enhanced fields
  status           SettlementStatus @default(PENDING)
  paymentMethod    PaymentMethod?
  paymentReference String?
  paymentDate      DateTime?
  bankName         String?
  bankAccount      String?
  bankBranch       String?
  currency         String           @default("VND")
  postedToGL       Boolean          @default(false)
  postedAt         DateTime?
  glJournalId      String?
  createdBy        String?
  approvedBy       String?
  approvedAt       DateTime?

  batchId String?
  batch   SettlementBatch? @relation(fields: [batchId], references: [id])

  claimId String
  claim   Claim  @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([batchId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// PHASE 6: CLAIMS & SETTLEMENT NEW MODELS
// ═══════════════════════════════════════════════════════════════

model ClaimLineItem {
  id          String   @id @default(cuid())
  claimId     String
  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  productId   String?
  productName String?
  productSku  String?
  quantity    Int?
  unitPrice   Decimal? @db.Decimal(18, 2)
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  createdAt   DateTime @default(now())

  @@index([claimId])
}

model ClaimDocument {
  id           String   @id @default(cuid())
  claimId      String
  claim        Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String
  fileSize     Int
  filePath     String
  documentType String // INVOICE, POP, CONTRACT, SUPPORTING
  uploadedBy   String?
  uploadedAt   DateTime @default(now())

  @@index([claimId])
}

model ClaimApproval {
  id             String         @id @default(cuid())
  claimId        String
  claim          Claim          @relation(fields: [claimId], references: [id], onDelete: Cascade)
  level          Int            @default(1)
  status         ApprovalStatus @default(PENDING)
  approverId     String?
  approvedAmount Decimal?       @db.Decimal(18, 2)
  comments       String?
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())

  @@index([claimId])
  @@index([approverId])
}

model ClaimAuditLog {
  id         String   @id @default(cuid())
  claimId    String
  claim      Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  action     String // CREATED, SUBMITTED, VALIDATED, MATCHED, APPROVED, REJECTED, SETTLED
  fromStatus String?
  toStatus   String?
  userId     String?
  userName   String?
  details    Json?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([claimId])
  @@index([createdAt])
}

model ClaimPromotionMatch {
  id              String    @id @default(cuid())
  claimId         String
  claim           Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  promotionId     String
  promotion       Promotion @relation(fields: [promotionId], references: [id])
  confidenceScore Float
  matchReason     String
  matchFactors    Json?
  expectedAmount  Decimal   @db.Decimal(18, 2)
  variance        Decimal   @db.Decimal(18, 2)
  variancePercent Float
  isAccepted      Boolean   @default(false)
  acceptedBy      String?
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([claimId])
  @@index([promotionId])
}

model SettlementBatch {
  id          String      @id @default(cuid())
  code        String      @unique
  companyId   String
  batchDate   DateTime
  status      BatchStatus @default(DRAFT)
  totalAmount Decimal     @default(0) @db.Decimal(18, 2)
  itemCount   Int         @default(0)
  notes       String?
  createdBy   String?
  approvedBy  String?
  approvedAt  DateTime?
  processedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  settlements Settlement[]

  @@index([companyId])
  @@index([status])
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  createdAt   DateTime        @default(now())

  fundId      String
  fund        Fund       @relation(fields: [fundId], references: [id])
  promotionId String?
  promotion   Promotion? @relation(fields: [promotionId], references: [id])
  claimId     String?
  claim       Claim?     @relation(fields: [claimId], references: [id])

  @@index([fundId])
  @@index([promotionId])
  @@index([claimId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// FILE MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model File {
  id           String       @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  s3Key        String       @unique
  s3Bucket     String
  category     FileCategory @default(OTHER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  poa POA?
  pop POP?

  @@index([uploadedById])
  @@index([category])
}

