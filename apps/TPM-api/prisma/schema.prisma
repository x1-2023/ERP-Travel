model Dashboard {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  name        String
  description String?
  type        DashboardType @default(PERSONAL)
  isDefault   Boolean       @default(false)

  layout          Json?
  filters         Json?
  refreshInterval Int?

  widgets DashboardWidget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, userId])
  @@index([type])
}

model DashboardWidget {
  id          String    @id @default(cuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  title      String
  widgetType WidgetType
  dataSource String
  config     Json
  position   Json

  refreshInterval Int?
  cacheSeconds    Int? @default(300)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dashboardId])
}

model ReportDefinition {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name        String
  description String?
  category    String?

  dataSource   String
  columns      Json
  filters      Json?
  groupBy      String[] @default([])
  sortBy       Json?
  calculations Json?

  defaultFormat ReportFormat @default(EXCEL)
  isTemplate    Boolean      @default(false)

  schedules  ReportSchedule[]
  executions ReportExecution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("ReportDefinitionCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, category])
}

model ReportSchedule {
  id       String           @id @default(cuid())
  reportId String
  report   ReportDefinition @relation(fields: [reportId], references: [id], onDelete: Cascade)

  frequency      ReportFrequency
  cronExpression String?
  format         ReportFormat    @default(EXCEL)

  recipients String[] @default([])
  filters    Json?

  isActive  Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId, isActive])
  @@index([nextRunAt])
}

model ReportExecution {
  id       String           @id @default(cuid())
  reportId String
  report   ReportDefinition @relation(fields: [reportId], references: [id], onDelete: Cascade)

  format     ReportFormat
  filters    Json?
  parameters Json?

  status       String    @default("PENDING")
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  fileUrl  String?
  fileSize Int?
  rowCount Int?

  createdAt DateTime @default(now())

  @@index([reportId, status])
  @@index([createdAt])
}

model Notification {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  type    NotificationType
  channel NotificationChannel @default(IN_APP)
  status  NotificationStatus  @default(UNREAD)

  title     String
  message   String
  data      Json?
  actionUrl String?

  readAt    DateTime?
  sentAt    DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([companyId, type])
  @@index([createdAt])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  notificationType NotificationType
  channels         NotificationChannel[]
  isEnabled        Boolean               @default(true)

  quietHoursStart String?
  quietHoursEnd   String?
  timezone        String? @default("UTC")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, notificationType])
}

model PushToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  token      String         @unique
  platform   DevicePlatform
  deviceName String?

  isActive   Boolean   @default(true)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

model AlertRule {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  name        String
  description String?

  metric    String
  condition AlertCondition
  threshold Float
  severity  AlertSeverity  @default(WARNING)

  channels   NotificationChannel[]
  recipients String[]              @default([])

  cooldownMinutes Int     @default(60)
  isActive        Boolean @default(true)

  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)

  // Pepsi V3: Entity-scoped alerts
  entityType String? // PROMOTION, BUDGET, CLAIM, CONTRACT, STORE

  triggeredAlerts TriggeredAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@index([metric])
  @@index([entityType])
}

model TriggeredAlert {
  id     String    @id @default(cuid())
  ruleId String
  rule   AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  currentValue   Float
  thresholdValue Float
  message        String

  acknowledgedAt   DateTime?
  acknowledgedById String?
  acknowledgedBy   User?     @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  acknowledgeNote  String?

  // Pepsi V3: Extended alert fields
  entityType String? // PROMOTION, BUDGET, CLAIM, CONTRACT, STORE
  entityId   String?
  title      String?
  severity   AlertSeverity?
  status     String? // ACTIVE, ACKNOWLEDGED, RESOLVED
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([ruleId, createdAt])
  @@index([acknowledgedAt])
  @@index([entityType, entityId])
  @@index([status])
}

model Insight {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type        InsightType
  title       String
  description String
  details     Json?

  metric     String?
  impact     String?
  confidence Float?

  actionable  Boolean   @default(true)
  actionTaken Boolean   @default(false)
  dismissedAt DateTime?

  relatedEntityType String?
  relatedEntityId   String?

  validUntil DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, type])
  @@index([createdAt])
  @@index([actionable, actionTaken])
}

model ForecastModel {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name       String
  metric     String
  algorithm  String @default("linear_regression")
  parameters Json?

  trainingDataStart DateTime?
  trainingDataEnd   DateTime?
  accuracy          Float?

  isActive      Boolean   @default(true)
  lastTrainedAt DateTime?

  forecasts Forecast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, metric])
}

model Forecast {
  id      String        @id @default(cuid())
  modelId String
  model   ForecastModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  periodStart    DateTime
  periodEnd      DateTime
  predictedValue Float
  confidenceLow  Float?
  confidenceHigh Float?
  actualValue    Float?

  createdAt DateTime @default(now())

  @@index([modelId, periodStart])
}

model OfflineSyncQueue {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  entityType String
  entityId   String?
  action     String
  payload    Json

  status       SyncQueueStatus @default(PENDING)
  conflictData Json?
  errorMessage String?

  clientTimestamp DateTime
  syncedAt        DateTime?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([createdAt])
}

model UserDevice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  deviceId   String         @unique
  platform   DevicePlatform
  deviceName String?
  appVersion String?
  osVersion  String?

  lastSyncAt   DateTime?
  lastActiveAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

