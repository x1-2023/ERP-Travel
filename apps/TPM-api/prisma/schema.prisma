  @@index([companyId, customerId])
  @@map("customer_inventory")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 9: DELIVERY PROFILE
// ═══════════════════════════════════════════════════════════════

enum DeliveryDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleType {
  ONE_TIME
  RECURRING
}

enum DeliveryFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum DeliveryPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model DeliveryProfile {
  id        String @id @default(cuid())
  companyId String

  customerId String   @unique
  customer   Customer @relation("CustomerDeliveryProfile", fields: [customerId], references: [id])

  deliveryAddress String?
  deliveryCity    String?
  deliveryRegion  String?
  deliveryZone    String?

  contactPerson String?
  contactPhone  String?
  contactEmail  String?

  preferredDays      DeliveryDay[] @default([])
  preferredTimeStart String?
  preferredTimeEnd   String?

  standardLeadTime Int  @default(2)
  expressLeadTime  Int?

  maxDeliveriesPerWeek Int?
  maxUnitsPerDelivery  Int?
  warehouseCapacity    Int?

  requiresAppointment Boolean @default(false)
  requiresPOD         Boolean @default(true)
  specialInstructions String?

  blackoutDates   DateTime[] @default([])
  holidaySchedule String?

  routeCode      String?
  routeSequence  Int?
  distanceFromDC Decimal? @db.Decimal(10, 2)

  avgDeliveryTime Decimal? @db.Decimal(5, 2)
  onTimeRate      Decimal? @db.Decimal(5, 2)

  isActive Boolean @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedules           DeliverySchedule[]
  promotionDeliveries PromotionDelivery[]

  @@index([companyId, isActive])
  @@index([companyId, routeCode])
  @@map("delivery_profiles")
}

model DeliverySchedule {
  id        String @id @default(cuid())
  companyId String

  profileId String
  profile   DeliveryProfile @relation(fields: [profileId], references: [id])

  scheduleType ScheduleType @default(RECURRING)

  frequency   DeliveryFrequency?
  dayOfWeek   DeliveryDay?
  dayOfMonth  Int?
  weekOfMonth Int?

  specificDate DateTime?

  timeWindowStart String?
  timeWindowEnd   String?

  estimatedUnits Int?
  estimatedValue Decimal?         @db.Decimal(18, 2)
  priority       DeliveryPriority @default(NORMAL)

  isActive Boolean @default(true)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, profileId])
  @@index([companyId, scheduleType])
  @@map("delivery_schedules")
}

model PromotionDelivery {
  id        String @id @default(cuid())
  companyId String

  promotionId String
  promotion   Promotion @relation("PromotionDeliveries", fields: [promotionId], references: [id])

  profileId String
  profile   DeliveryProfile @relation(fields: [profileId], references: [id])

  plannedDate DateTime
  actualDate  DateTime?

  plannedUnits Int
  actualUnits  Int?

  plannedValue Decimal  @db.Decimal(18, 2)
  actualValue  Decimal? @db.Decimal(18, 2)

  status   DeliveryStatus   @default(PLANNED)
  priority DeliveryPriority @default(NORMAL)

  deliveryNote String?
  podReference String?
  podSignedAt  DateTime?
  podSignedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, promotionId])
  @@index([companyId, profileId])
  @@index([companyId, plannedDate])
  @@index([companyId, status])
  @@map("promotion_deliveries")
}

