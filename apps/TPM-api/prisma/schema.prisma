  BOX
}

enum PepsiChannel {
  MT
  GT
  HORECA
  VENDING
  ECOMMERCE
  WHOLESALE
}

enum PepsiRegion {
  SOUTH
  NORTH
  CENTRAL
  HIGHLAND
}

enum CustomerTier {
  DIAMOND
  GOLD
  SILVER
  BRONZE
}

// ═══════════════════════════════════════════════════════════════
// PEPSI V3 MODELS
// ═══════════════════════════════════════════════════════════════

model VolumeContract {
  id        String @id @default(cuid())
  companyId String
  code      String
  name      String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  status    VolumeContractStatus @default(DRAFT)
  startDate DateTime
  endDate   DateTime

  targetVolume   Decimal   @db.Decimal(18, 2)
  currentVolume  Decimal   @default(0) @db.Decimal(18, 2)
  bonusType      BonusType @default(PERCENTAGE)
  bonusValue     Decimal   @db.Decimal(18, 2)
  bonusCondition Json?

  channel    PepsiChannel?
  region     PepsiRegion?
  categories PepsiCategory[] @default([])

  riskLevel      RiskLevel @default(ON_TRACK)
  completionRate Decimal   @default(0) @db.Decimal(5, 2)

  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milestones VolumeContractMilestone[]
  progress   VolumeContractProgress[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("volume_contracts")
}

model VolumeContractMilestone {
  id         String         @id @default(cuid())
  contractId String
  contract   VolumeContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  name           String // Q1, H1, 9M, FY
  targetVolume   Decimal   @db.Decimal(18, 2)
  achievedVolume Decimal   @default(0) @db.Decimal(18, 2)
  deadline       DateTime
  achievedDate   DateTime?

  bonusAmount Decimal? @db.Decimal(18, 2)
  isAchieved  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([deadline])
  @@map("volume_contract_milestones")
}

model VolumeContractProgress {
  id         String         @id @default(cuid())
  contractId String
  contract   VolumeContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  month   Int
  year    Int
  volume  Decimal @db.Decimal(18, 2)
  revenue Decimal @default(0) @db.Decimal(18, 2)
  target  Decimal @default(0) @db.Decimal(18, 2)

  cumVolume  Decimal @default(0) @db.Decimal(18, 2)
  cumTarget  Decimal @default(0) @db.Decimal(18, 2)
  gapPercent Decimal @default(0) @db.Decimal(5, 2)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, year, month])
  @@index([contractId])
  @@map("volume_contract_progress")
}

model PromoSuggestion {
  id        String @id @default(cuid())
  companyId String

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  contractId String?

  type     PromoSuggestionType
  status   PromoSuggestionStatus @default(PENDING)
  priority Int                   @default(5) // 1-10

  title       String
  description String
  rationale   String?

  suggestedConfig Json? // promotion config, reallocation details, etc.
  impactEstimate  Json? // { revenue, volume, roi, cost }
  confidence      Float @default(0.5) // 0-1

  dataInputs   Json? // source data used for suggestion
  modelVersion String?

  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  appliedAt   DateTime?
  promotionId String? // resulting promotion if applied
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([contractId])
  @@index([status])
  @@index([type, status])
  @@map("promo_suggestions")
}

model ClaimAIMatch {
  id      String @id @default(cuid())
  claimId String @unique
  claim   Claim  @relation(fields: [claimId], references: [id])

  recommendation ClaimRecommendation
  confidence     Float               @default(0.5)
  matchScore     Float               @default(0)

  matchedPromotionId String?
  matchedAmount      Decimal? @db.Decimal(18, 2)
  variance           Decimal? @db.Decimal(18, 2)
  variancePercent    Float?

  flags        String[] @default([])
  riskFactors  Json?
  reasoning    String?
  modelVersion String?

  processedAt   DateTime  @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  finalDecision String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recommendation])
  @@index([confidence])
  @@index([processedAt])
  @@map("claim_ai_matches")
}

model PostPromotionAnalysis {
  id        String @id @default(cuid())
  companyId String

  promotionId String    @unique
  promotion   Promotion @relation(fields: [promotionId], references: [id])

  result       AnalysisResult
  overallScore Float          @default(0) // 0-100

  // Financial metrics
  totalSpend         Decimal @db.Decimal(18, 2)
  incrementalRevenue Decimal @default(0) @db.Decimal(18, 2)
  roi                Float   @default(0)
  costPerUnit        Decimal @default(0) @db.Decimal(18, 2)

  // Volume metrics
  baselineVolume    Decimal @default(0) @db.Decimal(18, 2)
  actualVolume      Decimal @default(0) @db.Decimal(18, 2)
  incrementalVolume Decimal @default(0) @db.Decimal(18, 2)
  upliftPercent     Float   @default(0)

  // Execution metrics
  executionScore  Float @default(0)
  storeCompliance Float @default(0)
  onTimeDelivery  Float @default(0)

  // Insights
  keyFindings     Json? // array of findings
  recommendations Json? // array of recommendations
  lessonsLearned  Json? // array of lessons
  baselineUpdate  Json? // suggested baseline adjustments

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([result])
  @@index([generatedAt])
  @@map("post_promotion_analyses")
}

model PepsiProduct {
  id        String @id @default(cuid())
  companyId String

  sku          String
  name         String
  nameVi       String?
  category     PepsiCategory
  brand        String
  packType     PepsiPackType
  packSize     String? // "330ml", "1.5L", etc.
  unitsPerCase Int           @default(24)

  basePrice Decimal @db.Decimal(18, 2)
  costPrice Decimal @default(0) @db.Decimal(18, 2)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([category])
  @@index([brand])
  @@map("pepsi_products")
}

model PepsiStore {
  id        String @id @default(cuid())
  companyId String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  code     String
  name     String
  address  String?
  district String?
  city     String?
  region   PepsiRegion?
  channel  PepsiChannel?

  tier CustomerTier @default(SILVER)

  monthlyTarget Decimal @default(0) @db.Decimal(18, 2)
  monthlyActual Decimal @default(0) @db.Decimal(18, 2)

  isActive  Boolean @default(true)
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([customerId])
  @@index([region])
  @@index([channel])
  @@map("pepsi_stores")
}

// ═══════════════════════════════════════════════════════════════
// Sprint 0 Fix 8: TOKEN BLACKLIST
// ═══════════════════════════════════════════════════════════════

model TokenBlacklist {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  reason    String // 'logout', 'password_change', 'admin_revoke', 'security_incident'
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}
