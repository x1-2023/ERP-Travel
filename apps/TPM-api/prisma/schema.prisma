// ═══════════════════════════════════════════════════════════════
// ACCRUAL ENGINE MODELS
// ═══════════════════════════════════════════════════════════════

model FiscalPeriod {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  year    Int
  month   Int
  quarter Int

  name      String
  startDate DateTime
  endDate   DateTime

  status     FiscalPeriodStatus @default(OPEN)
  closedAt   DateTime?
  closedById String?
  closedBy   User?              @relation("PeriodClosedBy", fields: [closedById], references: [id])

  totalAccrued  Decimal @default(0) @db.Decimal(18, 2)
  totalReversed Decimal @default(0) @db.Decimal(18, 2)
  totalSettled  Decimal @default(0) @db.Decimal(18, 2)

  accrualEntries AccrualEntry[]
  glJournals     GLJournal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year, month])
  @@index([companyId, status])
  @@index([companyId, year, quarter])
}

model AccrualEntry {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  promotionId    String
  promotion      Promotion    @relation(fields: [promotionId], references: [id])
  tacticId       String?
  tactic         Tactic?      @relation(fields: [tacticId], references: [id])
  fiscalPeriodId String
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id])

  entryType AccrualEntryType
  entryDate DateTime

  amount           Decimal @db.Decimal(18, 2)
  cumulativeAmount Decimal @db.Decimal(18, 2)

  calculationMethod AccrualCalculationMethod @default(TIME_BASED)
  calculationBasis  Json?

  glJournalId String?
  glJournal   GLJournal? @relation(fields: [glJournalId], references: [id])

  status     AccrualStatus @default(PENDING)
  postedAt   DateTime?
  postedById String?
  postedBy   User?         @relation("AccrualPostedBy", fields: [postedById], references: [id])

  isReversal      Boolean        @default(false)
  reversedEntryId String?
  reversedEntry   AccrualEntry?  @relation("AccrualReversal", fields: [reversedEntryId], references: [id])
  reversals       AccrualEntry[] @relation("AccrualReversal")

  notes String?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("AccrualCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, promotionId])
  @@index([companyId, fiscalPeriodId])
  @@index([companyId, status])
  @@index([companyId, entryDate])
}

model GLJournal {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  journalNumber  String       @unique
  journalDate    DateTime
  fiscalPeriodId String
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id])

  description String
  source      GLJournalSource
  sourceRef   String?

  status     GLJournalStatus @default(DRAFT)
  postedAt   DateTime?
  postedById String?
  postedBy   User?           @relation("JournalPostedBy", fields: [postedById], references: [id])

  totalDebit  Decimal @db.Decimal(18, 2)
  totalCredit Decimal @db.Decimal(18, 2)

  lines          GLJournalLine[]
  accrualEntries AccrualEntry[]

  erpExported   Boolean   @default(false)
  erpExportedAt DateTime?
  erpReference  String?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("JournalCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, fiscalPeriodId])
  @@index([companyId, journalDate])
  @@index([companyId, status])
}

model GLJournalLine {
  id        String    @id @default(cuid())
  journalId String
  journal   GLJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  lineNumber Int

  accountCode String
  accountName String

  debitAmount  Decimal @default(0) @db.Decimal(18, 2)
  creditAmount Decimal @default(0) @db.Decimal(18, 2)

  costCenter   String?
  profitCenter String?
  customerId   String?
  productId    String?
  brandCode    String?
  channelCode  String?

  description String?

  @@index([journalId])
  @@index([accountCode])
}

model GLAccount {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code     String
  name     String
  type     GLAccountType
  category String?

  isActive Boolean @default(true)

  isDefaultTradeExpense     Boolean @default(false)
  isDefaultAccruedLiability Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type])
}

model AccrualConfig {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  tradeExpenseAccount     String
  accruedLiabilityAccount String

  defaultCalculationMethod AccrualCalculationMethod @default(TIME_BASED)
  accrualFrequency         AccrualFrequency         @default(MONTHLY)

  autoCalculate Boolean @default(true)
  autoPost      Boolean @default(false)

  minAccrualAmount         Decimal @default(0) @db.Decimal(18, 2)
  varianceThresholdPercent Decimal @default(10) @db.Decimal(5, 2)

  allowBackdatedEntries Boolean @default(false)
  gracePeriodDays       Int     @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// DEDUCTION MANAGEMENT ENUMS
// ═══════════════════════════════════════════════════════════════

enum DeductionSource {
  ERP_AR
  BANK_LOCKBOX
  EDI_812
  MANUAL
  CUSTOMER_PORTAL
}

enum DeductionCategory {
  TRADE_PROMOTION
  PRICING
  LOGISTICS
  QUALITY
  ADVERTISING
  OTHER
}

enum DeductionStatus {
  PENDING
  MATCHED
  UNDER_REVIEW
  APPROVED
  DISPUTED
  RESOLVED
  WRITTEN_OFF
  REJECTED
}

enum MatchMethod {
  AUTO_EXACT
  AUTO_FUZZY
  AUTO_AI
  MANUAL
}

enum DeductionResolution {
  FULL_MATCH
  PARTIAL_MATCH
  OVERPAYMENT
  UNDERPAYMENT
  INVALID
  WRITE_OFF
}

enum DisputeStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_INTERNAL
  ESCALATED
  RESOLVED
  CLOSED
}

enum ImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// ═══════════════════════════════════════════════════════════════
// DEDUCTION MANAGEMENT MODELS
// ═══════════════════════════════════════════════════════════════

model Deduction {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  deductionNumber String
  externalRef     String?

  source         DeductionSource
  sourceDocument String?
  sourceDate     DateTime?
  importBatchId  String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("VND")

  deductionDate DateTime
  dueDate       DateTime?
  receivedDate  DateTime

  reasonCode        String?
  reasonDescription String?
  category          DeductionCategory @default(TRADE_PROMOTION)

  status DeductionStatus @default(PENDING)

  matchedPromotionId String?
  matchedPromotion   Promotion?   @relation(fields: [matchedPromotionId], references: [id])
  matchedClaimId     String?
  matchedClaim       Claim?       @relation(fields: [matchedClaimId], references: [id])
  matchScore         Int?
  matchMethod        MatchMethod?
  matchedAt          DateTime?
  matchedById        String?
  matchedBy          User?        @relation("DeductionMatchedBy", fields: [matchedById], references: [id])

  resolutionType  DeductionResolution?
  resolvedAmount  Decimal?             @db.Decimal(18, 2)
  varianceAmount  Decimal?             @db.Decimal(18, 2)
  resolvedAt      DateTime?
  resolvedById    String?
  resolvedBy      User?                @relation("DeductionResolvedBy", fields: [resolvedById], references: [id])
  resolutionNotes String?

  writeOffReason       String?
  writeOffApprovedById String?
  writeOffApprovedBy   User?   @relation("DeductionWriteOffBy", fields: [writeOffApprovedById], references: [id])

  daysOutstanding Int     @default(0)
  agingBucket     String?

  disputes   DeductionDispute[]
  documents  DeductionDocument[]
  comments   DeductionComment[]
  activities DeductionActivity[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("DeductionCreatedBy", fields: [createdById], references: [id])

  @@unique([companyId, deductionNumber])
  @@index([companyId, customerId])
  @@index([companyId, status])
  @@index([companyId, deductionDate])
  @@index([companyId, agingBucket])
  @@index([matchedPromotionId])
  @@index([matchedClaimId])
}

model DeductionDispute {
  id          String    @id @default(cuid())
  deductionId String
  deduction   Deduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  disputeNumber String   @unique
  disputeDate   DateTime @default(now())
  disputeReason String
  disputeAmount Decimal  @db.Decimal(18, 2)

  status DisputeStatus @default(OPEN)

  customerResponse     String?
  customerResponseDate DateTime?
  customerContactName  String?
  customerContactEmail String?

  resolution     String?
  resolvedAmount Decimal?  @db.Decimal(18, 2)
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?     @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])

  isEscalated      Boolean   @default(false)
  escalatedAt      DateTime?
  escalatedToId    String?
  escalatedTo      User?     @relation("DisputeEscalatedTo", fields: [escalatedToId], references: [id])
  escalationReason String?

  documents DisputeDocument[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("DisputeCreatedBy", fields: [createdById], references: [id])

  @@index([deductionId])
  @@index([status])
}

model DeductionDocument {
  id          String    @id @default(cuid())
  deductionId String
  deduction   Deduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  fileName     String
  fileType     String
  fileSize     Int
  filePath     String
  documentType String

  uploadedAt   DateTime @default(now())
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([deductionId])
}

model DisputeDocument {
  id        String           @id @default(cuid())
  disputeId String
  dispute   DeductionDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  fileName     String
  fileType     String
  fileSize     Int
  filePath     String
  documentType String

  uploadedAt   DateTime @default(now())
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([disputeId])
}

model DeductionComment {
  id          String    @id @default(cuid())
  deductionId String
  deduction   Deduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  content    String
  isInternal Boolean @default(true)

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([deductionId])
}

model DeductionActivity {
  id          String    @id @default(cuid())
  deductionId String
  deduction   Deduction @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  action      String
  description String
  oldValue    Json?
  newValue    Json?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([deductionId])
  @@index([createdAt])
}

model WriteOffRule {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name        String
  description String?

  maxAmount  Decimal             @db.Decimal(18, 2)
  minAgeDays Int                 @default(90)
  categories DeductionCategory[]

  requiresApproval Boolean @default(true)
  approverRoleId   String?

  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model DeductionImportBatch {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  source   DeductionSource
  fileName String?
  filePath String?

  totalRecords   Int
  successCount   Int @default(0)
  errorCount     Int @default(0)
  duplicateCount Int @default(0)

  status ImportBatchStatus @default(PENDING)
  errors Json?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([companyId, status])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// SECURITY & COMPLIANCE ENUMS
// ═══════════════════════════════════════════════════════════════

enum SSOProvider {
  AZURE_AD
  GOOGLE
  OKTA
  SAML_GENERIC
}

enum MFAType {
  TOTP
  SMS
  EMAIL
}

enum MFAChallengeStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
}

enum SOXControlType {
  SEGREGATION_OF_DUTIES
  AMOUNT_THRESHOLD
  DUAL_CONTROL
  TIME_RESTRICTION
  DATA_ACCESS
}

enum SOXControlStatus {
  ACTIVE
  INACTIVE
  TESTING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  MFA_SETUP
  MFA_VERIFY
  SSO_LOGIN
  APPROVE
  REJECT
  MATCH
  WRITE_OFF
  EXPORT
  IMPORT
  CONFIG_CHANGE
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ═══════════════════════════════════════════════════════════════
// SECURITY & COMPLIANCE MODELS
// ═══════════════════════════════════════════════════════════════

model SSOConfig {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  provider  SSOProvider
  isEnabled Boolean     @default(false)

  entityId      String?
  ssoUrl        String?
  sloUrl        String?
  certificate   String?
  spCertificate String?
  spPrivateKey  String?

  clientId     String?
  clientSecret String?
  tenantId     String?
  discoveryUrl String?

  emailAttribute   String  @default("email")
  nameAttribute    String  @default("name")
  roleAttribute    String?
  attributeMapping Json?

  autoProvision Boolean @default(false)
  defaultRole   Role    @default(KAM)
  forceSSOLogin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider])
}

model MFAConfig {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  isEnabled     Boolean   @default(false)
  enforcedRoles Role[]    @default([])
  allowedTypes  MFAType[] @default([TOTP])

  totpIssuer String @default("PromoMaster")
  totpDigits Int    @default(6)
  totpPeriod Int    @default(30)

  gracePeriodDays Int @default(7)
  maxAttempts     Int @default(5)
  lockoutMinutes  Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserMFA {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type      MFAType
  isActive  Boolean @default(false)
  isDefault Boolean @default(false)

  secret      String?
  backupCodes String[] @default([])

  verifiedAt DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId, isActive])
}

model MFAChallenge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   MFAType
  status MFAChallengeStatus @default(PENDING)

  challengeCode String?
  expiresAt     DateTime
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)

  verifiedAt DateTime?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([expiresAt])
}

model SOXControl {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code        String
  name        String
  description String?

  type   SOXControlType
  status SOXControlStatus @default(ACTIVE)

  config Json

  isBlocking Boolean @default(true)
  severity   String  @default("HIGH")

  lastTestedAt   DateTime?
  lastTestResult String?

  violations SOXViolation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type, status])
}

model SOXViolation {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  controlId String
  control   SOXControl @relation(fields: [controlId], references: [id])

  userId String
  user   User   @relation("SOXViolationUser", fields: [userId], references: [id])

  action     String
  entityType String
  entityId   String?
  details    Json?

  wasBlocked   Boolean   @default(true)
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("SOXViolationReviewer", fields: [reviewedById], references: [id])
  reviewNotes  String?
  isExcepted   Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([companyId, controlId])
  @@index([companyId, userId])
  @@index([createdAt])
}

model ImmutableAuditLog {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  action      AuditAction
  entityType  String
  entityId    String?
  description String

  oldValues Json?
  newValues Json?
  metadata  Json?

  sequenceNumber Int
  previousHash   String?
  entryHash      String

  timestamp DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([companyId, sequenceNumber])
  @@index([companyId, entityType, entityId])
  @@index([companyId, userId])
  @@index([companyId, action])
  @@index([companyId, timestamp])
}

model UserSession {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  token  String        @unique
  status SessionStatus @default(ACTIVE)

  ipAddress  String?
  userAgent  String?
  deviceInfo Json?

  loginAt        DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime
  logoutAt       DateTime?

  authMethod  String  @default("password")
  mfaVerified Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([companyId, status])
  @@index([expiresAt])
  @@index([token])
}

