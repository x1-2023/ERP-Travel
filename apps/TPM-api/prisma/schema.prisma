// ═══════════════════════════════════════════════════════════════
// PHASE 5: BUDGET & TARGET ALLOCATION
// ═══════════════════════════════════════════════════════════════

// Geographic Hierarchy Enums
enum GeographicLevel {
  COUNTRY
  REGION
  PROVINCE
  DISTRICT
  DEALER
}

enum AllocationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  LOCKED
}

enum TargetMetric {
  CASES
  VOLUME_LITERS
  REVENUE_VND
  UNITS
}

// Geographic Unit - Master Data for hierarchy
model GeographicUnit {
  id     String          @id @default(cuid())
  code   String          @unique
  name   String
  nameEn String?
  level  GeographicLevel

  // Self-referencing hierarchy
  parentId String?
  parent   GeographicUnit?  @relation("GeographicHierarchy", fields: [parentId], references: [id])
  children GeographicUnit[] @relation("GeographicHierarchy")

  // Metadata
  latitude  Float?
  longitude Float?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  // Relations
  budgetAllocations BudgetAllocation[]
  targetAllocations TargetAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([level])
  @@index([code])
}

// Budget - Main budget entity for allocation (Aforza-enhanced)
model Budget {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  category    String? // Budget category (e.g., "Trade Marketing", "Sales")

  // Aforza Fund Type
  fundType BudgetFundType @default(PROMOTIONAL)

  // Period
  year      Int
  quarter   Int? // 1-4, null for annual
  startDate DateTime?
  endDate   DateTime?

  // Budget amounts (VND)
  totalAmount     Decimal @db.Decimal(18, 2)
  allocatedAmount Decimal @default(0) @db.Decimal(18, 2)
  spentAmount     Decimal @default(0) @db.Decimal(18, 2)

  // Approval Workflow (Aforza-style)
  approvalStatus BudgetApprovalStatus @default(DRAFT)
  approvalLevel  Int                  @default(0) // Required approval levels (calculated from amount)
  currentLevel   Int                  @default(0) // Current approval level reached

  // Status
  status   String  @default("DRAFT")
  isActive Boolean @default(true)

  // Budget Constraints (JSON for flexibility)
  constraints Json? // e.g., {"maxRegionPercent": 30, "minTacticalPercent": 15}

  // Period Comparison (link to previous period budget)
  previousPeriodId String? @unique
  previousPeriod   Budget? @relation("PeriodComparison", fields: [previousPeriodId], references: [id])
  nextPeriod       Budget? @relation("PeriodComparison")

  // Company relation (for multi-tenant)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Relations
  allocations BudgetAllocation[]
  approvals   BudgetApproval[] // Approval history/audit trail
  activities  FundActivity[] // Activities linked to this budget

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([year, quarter])
  @@index([status])
  @@index([approvalStatus])
  @@index([companyId])
  @@index([fundType])
}

// Budget Allocation - Hierarchical budget distribution
model BudgetAllocation {
  id   String @id @default(cuid())
  code String @unique

  // Link to parent Budget
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Link to Geographic Unit
  geographicUnitId String
  geographicUnit   GeographicUnit @relation(fields: [geographicUnitId], references: [id])

  // Self-referencing hierarchy (for allocation tree)
  parentId String?
  parent   BudgetAllocation?  @relation("BudgetAllocationHierarchy", fields: [parentId], references: [id])
  children BudgetAllocation[] @relation("BudgetAllocationHierarchy")

  // Amounts (in VND)
  allocatedAmount Decimal @db.Decimal(18, 2) // Amount allocated to this level
  spentAmount     Decimal @default(0) @db.Decimal(18, 2) // Amount already spent

  // Computed fields (updated by triggers/jobs)
  childrenAllocated   Decimal @default(0) @db.Decimal(18, 2) // Sum allocated to children
  availableToAllocate Decimal @default(0) @db.Decimal(18, 2) // allocatedAmount - childrenAllocated

  // Status & Workflow
  status     AllocationStatus @default(DRAFT)
  approvedBy String?
  approvedAt DateTime?

  // Metadata
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations to FundActivity
  activities FundActivity[]

  @@unique([budgetId, geographicUnitId])
  @@index([budgetId])
  @@index([parentId])
  @@index([geographicUnitId])
  @@index([status])
}

// Budget Approval - Audit trail for multi-level approval workflow (Aforza-style)
model BudgetApproval {
  id String @id @default(cuid())

  // Link to Budget
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Approval Level Info
  level Int // 1, 2, 3 (approval sequence)
  role  String // KAM Manager, Trade Marketing Manager, Finance Director

  // Approval Status
  status BudgetApprovalStatus @default(UNDER_REVIEW)

  // Reviewer Info
  reviewerId   String?
  reviewerName String?
  comments     String? @db.Text

  // Timestamps
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([budgetId])
  @@index([status])
  @@index([level])
}

// Fund Activity - Link budget/allocation to specific activities (Aforza-style)
model FundActivity {
  id String @id @default(cuid())

  // Link to Budget (top-level tracking)
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Link to specific allocation (optional - for more granular tracking)
  budgetAllocationId String?
  budgetAllocation   BudgetAllocation? @relation(fields: [budgetAllocationId], references: [id])

  // Link to Promotion (if applicable)
  promotionId String?

  // Activity Details
  activityType String // 'promotion', 'display', 'sampling', 'event', 'listing_fee'
  activityName String
  activityCode String?

  // Financial Tracking
  allocatedAmount Decimal @db.Decimal(18, 2)
  spentAmount     Decimal @default(0) @db.Decimal(18, 2)

  // Performance Metrics (for ROI calculation)
  revenueGenerated Decimal? @db.Decimal(18, 2)
  unitsImpacted    Int?
  roi              Decimal? @db.Decimal(8, 4) // Calculated: revenue/spent

  // Period
  startDate DateTime
  endDate   DateTime

  // Status
  status String @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, CANCELLED

  // Metadata
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([budgetId])
  @@index([budgetAllocationId])
  @@index([activityType])
  @@index([status])
  @@index([promotionId])
}

// Target - Main target entity
model Target {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Period
  year    Int
  quarter Int? // 1-4, null for annual
  month   Int? // 1-12, null for quarterly/annual

  // Overall target
  totalTarget   Decimal      @db.Decimal(18, 2)
  totalAchieved Decimal      @default(0) @db.Decimal(18, 2)
  metric        TargetMetric @default(CASES)

  // Status
  status   String  @default("DRAFT")
  isActive Boolean @default(true)

  // Relations
  allocations TargetAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@index([year, quarter])
  @@index([status])
}

// Target Allocation - Hierarchical target distribution
model TargetAllocation {
  id   String @id @default(cuid())
  code String @unique

  // Link to parent Target
  targetId String
  target   Target @relation(fields: [targetId], references: [id], onDelete: Cascade)

  // Link to Geographic Unit
  geographicUnitId String
  geographicUnit   GeographicUnit @relation(fields: [geographicUnitId], references: [id])

  // Self-referencing hierarchy
  parentId String?
  parent   TargetAllocation?  @relation("TargetAllocationHierarchy", fields: [parentId], references: [id])
  children TargetAllocation[] @relation("TargetAllocationHierarchy")

  // Target values
  targetValue   Decimal      @db.Decimal(18, 2) // Target for this level
  achievedValue Decimal      @default(0) @db.Decimal(18, 2) // Achieved so far
  metric        TargetMetric @default(CASES)

  // Computed fields
  childrenTarget  Decimal @default(0) @db.Decimal(18, 2) // Sum of children targets
  progressPercent Decimal @default(0) @db.Decimal(5, 2) // (achieved/target)*100

  // Status
  status AllocationStatus @default(DRAFT)

  // Metadata
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([targetId, geographicUnitId])
  @@index([targetId])
  @@index([parentId])
  @@index([geographicUnitId])
}

// ═══════════════════════════════════════════════════════════════
// MODULE 7: SELL-IN / SELL-OUT TRACKING
// ═══════════════════════════════════════════════════════════════

model SellIn {
  id        String @id @default(cuid())
  companyId String

  transactionCode String   @unique
  transactionDate DateTime

  promotionId String?
  promotion   Promotion? @relation("PromotionSellIns", fields: [promotionId], references: [id])

  customerId String
  customer   Customer @relation("CustomerSellIns", fields: [customerId], references: [id])

  channelId String?
  regionId  String?

  productId String
  product   Product @relation("ProductSellIns", fields: [productId], references: [id])

  quantity     Int
  quantityCase Decimal? @db.Decimal(18, 2)

  grossValue    Decimal  @db.Decimal(18, 2)
  discountValue Decimal? @db.Decimal(18, 2)
  netValue      Decimal  @db.Decimal(18, 2)

  sourceSystem    String?
  sourceReference String?

  periodYear  Int
  periodMonth Int
  periodWeek  Int

  importedAt   DateTime @default(now())
  importedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, transactionDate])
  @@index([companyId, promotionId])
  @@index([companyId, customerId, productId])
  @@index([companyId, periodYear, periodMonth])
  @@map("sell_in")
}

model SellOut {
  id        String @id @default(cuid())
  companyId String

  transactionCode String   @unique
  transactionDate DateTime

  promotionId String?
  promotion   Promotion? @relation("PromotionSellOuts", fields: [promotionId], references: [id])

  customerId String
  customer   Customer @relation("CustomerSellOuts", fields: [customerId], references: [id])

  channelId String?
  regionId  String?

  productId String
  product   Product @relation("ProductSellOuts", fields: [productId], references: [id])

  quantity     Int
  quantityCase Decimal? @db.Decimal(18, 2)

  sellingPrice Decimal @db.Decimal(18, 2)
  totalValue   Decimal @db.Decimal(18, 2)

  sourceSystem    String?
  sourceReference String?

  periodYear  Int
  periodMonth Int
  periodWeek  Int

  importedAt   DateTime @default(now())
  importedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, transactionDate])
  @@index([companyId, promotionId])
  @@index([companyId, customerId, productId])
  @@index([companyId, periodYear, periodMonth])
  @@map("sell_out")
}

model CustomerInventory {
  id        String @id @default(cuid())
  companyId String

  snapshotDate DateTime

  customerId String
  customer   Customer @relation("CustomerInventories", fields: [customerId], references: [id])

  productId String
  product   Product @relation("ProductInventories", fields: [productId], references: [id])

  openingStock Int @default(0)
  receivedQty  Int @default(0)
  soldQty      Int @default(0)
  adjustments  Int @default(0)
  closingStock Int @default(0)

