// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  ADMIN
  MANAGER
  KAM
  FINANCE
}

enum PromotionStatus {
  DRAFT
  PLANNED
  CONFIRMED
  EXECUTING
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  PENDING
  MATCHED
  APPROVED
  DISPUTED
  SETTLED
  REJECTED
}

enum FundType {
  FIXED // On-Invoice
  VARIABLE // Off-Invoice (performance-based)
}

enum TransactionType {
  BUDGET_ALLOCATION
  COMMITMENT
  RELEASE
  CLAIM_SETTLEMENT
  ADJUSTMENT
}

enum FileCategory {
  POA
  POP
  INVOICE
  CONTRACT
  REPORT
  OTHER
}

enum POAStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POPStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApprovalRuleType {
  AUTO_APPROVE
  SINGLE_APPROVAL
  MULTI_LEVEL
}

enum TacticType {
  DISCOUNT
  REBATE
  DISPLAY
  LISTING_FEE
  COOP_ADVERTISING
  SAMPLING
  OTHER
}

enum Channel {
  MT // Modern Trade
  GT // General Trade
  ECOMMERCE
  HORECA
  OTHER
}

// Business Planning
enum PeriodType {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BaselineSourceType {
  HISTORICAL
  MANUAL
  IBP_IMPORT
  NIELSEN
  FORECAST
  ADJUSTED
}

enum ADLEntryType {
  INCLUDE  // Explicitly allow
  EXCLUDE  // Explicitly deny (overrides INCLUDE from parent)
}

enum ADLScope {
  COMPANY   // All customers in company
  CHANNEL   // All customers in channel (MT, GT, etc.)
  CUSTOMER  // Specific customer
}

// ═══════════════════════════════════════════════════════════════
// ACCRUAL ENGINE ENUMS
// ═══════════════════════════════════════════════════════════════

enum FiscalPeriodStatus {
  OPEN          // Normal operations
  SOFT_CLOSE    // No new transactions, adjustments allowed
  HARD_CLOSE    // Fully locked
}

enum AccrualEntryType {
  INITIAL_RESERVE   // When promotion confirmed
  MONTHLY_ACCRUAL   // Regular monthly accrual
  ADJUSTMENT        // Manual adjustment
  TRUE_UP           // End of promotion true-up
  REVERSAL          // Full or partial reversal
  SETTLEMENT        // When claim settled
}

enum AccrualCalculationMethod {
  TIME_BASED        // Pro-rata based on days
  EXECUTION_BASED   // Based on execution percentage
  CLAIM_BASED       // Based on claims submitted
  MANUAL            // Manual entry
}

enum AccrualStatus {
  PENDING           // Calculated, not posted
  POSTED            // Posted to GL
  REVERSED          // Has been reversed
  VOIDED            // Voided (error correction)
}

enum GLJournalSource {
  ACCRUAL           // From accrual engine
  SETTLEMENT        // From claim settlement
  ADJUSTMENT        // Manual adjustment
  REVERSAL          // Reversal entry
  IMPORT            // Imported from ERP
}

enum GLJournalStatus {
  DRAFT             // Created, not posted
  PENDING_APPROVAL  // Awaiting approval
  POSTED            // Posted to GL
  REVERSED          // Has been reversed
  VOIDED            // Voided
}

enum GLAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccrualFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ═══════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════

model Company {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  logo      String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  customers          Customer[]
  products           Product[]
  funds              Fund[]
  approvalRules      ApprovalRule[]
  adl                AuthorizedDistributionList[]
  adlEntries         ADLEntry[]            @relation("ADLEntries")
  promotionTemplates PromotionTemplate[]
  // Accrual Engine
  fiscalPeriods      FiscalPeriod[]
  accrualEntries     AccrualEntry[]
  glJournals         GLJournal[]
  glAccounts         GLAccount[]
  accrualConfig      AccrualConfig?
  // Deduction Management
  deductions           Deduction[]
  writeOffRules        WriteOffRule[]
  deductionImportBatches DeductionImportBatch[]
  // Security & Compliance
  ssoConfig            SSOConfig?
  mfaConfig            MFAConfig?
  soxControls          SOXControl[]
  soxViolations        SOXViolation[]
  auditLogs            ImmutableAuditLog[]
  sessions             UserSession[]
  // Integration
  erpConnections       ERPConnection[]
  apiKeys              APIKey[]
  webhookSubscriptions WebhookSubscription[]
  // Phase 4: Enterprise Polish
  dashboards           Dashboard[]
  reportDefinitions    ReportDefinition[]
  notifications        Notification[]
  alertRules           AlertRule[]
  insights             Insight[]
  forecastModels       ForecastModel[]
  // Business Planning
  baselines            Baseline[]
  // Clash Detection
  clashRules           ClashRule[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(KAM)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  promotions Promotion[] @relation("CreatedBy")
  claims     Claim[]     @relation("ReviewedBy")
  files      File[]
  aiConversations AIConversation[]
  adlEntriesCreated ADLEntry[]
  templatesCreated PromotionTemplate[] @relation("TemplatesCreated")
  // Accrual Engine
  periodsClosedBy    FiscalPeriod[]  @relation("PeriodClosedBy")
  accrualsCreatedBy  AccrualEntry[]  @relation("AccrualCreatedBy")
  accrualsPostedBy   AccrualEntry[]  @relation("AccrualPostedBy")
  journalsCreatedBy  GLJournal[]     @relation("JournalCreatedBy")
  journalsPostedBy   GLJournal[]     @relation("JournalPostedBy")
  // Deduction Management
  deductionsCreated    Deduction[]        @relation("DeductionCreatedBy")
  deductionsMatched    Deduction[]        @relation("DeductionMatchedBy")
  deductionsResolved   Deduction[]        @relation("DeductionResolvedBy")
  deductionsWrittenOff Deduction[]        @relation("DeductionWriteOffBy")
  disputesCreated      DeductionDispute[] @relation("DisputeCreatedBy")
  disputesResolved     DeductionDispute[] @relation("DisputeResolvedBy")
  disputesEscalatedTo  DeductionDispute[] @relation("DisputeEscalatedTo")
  deductionDocuments   DeductionDocument[]
  disputeDocuments     DisputeDocument[]
  deductionComments    DeductionComment[]
  deductionActivities  DeductionActivity[]
  writeOffRules        WriteOffRule[]
  importBatches        DeductionImportBatch[]
  // Security & Compliance
  mfaEnabled           Boolean            @default(false)
  mfaSecret            String?
  mfaBackupCodes       String[]           @default([])
  ssoId                String?            // External SSO identifier
  ssoProvider          SSOProvider?
  lastSSOLoginAt       DateTime?
  userMFA              UserMFA[]
  mfaChallenges        MFAChallenge[]
  soxViolations        SOXViolation[]     @relation("SOXViolationUser")
  soxViolationsReviewed SOXViolation[]   @relation("SOXViolationReviewer")
  auditLogs            ImmutableAuditLog[]
  sessions             UserSession[]
  // Integration
  erpConnectionsCreated ERPConnection[]
  apiKeysCreated       APIKey[]
  apiKeysRevoked       APIKey[]           @relation("APIKeyRevokedBy")
  webhooksCreated      WebhookSubscription[]
  // Phase 4: Enterprise Polish
  dashboards           Dashboard[]
  reportDefinitions    ReportDefinition[]  @relation("ReportDefinitionCreatedBy")
  reportSchedules      ReportSchedule[]
  notifications        Notification[]
  notificationPrefs    NotificationPreference[]
  pushTokens           PushToken[]
  alertRulesCreated    AlertRule[]
  acknowledgedAlerts   TriggeredAlert[]    @relation("AlertAcknowledgedBy")
  offlineQueue         OfflineSyncQueue[]
  devices              UserDevice[]
  // Business Planning
  baselinesCreated     Baseline[]          @relation("BaselineCreatedBy")
  baselinesUpdated     Baseline[]          @relation("BaselineUpdatedBy")
  baselinesLocked      Baseline[]          @relation("BaselineLockedBy")
  // Clash Detection
  clashesResolved      PromotionClash[]    @relation("ClashResolvedBy")

  @@index([companyId])
}

model Customer {
  id         String   @id @default(cuid())
  code       String
  name       String
  channel    Channel  @default(MT)
  subChannel String?
  address    String?
  taxCode    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  funds      Fund[]
  promotions Promotion[]
  claims     Claim[]
  adl        AuthorizedDistributionList[]
  adlEntries ADLEntry[]  @relation("ADLEntries")
  // Deduction Management
  deductions Deduction[]
  // Business Planning
  baselines  Baseline[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, channel])
  @@index([companyId, isActive])
}

model Product {
  id        String   @id @default(cuid())
  sku       String
  name      String
  category  String?
  brand     String?
  cogs      Decimal? @db.Decimal(15, 2)
  price     Decimal? @db.Decimal(15, 2)
  unit      String   @default("EA")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  tacticItems TacticItem[]
  adl         AuthorizedDistributionList[]
  adlEntries  ADLEntry[]   @relation("ADLEntries")
  // Business Planning
  baselines   Baseline[]

  @@unique([companyId, sku])
  @@index([companyId])
}

model Fund {
  id          String   @id @default(cuid())
  code        String
  name        String
  type        FundType @default(FIXED)
  year        Int
  totalBudget Decimal  @db.Decimal(15, 2)
  committed   Decimal  @default(0) @db.Decimal(15, 2)
  available   Decimal  @db.Decimal(15, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  customerId   String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  promotions   Promotion[]
  transactions Transaction[]

  @@unique([companyId, code, year])
  @@index([companyId])
  @@index([customerId])
  @@index([companyId, year, isActive])
  @@index([companyId, type])
}

model Promotion {
  id          String          @id @default(cuid())
  code        String
  name        String
  description String?
  status      PromotionStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  budget      Decimal         @db.Decimal(15, 2)
  actualSpend Decimal?        @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  fundId        String
  fund          Fund     @relation(fields: [fundId], references: [id])
  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])

  // Template/Clone tracking
  templateId    String?  // If created from template
  clonedFromId  String?  // If cloned from another promotion

  tactics      Tactic[]
  claims       Claim[]
  transactions Transaction[]
  poas         POA[]
  // Accrual Engine
  accrualEntries AccrualEntry[]
  // Deduction Management
  deductions   Deduction[]
  // Clash Detection
  clashesAsA   PromotionClash[] @relation("ClashPromotionA")
  clashesAsB   PromotionClash[] @relation("ClashPromotionB")

  @@index([customerId])
  @@index([fundId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([customerId, status, startDate])
  @@index([customerId, startDate, endDate])
  @@index([status, startDate, endDate])
}

model Tactic {
  id        String     @id @default(cuid())
  type      TacticType
  mechanic  String?
  value     Decimal?   @db.Decimal(10, 2)
  budget    Decimal    @db.Decimal(15, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  promotionId String
  promotion   Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  items       TacticItem[]
  // Accrual Engine
  accrualEntries AccrualEntry[]

  @@index([promotionId])
}

model TacticItem {
  id        String   @id @default(cuid())
  quantity  Int?
  discount  Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tacticId  String
  tactic    Tactic  @relation(fields: [tacticId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([tacticId])
  @@index([productId])
}

model Claim {
  id          String      @id @default(cuid())
  code        String
  amount      Decimal     @db.Decimal(15, 2)
  status      ClaimStatus @default(PENDING)
  claimDate   DateTime
  description String?
  documents   Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  promotionId  String?
  promotion    Promotion?  @relation(fields: [promotionId], references: [id])
  reviewedById String?
  reviewedBy   User?       @relation("ReviewedBy", fields: [reviewedById], references: [id])

  settlement   Settlement?
  transactions Transaction[]
  pops         POP[]
  // Deduction Management
  deductions   Deduction[]

  @@index([customerId])
  @@index([promotionId])
  @@index([status])
  @@index([status, claimDate])
  @@index([customerId, status])
}

model Settlement {
  id            String   @id @default(cuid())
  settledAmount Decimal  @db.Decimal(15, 2)
  variance      Decimal? @db.Decimal(15, 2)
  notes         String?
  settledAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  claimId String @unique
  claim   Claim  @relation(fields: [claimId], references: [id])
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  description String?
  createdAt   DateTime        @default(now())

  fundId      String
  fund        Fund       @relation(fields: [fundId], references: [id])
  promotionId String?
  promotion   Promotion? @relation(fields: [promotionId], references: [id])
  claimId     String?
  claim       Claim?     @relation(fields: [claimId], references: [id])

  @@index([fundId])
  @@index([promotionId])
  @@index([claimId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// FILE MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model File {
  id          String       @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  s3Key       String       @unique
  s3Bucket    String
  category    FileCategory @default(OTHER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  poa POA?
  pop POP?

  @@index([uploadedById])
  @@index([category])
}

model POA {
  id          String    @id @default(cuid())
  status      POAStatus @default(PENDING)
  approvedAt  DateTime?
  approvedBy  String?
  rejectedAt  DateTime?
  rejectedBy  String?
  rejectReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  fileId      String    @unique
  file        File      @relation(fields: [fileId], references: [id])
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id])

  @@index([promotionId])
  @@index([status])
}

model POP {
  id           String    @id @default(cuid())
  status       POPStatus @default(PENDING)
  verifiedAt   DateTime?
  verifiedBy   String?
  rejectedAt   DateTime?
  rejectedBy   String?
  rejectReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  fileId  String @unique
  file    File   @relation(fields: [fileId], references: [id])
  claimId String
  claim   Claim  @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// APPROVAL RULES
// ═══════════════════════════════════════════════════════════════

model ApprovalRule {
  id          String           @id @default(cuid())
  name        String
  description String?
  type        ApprovalRuleType @default(SINGLE_APPROVAL)
  minAmount   Decimal          @db.Decimal(15, 2)
  maxAmount   Decimal?         @db.Decimal(15, 2)
  channel     Channel?
  approverRoles Role[]
  priority    Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
  @@index([minAmount])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════════════════
// AUTHORIZED DISTRIBUTION LIST (ADL)
// ═══════════════════════════════════════════════════════════════

model AuthorizedDistributionList {
  id         String    @id @default(cuid())
  isActive   Boolean   @default(true)
  validFrom  DateTime  @default(now())
  validTo    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
  @@index([companyId])
}

model ADLEntry {
  id          String       @id @default(cuid())

  scope       ADLScope
  channel     Channel?
  customerId  String?
  customer    Customer?    @relation("ADLEntries", fields: [customerId], references: [id])

  productId   String?
  product     Product?     @relation("ADLEntries", fields: [productId], references: [id])
  brand       String?
  category    String?

  entryType   ADLEntryType @default(INCLUDE)

  effectiveFrom DateTime   @default(now())
  effectiveTo   DateTime?

  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  companyId   String
  company     Company      @relation("ADLEntries", fields: [companyId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId, scope, channel])
  @@index([companyId, customerId, productId])
  @@index([companyId, brand])
  @@index([companyId, category])
  @@index([effectiveFrom, effectiveTo])
}

// ═══════════════════════════════════════════════════════════════
// PROMOTION TEMPLATES
// ═══════════════════════════════════════════════════════════════

enum TemplateCategory {
  SEASONAL
  DISPLAY
  LISTING
  REBATE
  CUSTOM
}

model PromotionTemplate {
  id          String           @id @default(cuid())
  name        String
  description String?

  template    Json
  category    TemplateCategory @default(CUSTOM)
  channels    Channel[]        @default([])
  isPublic    Boolean          @default(false)
  usageCount  Int              @default(0)

  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  createdById String
  createdBy   User             @relation("TemplatesCreated", fields: [createdById], references: [id])

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([companyId, category])
  @@index([companyId, isPublic])
}

// ═══════════════════════════════════════════════════════════════
// AI MODELS
// ═══════════════════════════════════════════════════════════════

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json     @default("[]")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("ai_conversations")
}

model AISuggestion {
  id        String   @id @default(cuid())
  type      String
  input     Json
  output    Json
  accepted  Boolean?
  feedback  String?
  userId    String
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@map("ai_suggestions")
}

// ═══════════════════════════════════════════════════════════════
// ACCRUAL ENGINE MODELS
// ═══════════════════════════════════════════════════════════════

model FiscalPeriod {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])

  year          Int
  month         Int
  quarter       Int

  name          String
  startDate     DateTime
  endDate       DateTime

  status        FiscalPeriodStatus @default(OPEN)
  closedAt      DateTime?
  closedById    String?
  closedBy      User?              @relation("PeriodClosedBy", fields: [closedById], references: [id])

  totalAccrued  Decimal            @default(0) @db.Decimal(18, 2)
  totalReversed Decimal            @default(0) @db.Decimal(18, 2)
  totalSettled  Decimal            @default(0) @db.Decimal(18, 2)

  accrualEntries AccrualEntry[]
  glJournals     GLJournal[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([companyId, year, month])
  @@index([companyId, status])
  @@index([companyId, year, quarter])
}

model AccrualEntry {
  id              String                   @id @default(cuid())
  companyId       String
  company         Company                  @relation(fields: [companyId], references: [id])

  promotionId     String
  promotion       Promotion                @relation(fields: [promotionId], references: [id])
  tacticId        String?
  tactic          Tactic?                  @relation(fields: [tacticId], references: [id])
  fiscalPeriodId  String
  fiscalPeriod    FiscalPeriod             @relation(fields: [fiscalPeriodId], references: [id])

  entryType       AccrualEntryType
  entryDate       DateTime

  amount          Decimal                  @db.Decimal(18, 2)
  cumulativeAmount Decimal                 @db.Decimal(18, 2)

  calculationMethod AccrualCalculationMethod @default(TIME_BASED)
  calculationBasis  Json?

  glJournalId     String?
  glJournal       GLJournal?               @relation(fields: [glJournalId], references: [id])

  status          AccrualStatus            @default(PENDING)
  postedAt        DateTime?
  postedById      String?
  postedBy        User?                    @relation("AccrualPostedBy", fields: [postedById], references: [id])

  isReversal      Boolean                  @default(false)
  reversedEntryId String?
  reversedEntry   AccrualEntry?            @relation("AccrualReversal", fields: [reversedEntryId], references: [id])
  reversals       AccrualEntry[]           @relation("AccrualReversal")

  notes           String?

  createdAt       DateTime                 @default(now())
  createdById     String
  createdBy       User                     @relation("AccrualCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, promotionId])
  @@index([companyId, fiscalPeriodId])
  @@index([companyId, status])
  @@index([companyId, entryDate])
}

model GLJournal {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])

  journalNumber   String          @unique
  journalDate     DateTime
  fiscalPeriodId  String
  fiscalPeriod    FiscalPeriod    @relation(fields: [fiscalPeriodId], references: [id])

  description     String
  source          GLJournalSource
  sourceRef       String?

  status          GLJournalStatus @default(DRAFT)
  postedAt        DateTime?
  postedById      String?
  postedBy        User?           @relation("JournalPostedBy", fields: [postedById], references: [id])

  totalDebit      Decimal         @db.Decimal(18, 2)
  totalCredit     Decimal         @db.Decimal(18, 2)

  lines           GLJournalLine[]
  accrualEntries  AccrualEntry[]

  erpExported     Boolean         @default(false)
  erpExportedAt   DateTime?
  erpReference    String?

  createdAt       DateTime        @default(now())
  createdById     String
  createdBy       User            @relation("JournalCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, fiscalPeriodId])
  @@index([companyId, journalDate])
  @@index([companyId, status])
}

model GLJournalLine {
  id              String          @id @default(cuid())
  journalId       String
  journal         GLJournal       @relation(fields: [journalId], references: [id], onDelete: Cascade)

  lineNumber      Int

  accountCode     String
  accountName     String

  debitAmount     Decimal         @default(0) @db.Decimal(18, 2)
  creditAmount    Decimal         @default(0) @db.Decimal(18, 2)

  costCenter      String?
  profitCenter    String?
  customerId      String?
  productId       String?
  brandCode       String?
  channelCode     String?

  description     String?

  @@index([journalId])
  @@index([accountCode])
}

model GLAccount {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])

  code            String
  name            String
  type            GLAccountType
  category        String?

  isActive        Boolean         @default(true)

  isDefaultTradeExpense   Boolean @default(false)
  isDefaultAccruedLiability Boolean @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type])
}

model AccrualConfig {
  id              String                   @id @default(cuid())
  companyId       String                   @unique
  company         Company                  @relation(fields: [companyId], references: [id])

  tradeExpenseAccount     String
  accruedLiabilityAccount String

  defaultCalculationMethod AccrualCalculationMethod @default(TIME_BASED)
  accrualFrequency        AccrualFrequency @default(MONTHLY)

  autoCalculate           Boolean          @default(true)
  autoPost                Boolean          @default(false)

  minAccrualAmount        Decimal          @default(0) @db.Decimal(18, 2)
  varianceThresholdPercent Decimal         @default(10) @db.Decimal(5, 2)

  allowBackdatedEntries   Boolean          @default(false)
  gracePeriodDays         Int              @default(5)

  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// DEDUCTION MANAGEMENT ENUMS
// ═══════════════════════════════════════════════════════════════

enum DeductionSource {
  ERP_AR
  BANK_LOCKBOX
  EDI_812
  MANUAL
  CUSTOMER_PORTAL
}

enum DeductionCategory {
  TRADE_PROMOTION
  PRICING
  LOGISTICS
  QUALITY
  ADVERTISING
  OTHER
}

enum DeductionStatus {
  PENDING
  MATCHED
  UNDER_REVIEW
  APPROVED
  DISPUTED
  RESOLVED
  WRITTEN_OFF
  REJECTED
}

enum MatchMethod {
  AUTO_EXACT
  AUTO_FUZZY
  AUTO_AI
  MANUAL
}

enum DeductionResolution {
  FULL_MATCH
  PARTIAL_MATCH
  OVERPAYMENT
  UNDERPAYMENT
  INVALID
  WRITE_OFF
}

enum DisputeStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_INTERNAL
  ESCALATED
  RESOLVED
  CLOSED
}

enum ImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// ═══════════════════════════════════════════════════════════════
// DEDUCTION MANAGEMENT MODELS
// ═══════════════════════════════════════════════════════════════

model Deduction {
  id                String            @id @default(cuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])

  deductionNumber   String
  externalRef       String?

  source            DeductionSource
  sourceDocument    String?
  sourceDate        DateTime?
  importBatchId     String?

  customerId        String
  customer          Customer          @relation(fields: [customerId], references: [id])

  amount            Decimal           @db.Decimal(18, 2)
  currency          String            @default("VND")

  deductionDate     DateTime
  dueDate           DateTime?
  receivedDate      DateTime

  reasonCode        String?
  reasonDescription String?
  category          DeductionCategory @default(TRADE_PROMOTION)

  status            DeductionStatus   @default(PENDING)

  matchedPromotionId String?
  matchedPromotion   Promotion?       @relation(fields: [matchedPromotionId], references: [id])
  matchedClaimId     String?
  matchedClaim       Claim?           @relation(fields: [matchedClaimId], references: [id])
  matchScore         Int?
  matchMethod        MatchMethod?
  matchedAt          DateTime?
  matchedById        String?
  matchedBy          User?            @relation("DeductionMatchedBy", fields: [matchedById], references: [id])

  resolutionType     DeductionResolution?
  resolvedAmount     Decimal?         @db.Decimal(18, 2)
  varianceAmount     Decimal?         @db.Decimal(18, 2)
  resolvedAt         DateTime?
  resolvedById       String?
  resolvedBy         User?            @relation("DeductionResolvedBy", fields: [resolvedById], references: [id])
  resolutionNotes    String?

  writeOffReason     String?
  writeOffApprovedById String?
  writeOffApprovedBy User?            @relation("DeductionWriteOffBy", fields: [writeOffApprovedById], references: [id])

  daysOutstanding    Int              @default(0)
  agingBucket        String?

  disputes           DeductionDispute[]
  documents          DeductionDocument[]
  comments           DeductionComment[]
  activities         DeductionActivity[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdById        String?
  createdBy          User?            @relation("DeductionCreatedBy", fields: [createdById], references: [id])

  @@unique([companyId, deductionNumber])
  @@index([companyId, customerId])
  @@index([companyId, status])
  @@index([companyId, deductionDate])
  @@index([companyId, agingBucket])
  @@index([matchedPromotionId])
  @@index([matchedClaimId])
}

model DeductionDispute {
  id                String           @id @default(cuid())
  deductionId       String
  deduction         Deduction        @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  disputeNumber     String           @unique
  disputeDate       DateTime         @default(now())
  disputeReason     String
  disputeAmount     Decimal          @db.Decimal(18, 2)

  status            DisputeStatus    @default(OPEN)

  customerResponse  String?
  customerResponseDate DateTime?
  customerContactName String?
  customerContactEmail String?

  resolution        String?
  resolvedAmount    Decimal?         @db.Decimal(18, 2)
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedBy        User?            @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])

  isEscalated       Boolean          @default(false)
  escalatedAt       DateTime?
  escalatedToId     String?
  escalatedTo       User?            @relation("DisputeEscalatedTo", fields: [escalatedToId], references: [id])
  escalationReason  String?

  documents         DisputeDocument[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdById       String
  createdBy         User             @relation("DisputeCreatedBy", fields: [createdById], references: [id])

  @@index([deductionId])
  @@index([status])
}

model DeductionDocument {
  id              String         @id @default(cuid())
  deductionId     String
  deduction       Deduction      @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  fileName        String
  fileType        String
  fileSize        Int
  filePath        String
  documentType    String

  uploadedAt      DateTime       @default(now())
  uploadedById    String
  uploadedBy      User           @relation(fields: [uploadedById], references: [id])

  @@index([deductionId])
}

model DisputeDocument {
  id              String           @id @default(cuid())
  disputeId       String
  dispute         DeductionDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  fileName        String
  fileType        String
  fileSize        Int
  filePath        String
  documentType    String

  uploadedAt      DateTime         @default(now())
  uploadedById    String
  uploadedBy      User             @relation(fields: [uploadedById], references: [id])

  @@index([disputeId])
}

model DeductionComment {
  id              String         @id @default(cuid())
  deductionId     String
  deduction       Deduction      @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  content         String
  isInternal      Boolean        @default(true)

  createdAt       DateTime       @default(now())
  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])

  @@index([deductionId])
}

model DeductionActivity {
  id              String         @id @default(cuid())
  deductionId     String
  deduction       Deduction      @relation(fields: [deductionId], references: [id], onDelete: Cascade)

  action          String
  description     String
  oldValue        Json?
  newValue        Json?

  createdAt       DateTime       @default(now())
  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])

  @@index([deductionId])
  @@index([createdAt])
}

model WriteOffRule {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])

  name            String
  description     String?

  maxAmount       Decimal             @db.Decimal(18, 2)
  minAgeDays      Int                 @default(90)
  categories      DeductionCategory[]

  requiresApproval Boolean            @default(true)
  approverRoleId   String?

  isActive        Boolean             @default(true)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdById     String
  createdBy       User                @relation(fields: [createdById], references: [id])

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model DeductionImportBatch {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])

  source          DeductionSource
  fileName        String?
  filePath        String?

  totalRecords    Int
  successCount    Int            @default(0)
  errorCount      Int            @default(0)
  duplicateCount  Int            @default(0)

  status          ImportBatchStatus @default(PENDING)
  errors          Json?

  startedAt       DateTime?
  completedAt     DateTime?

  createdAt       DateTime       @default(now())
  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])

  @@index([companyId, status])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// SECURITY & COMPLIANCE ENUMS
// ═══════════════════════════════════════════════════════════════

enum SSOProvider {
  AZURE_AD
  GOOGLE
  OKTA
  SAML_GENERIC
}

enum MFAType {
  TOTP
  SMS
  EMAIL
}

enum MFAChallengeStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
}

enum SOXControlType {
  SEGREGATION_OF_DUTIES
  AMOUNT_THRESHOLD
  DUAL_CONTROL
  TIME_RESTRICTION
  DATA_ACCESS
}

enum SOXControlStatus {
  ACTIVE
  INACTIVE
  TESTING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  MFA_SETUP
  MFA_VERIFY
  SSO_LOGIN
  APPROVE
  REJECT
  MATCH
  WRITE_OFF
  EXPORT
  IMPORT
  CONFIG_CHANGE
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ═══════════════════════════════════════════════════════════════
// SECURITY & COMPLIANCE MODELS
// ═══════════════════════════════════════════════════════════════

model SSOConfig {
  id              String       @id @default(cuid())
  companyId       String       @unique
  company         Company      @relation(fields: [companyId], references: [id])

  provider        SSOProvider
  isEnabled       Boolean      @default(false)

  entityId        String?
  ssoUrl          String?
  sloUrl          String?
  certificate     String?
  spCertificate   String?
  spPrivateKey    String?

  clientId        String?
  clientSecret    String?
  tenantId        String?
  discoveryUrl    String?

  emailAttribute    String     @default("email")
  nameAttribute     String     @default("name")
  roleAttribute     String?
  attributeMapping  Json?

  autoProvision   Boolean      @default(false)
  defaultRole     Role         @default(KAM)
  forceSSOLogin   Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([provider])
}

model MFAConfig {
  id              String       @id @default(cuid())
  companyId       String       @unique
  company         Company      @relation(fields: [companyId], references: [id])

  isEnabled       Boolean      @default(false)
  enforcedRoles   Role[]       @default([])
  allowedTypes    MFAType[]    @default([TOTP])

  totpIssuer      String       @default("PromoMaster")
  totpDigits      Int          @default(6)
  totpPeriod      Int          @default(30)

  gracePeriodDays Int          @default(7)
  maxAttempts     Int          @default(5)
  lockoutMinutes  Int          @default(30)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model UserMFA {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])

  type            MFAType
  isActive        Boolean      @default(false)
  isDefault       Boolean      @default(false)

  secret          String?
  backupCodes     String[]     @default([])

  verifiedAt      DateTime?
  lastUsedAt      DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([userId, type])
  @@index([userId, isActive])
}

model MFAChallenge {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])

  type            MFAType
  status          MFAChallengeStatus  @default(PENDING)

  challengeCode   String?
  expiresAt       DateTime
  attempts        Int                 @default(0)
  maxAttempts     Int                 @default(5)

  verifiedAt      DateTime?
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime            @default(now())

  @@index([userId, status])
  @@index([expiresAt])
}

model SOXControl {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])

  code            String
  name            String
  description     String?

  type            SOXControlType
  status          SOXControlStatus @default(ACTIVE)

  config          Json

  isBlocking      Boolean          @default(true)
  severity        String           @default("HIGH")

  lastTestedAt    DateTime?
  lastTestResult  String?

  violations      SOXViolation[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type, status])
}

model SOXViolation {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])

  controlId       String
  control         SOXControl       @relation(fields: [controlId], references: [id])

  userId          String
  user            User             @relation("SOXViolationUser", fields: [userId], references: [id])

  action          String
  entityType      String
  entityId        String?
  details         Json?

  wasBlocked      Boolean          @default(true)
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?            @relation("SOXViolationReviewer", fields: [reviewedById], references: [id])
  reviewNotes     String?
  isExcepted      Boolean          @default(false)

  createdAt       DateTime         @default(now())

  @@index([companyId, controlId])
  @@index([companyId, userId])
  @@index([createdAt])
}

model ImmutableAuditLog {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])

  userId          String
  user            User         @relation(fields: [userId], references: [id])

  action          AuditAction
  entityType      String
  entityId        String?
  description     String

  oldValues       Json?
  newValues       Json?
  metadata        Json?

  sequenceNumber  Int
  previousHash    String?
  entryHash       String

  timestamp       DateTime     @default(now())

  createdAt       DateTime     @default(now())

  @@unique([companyId, sequenceNumber])
  @@index([companyId, entityType, entityId])
  @@index([companyId, userId])
  @@index([companyId, action])
  @@index([companyId, timestamp])
}

model UserSession {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])

  userId          String
  user            User           @relation(fields: [userId], references: [id])

  token           String         @unique
  status          SessionStatus  @default(ACTIVE)

  ipAddress       String?
  userAgent       String?
  deviceInfo      Json?

  loginAt         DateTime       @default(now())
  lastActivityAt  DateTime       @default(now())
  expiresAt       DateTime
  logoutAt        DateTime?

  authMethod      String         @default("password")
  mfaVerified     Boolean        @default(false)

  createdAt       DateTime       @default(now())

  @@index([userId, status])
  @@index([companyId, status])
  @@index([expiresAt])
  @@index([token])
}

// ═══════════════════════════════════════════════════════════════
// INTEGRATION & SYNC ENUMS
// ═══════════════════════════════════════════════════════════════

enum ERPType {
  SAP_S4HANA
  SAP_ECC
  ORACLE_EBS
  ORACLE_CLOUD
  DYNAMICS_365
  DYNAMICS_NAV
  GENERIC_REST
  GENERIC_SOAP
}

enum ERPConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
  TESTING
}

enum SyncDirection {
  INBOUND
  OUTBOUND
  BIDIRECTIONAL
}

enum SyncFrequency {
  REALTIME
  HOURLY
  DAILY
  WEEKLY
  MANUAL
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL
  CANCELLED
}

enum EntitySyncType {
  CUSTOMER
  PRODUCT
  PRICE
  PROMOTION
  CLAIM
  SETTLEMENT
  GL_JOURNAL
  DEDUCTION
}

enum WebhookEventType {
  PROMOTION_CREATED
  PROMOTION_UPDATED
  PROMOTION_APPROVED
  PROMOTION_REJECTED
  PROMOTION_STARTED
  PROMOTION_ENDED
  CLAIM_SUBMITTED
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_SETTLED
  DEDUCTION_CREATED
  DEDUCTION_MATCHED
  DEDUCTION_DISPUTED
  DEDUCTION_RESOLVED
  ACCRUAL_POSTED
  JOURNAL_CREATED
  JOURNAL_POSTED
  SYNC_COMPLETED
  SYNC_FAILED
  INTEGRATION_ERROR
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
  ABANDONED
}

enum APIKeyStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  REVOKED
}

// ═══════════════════════════════════════════════════════════════
// INTEGRATION & SYNC MODELS
// ═══════════════════════════════════════════════════════════════

model ERPConnection {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])

  name              String
  erpType           ERPType
  status            ERPConnectionStatus @default(INACTIVE)

  baseUrl           String
  username          String?
  password          String?
  apiKey            String?
  clientId          String?
  clientSecret      String?

  sapClient         String?
  sapSystemId       String?
  sapLanguage       String?             @default("EN")

  oracleOrgId       String?
  oracleRespId      String?

  timeout           Int                 @default(30000)
  retryAttempts     Int                 @default(3)

  lastPingAt        DateTime?
  lastPingStatus    Boolean?
  lastErrorMessage  String?

  syncConfigs       SyncConfig[]
  syncJobs          SyncJob[]
  mappings          ERPFieldMapping[]

  isDefault         Boolean             @default(false)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdById       String
  createdBy         User                @relation(fields: [createdById], references: [id])

  @@unique([companyId, name])
  @@index([companyId, status])
}

model ERPFieldMapping {
  id                String              @id @default(cuid())
  connectionId      String
  connection        ERPConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  entityType        EntitySyncType

  promoMasterField  String
  erpField          String
  erpTable          String?

  transformType     String?
  transformConfig   Json?

  direction         SyncDirection       @default(BIDIRECTIONAL)

  isRequired        Boolean             @default(false)
  isActive          Boolean             @default(true)

  @@unique([connectionId, entityType, promoMasterField])
  @@index([connectionId, entityType])
}

model SyncConfig {
  id                String              @id @default(cuid())
  connectionId      String
  connection        ERPConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  entityType        EntitySyncType
  direction         SyncDirection
  frequency         SyncFrequency       @default(DAILY)

  cronExpression    String?

  filterConditions  Json?

  batchSize         Int                 @default(100)
  conflictStrategy  String              @default("ERP_WINS")

  lastSyncAt        DateTime?
  lastSyncStatus    SyncStatus?
  lastSyncRecords   Int?

  isActive          Boolean             @default(true)

  jobs              SyncJob[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([connectionId, entityType, direction])
  @@index([connectionId, isActive])
}

model SyncJob {
  id                String              @id @default(cuid())
  connectionId      String
  connection        ERPConnection       @relation(fields: [connectionId], references: [id])
  configId          String?
  config            SyncConfig?         @relation(fields: [configId], references: [id])

  entityType        EntitySyncType
  direction         SyncDirection

  status            SyncStatus          @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?

  totalRecords      Int                 @default(0)
  processedRecords  Int                 @default(0)
  successRecords    Int                 @default(0)
  failedRecords     Int                 @default(0)
  skippedRecords    Int                 @default(0)

  errors            Json?
  errorMessage      String?

  triggeredBy       String
  triggeredById     String?

  logs              SyncJobLog[]

  createdAt         DateTime            @default(now())

  @@index([connectionId, status])
  @@index([entityType, status])
  @@index([startedAt])
}

model SyncJobLog {
  id                String              @id @default(cuid())
  jobId             String
  job               SyncJob             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  level             String
  message           String
  details           Json?

  entityId          String?
  erpReference      String?

  createdAt         DateTime            @default(now())

  @@index([jobId, level])
  @@index([createdAt])
}

model EntitySyncStatus {
  id                String              @id @default(cuid())
  companyId         String
  connectionId      String

  entityType        EntitySyncType
  entityId          String
  erpReference      String?

  lastSyncAt        DateTime?
  lastSyncDirection SyncDirection?
  syncHash          String?

  hasConflict       Boolean             @default(false)
  conflictDetails   Json?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([companyId, entityType, entityId])
  @@index([connectionId, entityType])
  @@index([hasConflict])
}

model APIKey {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])

  name              String
  keyHash           String              @unique
  keyPrefix         String

  status            APIKeyStatus        @default(ACTIVE)

  scopes            String[]            @default(["read"])
  allowedIPs        String[]            @default([])
  allowedOrigins    String[]            @default([])

  rateLimitRequests Int                 @default(1000)
  rateLimitWindow   Int                 @default(3600)

  expiresAt         DateTime?

  lastUsedAt        DateTime?
  totalRequests     BigInt              @default(0)

  createdAt         DateTime            @default(now())
  createdById       String
  createdBy         User                @relation(fields: [createdById], references: [id])
  revokedAt         DateTime?
  revokedById       String?
  revokedBy         User?               @relation("APIKeyRevokedBy", fields: [revokedById], references: [id])
  revokeReason      String?

  requestLogs       APIRequestLog[]

  @@index([companyId, status])
  @@index([keyPrefix])
}

model APIRequestLog {
  id                String              @id @default(cuid())
  apiKeyId          String?
  apiKey            APIKey?             @relation(fields: [apiKeyId], references: [id])

  method            String
  path              String
  queryParams       Json?

  statusCode        Int
  responseTime      Int

  ipAddress         String?
  userAgent         String?

  rateLimitRemaining Int?

  errorMessage      String?

  createdAt         DateTime            @default(now())

  @@index([apiKeyId, createdAt])
  @@index([path, createdAt])
  @@index([statusCode])
}

model WebhookSubscription {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])

  name              String
  description       String?

  url               String
  secret            String

  events            WebhookEventType[]

  isActive          Boolean             @default(true)

  customHeaders     Json?

  maxRetries        Int                 @default(5)
  retryDelayMs      Int                 @default(60000)

  lastDeliveryAt    DateTime?
  lastDeliveryStatus WebhookDeliveryStatus?
  consecutiveFailures Int               @default(0)

  autoDisableAfter  Int                 @default(10)
  disabledAt        DateTime?
  disableReason     String?

  deliveries        WebhookDelivery[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdById       String
  createdBy         User                @relation(fields: [createdById], references: [id])

  @@index([companyId, isActive])
}

model WebhookDelivery {
  id                String              @id @default(cuid())
  subscriptionId    String
  subscription      WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  eventType         WebhookEventType
  eventId           String              @unique

  payload           Json

  status            WebhookDeliveryStatus @default(PENDING)

  attempts          Int                 @default(0)
  maxAttempts       Int                 @default(5)
  nextRetryAt       DateTime?

  lastAttemptAt     DateTime?
  lastResponseCode  Int?
  lastResponseBody  String?
  lastErrorMessage  String?

  deliveredAt       DateTime?
  responseTime      Int?

  createdAt         DateTime            @default(now())

  @@index([subscriptionId, status])
  @@index([eventType, createdAt])
  @@index([status, nextRetryAt])
}

// ═══════════════════════════════════════════════════════════════
// PHASE 4: ENTERPRISE POLISH ENUMS
// ═══════════════════════════════════════════════════════════════

enum DashboardType {
  PERSONAL
  TEAM
  EXECUTIVE
  OPERATIONAL
}

enum WidgetType {
  KPI_CARD
  LINE_CHART
  BAR_CHART
  PIE_CHART
  TABLE
  HEATMAP
  FUNNEL
  GAUGE
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
  JSON
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ON_DEMAND
}

enum NotificationType {
  PROMOTION_STATUS
  CLAIM_UPDATE
  FUND_ALERT
  APPROVAL_REQUEST
  SETTLEMENT_COMPLETE
  SYSTEM_ALERT
  REPORT_READY
  DEADLINE_REMINDER
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
  DISMISSED
}

enum AlertCondition {
  THRESHOLD_ABOVE
  THRESHOLD_BELOW
  PERCENTAGE_CHANGE
  ABSOLUTE_CHANGE
  STATUS_CHANGE
  DEADLINE_APPROACHING
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
  URGENT
}

enum InsightType {
  RECOMMENDATION
  ANOMALY
  TREND
  FORECAST
  OPTIMIZATION
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum SyncQueueStatus {
  PENDING
  SYNCING
  SYNCED
  CONFLICT
  FAILED
}

// ═══════════════════════════════════════════════════════════════
// PHASE 4: ENTERPRISE POLISH MODELS
// ═══════════════════════════════════════════════════════════════

model Dashboard {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])

  name          String
  description   String?
  type          DashboardType  @default(PERSONAL)
  isDefault     Boolean        @default(false)

  layout        Json?
  filters       Json?
  refreshInterval Int?

  widgets       DashboardWidget[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId, userId])
  @@index([type])
}

model DashboardWidget {
  id            String         @id @default(cuid())
  dashboardId   String
  dashboard     Dashboard      @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  title         String
  widgetType    WidgetType
  dataSource    String
  config        Json
  position      Json

  refreshInterval Int?
  cacheSeconds  Int?           @default(300)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([dashboardId])
}

model ReportDefinition {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])

  name          String
  description   String?
  category      String?

  dataSource    String
  columns       Json
  filters       Json?
  groupBy       String[]       @default([])
  sortBy        Json?
  calculations  Json?

  defaultFormat ReportFormat   @default(EXCEL)
  isTemplate    Boolean        @default(false)

  schedules     ReportSchedule[]
  executions    ReportExecution[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdById   String
  createdBy     User           @relation("ReportDefinitionCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, category])
}

model ReportSchedule {
  id            String           @id @default(cuid())
  reportId      String
  report        ReportDefinition @relation(fields: [reportId], references: [id], onDelete: Cascade)

  frequency     ReportFrequency
  cronExpression String?
  format        ReportFormat     @default(EXCEL)

  recipients    String[]         @default([])
  filters       Json?

  isActive      Boolean          @default(true)
  lastRunAt     DateTime?
  nextRunAt     DateTime?

  userId        String
  user          User             @relation(fields: [userId], references: [id])

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([reportId, isActive])
  @@index([nextRunAt])
}

model ReportExecution {
  id            String           @id @default(cuid())
  reportId      String
  report        ReportDefinition @relation(fields: [reportId], references: [id], onDelete: Cascade)

  format        ReportFormat
  filters       Json?
  parameters    Json?

  status        String           @default("PENDING")
  startedAt     DateTime?
  completedAt   DateTime?
  errorMessage  String?

  fileUrl       String?
  fileSize      Int?
  rowCount      Int?

  createdAt     DateTime         @default(now())

  @@index([reportId, status])
  @@index([createdAt])
}

model Notification {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  userId        String
  user          User               @relation(fields: [userId], references: [id])

  type          NotificationType
  channel       NotificationChannel @default(IN_APP)
  status        NotificationStatus  @default(UNREAD)

  title         String
  message       String
  data          Json?
  actionUrl     String?

  readAt        DateTime?
  sentAt        DateTime?
  expiresAt     DateTime?

  createdAt     DateTime           @default(now())

  @@index([userId, status])
  @@index([companyId, type])
  @@index([createdAt])
}

model NotificationPreference {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])

  notificationType NotificationType
  channels      NotificationChannel[]
  isEnabled     Boolean            @default(true)

  quietHoursStart String?
  quietHoursEnd   String?
  timezone      String?            @default("UTC")

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([userId, notificationType])
}

model PushToken {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])

  token         String           @unique
  platform      DevicePlatform
  deviceName    String?

  isActive      Boolean          @default(true)
  lastUsedAt    DateTime?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId, isActive])
}

model AlertRule {
  id            String           @id @default(cuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id])
  userId        String
  user          User             @relation(fields: [userId], references: [id])

  name          String
  description   String?

  metric        String
  condition     AlertCondition
  threshold     Float
  severity      AlertSeverity    @default(WARNING)

  channels      NotificationChannel[]
  recipients    String[]         @default([])

  cooldownMinutes Int            @default(60)
  isActive      Boolean          @default(true)

  lastTriggeredAt DateTime?
  triggerCount  Int              @default(0)

  triggeredAlerts TriggeredAlert[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([companyId, isActive])
  @@index([metric])
}

model TriggeredAlert {
  id            String           @id @default(cuid())
  ruleId        String
  rule          AlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  currentValue  Float
  thresholdValue Float
  message       String

  acknowledgedAt DateTime?
  acknowledgedById String?
  acknowledgedBy User?           @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  acknowledgeNote String?

  createdAt     DateTime         @default(now())

  @@index([ruleId, createdAt])
  @@index([acknowledgedAt])
}

model Insight {
  id            String           @id @default(cuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id])

  type          InsightType
  title         String
  description   String
  details       Json?

  metric        String?
  impact        String?
  confidence    Float?

  actionable    Boolean          @default(true)
  actionTaken   Boolean          @default(false)
  dismissedAt   DateTime?

  relatedEntityType String?
  relatedEntityId   String?

  validUntil    DateTime?

  createdAt     DateTime         @default(now())

  @@index([companyId, type])
  @@index([createdAt])
  @@index([actionable, actionTaken])
}

model ForecastModel {
  id            String           @id @default(cuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id])

  name          String
  metric        String
  algorithm     String           @default("linear_regression")
  parameters    Json?

  trainingDataStart DateTime?
  trainingDataEnd   DateTime?
  accuracy      Float?

  isActive      Boolean          @default(true)
  lastTrainedAt DateTime?

  forecasts     Forecast[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([companyId, metric])
}

model Forecast {
  id            String           @id @default(cuid())
  modelId       String
  model         ForecastModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  periodStart   DateTime
  periodEnd     DateTime
  predictedValue Float
  confidenceLow Float?
  confidenceHigh Float?
  actualValue   Float?

  createdAt     DateTime         @default(now())

  @@index([modelId, periodStart])
}

model OfflineSyncQueue {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])

  entityType    String
  entityId      String?
  action        String
  payload       Json

  status        SyncQueueStatus  @default(PENDING)
  conflictData  Json?
  errorMessage  String?

  clientTimestamp DateTime
  syncedAt      DateTime?

  createdAt     DateTime         @default(now())

  @@index([userId, status])
  @@index([createdAt])
}

model UserDevice {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])

  deviceId      String           @unique
  platform      DevicePlatform
  deviceName    String?
  appVersion    String?
  osVersion     String?

  lastSyncAt    DateTime?
  lastActiveAt  DateTime?

  isActive      Boolean          @default(true)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId, isActive])
}

// ═══════════════════════════════════════════════════════════════
// CLASH DETECTION ENUMS
// ═══════════════════════════════════════════════════════════════

enum ClashType {
  TIME_OVERLAP
  CUSTOMER_OVERLAP
  PRODUCT_OVERLAP
  CHANNEL_OVERLAP
  DISCOUNT_STACK
  EXCLUSIVITY_VIOLATION
  MECHANIC_CONFLICT
  BUDGET_EXCEEDED
}

enum ClashSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ClashStatus {
  DETECTED
  ACKNOWLEDGED
  RESOLVED
  IGNORED
}

// ═══════════════════════════════════════════════════════════════
// CLASH DETECTION MODELS
// ═══════════════════════════════════════════════════════════════

model PromotionClash {
  id              String        @id @default(cuid())
  companyId       String

  promotionAId    String
  promotionA      Promotion     @relation("ClashPromotionA", fields: [promotionAId], references: [id])
  promotionBId    String
  promotionB      Promotion     @relation("ClashPromotionB", fields: [promotionBId], references: [id])

  clashType       ClashType
  severity        ClashSeverity @default(MEDIUM)
  status          ClashStatus   @default(DETECTED)

  overlapStartDate DateTime?
  overlapEndDate   DateTime?
  overlapDays      Int?
  affectedProducts String[]     @default([])
  affectedCustomer String?

  combinedDiscount Decimal?     @db.Decimal(10, 2)
  estimatedImpact  Decimal?     @db.Decimal(18, 2)

  resolvedAt       DateTime?
  resolvedById     String?
  resolvedBy       User?        @relation("ClashResolvedBy", fields: [resolvedById], references: [id])
  resolutionNote   String?

  detectedAt       DateTime     @default(now())
  description      String?
  details          Json?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([promotionAId, promotionBId, clashType])
  @@index([companyId, status])
  @@index([companyId, severity])
  @@index([promotionAId])
  @@index([promotionBId])
  @@index([detectedAt])
}

model ClashRule {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])

  name            String
  description     String?
  clashType       ClashType
  severity        ClashSeverity @default(MEDIUM)

  config          Json

  isActive        Boolean       @default(true)
  isBlocking      Boolean       @default(false)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@index([clashType])
}

// ═══════════════════════════════════════════════════════════════
// BUSINESS PLANNING - BASELINE MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model Baseline {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])

  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  productId       String?
  product         Product?           @relation(fields: [productId], references: [id])
  channel         Channel?
  category        String?
  brand           String?
  region          String?

  periodType      PeriodType         @default(MONTHLY)
  periodYear      Int
  periodMonth     Int?
  periodWeek      Int?
  periodQuarter   Int?

  baselineVolume  Decimal            @db.Decimal(18, 2)
  baselineRevenue Decimal            @db.Decimal(18, 2)
  baselineUnits   Int?
  baselineCases   Decimal?           @db.Decimal(18, 2)
  avgPricePerUnit Decimal?           @db.Decimal(18, 4)
  avgPricePerCase Decimal?           @db.Decimal(18, 4)

  sourceType      BaselineSourceType @default(HISTORICAL)
  calculationMethod String?
  historicalPeriods Int?
  calculationDetails Json?

  isLocked        Boolean            @default(false)
  lockedAt        DateTime?
  lockedById      String?
  lockedBy        User?              @relation("BaselineLockedBy", fields: [lockedById], references: [id])
  lockReason      String?

  notes           String?
  tags            String[]           @default([])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdById     String
  createdBy       User               @relation("BaselineCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?              @relation("BaselineUpdatedBy", fields: [updatedById], references: [id])

  @@unique([companyId, customerId, productId, channel, category, brand, region, periodType, periodYear, periodMonth, periodWeek, periodQuarter], name: "baseline_unique_scope")
  @@index([companyId, periodYear, periodMonth])
  @@index([companyId, customerId, periodYear])
  @@index([companyId, productId, periodYear])
  @@index([companyId, channel, periodYear])
  @@index([companyId, isLocked])
  @@map("baselines")
}
