// Prismy CRM — Customer Relationship Management
// Database: prismy_crm (PostgreSQL)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
//  CORE: Companies & Contacts
// ═══════════════════════════════════════

model Company {
  id       String       @id @default(cuid())
  name     String
  domain   String?
  industry String?
  size     CompanySize?
  phone    String?
  email    String?
  website  String?
  address  String?
  city     String?
  province String?
  country  String       @default("VN")
  taxCode  String?
  notes    String?
  logoUrl  String?

  contacts    Contact[]
  deals       Deal[]
  activities  Activity[]
  quotes      Quote[]
  orders      SalesOrder[]
  tags        CompanyTag[]
  portalUsers PortalUser[]
  tickets     SupportTicket[]
  documents   Document[]

  // Phase 6: Account Hierarchy
  parentId String?
  parent   Company?  @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children Company[] @relation("CompanyHierarchy")

  // Phase 7: Partner
  partner Partner?

  // Phase 6: Compliance
  sanctionsStatus ComplianceStatus @default(NOT_CHECKED)

  externalMrpId String?
  externalOtbId String?
  externalTpmId String?

  ownerId   String
  owner     User     @relation("CompanyOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([ownerId])
  @@index([industry])
  @@index([parentId])
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

model Contact {
  id         String        @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  mobile     String?
  jobTitle   String?
  department String?
  avatarUrl  String?
  notes      String?
  source     LeadSource?
  status     ContactStatus @default(ACTIVE)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  deals           DealContact[]
  activities      Activity[]
  quotes          Quote[]
  tags            ContactTag[]
  audienceMembers AudienceMember[]
  campaignSends   CampaignSend[]
  documents       Document[]

  country        String? // ISO 3166-1 alpha-2
  externalHrmId  String?
  score          Int       @default(0)
  lastActivityAt DateTime?

  ownerId   String
  owner     User     @relation("ContactOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([companyId])
  @@index([ownerId])
  @@index([status])
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EMAIL
  SOCIAL_MEDIA
  TRADE_SHOW
  ADVERTISEMENT
  PARTNER
  OTHER
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  LEAD
  CUSTOMER
  CHURNED
}

// ═══════════════════════════════════════
//  PIPELINE: Deals & Stages
// ═══════════════════════════════════════

model PipelineConfig {
  id        String   @id @default(cuid())
  name      String   @default("Default Pipeline")
  isDefault Boolean  @default(true)
  stages    Stage[]
  deals     Deal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stage {
  id          String  @id @default(cuid())
  name        String
  order       Int
  probability Int     @default(0)
  color       String  @default("#3B82F6")
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)

  pipelineId String
  pipeline   PipelineConfig @relation(fields: [pipelineId], references: [id])
  deals      Deal[]

  @@index([pipelineId, order])
}

model Deal {
  id              String    @id @default(cuid())
  title           String
  value           Decimal   @default(0)
  currency        String    @default("VND")
  probability     Int?
  expectedCloseAt DateTime?
  closedAt        DateTime?
  lostReason      String?
  competitorName  String?
  healthScore     Int?
  lastActivityAt  DateTime?
  notes           String?

  // Phase 6: Compliance
  dealType         String?
  complianceStatus ComplianceStatus @default(NOT_CHECKED)

  stageId    String
  stage      Stage          @relation(fields: [stageId], references: [id])
  pipelineId String
  pipeline   PipelineConfig @relation(fields: [pipelineId], references: [id])

  companyId  String?
  company    Company?        @relation(fields: [companyId], references: [id])
  contacts   DealContact[]
  activities Activity[]
  quotes     Quote[]
  orders     SalesOrder[]
  tags       DealTag[]
  documents  Document[]
  checklists DealChecklist[]

  // Phase 7: Partner attribution
  partnerId     String?
  partner       Partner?           @relation("PartnerDeals", fields: [partnerId], references: [id])
  registrations DealRegistration[]
  commissions   Commission[]

  externalMrpWorkOrderId String?
  externalOtbBudgetRef   String?

  ownerId   String
  owner     User     @relation("DealOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stageId])
  @@index([companyId])
  @@index([ownerId])
  @@index([expectedCloseAt])
  @@index([partnerId])
}

model DealContact {
  id        String          @id @default(cuid())
  role      DealContactRole @default(OTHER)
  isPrimary Boolean         @default(false)
  notes     String?
  dealId    String
  deal      Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact         @relation(fields: [contactId], references: [id])

  @@unique([dealId, contactId])
}

enum DealContactRole {
  DECISION_MAKER
  BUDGET_HOLDER
  TECHNICAL_EVALUATOR
  INFLUENCER
  CHAMPION
  GATEKEEPER
  END_USER
  PROCUREMENT
  OTHER
}

// ═══════════════════════════════════════
//  ACTIVITIES: Timeline & Tasks
// ═══════════════════════════════════════

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  subject     String
  description String?
  dueAt       DateTime?
  completedAt DateTime?
  duration    Int?
  isCompleted Boolean      @default(false)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([dealId])
  @@index([userId])
  @@index([type])
  @@index([dueAt])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
  LUNCH
  DEMO
  FOLLOW_UP
}

// ═══════════════════════════════════════
//  QUOTATION & ORDERS
// ═══════════════════════════════════════

enum ProductCategory {
  DRONE
  PAYLOAD
  CAMERA
  TRAINING
  MAINTENANCE
  SOFTWARE
  SPARE_PART
  ACCESSORY
  OTHER
}

enum BundleType {
  PACKAGE
  KIT
  SERVICE_PLAN
}

enum CompatibilityType {
  COMPATIBLE
  INCOMPATIBLE
  REQUIRES
}

enum CustomerTier {
  GOVERNMENT
  COMMERCIAL
  ACADEMIC
  PARTNER
}

model Product {
  id          String          @id @default(cuid())
  name        String
  sku         String?         @unique
  description String?
  unitPrice   Decimal         @default(0)
  currency    String          @default("VND")
  unit        String          @default("piece")
  isActive    Boolean         @default(true)
  category    ProductCategory @default(OTHER)

  // Phase 6: Export Control
  eccn        String?
  itar        Boolean @default(false)
  exportNotes String?

  externalMrpPartId String?

  quoteItems        QuoteItem[]
  orderItems        OrderItem[]
  bundleItems       ProductBundleItem[]
  compatibilityFrom ProductCompatibility[] @relation("CompatibilityFrom")
  compatibilityTo   ProductCompatibility[] @relation("CompatibilityTo")
  pricingTiers      PricingTier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
  @@index([category])
}

model ProductBundle {
  id           String              @id @default(cuid())
  name         String
  description  String?
  sku          String              @unique
  bundleType   BundleType
  basePrice    Float
  currency     String              @default("USD")
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)
  items        ProductBundleItem[]
  pricingTiers PricingTier[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model ProductBundleItem {
  id         String        @id @default(cuid())
  bundleId   String
  bundle     ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Int           @default(1)
  isRequired Boolean       @default(true)
  sortOrder  Int           @default(0)

  @@unique([bundleId, productId])
}

model ProductCompatibility {
  id               String            @id @default(cuid())
  productId        String
  product          Product           @relation("CompatibilityFrom", fields: [productId], references: [id])
  relatedProductId String
  relatedProduct   Product           @relation("CompatibilityTo", fields: [relatedProductId], references: [id])
  type             CompatibilityType
  notes            String?

  @@unique([productId, relatedProductId])
}

model PricingTier {
  id              String         @id @default(cuid())
  productId       String?
  product         Product?       @relation(fields: [productId], references: [id])
  bundleId        String?
  bundle          ProductBundle? @relation(fields: [bundleId], references: [id])
  tier            CustomerTier
  priceMultiplier Float
  minQuantity     Int            @default(1)

  @@unique([productId, tier])
  @@unique([bundleId, tier])
}

model Quote {
  id              String      @id @default(cuid())
  quoteNumber     String      @unique
  status          QuoteStatus @default(DRAFT)
  validUntil      DateTime?
  notes           String?
  terms           String?
  subtotal        Decimal     @default(0)
  discountPercent Decimal     @default(0)
  discountAmount  Decimal     @default(0)
  taxPercent      Decimal     @default(10)
  taxAmount       Decimal     @default(0)
  total           Decimal     @default(0)
  currency        String      @default("VND")

  contactId String?
  contact   Contact?    @relation(fields: [contactId], references: [id])
  companyId String?
  company   Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  dealId    String?
  deal      Deal?       @relation(fields: [dealId], references: [id])
  items     QuoteItem[]
  order     SalesOrder?

  sentAt DateTime?

  createdById String
  createdBy   User     @relation("QuoteCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteNumber])
  @@index([status])
  @@index([dealId])
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuoteItem {
  id          String  @id @default(cuid())
  quantity    Decimal @default(1)
  unitPrice   Decimal
  discount    Decimal @default(0)
  total       Decimal
  description String?
  sortOrder   Int     @default(0)

  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

model SalesOrder {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @default(0)
  taxAmount       Decimal     @default(0)
  total           Decimal     @default(0)
  currency        String      @default("VND")
  shippingAddress String?
  notes           String?
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  companyId     String?
  company       Company?             @relation(fields: [companyId], references: [id])
  dealId        String?
  deal          Deal?                @relation(fields: [dealId], references: [id])
  quoteId       String?              @unique
  quote         Quote?               @relation(fields: [quoteId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  trackingNumber     String?
  shippingProvider   String?
  refundAmount       Float?
  cancellationReason String?
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  refundedAt         DateTime?

  externalMrpWorkOrderId String?

  createdById String
  createdBy   User     @relation("OrderCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderNumber])
  @@index([status])
  @@index([companyId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderStatusHistory {
  id         String     @id @default(cuid())
  orderId    String
  order      SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  note       String?
  userId     String?
  user       User?      @relation("OrderStatusHistoryUser", fields: [userId], references: [id])
  createdAt  DateTime   @default(now())

  @@index([orderId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  quantity    Decimal
  unitPrice   Decimal
  total       Decimal
  description String?

  orderId   String
  order     SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?   @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ═══════════════════════════════════════
//  TAGGING SYSTEM
// ═══════════════════════════════════════

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#6B7280")
  contacts  ContactTag[]
  companies CompanyTag[]
  deals     DealTag[]
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model CompanyTag {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
}

model DealTag {
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
}

// ═══════════════════════════════════════
//  USERS & AUTH
// ═══════════════════════════════════════

model User {
  id        String   @id
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(MEMBER)

  ownedCompanies          Company[]                @relation("CompanyOwner")
  ownedContacts           Contact[]                @relation("ContactOwner")
  ownedDeals              Deal[]                   @relation("DealOwner")
  activities              Activity[]
  createdQuotes           Quote[]                  @relation("QuoteCreator")
  createdOrders           SalesOrder[]             @relation("OrderCreator")
  assignedTickets         SupportTicket[]          @relation("TicketAssignee")
  ticketMessages          TicketMessage[]          @relation("TicketMessageUser")
  createdCampaigns        Campaign[]               @relation("CampaignCreator")
  createdAudiences        Audience[]               @relation("AudienceCreator")
  emailLogs               EmailLog[]
  orderStatusChanges      OrderStatusHistory[]     @relation("OrderStatusHistoryUser")
  notifications           Notification[]
  webhooks                Webhook[]
  notificationPreferences NotificationPreference[]
  emailTemplates          EmailTemplate[]          @relation("EmailTemplateCreator")
  uploadedDocuments       Document[]               @relation("DocumentUploader")
  complianceChecks        ComplianceCheck[]        @relation("ComplianceChecker")
  exchangeRateUpdates     ExchangeRate[]           @relation("ExchangeRateUpdater")
  approvedRegistrations   DealRegistration[]       @relation("RegistrationApprover")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

// ═══════════════════════════════════════
//  CUSTOMER PORTAL
// ═══════════════════════════════════════

model PortalUser {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String
  lastName  String
  phone     String?
  isActive  Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  sessions PortalSession[]
  tickets  SupportTicket[]
  messages TicketMessage[]

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([email])
}

model PortalSession {
  id         String   @id @default(cuid())
  token      String   @unique
  magicToken String?  @unique
  expiresAt  DateTime
  isUsed     Boolean  @default(false)

  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)

  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([magicToken])
  @@index([portalUserId])
}

model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique
  subject      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String?

  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id])
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id])

  messages TicketMessage[]

  firstResponseAt DateTime?
  resolvedAt      DateTime?
  slaBreached     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([portalUserId])
  @@index([companyId])
  @@index([status])
  @@index([assigneeId])
  @@index([ticketNumber])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketMessage {
  id         String  @id @default(cuid())
  content    String
  isInternal Boolean @default(false)

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  portalUserId String?
  portalUser   PortalUser? @relation(fields: [portalUserId], references: [id])
  userId       String?
  user         User?       @relation("TicketMessageUser", fields: [userId], references: [id])

  attachments Json?
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

// ═══════════════════════════════════════
//  CAMPAIGN ENGINE
// ═══════════════════════════════════════

model Campaign {
  id      String         @id @default(cuid())
  name    String
  subject String
  content String?        @db.Text
  status  CampaignStatus @default(DRAFT)
  type    CampaignType   @default(EMAIL)

  audienceId String?
  audience   Audience? @relation(fields: [audienceId], references: [id])

  variants CampaignVariant[]
  sends    CampaignSend[]

  scheduledAt DateTime?
  sentAt      DateTime?
  completedAt DateTime?

  // Stats (denormalized for performance)
  totalSent         Int @default(0)
  totalOpened       Int @default(0)
  totalClicked      Int @default(0)
  totalBounced      Int @default(0)
  totalUnsubscribed Int @default(0)

  // TPM integration
  externalTpmPromoId String?

  createdById String
  createdBy   User     @relation("CampaignCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([audienceId])
  @@index([createdById])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum CampaignType {
  EMAIL
  SMS
  PUSH
}

model CampaignVariant {
  id           String  @id @default(cuid())
  name         String  @default("Original")
  subject      String?
  content      String? @db.Text
  splitPercent Int     @default(100)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  sends CampaignSend[]

  // Variant stats
  totalSent    Int @default(0)
  totalOpened  Int @default(0)
  totalClicked Int @default(0)

  createdAt DateTime @default(now())

  @@index([campaignId])
}

model Audience {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        AudienceType @default(STATIC)
  rules       Json?

  members   AudienceMember[]
  campaigns Campaign[]

  createdById String
  createdBy   User     @relation("AudienceCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

enum AudienceType {
  STATIC
  DYNAMIC
}

model AudienceMember {
  id         String   @id @default(cuid())
  audienceId String
  audience   Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  addedAt DateTime @default(now())

  @@unique([audienceId, contactId])
  @@index([audienceId])
  @@index([contactId])
}

model CampaignSend {
  id     String     @id @default(cuid())
  status SendStatus @default(PENDING)

  campaignId String
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    CampaignVariant? @relation(fields: [variantId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([contactId])
  @@index([status])
}

enum SendStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

// ═══════════════════════════════════════
//  EMAIL LOG
// ═══════════════════════════════════════

model EmailLog {
  id        String      @id @default(cuid())
  to        String
  subject   String
  template  String
  status    EmailStatus @default(PENDING)
  messageId String?
  error     String?
  sentAt    DateTime?
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  quoteId    String?
  campaignId String?

  @@index([userId])
  @@index([status])
  @@index([template])
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

// ═══════════════════════════════════════
//  EMAIL TEMPLATES
// ═══════════════════════════════════════

model EmailTemplate {
  id        String  @id @default(cuid())
  name      String
  subject   String
  body      String  @db.Text
  category  String? // 'campaign', 'transactional', 'notification'
  isDefault Boolean @default(false)

  createdById String?
  createdBy   User?    @relation("EmailTemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdById])
}

// ═══════════════════════════════════════
//  UNSUBSCRIBE
// ═══════════════════════════════════════

model Unsubscribe {
  id         String   @id @default(cuid())
  email      String
  contactId  String?
  campaignId String?
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([email])
  @@index([email])
}

// ═══════════════════════════════════════
//  AUDIT & SYSTEM
// ═══════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  changes   Json?
  userId    String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ═══════════════════════════════════════
//  SYSTEM: Settings (key-value JSON)
// ═══════════════════════════════════════

model SlaConfig {
  id                 String   @id @default(cuid())
  priority           String   @unique // LOW, MEDIUM, HIGH, URGENT
  firstResponseHours Int
  resolutionHours    Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

// ═══════════════════════════════════════
//  WEBHOOKS
// ═══════════════════════════════════════

model Webhook {
  id          String       @id @default(cuid())
  name        String
  url         String
  events      String[]
  secret      String
  active      Boolean      @default(true)
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  logs        WebhookLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([createdById])
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean
  duration   Int?
  attempt    Int      @default(1)
  error      String?
  createdAt  DateTime @default(now())

  @@index([webhookId, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String
  inApp     Boolean  @default(true)
  email     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, eventType])
  @@index([userId])
}

// ═══════════════════════════════════════
//  PHASE 6: Multi-Currency
// ═══════════════════════════════════════

model ExchangeRate {
  id          String   @id @default(cuid())
  currency    String   @unique
  symbol      String
  name        String
  rateToBase  Decimal  @default(1)
  isBase      Boolean  @default(false)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("ExchangeRateUpdater", fields: [updatedById], references: [id])
}

// ═══════════════════════════════════════
//  PHASE 6: Document Management
// ═══════════════════════════════════════

enum DocumentCategory {
  PROPOSAL
  CONTRACT
  NDA
  COMPLIANCE
  TECHNICAL
  CERTIFICATE
  INVOICE
  OTHER
}

model Document {
  id          String           @id @default(cuid())
  name        String
  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String
  category    DocumentCategory @default(OTHER)
  description String?
  version     Int              @default(1)
  parentId    String?
  parent      Document?        @relation("DocumentVersions", fields: [parentId], references: [id])
  versions    Document[]       @relation("DocumentVersions")

  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  uploadedById String
  uploadedBy   User     @relation("DocumentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([dealId])
  @@index([companyId])
  @@index([contactId])
  @@index([category])
}

// ═══════════════════════════════════════
//  PHASE 6: Compliance & Export Control
// ═══════════════════════════════════════

enum ComplianceStatus {
  NOT_CHECKED
  CLEAR
  FLAGGED
  BLOCKED
  REVIEW_REQUIRED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ComplianceCheck {
  id          String           @id @default(cuid())
  entityType  String
  entityId    String
  checkType   String
  status      ComplianceStatus @default(NOT_CHECKED)
  riskLevel   RiskLevel?
  result      Json?
  notes       String?
  checkedAt   DateTime         @default(now())
  checkedById String?
  checkedBy   User?            @relation("ComplianceChecker", fields: [checkedById], references: [id])
  expiresAt   DateTime?

  @@index([entityType, entityId])
  @@index([status])
}

model DealChecklist {
  id        String    @id @default(cuid())
  dealId    String
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  key       String
  label     String
  checked   Boolean   @default(false)
  checkedAt DateTime?
  checkedBy String?
  notes     String?

  @@unique([dealId, key])
  @@index([dealId])
}

// ═══════════════════════════════════════
//  PHASE 7: Partner/Channel Management
// ═══════════════════════════════════════

enum PartnerType {
  RESELLER
  INTEGRATOR
  DISTRIBUTOR
  REFERRAL
  OEM
  CONSULTANT
}

enum CertificationLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model Partner {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  company            Company            @relation(fields: [companyId], references: [id])
  partnerType        PartnerType
  territory          String?
  commissionRate     Float              @default(0.15)
  certificationLevel CertificationLevel @default(BRONZE)
  contractStartDate  DateTime?
  contractEndDate    DateTime?
  isActive           Boolean            @default(true)
  notes              String?
  registrations      DealRegistration[]
  commissions        Commission[]
  deals              Deal[]             @relation("PartnerDeals")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model DealRegistration {
  id            String             @id @default(cuid())
  dealId        String
  deal          Deal               @relation(fields: [dealId], references: [id])
  partnerId     String
  partner       Partner            @relation(fields: [partnerId], references: [id])
  status        RegistrationStatus @default(PENDING)
  registeredAt  DateTime           @default(now())
  expiresAt     DateTime
  approvedById  String?
  approvedBy    User?              @relation("RegistrationApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  rejectionNote String?
  notes         String?
  commission    Commission?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([dealId, partnerId])
}

model Commission {
  id             String            @id @default(cuid())
  dealId         String
  deal           Deal              @relation(fields: [dealId], references: [id])
  partnerId      String
  partner        Partner           @relation(fields: [partnerId], references: [id])
  registrationId String?           @unique
  registration   DealRegistration? @relation(fields: [registrationId], references: [id])
  amount         Float
  currency       String            @default("USD")
  rate           Float
  status         CommissionStatus  @default(PENDING)
  paidAt         DateTime?
  invoiceNumber  String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}
