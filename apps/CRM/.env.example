# Database
DATABASE_URL="postgresql://user:password@localhost:5432/prismy_crm?schema=public"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3018"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Prismy CRM <noreply@your-domain.com>"
# Nếu chưa verify domain, dùng: Prismy CRM <onboarding@resend.dev>

# Seed (optional — used by `npx prisma db seed`)
# SEED_ADMIN_ID="supabase-auth-user-id-for-admin"
# SEED_MEMBER_ID="supabase-auth-user-id-for-member"
