// RTR HRM System — Prisma Schema
// TIP-001: Core Models (Employee, Contract, User, Auth, Org Structure, Audit)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════ ENUMS ═══════════════

enum UserRole {
  SUPER_ADMIN
  HR_MANAGER
  HR_STAFF
  DEPT_MANAGER
  EMPLOYEE
  ACCOUNTANT
}

enum EmployeeStatus {
  ACTIVE
  PROBATION
  ON_LEAVE
  RESIGNED
  TERMINATED
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContractType {
  PROBATION
  DEFINITE_TERM
  INDEFINITE_TERM
  SEASONAL
  PART_TIME
  INTERN
}

enum DocumentType {
  CONTRACT_PROBATION
  CONTRACT_OFFICIAL
  CONTRACT_INTERN
  NDA
  RESIGNATION_LETTER
  HANDOVER_MINUTES
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  KPI_PUBLISH
  PAYROLL_MARK_PAID
  PAYSLIP_EMAIL_SENT
  OFFBOARDING_CANCELLED
  REPORTS_BATCH_CLOSED
  DOCUMENT_GENERATE
  DATA_IMPORT
  DATA_IMPORT_ROLLBACK
}

enum RequisitionStatus {
  DRAFT
  APPROVED
  OPEN
  CLOSED
  CANCELLED
}

enum ApplicationStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFERED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum InterviewResult {
  PASS
  FAIL
  PENDING
}

enum OnboardingTaskStatus {
  PENDING
  DONE
  SKIPPED
}

enum HREventType {
  DEPARTMENT_TRANSFER
  PROMOTION
  RECOGNITION
  DISCIPLINARY
  SALARY_ADJUSTMENT
}

enum HREventStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OffboardingStatus {
  INITIATED
  MANAGER_APPROVED
  HR_APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OffboardingTaskStatus {
  PENDING
  DONE
  SKIPPED
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  CANCELLED
}

enum ReviewCycle {
  MIDYEAR
  ANNUAL
  PROBATION
  ADHOC
}

enum ReviewStatus {
  DRAFT
  SELF_PENDING
  SELF_DONE
  MANAGER_PENDING
  MANAGER_DONE
  HR_REVIEWING
  COMPLETED
}

enum RatingScale {
  EXCELLENT
  GOOD
  SATISFACTORY
  NEEDS_IMPROVEMENT
  UNSATISFACTORY
}

enum PayrollItemType {
  BASE_SALARY
  MEAL_ALLOWANCE
  PHONE_ALLOWANCE
  FUEL_ALLOWANCE
  PERF_ALLOWANCE
  KPI_CURRENT
  KPI_PREV1
  KPI_PREV2
  OT_WEEKDAY
  OT_WEEKEND
  OT_HOLIDAY
  NIGHT_SHIFT
  BUSINESS_TRIP
  HAZARD_ALLOWANCE
  OTHER_ALLOWANCE
  ADVANCE_DEDUCTION
  BONUS
}

enum ReportType {
  BUSINESS_TRIP
  OVERTIME
  LEAVE_PAID
  LEAVE_UNPAID
  LEAVE_SICK
  LEAVE_MATERNITY
  LEAVE_WEDDING
  NOTE
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  RETURNED_L1
  APPROVED_L1
  RETURNED_L2
  APPROVED_FINAL
  CLOSED
  CANCELLED
}

enum OvertimeType {
  WEEKDAY
  WEEKEND
  HOLIDAY
  NIGHT_SHIFT
}

enum NotificationType {
  CONTRACT_EXPIRY
  EMPLOYEE_CREATED
  EMPLOYEE_UPDATED
  CONTRACT_CREATED
  SALARY_UPDATED
  REPORT_SUBMITTED
  REPORT_APPROVED
  REPORT_RETURNED
  OT_REQUEST
  ONBOARDING_COMPLETE
  HR_EVENT
  OFFBOARDING
  PAYROLL
  GENERAL
  REVIEW
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  DEDUCTED
}

enum KPIStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
  LEAVE
  HOLIDAY
}

// ═══════════════ AUTH & USER ═══════════════

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  role      UserRole @default(EMPLOYEE)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee               Employee?
  auditLogs              AuditLog[]
  sessions               Session[]
  notifications          Notification[]
  requisitionsRequested  JobRequisition[] @relation("JRRequester")
  hrEventsRequested      HREvent[]        @relation("HREventRequester")
  generatedDocuments     GeneratedDocument[] @relation("DocGenerator")
  payrollsCreated        PayrollPeriod[]     @relation("PayrollCreator")
  reportActivities       ReportActivity[]
  reportsApprovedL1      Report[]            @relation("ReportL1")
  reportsApprovedL2      Report[]            @relation("ReportL2")
  advancesApproved       SalaryAdvance[]     @relation("AdvanceApprover")
  kpiPeriodsCreated      KPIPeriod[]         @relation("KPICreator")
  kpiScoresEntered       KPIScore[]          @relation("KPIEnterer")
  templatesUploaded      DocumentTemplate[]  @relation("TemplateUploader")
  templateGenerations    DocumentGeneration[] @relation("TemplateGenerator")
  reviewPeriodsCreated   ReviewPeriod[]       @relation("ReviewPeriodCreator")
  reviewsAsReviewer      EmployeeReview[]     @relation("ReviewerUser")
  importSessions         ImportSession[]      @relation("ImportUser")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ═══════════════ ORG STRUCTURE ═══════════════

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  managerId   String?  @map("manager_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employees    Employee[]
  positions    Position[]
  manager      Employee?        @relation("DeptManager", fields: [managerId], references: [id])
  requisitions JobRequisition[]

  @@map("departments")
}

model Position {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  departmentId String?  @map("department_id")
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employees    Employee[]
  department   Department?      @relation(fields: [departmentId], references: [id])
  requisitions JobRequisition[]

  @@map("positions")
}

// ═══════════════ EMPLOYEE (34 RTR FIELDS) ═══════════════

model Employee {
  id           String         @id @default(cuid())
  employeeCode String         @unique @map("employee_code")
  userId       String?        @unique @map("user_id")

  // === NHÓM A: ĐỊNH DANH ===
  fullName    String  @map("full_name")
  nameNoAccent String @map("name_no_accent")
  gender      Gender
  dateOfBirth DateTime? @map("date_of_birth")

  // === NHÓM B: ĐỊA CHỈ & LIÊN LẠC ===
  permanentAddress String? @map("permanent_address")
  currentAddress   String? @map("current_address")
  phone            String?

  // === NHÓM C: CCCD ===
  nationalId      String? @unique @map("national_id")
  nationalIdDate  DateTime? @map("national_id_date")
  nationalIdPlace String?   @map("national_id_place")

  // === NHÓM D: CÔNG VIỆC ===
  departmentId  String? @map("department_id")
  positionId    String? @map("position_id")
  teamManagerId String? @map("team_manager_id")
  jobDescription String? @map("job_description")
  startDate     DateTime? @map("start_date")
  resignDate    DateTime? @map("resign_date")
  status        EmployeeStatus @default(PROBATION)

  // === NHÓM G: NGÂN HÀNG & THUẾ ===
  bankAccount   String? @map("bank_account")
  bankBranch    String? @map("bank_branch")
  taxCode       String? @map("tax_code")
  taxCodeOld    String? @map("tax_code_old")
  insuranceCode String? @map("insurance_code")

  // === NHÓM H: EMAIL ===
  companyEmail  String? @map("company_email")
  personalEmail String? @map("personal_email")

  // === NHÓM I: PHƯƠNG TIỆN & HỌC VẤN ===
  vehiclePlate String? @map("vehicle_plate")
  school       String?
  major        String?

  // === NHÓM J: HỒ SƠ ===
  hrDocsSubmitted  Json? @default("{}") @map("hr_docs_submitted")
  resignDecisionNo String? @map("resign_decision_no")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User?        @relation(fields: [userId], references: [id])
  department    Department?  @relation(fields: [departmentId], references: [id])
  position      Position?    @relation(fields: [positionId], references: [id])
  teamManager   Employee?    @relation("TeamManager", fields: [teamManagerId], references: [id])
  directReports Employee[]   @relation("TeamManager")
  managedDepts  Department[] @relation("DeptManager")
  contracts     Contract[]
  dependents    Dependent[]
  changeHistory       EmployeeChangeHistory[]
  auditLogs           AuditLog[]
  fromApplication      Application?
  onboardingChecklist  OnboardingChecklist?
  hrEvents             HREvent[]
  disciplinaryRecords  DisciplinaryRecord[]
  generatedDocuments    GeneratedDocument[]
  offboardingInstance   OffboardingInstance?
  payrolls              EmployeePayroll[]
  reports               Report[]
  leaveBalances         LeaveBalance[]
  attendanceRecords     AttendanceRecord[]
  salaryAdvances        SalaryAdvance[]
  kpiScores             KPIScore[]
  templateGenerations   DocumentGeneration[] @relation("TemplateGeneration")
  reviews               EmployeeReview[]

  @@map("employees")
}

model Dependent {
  id           String    @id @default(cuid())
  employeeId   String    @map("employee_id")
  fullName     String    @map("full_name")
  relationship String
  nationalId   String?   @map("national_id")
  dateOfBirth  DateTime  @map("date_of_birth")
  taxDepCode   String?   @map("tax_dep_code")
  registeredAt DateTime? @map("registered_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("dependents")
}

// ═══════════════ CONTRACT (với Phụ lục 1/2/3) ═══════════════

model Contract {
  id         String         @id @default(cuid())
  employeeId String         @map("employee_id")

  contractNo  String? @map("contract_no")
  probationNo String? @map("probation_no")
  type        ContractType
  status      ContractStatus @default(DRAFT)

  probationFrom DateTime? @map("probation_from")
  probationTo   DateTime? @map("probation_to")

  officialFrom DateTime? @map("official_from")
  officialTo   DateTime? @map("official_to")

  baseSalary     Decimal? @map("base_salary") @db.Decimal(15, 2)
  mealAllowance  Decimal? @map("meal_allowance") @db.Decimal(15, 2)
  phoneAllowance Decimal? @map("phone_allowance") @db.Decimal(15, 2)
  fuelAllowance  Decimal? @map("fuel_allowance") @db.Decimal(15, 2)
  perfAllowance  Decimal? @map("perf_allowance") @db.Decimal(15, 2)
  kpiAmount      Decimal? @map("kpi_amount") @db.Decimal(15, 2)

  annexNo1   String?   @map("annex_no_1")
  annexDate1 DateTime? @map("annex_date_1")
  annexNo2   String?   @map("annex_no_2")
  annexDate2 DateTime? @map("annex_date_2")
  annexNo3   String?   @map("annex_no_3")
  annexDate3 DateTime? @map("annex_date_3")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee           Employee            @relation(fields: [employeeId], references: [id])
  generatedDocuments GeneratedDocument[]

  @@map("contracts")
}

// ═══════════════ DOCUMENTS (TIP-006) ═══════════════

model GeneratedDocument {
  id          String       @id @default(cuid())
  employeeId  String       @map("employee_id")
  contractId  String?      @map("contract_id")
  type        DocumentType
  fileName    String       @map("file_name")
  filePath    String?      @map("file_path")
  generatedBy String       @map("generated_by")
  generatedAt DateTime     @default(now()) @map("generated_at")
  metadata    Json?        @default("{}")

  employee        Employee @relation(fields: [employeeId], references: [id])
  contract        Contract? @relation(fields: [contractId], references: [id])
  generatedByUser User     @relation("DocGenerator", fields: [generatedBy], references: [id])

  @@map("generated_documents")
}

// ═══════════════ DOCUMENT TEMPLATE LIBRARY (TIP-020) ═══════════════

enum TemplateCategory {
  CONTRACT
  OFFICIAL_DOCUMENT
  MEETING
  RECRUITMENT
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  EMPLOYEE
  TEXTAREA
  CHECKBOX
}

model DocumentTemplate {
  id          String           @id @default(cuid())
  name        String
  category    TemplateCategory
  description String?
  fileName    String           @map("file_name")
  filePath    String           @map("file_path")
  fileSize    Int              @map("file_size")
  fields      Json             @default("[]")
  isActive    Boolean          @default(true) @map("is_active")
  usageCount  Int              @default(0) @map("usage_count")
  uploadedBy  String           @map("uploaded_by")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  uploader    User               @relation("TemplateUploader", fields: [uploadedBy], references: [id])
  generations DocumentGeneration[]

  @@map("document_templates")
}

model DocumentGeneration {
  id          String   @id @default(cuid())
  templateId  String   @map("template_id")
  employeeId  String?  @map("employee_id")
  generatedBy String   @map("generated_by")
  fieldValues Json     @default("{}")
  fileName    String   @map("file_name")
  createdAt   DateTime @default(now()) @map("created_at")

  template  DocumentTemplate @relation(fields: [templateId], references: [id])
  employee  Employee?        @relation("TemplateGeneration", fields: [employeeId], references: [id])
  generator User             @relation("TemplateGenerator", fields: [generatedBy], references: [id])

  @@map("document_generations")
}

// ═══════════════ AUDIT & CHANGE HISTORY ═══════════════

model EmployeeChangeHistory {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  changedBy  String   @map("changed_by")
  fieldName  String   @map("field_name")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_change_history")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  employeeId String?     @map("employee_id")
  action     AuditAction
  entity     String
  entityId   String?     @map("entity_id")
  oldData    Json?       @map("old_data")
  newData    Json?       @map("new_data")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  actorName  String?     @map("actor_name")
  actorRole  String?     @map("actor_role")
  targetName String?     @map("target_name")
  createdAt  DateTime    @default(now()) @map("created_at")

  user     User?     @relation(fields: [userId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════ RECRUITMENT (TIP-004) ═══════════════

model JobRequisition {
  id           String            @id @default(cuid())
  title        String
  departmentId String            @map("department_id")
  positionId   String            @map("position_id")
  requestedBy  String            @map("requested_by")
  headcount    Int               @default(1)
  contractType ContractType
  salaryFrom   Decimal?          @map("salary_from") @db.Decimal(15, 2)
  salaryTo     Decimal?          @map("salary_to") @db.Decimal(15, 2)
  description  String?
  requirements String?
  status       RequisitionStatus @default(DRAFT)
  approvedBy   String?           @map("approved_by")
  approvedAt   DateTime?         @map("approved_at")
  closedAt     DateTime?         @map("closed_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  department   Department     @relation(fields: [departmentId], references: [id])
  position     Position       @relation(fields: [positionId], references: [id])
  requester    User           @relation("JRRequester", fields: [requestedBy], references: [id])
  applications Application[]

  @@map("job_requisitions")
}

model Candidate {
  id             String    @id @default(cuid())
  fullName       String    @map("full_name")
  email          String    @unique
  phone          String?
  nationalId     String?   @map("national_id")
  dateOfBirth    DateTime? @map("date_of_birth")
  currentAddress String?   @map("current_address")
  school         String?
  major          String?
  cvUrl          String?   @map("cv_url")
  source         String?
  createdAt      DateTime  @default(now()) @map("created_at")

  applications Application[]

  @@map("candidates")
}

model Application {
  id              String            @id @default(cuid())
  requisitionId   String            @map("requisition_id")
  candidateId     String            @map("candidate_id")
  status          ApplicationStatus @default(NEW)
  coverLetter     String?           @map("cover_letter")
  expectedSalary  Decimal?          @map("expected_salary") @db.Decimal(15, 2)
  screeningNote   String?           @map("screening_note")
  screenedBy      String?           @map("screened_by")
  screenedAt      DateTime?         @map("screened_at")
  offeredSalary   Decimal?          @map("offered_salary") @db.Decimal(15, 2)
  offeredAt       DateTime?         @map("offered_at")
  offerNote       String?           @map("offer_note")
  offerDeadline   DateTime?         @map("offer_deadline")
  employeeId      String?           @unique @map("employee_id")
  rejectionReason      String?           @map("rejection_reason")
  interviewScheduledAt DateTime?         @map("interview_scheduled_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  requisition JobRequisition @relation(fields: [requisitionId], references: [id])
  candidate   Candidate      @relation(fields: [candidateId], references: [id])
  employee    Employee?      @relation(fields: [employeeId], references: [id])
  interviews  Interview[]

  @@map("applications")
}

model Interview {
  id             String          @id @default(cuid())
  applicationId  String          @map("application_id")
  round          Int             @default(1)
  scheduledAt    DateTime        @map("scheduled_at")
  location       String?
  interviewerIds String[]        @map("interviewer_ids")
  result         InterviewResult @default(PENDING)
  score          Int?
  notes          String?
  conductedAt    DateTime?       @map("conducted_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id])

  @@map("interviews")
}

// ═══════════════ ONBOARDING (TIP-005) ═══════════════

model OnboardingChecklist {
  id          String    @id @default(cuid())
  employeeId  String    @unique @map("employee_id")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  employee Employee          @relation(fields: [employeeId], references: [id])
  tasks    OnboardingTask[]

  @@map("onboarding_checklists")
}

model OnboardingTask {
  id          String               @id @default(cuid())
  checklistId String               @map("checklist_id")
  taskKey     String               @map("task_key")
  title       String
  description String?
  assignedTo  String?              @map("assigned_to")
  status      OnboardingTaskStatus @default(PENDING)
  doneAt      DateTime?            @map("done_at")
  doneBy      String?              @map("done_by")
  note        String?
  dueDate     DateTime?            @map("due_date")
  createdAt   DateTime             @default(now()) @map("created_at")

  checklist OnboardingChecklist @relation(fields: [checklistId], references: [id])

  @@map("onboarding_tasks")
}

// ═══════════════ HR EVENTS (TIP-005) ═══════════════

model HREvent {
  id              String        @id @default(cuid())
  employeeId      String        @map("employee_id")
  type            HREventType
  status          HREventStatus @default(PENDING)
  requestedBy     String        @map("requested_by")
  approvedBy      String?       @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  rejectedBy      String?       @map("rejected_by")
  rejectionReason String?       @map("rejection_reason")
  effectiveDate   DateTime      @map("effective_date")
  payload         Json          @default("{}")
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  employee  Employee @relation(fields: [employeeId], references: [id])
  requester User     @relation("HREventRequester", fields: [requestedBy], references: [id])

  @@map("hr_events")
}

model DisciplinaryRecord {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  hrEventId  String?  @map("hr_event_id")
  level      String
  reason     String
  decisionNo String?  @map("decision_no")
  issuedBy   String   @map("issued_by")
  issuedAt   DateTime @map("issued_at")
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("disciplinary_records")
}

// ═══════════════ OFFBOARDING (TIP-007) ═══════════════

model OffboardingInstance {
  id                String             @id @default(cuid())
  employeeId        String             @unique @map("employee_id")
  status            OffboardingStatus  @default(INITIATED)
  resignationDate   DateTime           @map("resignation_date")
  lastWorkingDate   DateTime?          @map("last_working_date")
  resignReason      String?            @map("resign_reason")
  resignDecisionNo  String?            @map("resign_decision_no")
  initiatedBy       String             @map("initiated_by")
  managerApprovedBy String?            @map("manager_approved_by")
  managerApprovedAt DateTime?          @map("manager_approved_at")
  hrApprovedBy      String?            @map("hr_approved_by")
  hrApprovedAt      DateTime?          @map("hr_approved_at")
  completedAt       DateTime?          @map("completed_at")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  employee Employee            @relation(fields: [employeeId], references: [id])
  tasks    OffboardingTask[]

  @@map("offboarding_instances")
}

model OffboardingTask {
  id           String                 @id @default(cuid())
  instanceId   String                 @map("instance_id")
  taskKey      String                 @map("task_key")
  title        String
  description  String?
  assignedRole String                 @map("assigned_role")
  status       OffboardingTaskStatus  @default(PENDING)
  dueDate      DateTime?              @map("due_date")
  doneAt       DateTime?              @map("done_at")
  doneBy       String?                @map("done_by")
  note         String?
  createdAt    DateTime               @default(now()) @map("created_at")

  instance OffboardingInstance @relation(fields: [instanceId], references: [id])

  @@map("offboarding_tasks")
}

// ═══════════════ PAYROLL (TIP-008) ═══════════════

model PayrollPeriod {
  id          String        @id @default(cuid())
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  notes       String?
  createdBy   String        @map("created_by")
  submittedBy String?       @map("submitted_by")
  submittedAt DateTime?     @map("submitted_at")
  approvedBy  String?       @map("approved_by")
  approvedAt  DateTime?     @map("approved_at")
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  createdByUser    User              @relation("PayrollCreator", fields: [createdBy], references: [id])
  employeePayrolls EmployeePayroll[]

  @@unique([month, year])
  @@map("payroll_periods")
}

model EmployeePayroll {
  id               String   @id @default(cuid())
  periodId         String   @map("period_id")
  employeeId       String   @map("employee_id")

  // === CÔNG (nhóm B) ===
  actualDays       Decimal  @map("actual_days") @db.Decimal(5, 2)
  standardDays     Decimal  @map("standard_days") @db.Decimal(5, 2)

  // === LƯƠNG THEO HĐ (nhóm C) ===
  baseSalary       Decimal  @map("base_salary") @db.Decimal(15, 2)
  mealAllowance    Decimal  @default(0) @map("meal_allowance") @db.Decimal(15, 2)
  phoneAllowance   Decimal  @default(0) @map("phone_allowance") @db.Decimal(15, 2)
  fuelAllowance    Decimal  @default(0) @map("fuel_allowance") @db.Decimal(15, 2)
  perfAllowance    Decimal  @default(0) @map("perf_allowance") @db.Decimal(15, 2)

  // === TỔNG LƯƠNG (nhóm D) ===
  totalContractSalary Decimal @map("total_contract_salary") @db.Decimal(15, 2)
  totalActualSalary   Decimal @map("total_actual_salary") @db.Decimal(15, 2)

  // === GIẢM TRỪ THUẾ TNCN (nhóm F) ===
  personalDeduction  Decimal @default(11000000) @map("personal_deduction") @db.Decimal(15, 2)
  dependentCount     Int     @default(0) @map("dependent_count")
  dependentDeduction Decimal @default(0) @map("dependent_deduction") @db.Decimal(15, 2)

  // === TỔNG THU NHẬP & CHỊU THUẾ (nhóm G) ===
  totalIncome        Decimal @map("total_income") @db.Decimal(15, 2)
  taxableIncome      Decimal @map("taxable_income") @db.Decimal(15, 2)

  // === GIẢM TRỪ VÀO LƯƠNG (nhóm H) ===
  insuranceBase      Decimal @map("insurance_base") @db.Decimal(15, 2)
  bhxhEmployee       Decimal @map("bhxh_employee") @db.Decimal(15, 2)
  bhytEmployee       Decimal @map("bhyt_employee") @db.Decimal(15, 2)
  bhtnEmployee       Decimal @map("bhtn_employee") @db.Decimal(15, 2)
  totalEmployeeIns   Decimal @map("total_employee_ins") @db.Decimal(15, 2)
  pitAmount          Decimal @map("pit_amount") @db.Decimal(15, 2)
  advanceDeduction   Decimal @default(0) @map("advance_deduction") @db.Decimal(15, 2)

  // === THỰC LĨNH (nhóm I) ===
  netSalary          Decimal @map("net_salary") @db.Decimal(15, 2)

  // === CÔNG TY ĐÓNG (nhóm J) ===
  bhxhEmployer       Decimal @map("bhxh_employer") @db.Decimal(15, 2)
  bhytEmployer       Decimal @map("bhyt_employer") @db.Decimal(15, 2)
  bhtnEmployer       Decimal @map("bhtn_employer") @db.Decimal(15, 2)
  bhtnldEmployer     Decimal @map("bhtnld_employer") @db.Decimal(15, 2)
  totalEmployerIns   Decimal @map("total_employer_ins") @db.Decimal(15, 2)

  // === TỒN PHÉP & BANK (nhóm K) ===
  remainingLeave     Decimal @default(0) @map("remaining_leave") @db.Decimal(5, 2)
  bankAccount        String? @map("bank_account")
  bankName           String? @map("bank_name")
  nameNoAccent       String? @map("name_no_accent")

  notes              String?
  isLocked           Boolean @default(false) @map("is_locked")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  period             PayrollPeriod  @relation(fields: [periodId], references: [id])
  employee           Employee       @relation(fields: [employeeId], references: [id])
  items              PayrollItem[]

  @@unique([periodId, employeeId])
  @@map("employee_payrolls")
}

model PayrollItem {
  id                String          @id @default(cuid())
  employeePayrollId String          @map("employee_payroll_id")
  type              PayrollItemType
  amount            Decimal         @db.Decimal(15, 2)
  description       String?
  sourceId          String?         @map("source_id")
  sourceType        String?         @map("source_type")
  createdAt         DateTime        @default(now()) @map("created_at")

  employeePayroll EmployeePayroll @relation(fields: [employeePayrollId], references: [id])
  report          Report?

  @@map("payroll_items")
}

// ═══════════════ NOTIFICATIONS ═══════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ═══════════════ REPORTS (TIP-009) ═══════════════

model Report {
  id              String       @id @default(cuid())
  employeeId      String       @map("employee_id")
  type            ReportType
  status          ReportStatus @default(DRAFT)

  submittedAt     DateTime?    @map("submitted_at")
  l1ApproverId    String?      @map("l1_approver_id")
  l1ApprovedAt    DateTime?    @map("l1_approved_at")
  l2ApproverId    String?      @map("l2_approver_id")
  l2ApprovedAt    DateTime?    @map("l2_approved_at")
  returnReason    String?      @map("return_reason")
  closedAt        DateTime?    @map("closed_at")

  startDate       DateTime     @map("start_date")
  endDate         DateTime     @map("end_date")
  notes           String?
  payload         Json         @default("{}")

  payrollItemId   String?      @unique @map("payroll_item_id")
  payrollPeriodId String?      @map("payroll_period_id")

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  employee        Employee     @relation(fields: [employeeId], references: [id])
  l1Approver      User?        @relation("ReportL1", fields: [l1ApproverId], references: [id])
  l2Approver      User?        @relation("ReportL2", fields: [l2ApproverId], references: [id])
  activities      ReportActivity[]
  payrollItem     PayrollItem? @relation(fields: [payrollItemId], references: [id])

  @@index([employeeId, status])
  @@index([status])
  @@map("reports")
}

model ReportActivity {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  actorId   String   @map("actor_id")
  actorRole String   @map("actor_role")
  action    String
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  report    Report   @relation(fields: [reportId], references: [id])
  actor     User     @relation(fields: [actorId], references: [id])

  @@map("report_activities")
}

model LeaveBalance {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  year          Int
  totalDays     Decimal  @default(12) @db.Decimal(5, 2)
  usedDays      Decimal  @default(0) @db.Decimal(5, 2)
  remainingDays Decimal  @default(12) @db.Decimal(5, 2)
  updatedAt     DateTime @updatedAt @map("updated_at")

  employee      Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@map("leave_balances")
}

// ═══════════════ SYSTEM SETTINGS ═══════════════

model SystemSetting {
  key       String   @id
  value     String
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ═══════════════ KPI (TIP-015) ═══════════════

model KPIPeriod {
  id          String    @id @default(cuid())
  month       Int
  year        Int
  status      KPIStatus @default(DRAFT)
  notes       String?
  createdBy   String    @map("created_by")
  publishedAt DateTime? @map("published_at")
  lockedAt    DateTime? @map("locked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdByUser User       @relation("KPICreator", fields: [createdBy], references: [id])
  scores        KPIScore[]

  @@unique([month, year])
  @@map("kpi_periods")
}

model KPIScore {
  id          String   @id @default(cuid())
  periodId    String   @map("period_id")
  employeeId  String   @map("employee_id")
  score       Decimal  @db.Decimal(5, 2)
  kpiAmount   Decimal  @db.Decimal(15, 2)
  notes       String?
  enteredBy   String   @map("entered_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  period   KPIPeriod @relation(fields: [periodId], references: [id])
  employee Employee  @relation(fields: [employeeId], references: [id])
  enterer  User      @relation("KPIEnterer", fields: [enteredBy], references: [id])

  @@unique([periodId, employeeId])
  @@map("kpi_scores")
}

// ═══════════════ SALARY ADVANCE (TIP-014) ═══════════════

model SalaryAdvance {
  id              String        @id @default(cuid())
  employeeId      String        @map("employee_id")
  amount          Decimal       @db.Decimal(15, 2)
  reason          String
  requestedAt     DateTime      @default(now()) @map("requested_at")
  approvedBy      String?       @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  rejectedBy      String?       @map("rejected_by")
  rejectionReason String?       @map("rejection_reason")
  status          AdvanceStatus @default(PENDING)
  deductMonth     Int?          @map("deduct_month")
  deductYear      Int?          @map("deduct_year")
  payrollItemId   String?       @unique @map("payroll_item_id")

  employee        Employee      @relation(fields: [employeeId], references: [id])
  approver        User?         @relation("AdvanceApprover", fields: [approvedBy], references: [id])

  @@map("salary_advances")
}

// ═══════════════ ATTENDANCE ═══════════════

model AttendanceRecord {
  id           String           @id @default(cuid())
  employeeId   String           @map("employee_id")
  date         DateTime         @map("date") @db.Date
  checkInAt    DateTime?        @map("check_in_at")
  checkOutAt   DateTime?        @map("check_out_at")
  checkInIp    String?          @map("check_in_ip")
  checkOutIp   String?          @map("check_out_ip")
  checkInLat   Decimal?         @map("check_in_lat") @db.Decimal(10, 7)
  checkInLng   Decimal?         @map("check_in_lng") @db.Decimal(10, 7)
  checkOutLat  Decimal?         @map("check_out_lat") @db.Decimal(10, 7)
  checkOutLng  Decimal?         @map("check_out_lng") @db.Decimal(10, 7)
  status       AttendanceStatus @default(PRESENT)
  workHours    Decimal?         @map("work_hours") @db.Decimal(4, 2)
  isManualEdit Boolean          @default(false) @map("is_manual_edit")
  editedBy     String?          @map("edited_by")
  editNote     String?          @map("edit_note")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  employee     Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("attendance_records")
}

// ═══════════════ PERFORMANCE REVIEW (TIP-021) ═══════════════

model ReviewPeriod {
  id        String      @id @default(cuid())
  name      String
  cycle     ReviewCycle
  startDate DateTime    @map("start_date")
  endDate   DateTime    @map("end_date")
  year      Int
  createdBy String      @map("created_by")
  createdAt DateTime    @default(now()) @map("created_at")

  creator   User            @relation("ReviewPeriodCreator", fields: [createdBy], references: [id])
  reviews   EmployeeReview[]

  @@map("review_periods")
}

model EmployeeReview {
  id               String       @id @default(cuid())
  periodId         String       @map("period_id")
  employeeId       String       @map("employee_id")
  reviewerId       String       @map("reviewer_id")
  status           ReviewStatus @default(DRAFT)

  selfRating       RatingScale? @map("self_rating")
  selfStrengths    String?      @map("self_strengths")
  selfWeaknesses   String?      @map("self_weaknesses")
  selfGoals        String?      @map("self_goals")
  selfSubmittedAt  DateTime?    @map("self_submitted_at")

  managerRating    RatingScale? @map("manager_rating")
  managerStrengths String?      @map("manager_strengths")
  managerWeaknesses String?     @map("manager_weaknesses")
  managerGoals     String?      @map("manager_goals")
  managerSubmittedAt DateTime?  @map("manager_submitted_at")

  competencyScores Json?        @map("competency_scores")

  finalRating      RatingScale? @map("final_rating")
  hrNotes          String?      @map("hr_notes")
  completedAt      DateTime?    @map("completed_at")

  triggeredHREventId String?    @map("triggered_hr_event_id")

  period           ReviewPeriod @relation(fields: [periodId], references: [id])
  employee         Employee     @relation(fields: [employeeId], references: [id])
  reviewer         User         @relation("ReviewerUser", fields: [reviewerId], references: [id])

  @@unique([periodId, employeeId])
  @@map("employee_reviews")
}

// ═══════════════ DATA IMPORT (TIP-022) ═══════════════

enum ImportType {
  EMPLOYEES
  PAYROLL
  ATTENDANCE
  CONTRACTS
}

enum ImportStatus {
  DRY_RUN
  COMPLETED
  ROLLED_BACK
  FAILED
}

model ImportSession {
  id            String       @id @default(cuid())
  type          ImportType
  status        ImportStatus @default(DRY_RUN)
  fileName      String       @map("file_name")
  fileSize      Int          @map("file_size")
  totalRows     Int          @map("total_rows")
  successRows   Int          @default(0) @map("success_rows")
  errorRows     Int          @default(0) @map("error_rows")
  mapping       Json         @default("{}")
  errors        Json         @default("[]")
  importedIds   Json         @default("[]") @map("imported_ids")
  rawData       Json?        @map("raw_data")
  metadata      Json?        @default("{}")
  importedBy    String       @map("imported_by")
  completedAt   DateTime?    @map("completed_at")
  rolledBackAt  DateTime?    @map("rolled_back_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  importer      User         @relation("ImportUser", fields: [importedBy], references: [id])

  @@map("import_sessions")
}
